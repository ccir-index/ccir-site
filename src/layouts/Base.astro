---
import '../styles/tokens.css';
import '../styles/base.css';
import Masthead from '../components/Masthead.astro';
import Tape from '../components/Tape.astro';
import { meta } from '../data/snapshot';

interface Props {
  title?: string;
  description?: string;
  showTape?: boolean;
  ogImage?: string;
  noindex?: boolean;
}

const {
  title = 'CCIR · Compute Credit Index Research',
  description = 'Independent analysis of the GPU compute market — aggregated from publicly-observed posted prices across dozens of providers.',
  // Ticker suppressed 2026-07-02: the v2026-07-01 panel activation (31→41
  // sources) + same-day restatements make day-over-day arrows read as market
  // moves when they're composition changes. Flip back to true once the panel
  // has a few days of stable history.
  showTape = false,
  ogImage = '/og-default.png',
  noindex = false,
} = Astro.props;

const SITE = 'https://ccir.io';
const canonicalPath = Astro.url.pathname
  .replace(/\/index\.html$/, '/')
  .replace(/\.html$/, '')
  .replace(/\/$/, '') || '/';
const canonical = new URL(canonicalPath, SITE).href;
const ogImageUrl = ogImage ? new URL(ogImage, SITE).href : undefined;
---
<!doctype html>
<html lang="en" data-theme="editorial">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width,initial-scale=1" />
  <title>{title}</title>
  <meta name="description" content={description} />
  {noindex && <meta name="robots" content="noindex,follow" />}
  {!noindex && <link rel="canonical" href={canonical} />}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="CCIR" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  {ogImageUrl && <meta property="og:image" content={ogImageUrl} />}
  <meta name="twitter:card" content={ogImageUrl ? 'summary_large_image' : 'summary'} />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  {ogImageUrl && <meta name="twitter:image" content={ogImageUrl} />}
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Sans:ital,wght@0,400;0,500;0,600;1,400&family=IBM+Plex+Mono:ital,wght@0,400;0,500;0,600&display=swap"
    rel="stylesheet"
  />
  <script is:inline>
    (function () {
      try {
        var t = localStorage.getItem('ccir-theme');
        if (t === 'editorial' || t === 'terminal') {
          document.documentElement.setAttribute('data-theme', t);
        }
      } catch (e) {}
    })();
  </script>
</head>
<body>
  <Masthead />
  {showTape && <Tape />}
  <main>
    <slot />
  </main>
  <footer class="site-footer">
    <div class="wrap disclosure-foot">
      <strong>Independent · Observable · Posted · No positions in the markets we measure</strong>
      Every rate is sourced from publicly-accessible, provider-operated
      pricing pages and official documentation — no solicited quotes, no
      broker-mediated prices, no sponsored feeds. CCIR holds no positions
      in the markets it measures and clears no trades.
    </div>
    <div class="wrap footer-inner">
      <div class="lhs">
        <strong>CCIR</strong> · Citable reference rates and independent
        analysis of the GPU compute market — rates, term structure, credit,
        and utilization, updated each morning by 07:30 ET.
      </div>
      <div class="rhs">
        <a href={`https://github.com/ccir-index/ccir-v2-data/tree/main/indices/snapshots/${meta.as_of_date}`}>Snapshots</a>
        <a href="/applications">Applications</a>
        <a href="/market-data">Data</a>
        <a href="/contact">Contact</a>
        <span class="social">
          <a href="https://www.linkedin.com/company/compute-credit-index-research/" aria-label="CCIR on LinkedIn" rel="me noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5zM.5 8h4V24h-4V8zm7.5 0h3.83v2.2h.05c.53-1 1.84-2.2 3.78-2.2 4.04 0 4.79 2.66 4.79 6.11V24h-4v-7.09c0-1.69-.03-3.86-2.36-3.86-2.36 0-2.72 1.84-2.72 3.74V24h-4V8z"/></svg>
          </a>
          <a href="https://x.com/CCIR_IO" aria-label="CCIR on X" rel="me noopener" target="_blank">
            <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
          </a>
        </span>
      </div>
    </div>
    <div class="wrap runid">
      Compute Credit Index Research LLC · Delaware · formed 2026-03-11
      <span aria-hidden="true"> · </span>run_id · {meta.run_id}
    </div>
  </footer>
  <style>
    .site-footer {
      border-top: 1px solid var(--rule-2);
      background: var(--surface-2);
      padding: 22px 0 24px;
      margin-top: 56px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      line-height: 1.55;
    }
    .disclosure-foot {
      max-width: 880px;
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.55;
      margin-bottom: 18px;
      padding-bottom: 18px;
      border-bottom: 1px solid var(--rule);
    }
    .disclosure-foot strong {
      display: block;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      margin-bottom: 6px;
    }
    .footer-inner {
      display: flex;
      gap: 24px;
      align-items: flex-start;
      flex-wrap: wrap;
    }
    .footer-inner .lhs { max-width: 720px; }
    .footer-inner .lhs strong { color: var(--ink); font-weight: var(--weight-strong); }
    .footer-inner .rhs {
      margin-left: auto;
      display: flex;
      gap: 16px;
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }
    .footer-inner .rhs a { color: var(--ink-dim); }
    .footer-inner .rhs a:hover { color: var(--accent); text-decoration: none; }
    .footer-inner .rhs .social {
      display: inline-flex;
      align-items: center;
      gap: 12px;
      padding-left: 14px;
      margin-left: 2px;
      border-left: 1px solid var(--rule);
    }
    .footer-inner .rhs .social a { display: inline-flex; }
    .footer-inner .rhs .social svg {
      width: 15px;
      height: 15px;
      fill: currentColor;
      display: block;
    }
    .runid {
      margin-top: 10px;
      color: var(--ink-faint);
      font-size: calc(var(--fs-xs) - 1px);
      letter-spacing: 0.04em;
    }
  </style>
</body>
</html>
