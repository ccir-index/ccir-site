---
/*
  Committed par curve — the flagship chart for /term. Server-rendered inline
  SVG; every number is known at build time, no client chart library.

  Axis choice: tenor in months on a SQUARE-ROOT scale. A linear month axis
  crushes OD/1M/3M into the left quarter of the plot; an equal-spaced
  ordinal axis lies about the time between marks (1M→3M would read as wide
  as 6M→1Y). sqrt(months) keeps order and a sense of elapsed time while
  giving the dense short end room to read. Disclosed in the caption.

  Tenor extent: OD → 3Y (extended 2026-07-16, John's call, reversing the
  2026-07-01 OD→1Y display cap — the committed-term panel now prints 1M-3Y
  and the multi-year tenors carry the credit story). The 1Y anchor-tenor
  emphasis stays: 1Y remains the reference tenor. Points render only at
  published tenors — a chip with no 2Y row draws 1Y→3Y directly.

  Series colors are chart-local custom properties defined for BOTH themes
  and validated with the dataviz six-checks script against each theme's
  surface (adjacency order = vertical order on the plot: B200, H200, H100,
  A100):
    terminal (dark, surface #111418):   worst adjacent CVD ΔE 12.9 — PASS
    editorial (light, surface #fbf7ee): worst adjacent CVD ΔE 15.8 — PASS
  Provisional cells are shape-encoded (hollow marks), never color-only.
*/
import { neocloudCommittedCell, tierOdCell, headlineValue, headlineStatOf, meta } from '../data/snapshot';
import { wpSpread } from '../data/committed_mi';
import type { Rate, Term } from '../data/types';

const fmt = (n: number, dp = 2) => n.toFixed(dp);

// --- geometry -------------------------------------------------------------
const W = 920;
const H = 430;
// Right gutter sized for the full end-label: "H200 2.96 −26% vs OD".
const MARGIN = { top: 28, right: 158, bottom: 38, left: 46 };
const x0 = MARGIN.left;
const x1 = W - MARGIN.right;
const y0 = MARGIN.top;
const y1 = H - MARGIN.bottom;
const innerW = x1 - x0;
const innerH = y1 - y0;

const MAX_MONTHS = 36;
const xOf = (months: number) =>
  x0 + innerW * (Math.sqrt(months) / Math.sqrt(MAX_MONTHS));

// Y floor at $0 (was $1 under the 1Y cap): 3Y implied levels reach below
// $1 — A100 3Y ≈ $0.79 on the 2026-07-16 print — and clipping them would
// misstate the curve.
const Y_MIN = 0;
const Y_MAX = 7;
const yOf = (v: number) => y0 + innerH * ((Y_MAX - v) / (Y_MAX - Y_MIN));
const yTicks = [0, 1, 2, 3, 4, 5, 6, 7];

// Tenor floor at 3M (John 2026-07-02): the 1M point both crowded the short
// end and escaped the y-domain — B200's 1M committed carries a scarcity
// premium ABOVE OD (short-end contango, tracked in gold/committed_mi) that
// belongs to the data story, not this chart's par-curve read.
const TENORS: { term: Term; months: number }[] = [
  { term: '3M', months: 3 },
  { term: '6M', months: 6 },
  { term: '1Y', months: 12 },
  { term: '2Y', months: 24 },
  { term: '3Y', months: 36 },
];
const X_TICKS = [{ label: 'OD', months: 0 }, ...TENORS.map((t) => ({ label: t.term as string, months: t.months }))];

// Divider between the on-demand anchor and the committed region — placed at
// the sqrt-space midpoint between OD (0) and the first committed tenor (3M).
const odDividerX = x0 + innerW * (Math.sqrt(3) / 2 / Math.sqrt(MAX_MONTHS));
const anchorX = xOf(12); // 1Y — the anchor tenor

// --- data -----------------------------------------------------------------
// Vertical order on the plot (B200 top … A100 bottom) is the palette's
// validated adjacency order; the array order here is render order only.
const CHIPS = [
  { chip: 'H100', cls: 'h100' },
  { chip: 'H200', cls: 'h200' },
  { chip: 'B200', cls: 'b200' },
  { chip: 'A100', cls: 'a100' },
];

interface Pt {
  x: number;
  y: number;
  months: number;
  value: number;
  prov: boolean;
  anchor: boolean;
  title: string;
}
interface SeriesView {
  chip: string;
  cls: string;
  path: string;
  pts: Pt[];
  end: Pt;
}

// OD anchor = the NEOCLOUD band's own OD companion (pooled T2IF+T3IF,
// US/EU-core — the SAME panel as the committed tenors, apples-to-apples,
// John 2026-07-02). Falls back to the T2IF US & EU headline on snapshots
// predating the band OD series (gold PR #41); the caption discloses which
// anchor is in effect.
// OD anchor = the Neocloud (operator-tier T2) guaranteed on-demand cell — the
// same segment as the committed tenors below, so the OD→committed step is
// apples-to-apples.
function odPoint(chip: string): Pt | null {
  const c = tierOdCell('T2', chip, 'ALL');
  if (!c) return null;
  const v = headlineValue(c);
  return {
    x: xOf(0),
    y: yOf(v),
    months: 0,
    value: v,
    prov: c.promotion_status === 'Provisional',
    anchor: false,
    title: `${chip} · on-demand (Neocloud, guaranteed) · ${headlineStatOf(c)} $${fmt(v)} · ${c.n_sources} sources / ${c.n_observations} obs · ${c.promotion_status}`,
  };
}

// Signed spread for the end label — the WITHIN-PROVIDER series
// (committed_mi.csv): each operator's committed ask differenced against its
// OWN on-demand rate, aggregated operator-equal. Replaces the interim
// band-median-vs-headline % — that differenced two DIFFERENT provider
// panels and carried a ~3pp composition gap on H100 1Y (−18% cross-panel
// vs −21% within-provider, 2026-07-02). A signed spread, not a "discount"
// (committed can price above spot). Null when the chip has no
// within-provider row at its end tenor — the label then omits the %.
const TERM_OF_MONTHS: Record<number, Term> = { 1: '1M', 3: '3M', 6: '6M', 12: '1Y', 24: '2Y', 36: '3Y' };

function spreadVsOd(chip: string, months: number): { txt: string; title: string } | null {
  const term = TERM_OF_MONTHS[months];
  if (!term) return null;
  const row = wpSpread(chip, term);
  if (!row) return null;
  const pct = row.spread * 100;
  const rounded = Math.round(Math.abs(pct));
  const txt = rounded === 0 ? '0% vs OD' : `${pct > 0 ? '+' : '−'}${rounded}% vs OD`;
  return {
    txt,
    title:
      `${chip} ${term} committed vs own OD: ${pct > 0 ? '+' : '−'}${Math.abs(pct).toFixed(1)}% — ` +
      `within-provider signed spread (both legs one operator's book), ` +
      `operator-equal median of ${row.n_pairs} provider pairs`,
  };
}

// Tenor point = the observed on-demand rate stepped down by the WITHIN-PROVIDER
// term spread (committed_mi: each operator's committed ask vs its OWN on-demand,
// operator-equal). Anchoring at OD and applying that spread keeps the line's
// drop equal to the end-label at every tenor. The raw committed median differences
// two DIFFERENT provider panels (OD n≫committed n) and overstates the discount —
// e.g. H100 1Y reads −24% cross-panel but −12% within-provider.
function tenorPoint(chip: string, term: Term, months: number, odValue: number): Pt | null {
  const sp = wpSpread(chip, term);
  if (!sp) return null;
  const v = odValue * (1 + sp.spread);
  const pctTxt = `${sp.spread >= 0 ? '+' : '−'}${Math.abs(sp.spread * 100).toFixed(1)}%`;
  return {
    x: xOf(months),
    y: yOf(v),
    months,
    value: v,
    prov: sp.n_pairs < 3,
    anchor: months === 12,
    title: `${chip} · ${term} committed vs own OD: ${pctTxt} — within-provider spread (${sp.n_pairs} provider pairs) → $${fmt(v)} implied off the $${fmt(odValue)} on-demand rate`,
  };
}

const series: SeriesView[] = CHIPS.flatMap(({ chip, cls }) => {
  const od = odPoint(chip);
  if (!od) return [];
  const pts = [
    od,
    ...TENORS.map((t) => tenorPoint(chip, t.term, t.months, od.value)),
  ].filter((p): p is Pt => p !== null);
  if (pts.length < 2) return [];
  const path = pts
    .map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`)
    .join(' ');
  return [{ chip, cls, path, pts, end: pts[pts.length - 1]! }];
});

// Direct end-labels — resolve vertical collisions (snapshot data changes
// daily; converging curves can land labels on top of each other). Labels
// are pushed apart to a minimum gap; a displaced label gets a short leader
// line back to its line end.
const LBL_GAP = 15;
const endLabels = (() => {
  const items = series
    .map((s) => ({ s, y: s.end.y }))
    .sort((a, b) => a.y - b.y);
  for (let i = 1; i < items.length; i++) {
    const prev = items[i - 1]!;
    const cur = items[i]!;
    if (cur.y - prev.y < LBL_GAP) cur.y = prev.y + LBL_GAP;
  }
  // keep inside the plot's vertical extent
  const over = items.length ? items[items.length - 1]!.y - (y1 - 2) : 0;
  if (over > 0) {
    for (let i = items.length - 1; i >= 0; i--) {
      items[i]!.y -= over;
      if (i > 0 && items[i]!.y - items[i - 1]!.y >= LBL_GAP) break;
    }
  }
  return items.map(({ s, y }) => ({
    s,
    y,
    leader: Math.abs(y - s.end.y) > 2,
    spd: spreadVsOd(s.chip, s.end.months),
  }));
})();

const chipNames = series.map((s) => s.chip).join(', ');
const ariaLabel =
  `Committed par curve, as of ${meta.as_of_date}: USD per GPU-hour by tenor for ${chipNames}. ` +
  `Each line runs from the on-demand anchor through committed asks at 3 and 6 months, 1 year (the anchor tenor), 2 years and 3 years where published. ` +
  `End labels give each chip's terminal rate and its within-provider signed spread — that chip's committed asks versus the same operators' own on-demand rates, aggregated operator-equal. ` +
  `Hollow points are thin panels (fewer than 3 provider pairs); hover any point for the spread and pair count.`;
---
<figure class="tcv" aria-describedby="tcv-caption">
  <div class="tcv-head">
    <span class="tcv-kicker">Committed par curve · USD per GPU-hr</span>
    <span class="tcv-asof">as of {meta.as_of_date}</span>
  </div>

  <div class="tcv-scroll">
    <svg
      viewBox={`0 0 ${W} ${H}`}
      role="img"
      aria-label={ariaLabel}
      class="tcv-svg"
    >
      {/* y grid — hairlines, recessive */}
      {yTicks.map((v) => (
        <line
          class:list={['grid', { baseline: v === Y_MIN }]}
          x1={x0} x2={x1} y1={yOf(v)} y2={yOf(v)}
        />
      ))}
      {yTicks.map((v) => (
        <text class="ytick" x={x0 - 8} y={yOf(v) + 3.5}>${v}</text>
      ))}

      {/* OD | committed divider */}
      <line class="divider" x1={odDividerX} x2={odDividerX} y1={y0} y2={y1} />

      {/* 1Y anchor tenor — subtle emphasis */}
      <line class="anchor-line" x1={anchorX} x2={anchorX} y1={y0} y2={y1} />
      <text class="anchor-cap" x={anchorX} y={y0 - 10}>1Y anchor</text>

      {/* x ticks */}
      {X_TICKS.map((t) => (
        <>
          <line class="xtickmark" x1={xOf(t.months)} x2={xOf(t.months)} y1={y1} y2={y1 + 4} />
          <text
            class:list={['xtick', { 'xtick-anchor': t.months === 12 }]}
            x={xOf(t.months)}
            y={y1 + 17}
          >{t.label}</text>
        </>
      ))}

      {/* series lines */}
      {series.map((s) => (
        <path class={`ln s-${s.cls}`} d={s.path} />
      ))}

      {/* marks — filled = Published, hollow = Provisional; 1Y slightly larger */}
      {series.map((s) => s.pts.map((p) => (
        <circle
          class:list={['pt', `s-${s.cls}`, { prov: p.prov }]}
          cx={p.x} cy={p.y} r={p.anchor ? 5.5 : 4.5}
        />
      )))}

      {/* hover targets — generous hit area, n disclosed via title */}
      {series.map((s) => s.pts.map((p) => (
        <circle class="hit" cx={p.x} cy={p.y} r={13}>
          <title>{p.title}</title>
        </circle>
      )))}

      {/* direct end-labels — rate + signed % vs OD; leader line when displaced */}
      {endLabels.map(({ s, y, leader, spd }) => (
        <>
          {leader && (
            <line class="leader" x1={s.end.x + 6} y1={s.end.y} x2={s.end.x + 9} y2={y} />
          )}
          <text class="lbl" x={s.end.x + 11} y={y + 3.5}>
            {spd && <title>{spd.title}</title>}
            <tspan class="lbl-name">{s.chip}</tspan>
            <tspan class="lbl-val" dx="5">{fmt(s.end.value)}</tspan>
            {spd && <tspan class="lbl-spd" dx="6">{spd.txt}</tspan>}
          </text>
        </>
      ))}
    </svg>
  </div>

  <figcaption class="tcv-foot" id="tcv-caption">
    <span class="tcv-note">
      Posted committed asks across the Neocloud segment ·
      as of {meta.as_of_date} · a market-intelligence series
    </span>
    <details class="tcv-details">
      <summary>Chart notes</summary>
      <ul class="tcv-notes-list">
        <li>OD anchor = the observed Neocloud (operator-tier T2) guaranteed
        on-demand rate.</li>
        <li>Each tenor = the OD anchor stepped down by the <strong>within-provider
        term spread</strong> — each operator's committed ask vs its <em>own</em>
        on-demand rate, aggregated operator-equal. So the line's drop equals the
        end-label at every tenor.</li>
        <li>This avoids the composition bias in a raw committed-vs-OD median,
        which differences two different provider panels and overstates the
        discount (H100 1Y: −24% cross-panel vs −12% within-provider). The plotted
        tenor levels are therefore OD-consistent implied levels, not raw medians.</li>
        <li>Hollow points = thin (fewer than 3 provider pairs). Hover any point
        for the spread and pair count. Points render only at published tenors —
        a line with no 2Y point runs 1Y to 3Y directly.</li>
        <li>A committed price is a <strong>fixed schedule</strong> — the posted
        price of a commitment starting today for its full term. It is not a
        forecast of future on-demand rates, and this chart is not a forward
        curve.</li>
        <li>Term axis compressed (√months) so the short end reads · 1-day snapshots ·
        B300 joins as its committed panel clears the gate.</li>
      </ul>
    </details>
  </figcaption>
</figure>

<style>
  /*
    Series colors — chart-local tokens, one set per site theme, derived to
    sit with each theme's palette and validated with the dataviz six-checks
    script against the theme surface (see component header comment).
    Terminal values double as the :root default (site default theme).
  */
  .tcv {
    --series-h100: #cc7d00; /* amber — kin to the terminal accent */
    --series-h200: #00829e; /* cyan — kin to --info */
    --series-b200: #cb69c5; /* magenta */
    --series-a100: #5f7fd9; /* slate blue */
    border: 1px solid var(--rule);
    background: var(--surface);
    padding: 12px 14px 12px;
    margin: 0 0 20px;
  }
  :global(html[data-theme="editorial"]) .tcv {
    --series-h100: #a3660f;
    --series-h200: #0d96b6;
    --series-b200: #a02887;
    --series-a100: #4d5fc0;
  }

  .tcv-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 12px;
    padding-bottom: 9px;
    margin-bottom: 4px;
    border-bottom: 1px solid var(--rule);
  }
  .tcv-kicker {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: var(--weight-strong);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eye);
    color: var(--ink-dim);
  }
  .tcv-asof {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--ink-faint);
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .tcv-scroll { overflow-x: auto; }
  .tcv-svg { display: block; width: 100%; min-width: 680px; height: auto; }

  /* chrome — recessive hairlines */
  .grid { stroke: var(--rule); stroke-width: 1; }
  .grid.baseline { stroke: var(--rule-2); }
  .divider { stroke: var(--rule-2); stroke-width: 1; }
  .xtickmark { stroke: var(--rule-2); stroke-width: 1; }

  .anchor-line { stroke: var(--accent); stroke-width: 1; opacity: 0.3; }
  .anchor-cap {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    fill: var(--accent);
    text-anchor: middle;
  }

  .ytick, .xtick {
    font-family: var(--font-mono);
    font-size: 10.5px;
    fill: var(--ink-faint);
    font-variant-numeric: tabular-nums;
  }
  .ytick { text-anchor: end; }
  .xtick { text-anchor: middle; }
  .xtick-anchor { fill: var(--accent); font-weight: var(--weight-strong); }

  /* marks */
  .ln {
    fill: none;
    stroke-width: 2;
    stroke-linejoin: round;
    stroke-linecap: round;
  }
  .ln.s-h100 { stroke: var(--series-h100); }
  .ln.s-h200 { stroke: var(--series-h200); }
  .ln.s-b200 { stroke: var(--series-b200); }
  .ln.s-a100 { stroke: var(--series-a100); }

  /* Published: filled dot with a 2px surface ring so marks stay legible
     where they cross a line. Provisional: hollow — surface fill, series
     stroke (shape encoding, not color-only). */
  .pt { stroke: var(--surface); stroke-width: 2; }
  .pt.s-h100 { fill: var(--series-h100); }
  .pt.s-h200 { fill: var(--series-h200); }
  .pt.s-b200 { fill: var(--series-b200); }
  .pt.s-a100 { fill: var(--series-a100); }
  .pt.prov { fill: var(--surface); }
  .pt.prov.s-h100 { stroke: var(--series-h100); }
  .pt.prov.s-h200 { stroke: var(--series-h200); }
  .pt.prov.s-b200 { stroke: var(--series-b200); }
  .pt.prov.s-a100 { stroke: var(--series-a100); }

  .hit { fill: transparent; cursor: help; }

  .leader { stroke: var(--ink-faint); stroke-width: 1; }

  /* direct labels — text wears ink tokens, identity comes from the line end */
  .lbl {
    font-family: var(--font-mono);
    font-size: 11px;
    font-variant-numeric: tabular-nums;
  }
  .lbl-name { fill: var(--ink); font-weight: var(--weight-strong); letter-spacing: 0.04em; }
  .lbl-val { fill: var(--ink-dim); }
  /* signed % vs OD — muted so the rate stays primary; neutral ink, not
     red/green (a spread is context, not P&L) */
  .lbl-spd { fill: var(--ink-faint); font-size: 10px; }

  .tcv-foot {
    display: flex;
    flex-direction: column;
    gap: 2px;
    margin-top: 6px;
    padding-top: 8px;
    border-top: 1px solid var(--rule);
  }
  .tcv-note {
    font-family: var(--font-mono);
    font-size: calc(var(--fs-xs) - 1px);
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    line-height: 1.6;
  }

  .tcv-details { margin-top: 2px; }
  .tcv-details summary {
    font-family: var(--font-mono);
    font-size: calc(var(--fs-xs) - 1px);
    color: var(--ink-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    cursor: pointer;
    width: fit-content;
  }
  .tcv-notes-list {
    margin: 6px 0 2px;
    padding-left: 18px;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .tcv-notes-list li {
    font-family: var(--font-mono);
    font-size: calc(var(--fs-xs) - 1px);
    color: var(--ink-faint);
    letter-spacing: 0.02em;
    line-height: 1.6;
  }
</style>
