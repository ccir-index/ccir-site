---
/*
  Inline SVG sparkline. Reads per-series history from the bundled
  indices_history CSV via seriesHistory(), capped to the trailing N points
  (default 7 — labelled as "7d" in the table headers, since snapshots are
  daily and gap-free). Auto-scaled (min..max within the window); a flat
  series renders as a centered horizontal line. Stroke uses currentColor so
  callers can theme via a wrapping color rule.

  Falls back to an empty span (preserving width/height for layout) when the
  series has fewer than two historical points.
*/
import { seriesHistory } from '../data/snapshot';

interface Props {
  seriesId: string;
  median: number;
  width?: number;
  height?: number;
  windowDays?: number;
}

const { seriesId, median, width = 60, height = 18, windowDays = 7 } = Astro.props;

const hist = seriesHistory(seriesId);
// Make sure today's median is reflected even if the bundled history file
// hasn't caught up to the current snapshot yet (e.g. between sync ticks),
// then cap to the trailing N-day window.
const points = (() => {
  let merged: { date: string; median: number }[] = hist;
  if (merged.length === 0) {
    return Number.isFinite(median) ? [{ date: '', median }] : [];
  }
  const last = merged[merged.length - 1]!;
  if (Number.isFinite(median) && Math.abs(last.median - median) > 1e-9) {
    merged = [...merged, { date: '', median }];
  }
  return merged.slice(-windowDays);
})();

const PAD = 1;
const innerW = Math.max(1, width - PAD * 2);
const innerH = Math.max(1, height - PAD * 2);

let polyline: string | null = null;
let endX = 0;
let endY = 0;

if (points.length >= 2) {
  const ys = points.map((p) => p.median);
  const lo = Math.min(...ys);
  const hi = Math.max(...ys);
  const span = hi - lo;
  const stepX = innerW / (points.length - 1);
  const coords = points.map((p, i) => {
    const x = PAD + i * stepX;
    const y = span > 0
      ? PAD + innerH - ((p.median - lo) / span) * innerH
      : PAD + innerH / 2;
    return [x, y] as const;
  });
  polyline = coords.map(([x, y]) => `${x.toFixed(2)},${y.toFixed(2)}`).join(' ');
  [endX, endY] = coords[coords.length - 1]!;
}
---
{polyline ? (
  <svg
    class="sparkline"
    width={width}
    height={height}
    viewBox={`0 0 ${width} ${height}`}
    role="img"
    aria-label={`${windowDays}-day trend (${points.length} points)`}
  >
    <polyline
      points={polyline}
      fill="none"
      stroke="currentColor"
      stroke-width="1"
      stroke-linejoin="round"
      stroke-linecap="round"
      vector-effect="non-scaling-stroke"
    />
    <circle cx={endX} cy={endY} r="1.4" fill="currentColor" />
  </svg>
) : (
  <span
    class="sparkline-empty"
    style={`display:inline-block;width:${width}px;height:${height}px;`}
    aria-hidden="true"
    role="presentation"
  ></span>
)}
<style>
  .sparkline { display: inline-block; vertical-align: middle; }
</style>
