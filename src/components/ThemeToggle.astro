---
// Two-state toggle. Flips the data-theme attribute on <html> between
// "editorial" (default) and "terminal". Persisted in localStorage under
// the key `ccir-theme`.
---
<button type="button" id="theme-toggle" aria-label="Toggle theme" title="Toggle theme">
  <span class="seg" data-theme-target="terminal">Terminal</span>
  <span class="seg" data-theme-target="editorial">Editorial</span>
</button>

<style>
  #theme-toggle {
    display: inline-flex;
    align-items: stretch;
    background: transparent;
    border: 1px solid var(--rule-2);
    color: var(--ink-dim);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--tracking-eye);
    text-transform: uppercase;
    cursor: pointer;
    border-radius: var(--rad);
    padding: 0;
    overflow: hidden;
  }
  #theme-toggle .seg {
    padding: 4px 10px;
    color: var(--ink-faint);
    transition: color 120ms, background 120ms;
  }
  #theme-toggle .seg + .seg { border-left: 1px solid var(--rule-2); }
  #theme-toggle:hover { border-color: var(--accent); }

  :global(html[data-theme="terminal"]) #theme-toggle .seg[data-theme-target="terminal"] {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }
  :global(html[data-theme="editorial"]) #theme-toggle .seg[data-theme-target="editorial"] {
    color: var(--accent);
    background: color-mix(in srgb, var(--accent) 14%, transparent);
  }
</style>

<script is:inline>
  (function () {
    var btn = document.getElementById('theme-toggle');
    if (!btn) return;
    btn.addEventListener('click', function () {
      var root = document.documentElement;
      var current = root.getAttribute('data-theme') || 'editorial';
      var next = current === 'terminal' ? 'editorial' : 'terminal';
      root.setAttribute('data-theme', next);
      try { localStorage.setItem('ccir-theme', next); } catch (e) {}
    });
  })();
</script>
