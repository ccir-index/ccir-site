---
/*
  Three operator segments of GPU compute — T1 Hyperscaler / T2 Neocloud /
  T3 Marketplace. The segment is a property of the operator (registry
  operator_class), not the chip; the same silicon is priced across all three.

  Each segment is a WSJ-style feature box:
    kicker (mono code badge) → serif headline (segment name) →
    standfirst (2-3 sentences) → operator matrix.
*/
import { TIERS, TIER_LABELS, TIER_LABELS_SHORT, type Tier } from '../data/types';

interface Props {
  compact?: boolean;
  headerless?: boolean;
}
const { compact = false, headerless = false } = Astro.props;

const tiers: Array<{
  code: Tier;
  name: string;
  standfirst: string;
}> = [
  {
    code: 'T1',
    name: TIER_LABELS.T1,
    standfirst:
      'The global hyperscale clouds — AWS, Azure, Google Cloud, Oracle. Deep managed capacity, enterprise contracts, and the widest service surface. On-demand GPU rates sit at the top of the market.',
  },
  {
    code: 'T2',
    name: TIER_LABELS.T2,
    standfirst:
      'The dedicated GPU specialists — CoreWeave, Lambda, Nebius and peers. Single-tenant clusters built for training and inference, priced below the hyperscalers.',
  },
  {
    code: 'T3',
    name: TIER_LABELS.T3,
    standfirst:
      'Marketplace and shared-pool venues — Vast, RunPod and aggregators. Self-serve capacity, interruptibility common, at the lowest rate band in the panel.',
  },
];

// Capability matrix — five attributes across three tiers. Each cell is a
// short editorial phrase, not a one-word label.
type AttrKey = 'tenancy' | 'fabric' | 'bundle' | 'operators' | 'use';
const attrs: Array<{ key: AttrKey; label: string; cells: Record<Tier, string> }> = [
  {
    key: 'tenancy',
    label: 'Footprint',
    cells: {
      T1: 'Managed multi-service hyperscale cloud',
      T2: 'Dedicated single-tenant GPU clusters',
      T3: 'Shared-pool or marketplace supply',
    },
  },
  {
    key: 'fabric',
    label: 'Networking',
    cells: {
      T1: 'Hyperscale backbone, managed networking',
      T2: 'Dedicated cluster fabric, often InfiniBand',
      T3: 'Variable — Ethernet or undisclosed',
    },
  },
  {
    key: 'bundle',
    label: 'Services',
    cells: {
      T1: 'Full enterprise services, support, compliance',
      T2: 'Focused GPU stack, lighter wrap',
      T3: 'Self-serve, minimal support',
    },
  },
  {
    key: 'operators',
    label: 'Examples in this segment',
    cells: {
      T1: 'e.g. AWS · Azure · Google Cloud · Oracle',
      T2: 'e.g. CoreWeave · Lambda · Nebius',
      T3: 'e.g. Vast · RunPod · marketplaces',
    },
  },
  {
    key: 'use',
    label: 'Typical use',
    cells: {
      T1: 'Enterprise & regulated workloads',
      T2: 'Dedicated training & inference',
      T3: 'Cost-sensitive batch, dev/test, spot',
    },
  },
];
---
<section class={`tiers ${compact ? 'tiers-compact' : ''}`}>
  {!headerless && (
    <header class="tiers-header">
      <div class="kicker">Operator Segments</div>
      <h2>Three Operator Segments</h2>
      <p class="standfirst">
        Each segment is a class of operator — hyperscaler, neocloud, or
        marketplace. CCIR publishes one reference rate per segment so users
        can compare the same silicon across where it is actually operated.
      </p>
    </header>
  )}

  <div class="tier-grid">
    {tiers.map((t) => (
      <article class={`tier-card tier-${t.code.toLowerCase()}`}>
        <header class="tc-head">
          <h3 class={`tc-name tc-name-${t.code.toLowerCase()}`}>{t.name}</h3>
        </header>
        <p class="tc-standfirst">{t.standfirst}</p>
      </article>
    ))}
  </div>

  <div class="cap-matrix-wrap">
    <table class="data cap-matrix">
      <thead>
        <tr>
          <th class="attr-col">Attribute</th>
          {TIERS.map((t) => (
            <th class={`tier-col tier-col-${t.toLowerCase()}`}>
              <span class={`seg-name seg-name-${t.toLowerCase()}`}>{TIER_LABELS_SHORT[t]}</span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {attrs.map((a) => (
          <tr>
            <td class="attr-name">{a.label}</td>
            {TIERS.map((t) => (
              <td class="attr-cell">{a.cells[t]}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
    <p class="cap-caption">
      Each segment describes a distinct class of operator — hyperscaler,
      neocloud, or marketplace. The segment is a property of the
      <strong>operator</strong>, not the chip: the same silicon is priced
      across all three, so the ladder compares one chip's hyperscale,
      neocloud, and marketplace rate side by side.
    </p>
  </div>
</section>

<style>
  .tiers { margin: 8px 0 32px; }
  .tiers-header { max-width: 80ch; margin-bottom: 18px; }
  .tiers-header h2 {
    font-size: var(--fs-2xl);
    margin: 4px 0 10px;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    margin-bottom: 18px;
  }
  @media (max-width: 900px) {
    .tier-grid { grid-template-columns: 1fr; }
  }

  .tier-card {
    background: var(--surface);
    padding: 18px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tc-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .tc-head h3 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--ink);
    font-weight: var(--weight-display);
    letter-spacing: -0.005em;
  }
  .tc-name-t1 { color: var(--tier-t1); }
  .tc-name-t2 { color: var(--accent); }  /* middle tier (Neocloud) highlighted */
  .tc-name-t3 { color: var(--tier-t3); }
  .seg-name {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eye);
    font-weight: var(--weight-strong);
  }
  .seg-name-t1 { color: var(--tier-t1); }
  .seg-name-t2 { color: var(--accent); }
  .seg-name-t3 { color: var(--tier-t3); }
  .tc-standfirst {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    color: var(--ink);
    margin: 0;
    line-height: 1.55;
  }

  .cap-matrix-wrap {
    border: 1px solid var(--rule);
    background: var(--surface);
    overflow-x: auto;
  }
  table.cap-matrix { width: 100%; border-collapse: collapse; }
  table.cap-matrix th.attr-col {
    text-align: left;
    width: 18%;
    min-width: 140px;
  }
  table.cap-matrix th.tier-col {
    text-align: left;
    width: 27.33%;
  }
  table.cap-matrix td.attr-name {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eye);
    color: var(--ink-dim);
    text-align: left;
    background: var(--surface-2);
    font-weight: var(--weight-strong);
    white-space: nowrap;
  }
  table.cap-matrix td.attr-cell {
    text-align: left;
    font-family: var(--font-body);
    color: var(--ink);
    line-height: 1.45;
    font-size: var(--fs-sm);
  }
  .cap-caption {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--ink-dim);
    line-height: 1.55;
    margin: 12px 16px 14px;
    font-style: italic;
    border-top: 1px solid var(--rule);
    padding-top: 12px;
    max-width: 80ch;
  }

  @media (max-width: 720px) {
    table.cap-matrix th, table.cap-matrix td {
      font-size: var(--fs-xs);
      padding: 8px 10px;
    }
  }
</style>
