---
/*
  Three tiers of GPU compute. Premium-chip classification —
  T1IF / T2IF / T3IF, assigned per-SKU from the attributes each SKU
  (fabric, host topology, bundle depth, support).

  Each tier is a WSJ-style feature box:
    kicker (mono code badge) → serif headline (full IF name) →
    standfirst (2-3 sentences, throughput framing) → capability matrix.
*/
import { TIERS, TIER_LABELS, type Tier } from '../data/types';

interface Props {
  compact?: boolean;
  headerless?: boolean;
}
const { compact = false, headerless = false } = Astro.props;

const tiers: Array<{
  code: Tier;
  name: string;
  standfirst: string;
}> = [
  {
    code: 'T1IF',
    name: TIER_LABELS.T1IF,
    standfirst:
      'Disclosed top-tier cluster fabric — non-blocking, rail-optimized RDMA at training scale — on dedicated single-tenant bare-metal, with the full enterprise bundle: managed operations, tiered support, observability, egress allowance, regulated-workload compliance. The most complete configuration in the CCIR panel.',
  },
  {
    code: 'T2IF',
    name: TIER_LABELS.T2IF,
    standfirst:
      'Dedicated single-tenant bare-metal with a disclosed, mid-tier real cluster fabric; no requirement for the full enterprise bundle. The middle configuration — real fabric, lighter wrap.',
  },
  {
    code: 'T3IF',
    name: TIER_LABELS.T3IF,
    standfirst:
      'Co-located, shared, or marketplace supply — plus dedicated hosts that don\'t disclose a real fabric. Variable Ethernet underlay, self-serve, no support tier, interruptibility common. The lowest rate band — and the most constrained configuration behind it.',
  },
];

// Capability matrix — five attributes across three tiers. Each cell is a
// short editorial phrase, not a one-word label.
type AttrKey = 'tenancy' | 'fabric' | 'bundle' | 'operators' | 'use';
const attrs: Array<{ key: AttrKey; label: string; cells: Record<Tier, string> }> = [
  {
    key: 'tenancy',
    label: 'Tenancy',
    cells: {
      T1IF: 'Dedicated bare-metal, single-tenant',
      T2IF: 'Dedicated bare-metal, single-tenant',
      T3IF: 'Shared-pool or marketplace',
    },
  },
  {
    key: 'fabric',
    label: 'Fabric',
    cells: {
      T1IF: 'Disclosed RDMA — non-blocking, rail-optimized, training-scale',
      T2IF: 'Disclosed mid-tier real cluster fabric',
      T3IF: 'Ethernet, undisclosed, or trivial RDMA',
    },
  },
  {
    key: 'bundle',
    label: 'Bundle depth',
    cells: {
      T1IF: 'Managed ops, tiered support, observability, egress allowance, compliance',
      T2IF: 'Bundle varies — not gated; observed mix of basic to richer disclosures',
      T3IF: 'Self-serve, no support tier',
    },
  },
  {
    key: 'operators',
    label: 'Examples at this tier',
    cells: {
      T1IF: 'e.g. AWS · CoreWeave (flagship SXM clusters)',
      T2IF: 'e.g. CoreWeave (A100) — same operator, different grade per SKU',
      T3IF: 'e.g. Scaleway · CoreWeave (L40S)',
    },
  },
  {
    key: 'use',
    label: 'Use case',
    cells: {
      T1IF: 'Production training, regulated workloads',
      T2IF: 'Dedicated training, less ceremony',
      T3IF: 'Cost-sensitive batch, dev/test, spot',
    },
  },
];
---
<section class={`tiers ${compact ? 'tiers-compact' : ''}`}>
  {!headerless && (
    <header class="tiers-header">
      <div class="kicker">Tier Structure</div>
      <h2>Three Production Tiers</h2>
      <p class="standfirst">
        Each tier bundles a defined set of attributes — fabric, host,
        support, compliance. CCIR publishes one reference rate per tier so
        users can match the rate to the class of compute they actually buy.
      </p>
    </header>
  )}

  <div class="tier-grid">
    {tiers.map((t) => (
      <article class={`tier-card tier-${t.code.toLowerCase()}`}>
        <header class="tc-head">
          <span class={`tc-badge tier-badge tier-badge-${t.code.toLowerCase()}`}>{t.code}</span>
          <h3>{t.name}</h3>
        </header>
        <p class="tc-standfirst">{t.standfirst}</p>
      </article>
    ))}
  </div>

  <div class="cap-matrix-wrap">
    <table class="data cap-matrix">
      <thead>
        <tr>
          <th class="attr-col">Attribute</th>
          {TIERS.map((t) => (
            <th class={`tier-col tier-col-${t.toLowerCase()}`}>
              <span class={`tier-badge tier-badge-${t.toLowerCase()}`}>{t}</span>
            </th>
          ))}
        </tr>
      </thead>
      <tbody>
        {attrs.map((a) => (
          <tr>
            <td class="attr-name">{a.label}</td>
            {TIERS.map((t) => (
              <td class="attr-cell">{a.cells[t]}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
    <p class="cap-caption">
      Each tier describes a distinct class of compute — fabric, host,
      bundled services, use case. Tiers are assigned
      <strong>per&#8209;SKU</strong>, not per operator: the same provider
      appears at several tiers as its products differ — CoreWeave's flagship
      SXM clusters classify as T1IF, its A100 as T2IF, its L40S as T3IF.
    </p>
  </div>
</section>

<style>
  .tiers { margin: 8px 0 32px; }
  .tiers-header { max-width: 80ch; margin-bottom: 18px; }
  .tiers-header h2 {
    font-size: var(--fs-2xl);
    margin: 4px 0 10px;
  }

  .tier-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1px;
    background: var(--rule);
    border: 1px solid var(--rule);
    margin-bottom: 18px;
  }
  @media (max-width: 900px) {
    .tier-grid { grid-template-columns: 1fr; }
  }

  .tier-card {
    background: var(--surface);
    padding: 18px 20px 18px;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .tc-head {
    display: flex;
    align-items: baseline;
    gap: 12px;
  }
  .tc-head h3 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    color: var(--ink);
    font-weight: var(--weight-display);
    letter-spacing: -0.005em;
  }
  .tc-standfirst {
    font-family: var(--font-body);
    font-size: var(--fs-md);
    color: var(--ink);
    margin: 0;
    line-height: 1.55;
  }

  .cap-matrix-wrap {
    border: 1px solid var(--rule);
    background: var(--surface);
    overflow-x: auto;
  }
  table.cap-matrix { width: 100%; border-collapse: collapse; }
  table.cap-matrix th.attr-col {
    text-align: left;
    width: 18%;
    min-width: 140px;
  }
  table.cap-matrix th.tier-col {
    text-align: left;
    width: 27.33%;
  }
  table.cap-matrix td.attr-name {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eye);
    color: var(--ink-dim);
    text-align: left;
    background: var(--surface-2);
    font-weight: var(--weight-strong);
    white-space: nowrap;
  }
  table.cap-matrix td.attr-cell {
    text-align: left;
    font-family: var(--font-body);
    color: var(--ink);
    line-height: 1.45;
    font-size: var(--fs-sm);
  }
  .cap-caption {
    font-family: var(--font-body);
    font-size: var(--fs-sm);
    color: var(--ink-dim);
    line-height: 1.55;
    margin: 12px 16px 14px;
    font-style: italic;
    border-top: 1px solid var(--rule);
    padding-top: 12px;
    max-width: 80ch;
  }

  @media (max-width: 720px) {
    table.cap-matrix th, table.cap-matrix td {
      font-size: var(--fs-xs);
      padding: 8px 10px;
    }
  }
</style>
