---
import { headlineRates, meta, seriesHistory } from '../data/snapshot';
import Sparkline from './Sparkline.astro';

// Premium-chip series only. Featured flagship cells under the 7-segment
// grammar. T1IF / T2IF / T3IF spread across the canonical 6 silicons.
const featured = [
  'CRI-T1IF-H100-ALL-GTD-OD-ALL',
  'CRI-T2IF-H100-ALL-GTD-OD-ALL',
  'CRI-T3IF-H100-ALL-ALL-OD-ALL',
  'CRI-T1IF-H200-ALL-GTD-OD-ALL',
  'CRI-T2IF-H200-ALL-GTD-OD-ALL',
  'CRI-T3IF-H200-ALL-ALL-OD-ALL',
  'CRI-T1IF-B200-ALL-GTD-OD-ALL',
  'CRI-T2IF-B200-ALL-GTD-OD-ALL',
  'CRI-T3IF-B200-ALL-ALL-OD-ALL',
  'CRI-T1IF-GB200-ALL-GTD-OD-ALL',
  'CRI-T2IF-A100-ALL-GTD-OD-ALL',
  'CRI-T3IF-A100-ALL-ALL-OD-ALL',
];

const ticks = featured
  .map((id) => headlineRates.find((r) => r.series_id === id))
  .filter((r): r is NonNullable<typeof r> => !!r);

const fmt = (n: number) => n.toFixed(2);
const short = (r: typeof ticks[number]) => {
  const parts = r.series_id.split('-');
  const tier = parts[1]!;
  const chip = parts.slice(2, parts.length - 4).join('-');
  return `${tier} ${chip}`;
};

// 30-day change: today's price_median vs the bundled history point closest
// to 30 calendar days ago. Returns null (→ flat glyph, no %) when there is
// no reference point at least ~2 weeks back — bootstrap days or new series
// don't have a meaningful 30-day window yet.
const DAY = 86_400_000;
const MIN_LOOKBACK_DAYS = 14; // reference must be at least this old to show a %

function change30(r: typeof ticks[number]): { pct: number; dir: 'up' | 'down' | 'flat' } | null {
  const hist = seriesHistory(r.series_id);
  if (hist.length < 2) return null;
  const latestMs = Date.parse(hist[hist.length - 1]!.date);
  const targetMs = latestMs - 30 * DAY;
  // Point whose date is nearest to 30 days ago.
  let ref = hist[0]!;
  let best = Infinity;
  for (const p of hist) {
    const d = Math.abs(Date.parse(p.date) - targetMs);
    if (d < best) { best = d; ref = p; }
  }
  const lookbackDays = (latestMs - Date.parse(ref.date)) / DAY;
  if (lookbackDays < MIN_LOOKBACK_DAYS || !(ref.median > 0)) return null;
  const pct = ((r.price_median - ref.median) / ref.median) * 100;
  const rounded = Math.round(pct * 10) / 10;
  const dir = rounded > 0 ? 'up' : rounded < 0 ? 'down' : 'flat';
  return { pct: rounded, dir };
}

const runLabel = meta.as_of_date;
---
<div class="tape" role="region" aria-label="Published premium-chip rates">
  <span class="tape-label">AS OF · {runLabel} · 30D CHANGE</span>
  <div class="tape-rail">
    <div class="tape-marquee">
      {[0, 1].map((dup) => (
        <div class="tape-track" aria-hidden={dup === 1 ? 'true' : 'false'}>
          {ticks.map((r) => {
            const chg = change30(r);
            const dir = chg?.dir ?? 'flat';
            const glyph = dir === 'up' ? '▲' : dir === 'down' ? '▼' : '─';
            const pctLabel = chg ? `${chg.pct > 0 ? '+' : ''}${chg.pct.toFixed(1)}%` : '';
            return (
              <span class="tick">
                <span class="sym">{short(r)}</span>
                <span class="px">${fmt(r.price_median)}</span>
                <span class={`dir dir-${dir}`}>{glyph}{pctLabel && ` ${pctLabel}`}</span>
                <span class="spark"><Sparkline seriesId={r.series_id} median={r.price_median} width={42} height={14} /></span>
              </span>
            );
          })}
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .tape {
    background: var(--surface-2);
    border-bottom: 1px solid var(--rule);
    border-top: 1px solid var(--rule);
    display: flex;
    align-items: stretch;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    overflow: hidden;
  }
  .tape-label {
    padding: 8px 14px;
    background: var(--surface-3);
    color: var(--accent);
    text-transform: uppercase;
    letter-spacing: var(--tracking-eye);
    border-right: 1px solid var(--rule);
    font-weight: var(--weight-strong);
    white-space: nowrap;
    display: flex;
    align-items: center;
  }
  .tape-rail {
    padding: 6px 0;
    flex: 1;
    overflow: hidden;
    position: relative;
    mask-image: linear-gradient(
      to right, transparent 0, black 24px,
      black calc(100% - 24px), transparent 100%
    );
  }
  .tape-marquee {
    display: flex;
    width: max-content;
    animation: tape-scroll 50s linear infinite;
  }
  .tape-rail:hover .tape-marquee { animation-play-state: paused; }
  .tape-track {
    display: flex;
    gap: 28px;
    padding: 0 14px;
  }
  @keyframes tape-scroll {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .tape-marquee { animation: none; }
    .tape-rail { overflow-x: auto; mask-image: none; }
  }
  .tick {
    display: inline-flex;
    gap: 6px;
    white-space: nowrap;
    align-items: center;
  }
  .tick .sym {
    color: var(--ink-dim);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .tick .px {
    color: var(--ink);
    font-weight: var(--weight-strong);
  }
  .tick .dir { font-size: var(--fs-xs); white-space: nowrap; }
  .tick .dir-up { color: var(--neg); }
  .tick .dir-down { color: var(--pos); }
  .tick .dir-flat { color: var(--ink-faint); }
  .tick .spark { display: inline-flex; }
</style>
