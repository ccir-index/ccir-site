---
// /applications retired with the market-intelligence repositioning
// (2026-07-04): the page carried the retired credit-lane content. Old links
// land on the benchmark rates. Static-host-safe meta-refresh redirect.
const DEST = '/rates';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <link rel="canonical" href={DEST} />
    <meta name="robots" content="noindex" />
    <title>Moved · CMR</title>
  </head>
  <body>
    <p>This page has moved to <a href={DEST}>{DEST}</a>.</p>
    <script set:html={`location.replace(${JSON.stringify(DEST)});`}></script>
  </body>
</html>
