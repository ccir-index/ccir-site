---
import Base from '../layouts/Base.astro';
import TokenIndexChart from '../components/TokenIndexChart.astro';
import { tokenModels, tokenMeta } from '../data/tokens';
import { meta } from '../data/snapshot';

const fmt = (n: number | null, dp = 2) => (n === null ? '—' : n.toFixed(dp));
const fmtDisp = (n: number | null) =>
  n === null ? '—' : `${Math.round(n * 100)}%`;

const basket = tokenModels.filter((m) => m.in_basket);
const rest = tokenModels.filter((m) => !m.in_basket);
---
<Base
  title="LLM Token Prices — Fixed-Basket $/Mtoken Price Series · CCIR"
  description="What a million tokens costs, measured on a constant basket. Daily posted input and output prices for a frozen five-model basket of open-weight LLMs, plus per-model cross-provider medians with dispersion disclosed."
  ogImage="/og/tokens.png"
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'CCIR Token Prices',
    description: 'Fixed-basket LLM token price series — daily posted input and output $/Mtoken for a frozen five-model basket of open-weight models, each priced as the operator-equal median across serving providers, plus per-model cross-provider price cells with dispersion disclosed.',
    url: 'https://ccir.io/tokens',
    creator: { '@type': 'Organization', name: 'CCIR', url: 'https://ccir.io' },
    temporalCoverage: '2026-07/..',
    keywords: [
      'LLM token prices', 'token price index', 'cost per million tokens',
      'LLM API pricing', 'DeepSeek API price', 'open-weight model pricing',
      'LLM inference cost', 'GPT-OSS pricing', 'Qwen API price',
      'token price per million', 'LLM price comparison',
    ],
    license: 'https://creativecommons.org/licenses/by/4.0/',
    isAccessibleForFree: true,
  })} />
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Market Intelligence · {meta.as_of_date}</div>
      <h1>Token Prices</h1>
      <p class="standfirst">
        What a million tokens costs, measured on a constant good. Daily
        posted input and output prices for a frozen basket of open-weight
        models — a series whose moves mean one thing: a provider changed a
        price.
      </p>
    </header>

    <aside class="mi-banner" role="note">
      <strong>A market-intelligence series on posted token prices.</strong>
      The basket is fixed — five open-weight models, one per lab, membership
      frozen and versioned, so the basket does not change under you. A move
      in this series is a repricing, not a shift in what people happened to
      buy. Input and output legs publish separately. Construction and
      panel-depth conventions are in the chart notes beneath the figure.
    </aside>

    <section class="chart-section">
      <header class="sec-head">
        <div class="kicker">Section 01 · The composite</div>
        <h2>The Fixed-Basket Series</h2>
      </header>

      <TokenIndexChart />
    </section>

    {tokenMeta && (
    <section class="models-section">
      <header class="sec-head">
        <div class="kicker">Section 02 · Per-model cells · {tokenMeta.seriesEnd}</div>
        <h2>Cross-Provider Model Prices</h2>
        <p class="sec-lede">
          The same open weights sell at very different prices depending on
          who serves them. Each row is one model version priced by at least
          three providers: the operator-equal median per leg, with the
          max/min dispersion across providers disclosed — the serving-grade
          spread a single posted price hides.
        </p>
      </header>

      <div class="tbl-scroll">
        <table class="models-tbl">
          <thead>
            <tr>
              <th class="t-model">Model</th>
              <th class="t-n">Providers</th>
              <th class="t-num">Input $/Mtok</th>
              <th class="t-num">Output $/Mtok</th>
              <th class="t-num">Output dispersion</th>
            </tr>
          </thead>
          <tbody>
            {basket.map((m) => (
              <tr class="basket-row">
                <td class="t-model">{m.model_display}<span class="basket-tag">basket</span></td>
                <td class="t-n">{m.n_providers}</td>
                <td class="t-num">{fmt(m.input_median)}</td>
                <td class="t-num">{fmt(m.output_median)}</td>
                <td class="t-num">{fmtDisp(m.output_dispersion_pct)}</td>
              </tr>
            ))}
            {rest.map((m) => (
              <tr>
                <td class="t-model">{m.model_display}</td>
                <td class="t-n">{m.n_providers}</td>
                <td class="t-num">{fmt(m.input_median)}</td>
                <td class="t-num">{fmt(m.output_median)}</td>
                <td class="t-num">{fmtDisp(m.output_dispersion_pct)}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="tbl-note">
        Posted list prices, operator-equal median per leg (one provider, one
        vote) · models shown at a minimum of 3 serving providers · dispersion
        = max/min − 1 across providers, output leg · as of {tokenMeta.seriesEnd}.
      </p>
    </section>
    )}

    <aside class="mi-more">
      <span class="kicker">More research</span>
      <a href="/rates/">CCIR Reference Rates — the GPU rental-rate benchmark
      beneath these serving markets →</a>
    </aside>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { margin-bottom: 18px; max-width: 84ch; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-3xl);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 12px;
    }

    .mi-banner {
      margin: 0 0 28px;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface);
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink);
      line-height: 1.6;
      max-width: 84ch;
    }
    .mi-banner strong { color: var(--accent); }

    .sec-head { margin-bottom: 14px; max-width: 84ch; }
    .sec-head h2 { font-size: var(--fs-2xl); margin: 4px 0 10px; }
    .sec-lede {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.6;
      margin: 0 0 4px;
    }

    .chart-section { margin: 0 0 36px; }
    .models-section { margin: 0 0 36px; }

    .tbl-scroll { overflow-x: auto; border: 1px solid var(--rule); background: var(--surface); }
    .models-tbl {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
    }
    .models-tbl th {
      text-align: left;
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      padding: 9px 12px;
      border-bottom: 1px solid var(--rule-2);
      white-space: nowrap;
    }
    .models-tbl td {
      padding: 7px 12px;
      border-bottom: 1px solid var(--rule);
      color: var(--ink);
      white-space: nowrap;
    }
    .models-tbl .t-num, .models-tbl th.t-num { text-align: right; font-variant-numeric: tabular-nums; }
    .models-tbl .t-n, .models-tbl th.t-n { text-align: right; font-variant-numeric: tabular-nums; }
    .basket-row td { background: color-mix(in srgb, var(--accent) 5%, transparent); }
    .basket-tag {
      margin-left: 8px;
      padding: 1px 6px;
      border: 1px solid var(--accent);
      color: var(--accent);
      font-size: calc(var(--fs-xs) - 2px);
      text-transform: uppercase;
      letter-spacing: 0.06em;
    }
    .tbl-note {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      line-height: 1.6;
      margin: 8px 0 0;
      max-width: 84ch;
    }

    .mi-more {
      margin: 0 0 36px;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      background: var(--surface);
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      line-height: 1.6;
    }
    .mi-more .kicker { display: block; margin-bottom: 4px; }
    .mi-more a { color: var(--accent); }
  </style>
</Base>
