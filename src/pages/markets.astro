---
import Base from '../layouts/Base.astro';
import { meta } from '../data/snapshot';
import { PREMIUM_CHIPS } from '../data/listings_history';

const DEFAULT_CHIP = 'h100-sxm-80gb';
const listingsMeta = (meta as any).listings_history;
const windowDays = listingsMeta?.window_days ?? 90;
const nChips = listingsMeta?.chips?.length ?? PREMIUM_CHIPS.length;
const totalRows = listingsMeta?.total_rows ?? 0;
const windowEnd = listingsMeta?.window_end ?? '—';
---
<Base title="Providers · CCIR">
  <section class="wrap top vast-page markets-page">
    <div class="kicker">PROVIDERS · DAILY LIST-ASK TIME-SERIES</div>
    <h1>Providers</h1>
    <div class="ticker-strip" role="group" aria-label="Snapshot stats">
      <div class="tk-cell"><span class="tk-lbl">Window</span><span class="tk-val">{windowDays}d</span></div>
      <div class="tk-cell"><span class="tk-lbl">Chips</span><span class="tk-val">{nChips}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Observations</span><span class="tk-val">{totalRows}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Last day</span><span class="tk-val">{windowEnd}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Cadence</span><span class="tk-val">1d</span></div>
      <div class="tk-cell tk-status"><span class="tk-dot"></span><span class="tk-val">LIVE</span></div>
    </div>
    <p class="standfirst lede">
      Each operator's posted rack rate for the chosen chip, plotted over
      time. Solid lines are guaranteed (non-interruptible) availability;
      dashed lines are interruptible. Bundled offerings (managed storage,
      premium support, fabric) are flagged in the legend and can be
      toggled off.
    </p>

    <div class="controls">
      <div class="control-row chip-row">
        <span class="control-label">Chip</span>
        <div class="pill-group" id="chip-pills" role="group" aria-label="Select up to 3 chips">
          {PREMIUM_CHIPS.map((c) => (
            <button type="button" class="pill" data-chip={c.id} data-default={c.id === DEFAULT_CHIP}>
              {c.label}
            </button>
          ))}
        </div>
        <span class="chip-cap" id="chip-cap-hint">multi-select · up to 3</span>
      </div>

      <div class="control-row toggles-row">
        <label class="toggle">
          <input type="checkbox" id="int-toggle" checked />
          Show interruptible
        </label>
        <label class="toggle">
          <input type="checkbox" id="bundled-toggle" checked />
          Show bundled
        </label>
        <label class="toggle log-toggle" id="log-toggle-wrap" hidden>
          <input type="checkbox" id="log-toggle" />
          Log scale
        </label>
      </div>
    </div>

    <div class="chart-wrap chart-wrap-hero">
      <div class="chart-status" id="chart-status">Loading…</div>
      <canvas id="chart" aria-label="Provider rack rates over time"></canvas>
    </div>

    <section class="legend-section">
      <header class="legend-head">
        <span class="sec-kicker-label">PROVIDERS</span>
        <span class="sec-note" id="legend-summary">—</span>
      </header>
      <div class="table-wrap">
        <table class="data multi-off" id="legend-table">
          <thead>
            <tr>
              <th class="chip-col">Chip</th>
              <th>Provider</th>
              <th>Type</th>
              <th class="num">Latest</th>
              <th class="num">7-day Δ</th>
              <th>Bundle</th>
              <th class="num">Days</th>
            </tr>
          </thead>
          <tbody id="legend-tbody"></tbody>
        </table>
      </div>
    </section>

    <p class="footnote">
      Refreshed once daily at the morning publish. History begins on the
      day this product launched — earlier periods are not backfilled.
    </p>
  </section>

  <script>
    import Chart from 'chart.js/auto';
    import 'chartjs-adapter-date-fns';
    import {
      fetchListingsCsv, filterRows, buildSeries, colorForSource,
      colorForChip, shortLabelForChip,
      type ChipId, type ProviderSeries,
    } from '../data/listings_history';

    const DEFAULT_CHIP: ChipId = 'h100-sxm-80gb';
    const MAX_CHIPS = 3;

    type Augmented = ProviderSeries & { chip: ChipId };

    const state = {
      chips: new Set<ChipId>([DEFAULT_CHIP]),
      include_interruptible: true,
      include_bundled: true,
      log_scale: false,
      cache: new Map<ChipId, Awaited<ReturnType<typeof fetchListingsCsv>> | null>(),
    };

    const statusEl = document.getElementById('chart-status') as HTMLDivElement;
    const canvas = document.getElementById('chart') as HTMLCanvasElement;
    const intToggle = document.getElementById('int-toggle') as HTMLInputElement;
    const bundledToggle = document.getElementById('bundled-toggle') as HTMLInputElement;
    const logToggle = document.getElementById('log-toggle') as HTMLInputElement;
    const logToggleWrap = document.getElementById('log-toggle-wrap') as HTMLElement;
    const legendTbody = document.getElementById('legend-tbody') as HTMLElement;
    const legendSummary = document.getElementById('legend-summary') as HTMLElement;
    const legendTable = document.getElementById('legend-table') as HTMLElement;

    let chart: Chart<'line'> | null = null;

    function setStatus(msg: string | null) {
      if (msg === null) {
        statusEl.style.display = 'none';
        statusEl.textContent = '';
      } else {
        statusEl.style.display = 'flex';
        statusEl.textContent = msg;
      }
    }

    function syncPills() {
      const grp = document.getElementById('chip-pills');
      if (!grp) return;
      const atCap = state.chips.size >= MAX_CHIPS;
      grp.querySelectorAll<HTMLButtonElement>('.pill').forEach((p) => {
        const isOn = state.chips.has(p.dataset.chip as ChipId);
        p.classList.toggle('on', isOn);
        p.classList.toggle('muted', atCap && !isOn);
      });
      const multi = state.chips.size > 1;
      legendTable.classList.toggle('multi-off', !multi);
      legendTable.classList.toggle('multi-on', multi);
      logToggleWrap.hidden = !multi;
    }

    function fmtPrice(n: number): string {
      return '$' + n.toFixed(2);
    }

    // Eastern Time, DST-aware. Daily snapshots are stamped at UTC midnight;
    // formatting in ET keeps the visible date aligned with all other site
    // cadence labels.
    const ET_TZ = 'America/New_York';
    const fmtTickDayET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, month: 'short', day: 'numeric',
    });
    const fmtTooltipDayET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, year: 'numeric', month: 'short', day: 'numeric',
    });

    function readToken(name: string): string {
      try {
        return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      } catch { return ''; }
    }

    function fmtChange(latest: number, prev: number | null): string {
      if (prev === null || prev === 0) return '—';
      const d = ((latest - prev) / prev) * 100;
      const sign = d > 0 ? '+' : '';
      const cls = d > 0 ? 'up' : d < 0 ? 'down' : '';
      return `<span class="${cls}">${sign}${d.toFixed(1)}%</span>`;
    }

    function renderLegend(series: Augmented[]) {
      const multi = state.chips.size > 1;
      const totalObs = series.reduce((acc, s) => acc + s.points.length, 0);
      legendSummary.textContent = `${series.length} lines · ${totalObs} observations`;
      legendTbody.innerHTML = series.map((s) => {
        const lineColor = multi ? colorForChip(s.chip) : colorForSource(s.source_name);
        const dot = `<span class="legend-dot" style="background:${lineColor}"></span>`;
        const chipBadge = `<span class="chip-badge" style="background:${colorForChip(s.chip)}">${shortLabelForChip(s.chip)}</span>`;
        const intBadge = s.interruptibility === 'INT'
          ? '<span class="tag int">INT</span>'
          : '<span class="tag gtd">GTD</span>';
        const bundle = s.bundled_any
          ? '<span class="tag bundled">BUNDLED</span>'
          : '<span class="dim">—</span>';
        // Only emit the chip cell when comparing chips. JS conditional render
        // keeps header + body column counts in sync; CSS-based hiding doesn't
        // reach innerHTML-inserted nodes reliably under Astro scoping.
        const chipCell = multi ? `<td>${chipBadge}</td>` : '';
        return '<tr>' +
          chipCell +
          `<td class="provider">${dot}<code>${s.source_name}</code></td>` +
          `<td>${intBadge}</td>` +
          `<td class="num posted">${fmtPrice(s.latest_price)}</td>` +
          `<td class="num">${fmtChange(s.latest_price, s.prev7_price)}</td>` +
          `<td>${bundle}</td>` +
          `<td class="num dim">${s.points.length}</td>` +
        '</tr>';
      }).join('');
    }

    function renderChart(series: Augmented[]) {
      const multi = state.chips.size > 1;
      const datasets = series.map((s) => {
        const color = multi ? colorForChip(s.chip) : colorForSource(s.source_name);
        const label = multi ? `${shortLabelForChip(s.chip)} · ${s.display_name}` : s.display_name;
        return {
          label,
          data: s.points,
          borderColor: color,
          backgroundColor: color,
          borderWidth: 1.5,
          borderDash: s.interruptibility === 'INT' ? [4, 3] : [],
          pointRadius: 0,
          pointHoverRadius: 4,
          tension: 0.05,
          spanGaps: true,
        };
      });

      if (chart) chart.destroy();

      const inkDim = readToken('--ink-dim') || '#9a9991';
      const ink = readToken('--ink') || '#e8e6e1';
      const grid = readToken('--vast-grid') || 'rgba(128,128,128,0.2)';
      const monoFont = { family: 'IBM Plex Mono, ui-monospace, Menlo, monospace', size: 11 };

      chart = new Chart(canvas, {
        type: 'line',
        data: { datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'nearest', axis: 'x', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              displayColors: true,
              callbacks: {
                title: (items) => {
                  const x = items[0]?.parsed?.x;
                  return x ? fmtTooltipDayET.format(x) : '';
                },
                label: (ctx) => `${ctx.dataset.label}: $${(ctx.parsed.y as number).toFixed(2)}/h`,
              },
            },
          },
          scales: {
            x: {
              type: 'time',
              time: { unit: 'day' },
              ticks: {
                color: inkDim,
                font: monoFont,
                maxRotation: 0,
                autoSkipPadding: 24,
                callback: (value) => {
                  const ms = typeof value === 'number' ? value : Number(value);
                  return fmtTickDayET.format(ms);
                },
              },
              title: { display: true, text: 'Date (ET)', color: inkDim, font: monoFont },
              grid: { color: grid, drawOnChartArea: false },
              border: { color: grid },
            },
            y: {
              type: state.log_scale && multi ? 'logarithmic' : 'linear',
              title: { display: true, text: '$/GPU-hour', color: inkDim, font: monoFont },
              ticks: { color: ink, font: monoFont, callback: (v) => '$' + (v as number).toFixed(2) },
              grid: { color: grid },
              border: { color: grid },
            },
          },
        },
      });
    }

    async function ensureCached(chips: ChipId[]) {
      const misses = chips.filter((c) => !state.cache.has(c));
      await Promise.all(misses.map(async (c) => {
        try {
          state.cache.set(c, await fetchListingsCsv(c));
        } catch (e) {
          state.cache.set(c, null);
        }
      }));
    }

    async function refresh() {
      setStatus('Loading…');
      const chips = [...state.chips];
      await ensureCached(chips);

      const series: Augmented[] = [];
      for (const chip of chips) {
        const rows = state.cache.get(chip) ?? [];
        if (rows.length === 0) continue;
        const filtered = filterRows(rows, {
          include_interruptible: state.include_interruptible,
          include_bundled: state.include_bundled,
        });
        for (const s of buildSeries(filtered)) series.push({ ...s, chip });
      }

      if (series.length === 0) {
        const label = chips.length === 1
          ? `No data for ${chips[0]} yet — history accrues as the daily pipeline runs.`
          : 'No matching observations yet for the selected chips.';
        setStatus(label);
        if (chart) { chart.destroy(); chart = null; }
        legendTbody.innerHTML = '';
        legendSummary.textContent = '0 lines';
        return;
      }

      setStatus(null);
      renderChart(series);
      renderLegend(series);
    }

    document.getElementById('chip-pills')!.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const pill = t.closest<HTMLButtonElement>('.pill');
      if (!pill || !pill.dataset.chip) return;
      const chip = pill.dataset.chip as ChipId;
      if (state.chips.has(chip)) {
        if (state.chips.size > 1) state.chips.delete(chip);
      } else {
        if (state.chips.size >= MAX_CHIPS) return;
        state.chips.add(chip);
      }
      syncPills();
      refresh();
    });
    intToggle.addEventListener('change', () => {
      state.include_interruptible = intToggle.checked;
      refresh();
    });
    bundledToggle.addEventListener('change', () => {
      state.include_bundled = bundledToggle.checked;
      refresh();
    });
    logToggle.addEventListener('change', () => {
      state.log_scale = logToggle.checked;
      refresh();
    });

    syncPills();
    refresh();
  </script>

  <style>
    /* Markets / Providers styling reuses the Bloomberg-feel patterns from
       /vast via the shared `.vast-page` wrap class plus the `--vast-*` token
       group at the bottom of tokens.css. Page-specific `.markets-page` is
       reserved for any one-off tweaks; today it just signals scope. */
    .vast-page.top { padding-top: 24px; }

    .vast-page > .kicker {
      color: var(--accent);
      letter-spacing: 0.14em;
      margin-bottom: 4px;
    }
    .vast-page h1 {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      margin: 0 0 10px;
      letter-spacing: -0.01em;
      line-height: 1.1;
    }

    /* Ticker strip — Bloomberg-style horizontal stat band */
    .vast-page .ticker-strip {
      display: flex;
      flex-wrap: wrap;
      align-items: stretch;
      border: 1px solid var(--rule-2);
      background: var(--vast-panel-bg);
      margin: 0 0 18px;
      font-family: var(--font-mono);
    }
    .vast-page .tk-cell {
      display: flex;
      align-items: baseline;
      gap: 8px;
      padding: 7px 14px;
      border-right: 1px solid var(--rule);
      flex: 0 0 auto;
    }
    .vast-page .tk-cell:last-child { border-right: 0; }
    .vast-page .tk-lbl {
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: 0.10em;
      font-weight: var(--weight-strong);
    }
    .vast-page .tk-val {
      font-size: var(--fs-sm);
      color: var(--ink);
      font-variant-numeric: tabular-nums;
      font-weight: var(--weight-strong);
    }
    .vast-page .tk-status { margin-left: auto; gap: 6px; }
    .vast-page .tk-status .tk-val { color: var(--pos); letter-spacing: 0.10em; }
    .vast-page .tk-dot {
      width: 7px;
      height: 7px;
      background: var(--pos);
      box-shadow: 0 0 6px var(--pos);
      display: inline-block;
      border-radius: 50%;
      animation: vast-pulse 2.4s ease-in-out infinite;
    }
    @keyframes vast-pulse {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.35; }
    }

    .vast-page .lede { max-width: 80ch; margin: 4px 0 22px; }

    .vast-page .controls {
      background: var(--vast-panel-bg);
      border: 1px solid var(--rule);
      padding: 12px 14px;
      margin-bottom: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .vast-page .control-row {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }
    .vast-page .control-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      min-width: 56px;
    }
    .vast-page .pill-group { display: flex; flex-wrap: wrap; gap: 5px; }
    .vast-page .pill {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--surface);
      color: var(--ink-dim);
      border: 1px solid var(--rule-2);
      padding: 5px 10px;
      cursor: pointer;
      border-radius: 0;
      font-weight: var(--weight-strong);
    }
    .vast-page .pill:hover { color: var(--ink); border-color: var(--accent); }
    .vast-page .pill.on {
      color: var(--accent);
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, transparent);
    }
    .vast-page .pill.muted { opacity: 0.45; cursor: not-allowed; }
    .vast-page .pill.muted:hover { color: var(--ink-dim); border-color: var(--rule-2); }

    .vast-page .chip-cap {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      margin-left: 8px;
    }

    .vast-page .toggles-row { gap: 22px; }
    .vast-page .toggle {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      cursor: pointer;
    }

    .vast-page .chart-wrap {
      position: relative;
      border: 1px solid var(--rule);
      background: var(--vast-panel-bg);
      padding: 14px;
      height: 460px;
      margin-bottom: 12px;
      border-radius: 0;
    }
    .vast-page .chart-wrap-hero {
      background: var(--vast-panel-bg-hero);
      border-color: var(--rule-2);
      /* Distinguishing hairline accent — info token signals daily-cadence
         provider product (vs warn for intraday on /marketplace). */
      border-left-width: 3px;
      border-left-color: var(--vast-info);
    }
    .vast-page .chart-status {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      background: color-mix(in srgb, var(--vast-panel-bg-hero) 80%, transparent);
      pointer-events: none;
      padding: 0 24px;
      text-align: center;
    }

    .vast-page .legend-section { margin-top: 14px; }
    .vast-page .legend-head {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    .vast-page .sec-kicker-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-weight: var(--weight-strong);
      padding-left: 4px;
      border-left: 1px solid var(--rule-2);
      padding-right: 2px;
    }
    .vast-page .sec-note {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      margin-left: auto;
    }

    .vast-page .table-wrap {
      border: 1px solid var(--rule);
      background: var(--vast-panel-bg);
      overflow-x: auto;
    }
    .vast-page .data {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
    }
    .vast-page .data th,
    .vast-page .data td {
      padding: var(--vast-cell-y) var(--vast-cell-x);
      border-bottom: 1px solid var(--rule);
      text-align: left;
      vertical-align: middle;
      height: var(--vast-row-h);
      font-variant-numeric: tabular-nums;
    }
    .vast-page .data th + th,
    .vast-page .data td + td {
      border-left: 1px solid var(--rule);
    }
    .vast-page .data th {
      background: var(--surface-3);
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: 0.10em;
      font-weight: var(--weight-strong);
      border-bottom: 1px solid var(--rule-2);
      white-space: nowrap;
    }
    .vast-page .data td.num,
    .vast-page .data th.num {
      text-align: right;
    }
    .vast-page .data td.dim,
    .vast-page .data .dim { color: var(--ink-dim); }
    .vast-page .data tbody tr:nth-child(even) td {
      background: var(--vast-row-stripe);
    }
    .vast-page .data tbody tr:hover td { background: var(--surface-3); }

    .vast-page #legend-table { width: 100%; }
    .vast-page #legend-table td.provider {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .vast-page #legend-table td.provider code {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      letter-spacing: 0.02em;
    }
    .vast-page .legend-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .vast-page .chip-badge {
      display: inline-block;
      padding: 2px 7px;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      font-weight: var(--weight-strong);
      color: #fff;
      border-radius: 0;
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    /* Hide the chip column when only one chip is selected — keeps legend tight. */
    .vast-page #legend-table.multi-off .chip-col { display: none; }

    /* Tag pills — semantic tokens, hairline border, mono. Mirrors /vast. */
    .vast-page .tag {
      display: inline-block;
      padding: 1px 6px;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      font-weight: var(--weight-strong);
      letter-spacing: 0.08em;
      border: 1px solid;
      border-radius: 0;
      text-transform: uppercase;
    }
    .vast-page .tag.gtd {
      color: var(--ink-dim);
      border-color: var(--rule-2);
      background: var(--surface-2);
    }
    .vast-page .tag.int {
      color: var(--vast-warn);
      border-color: color-mix(in srgb, var(--vast-warn) 50%, transparent);
      background: color-mix(in srgb, var(--vast-warn) 12%, transparent);
    }
    .vast-page .tag.bundled {
      color: var(--vast-info);
      border-color: color-mix(in srgb, var(--vast-info) 50%, transparent);
      background: color-mix(in srgb, var(--vast-info) 12%, transparent);
    }
    .vast-page #legend-table .up { color: var(--vast-neg); }
    .vast-page #legend-table .down { color: var(--vast-pos); }

    .vast-page .footnote {
      font-family: var(--font-body);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      margin: 14px 0 0;
      padding: 10px 14px;
      background: var(--vast-panel-bg);
      border-left: 2px solid var(--neutral);
      max-width: 80ch;
      line-height: 1.55;
    }
    .vast-page .footnote code {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs));
