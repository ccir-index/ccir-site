        el.addEventListener('pointerleave', hideHero);
        el.addEventListener('focus', function () {
          var r = el.getBoundingClientRect();
          showHero(el.getAttribute('data-gen'), r.left + r.width / 2, r.top + r.height / 2);
        });
        el.addEventListener('blur', hideHero);
