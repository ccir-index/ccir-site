      /* ---------- §02 crosshair + tooltip (od-vs-committed pattern) ---------- */
      var BW = [
        { x: 109.7, gen: 'B300', v: '0.98', spec: '~8.0 TB/s', rate: '$7.85', n: 5 },
        { x: 157.5, gen: 'B200', v: '0.87', spec: '8.0 TB/s',  rate: '$6.92', n: 8 },
        { x: 213.3, gen: 'H200', v: '0.87', spec: '4.8 TB/s',  rate: '$4.18', n: 14 },
        { x: 340.8, gen: 'H100 SXM', v: '0.96', spec: '3.35 TB/s', rate: '$3.22', n: 20 },
        { x: 500.2, gen: 'A100 80GB', v: '0.90', spec: '2.0 TB/s', rate: '$1.80', n: 13 }
      ];
      var W2 = 680;
      var box = document.getElementById('bw-chart');
      var tip2 = document.getElementById('bw-tip');
      var cross = document.getElementById('bw-cross');
      if (!box || !tip2 || !cross) return;
      var svg2 = box.querySelector('svg');

      function fillBwTip(d) {
        tip2.textContent = '';
        var head = document.createElement('strong');
        head.textContent = d.gen;
        tip2.appendChild(head);
        var rows = [
          ['$/TB/s-hr ', d.v],
          ['bandwidth ', d.spec],
          ['underlying ', d.rate + '/GPU-hr'],
          ['n ', String(d.n)]
        ];
        rows.forEach(function (r) {
          tip2.appendChild(document.createElement('br'));
          var lab = document.createElement('span');
          lab.className = 'tn';
          lab.textContent = r[0];
          tip2.appendChild(lab);
          tip2.appendChild(document.createTextNode(r[1]));
        });
      }

      function showBw(ev) {
        var r = svg2.getBoundingClientRect();
        var relX = ((ev.clientX - r.left) / r.width) * W2;
        var best = BW[0], bd = Math.abs(relX - BW[0].x);
        for (var i = 1; i < BW.length; i++) {
          var d = Math.abs(relX - BW[i].x);
          if (d < bd) { bd = d; best = BW[i]; }
        }
        if (relX < 30 || relX > 560) { hideBw(); return; }
        cross.setAttribute('x1', best.x);
        cross.setAttribute('x2', best.x);
        cross.style.display = '';
        fillBwTip(best);
        tip2.style.display = 'block';
        var left = (best.x / W2) * r.width + 12;
        if (left > r.width - 170) left -= 190;
        tip2.style.left = left + 'px';
        tip2.style.top = '18px';
      }
      function hideBw() {
        tip2.style.display = 'none';
        cross.style.display = 'none';
      }
      box.addEventListener('mousemove', showBw);
      box.addEventListener('mouseleave', hideBw);
    })();
  </script>

