---
import Base from '../../layouts/Base.astro';
import { meta } from '../../data/snapshot';

// Methodology change log — the site-visible record of versions, panel
// changes, and series notices. Entries are appended, never edited; the
// notice for a pending change carries its comment window and effective
// date. Non-material operational changes live in the public data
// repository's log; this page carries what a reader of the series needs.

// Announcement fields: id (YYMMDD-N), announced, effective, type,
// restatement (CCIR series are forward-only — always "None"), impact
// (estimated at announcement; realized appended), summary. Providers are
// not named; membership is disclosed at class/count grain.
const entries = [
  {
    id: '260715-4',
    date: '2026-07-15',
    effective: '2026-07-23',
    type: 'Provider change · pending',
    restatement: 'None',
    impact: 'T2 H100 OD US: n 12 → 14, est. ≈ +1.9%; retirement: none',
    title: 'v2.2.1 — two sources proposed for the on-demand rate panel; one member retired',
    body: [
      `Two neocloud-class sources are proposed for the on-demand rate
       panel. One is a subsidiary of an existing member with a
       materially different live rate card, admitted as a separate
       venue (no splice). Estimated impact: the two entries largely
       offset (−3.0% and +5.0% alone). Realized with/without publishes
       at the effective fixing. Comments through 2026-07-22:
       research@ccir.io.`,
      `Amended 2026-07-16: one panel member is retired from the roster
       at the same fixing. The member has published no purchasable
       rates since before the panel froze and has never contributed an
       observation to a published cell; no series is affected.`,
    ],
  },
  {
    id: '260715-3',
    date: '2026-07-15',
    effective: '2026-07-16',
    type: 'New series',
    restatement: 'None',
    impact: 'None to on-demand series',
    title: 'v2.2.0 — two sources added to committed-term cells',
    body: [
      `Two sources with firm published term prices (1/3-month and
       3-year tenors) join the committed-term cells. Enhanced
       per-region capture of hyperscaler reservation pricing (1/3/5-yr)
       begins as a cross-check surface with no separate panel vote.
       On-demand rows from term sources enter no on-demand cell.`,
    ],
  },
  {
    id: '260715-2',
    date: '2026-07-15',
    effective: '—',
    type: 'Note',
    restatement: 'None',
    impact: 'None',
    title: 'Candidate-source observation begins',
    body: [
      `Capture-only observation of candidate sources (rate cards,
       committed-term surfaces, marketplace feeds) began under panel
       provenance rules. No candidate holds a panel vote; proposals
       follow the Change Management Policy.`,
    ],
  },
  {
    id: '260715-1',
    date: '2026-07-15',
    effective: '2026-07-15',
    type: 'Provider change · realized',
    restatement: 'None',
    impact: 'Realized +2.3% (est. ≈ +2%) · T2 H100 OD US n 11 → 12',
    title: 'v2.1.0 effective — realized decomposition',
    body: [
      `The addition announced 2026-07-10 took effect. Realized
       with/without on the effective fixing: $3.60 with (n = 12) vs
       $3.52 without (n = 11), +2.3% composition. Day-over-day +1.0% =
       +2.3% composition − 1.3% market; use $3.52 for the market leg
       across the boundary. No comments were received by the close.`,
    ],
  },
  {
    id: '260710-2',
    date: '2026-07-10',
    effective: '2026-07-15',
    type: 'Provider change · realized 2026-07-15',
    restatement: 'None',
    impact: 'T2 H100 OD US: n 11 → 12, est. ≈ +2%',
    title: 'v2.1.0 — one source added to the on-demand rate panel',
    body: [
      `One source posting guaranteed on-demand and interruptible H100
       and B200 rates joins the neocloud panel. Its own capacity only:
       re-sold capacity of existing members is excluded, one operator
       one vote. A corporate affiliate remains a separate panel source
       while both rate cards stay live; no splice. Comments were open
       through 2026-07-14.`,
    ],
  },
  {
    id: '260710-1',
    date: '2026-07-10',
    effective: '2026-07-01',
    type: 'Composition note',
    restatement: 'None',
    impact: 'T2 A100 US $2.70 → $1.81 · T2 H200 US $5.14 → $4.29 · T1 H100 US $8.44 → $9.15',
    title: 'July 1–2 panel expansion — collection panel 31 → 41 sources',
    body: [
      `Eleven sources entered over 2026-07-01/02 and several cells
       stepped where new price levels entered. The steps are
       composition effects, not repricing; treat week-over-week
       comparisons across the boundary accordingly.`,
    ],
  },
  {
    id: '260703-1',
    date: '2026-07-03',
    effective: '2026-07-03',
    type: 'Composition note',
    restatement: 'None',
    impact: 'T1 H100 OD US: $8.44 → $9.15, n 3 → 4',
    title: 'Fourth source enters the hyperscaler H100 US cell',
    body: [
      `A fourth source's on-demand H100 US rows began flowing
       2026-07-02/03. The step is a composition effect — no panel
       source changed a posted rate on those dates.`,
    ],
  },
  {
    id: '260426-1',
    date: '2026-04-26',
    effective: '2026-04-26',
    type: 'Methodology version',
    restatement: 'None',
    impact: 'First public version',
    title: 'v2.0.0 — first public methodology',
    body: [
      `Chip × operator-class × geography series grammar, operator-equal
       weighting, published headline-statistic rule, frozen panel
       roster. Every published row carries its methodology version.`,
    ],
  },
];
---
<Base
  title="Methodology Change Log · CCIR"
  ogImage="/og/documents.png"
  description="The running record of CCIR methodology versions, panel changes, and series notices — each change announced with its effective date, anticipated effect, and comment window."
  showTape={false}
>
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Documents · Change Log · as published {meta.as_of_date}</div>
      <h1>Methodology Change Log</h1>
      <p class="standfirst">
        The record of changes to what the published series measure.
        Pending changes are announced with an estimated impact and a
        comment window; the realized impact is appended at the effective
        fixing. CCIR series are forward-only — no restatements. The
        <a href="/documents/change-management">Change Management Policy</a>
        governs classification. Comments:
        <a href="mailto:research@ccir.io">research@ccir.io</a>.
      </p>
    </header>

    <div class="log">
      {entries.map((e) => (
        <section class="entry">
          <div class="entry-head">
            <span class="entry-date">{e.id}</span>
            <span class="entry-tag">{e.type}</span>
          </div>
          <h2 class="entry-title">{e.title}</h2>
          <dl class="entry-meta">
            <div><dt>Announced</dt><dd>{e.date}</dd></div>
            <div><dt>Effective</dt><dd>{e.effective}</dd></div>
            <div><dt>Restatement</dt><dd>{e.restatement}</dd></div>
            <div><dt>Est. impact</dt><dd>{e.impact}</dd></div>
          </dl>
          {e.body.map((p) => <p class="entry-body">{p}</p>)}
        </section>
      ))}
    </div>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { max-width: 80ch; margin-bottom: 26px; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    .standfirst {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.65;
    }
    .log { max-width: 80ch; margin-bottom: 48px; }
    .entry {
      border-top: 1px solid var(--rule);
      padding: 18px 0 10px;
    }
    .entry-head {
      display: flex;
      align-items: baseline;
      gap: 14px;
      margin-bottom: 6px;
    }
    .entry-date {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--accent);
      font-weight: var(--weight-strong);
    }
    .entry-tag {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      border: 1px solid var(--rule);
      padding: 1px 8px;
    }
    .entry-title {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      margin: 0 0 10px;
    }
    .entry-meta {
      display: flex;
      flex-wrap: wrap;
      gap: 4px 26px;
      margin: 0 0 10px;
      padding: 8px 0;
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
    }
    .entry-meta div { display: flex; gap: 8px; align-items: baseline; }
    .entry-meta dt {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }
    .entry-meta dd {
      margin: 0;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
    }
    .entry-body {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.65;
      margin: 0 0 12px;
      max-width: 78ch;
    }
  </style>
</Base>
