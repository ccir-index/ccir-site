---
import Base from '../layouts/Base.astro';
import { meta } from '../data/snapshot';
---
<Base title="Contact · CCIR" showTape={false}>
  <section class="wrap top">
    <div class="kicker">Get in touch · {meta.as_of_date}</div>
    <h1>Contact CCIR</h1>

    <article class="card">
      <div class="card-kicker">Email</div>
      <a class="email" href="mailto:research@ccir.io">research@ccir.io</a>
    </article>
  </section>

  <style>
    .top { padding-top: 28px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-2xl);
      margin: 6px 0 20px;
    }

    .card {
      background: var(--surface);
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      padding: 20px 22px;
      max-width: 64ch;
      margin-bottom: 40px;
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .card-kicker {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
    }
    .card .email {
      font-family: var(--font-mono);
      font-size: var(--fs-xl);
      color: var(--accent);
      font-weight: var(--weight-strong);
      margin: 4px 0;
      word-break: break-all;
    }
    .card .email:hover { text-decoration: underline; }
  </style>
</Base>
