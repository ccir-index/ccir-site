---
import Base from '../layouts/Base.astro';

const GH_BASE = 'https://github.com/ccir-index/ccir-methodology/blob/main';

const docs = [
  {
    title: 'Methodology',
    slug: 'CMR_Methodology_v2_0_0.md',
    summary:
      'Panel definition, eligibility filters, source-class taxonomy, algorithmic tier classifier, publication thresholds, and the naming convention that binds the published rate to the SKU it references.',
    sections: [
      'Part 0 — Independence and administration posture',
      'Part 1 — What CMR measures (list-asks, intelligence-factory frame)',
      'Part 4 — Operator-equal median and multi-horizon fallback',
      'Part 11 — Algorithmic tier rubric (T1IF / T2IF / T3IF)',
    ],
  },
];

const VERSION = 'v2.0.0';
const EFFECTIVE = '2026-05-13';
const REPO_URL = 'https://github.com/ccir-index/ccir-methodology';
---
<Base
  title="Documents · CMR"
  description="The methodology behind CMR's benchmark rate family. Versioned, effective-dated, and publicly archived alongside the rate snapshots."
>
  <section class="wrap top">
    <h1>Documents</h1>
    <p class="dek">
      The methodology that defines how CMR produces and publishes its
      benchmark rate family. Versioned, effective-dated, and held in a
      public repository alongside the published rate snapshots.
    </p>

    <div class="bundle-meta">
      <span class="ver-pill">{VERSION}</span>
      <span class="sep">·</span>
      <span class="eff">Effective {EFFECTIVE}</span>
      <span class="sep">·</span>
      <a class="repo-link" href={REPO_URL} target="_blank" rel="noopener noreferrer">
        Public repository <span class="ext-mark" aria-hidden="true">↗</span>
      </a>
    </div>

    <div class="doc-stack">
      {docs.map((d) => (
        <article class="doc-card">
          <header class="doc-head">
            <span class="doc-kicker">{VERSION} · Effective {EFFECTIVE}</span>
            <h2>{d.title}</h2>
            <p class="doc-summary">{d.summary}</p>
          </header>
          <div class="doc-toc">
            <span class="toc-label">Inside</span>
            <ul>
              {d.sections.map((s) => <li>{s}</li>)}
            </ul>
          </div>
          <a class="doc-cta" href={`${GH_BASE}/${d.slug}`} target="_blank" rel="noopener noreferrer">
            Read on GitHub <span class="ext-mark" aria-hidden="true">↗</span>
          </a>
        </article>
      ))}
    </div>

    <p class="foot-note">
      CMR is an independent market-intelligence publisher. It holds no
      positions in the markets it measures; methodology changes are
      versioned, effective-dated, and archived.
    </p>
  </section>

  <style>
    .top { padding-top: 32px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 0 0 14px;
      letter-spacing: -0.01em;
    }
    .dek {
      font-family: var(--font-display);
      max-width: 70ch;
      color: var(--ink);
      margin: 0 0 24px;
      font-size: var(--fs-lg);
      line-height: 1.5;
    }
    :global(html[data-theme="terminal"]) h1 { font-family: var(--font-mono); }
    :global(html[data-theme="terminal"]) .dek {
      font-family: var(--font-mono);
      color: var(--ink-dim);
      font-size: var(--fs-md);
      line-height: 1.6;
    }

    .bundle-meta {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 8px 10px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      margin: 0 0 40px;
      padding: 12px 14px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface-2);
      max-width: 56rem;
    }
    .ver-pill {
      color: var(--accent);
      font-weight: var(--weight-strong);
      letter-spacing: 0.04em;
    }
    .bundle-meta .sep { color: var(--ink-faint); }
    .eff { color: var(--ink); }
    .repo-link {
      color: var(--accent);
      text-decoration: none;
      font-weight: var(--weight-strong);
      margin-left: auto;
    }
    .repo-link:hover { text-decoration: underline; }
    .ext-mark { font-size: 0.85em; margin-left: 2px; }

    .doc-stack {
      display: grid;
      gap: 20px;
      grid-template-columns: 1fr;
      margin-bottom: 40px;
    }
    @media (min-width: 1024px) {
      .doc-stack { grid-template-columns: 1fr 1fr; gap: 18px; }
    }

    .doc-card {
      display: flex;
      flex-direction: column;
      border: 1px solid var(--rule);
      background: var(--surface);
      padding: 20px 22px;
      gap: 16px;
      min-height: 360px;
    }
    .doc-card:hover { border-color: var(--accent); }
    .doc-head { display: flex; flex-direction: column; gap: 8px; }
    .doc-kicker {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
    }
    .doc-head h2 {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      line-height: 1.2;
      margin: 0;
      color: var(--ink);
    }
    :global(html[data-theme="terminal"]) .doc-head h2 { font-family: var(--font-mono); }
    .doc-summary {
      font-family: var(--font-display);
      font-size: var(--fs-sm);
      color: var(--ink);
      line-height: 1.55;
      margin: 0;
    }
    :global(html[data-theme="terminal"]) .doc-summary {
      font-family: var(--font-mono);
      color: var(--ink-dim);
    }

    .doc-toc {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      border-top: 1px dashed var(--rule-2);
      padding-top: 12px;
    }
    .toc-label {
      display: block;
      color: var(--accent);
      font-weight: var(--weight-strong);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-size: calc(var(--fs-xs) - 1px);
      margin-bottom: 6px;
    }
    .doc-toc ul {
      list-style: none;
      margin: 0;
      padding: 0;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .doc-toc li {
      line-height: 1.5;
      padding-left: 10px;
      position: relative;
    }
    .doc-toc li::before {
      content: '·';
      position: absolute;
      left: 0;
      color: var(--ink-faint);
    }

    .doc-cta {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-decoration: none;
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      padding-top: 14px;
      border-top: 1px solid var(--rule);
      margin-top: auto;
    }
    .doc-cta:hover { text-decoration: underline; }

    .foot-note {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      max-width: 80ch;
      margin: 0 0 48px;
      padding-top: 18px;
      border-top: 1px solid var(--rule-2);
      line-height: 1.6;
    }
  </style>
</Base>
