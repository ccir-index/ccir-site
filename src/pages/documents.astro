---
import Base from '../layouts/Base.astro';
import { meta } from '../data/snapshot';

const docs = [
  {
    href: '/documents/methodology',
    title: 'Methodology',
    blurb:
      'What the series measure, where the prices come from, how they are ' +
      'aggregated, and the series grammar — the document a citation of any ' +
      'CCIR series relies on.',
  },
  {
    href: '/documents/change-management',
    title: 'Change Management Policy',
    blurb:
      'How methodology changes are classified, disclosed, and versioned; ' +
      'what constitutes a material change; restatements versus series breaks.',
  },
  {
    href: '/documents/governance',
    title: 'Governance & Complaints',
    blurb:
      'Administrator identity, independence and conflicts posture, and how ' +
      'to raise a query or complaint about a published series.',
  },
];
---
<Base
  title="Documents · CCIR"
  ogImage="/og/documents.png"
  description="CCIR's public methodology, change-management, and governance documents — the reference documents a citation of any CCIR series relies on."
  showTape={false}
>
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Documents · {meta.as_of_date}</div>
      <h1>Reference Documents</h1>
      <p class="standfirst">
        The documents a citation of a CCIR series relies on: what the numbers
        measure, how changes to the measurement are governed, and who stands
        behind them. Deliberately short — each describes current practice, not
        aspiration.
      </p>
    </header>

    <div class="doc-list">
      {docs.map((d) => (
        <a class="doc-card" href={d.href}>
          <h2 class="doc-title">{d.title}</h2>
          <p class="doc-blurb">{d.blurb}</p>
          <span class="doc-go">Read →</span>
        </a>
      ))}
    </div>

    <p class="iosco-note">
      CCIR's methodology and governance are designed with reference to the
      International Organization of Securities Commissions (IOSCO)
      <em>Principles for Oil Price Reporting Agencies</em> (2012) and
      <em>Principles for Financial Benchmarks</em> (2013). CCIR does not claim
      assured compliance: independent external assurance of adherence — the
      convention established by commodity price-reporting agencies — will be
      sought when adoption warrants it.
    </p>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { max-width: 80ch; margin-bottom: 22px; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    .doc-list {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
      max-width: 980px;
    }
    @media (max-width: 860px) { .doc-list { grid-template-columns: 1fr; } }
    .doc-card {
      background: var(--surface);
      padding: 20px 22px;
      display: flex;
      flex-direction: column;
      gap: 8px;
      text-decoration: none;
      color: var(--ink);
    }
    .doc-card:hover { background: var(--surface-2); text-decoration: none; }
    .doc-title {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      margin: 0;
    }
    .doc-blurb {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.6;
      margin: 0;
      flex: 1;
    }
    .doc-go {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }
    .iosco-note {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.65;
      max-width: 80ch;
      margin: 26px 0 40px;
      padding-top: 16px;
      border-top: 1px solid var(--rule-2);
    }
  </style>
</Base>
