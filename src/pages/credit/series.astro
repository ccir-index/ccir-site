---
/*
  /credit/series — Credit Reference Series (v1, launch bundle 2026-07-12).

  The derived layer of the credit house: everything computed from the
  instrument tracker (/credit) and from lender filings. Three series:
    01 Spread at signing — disclosed spreads on GPU-collateralized
       instruments, by signing date (the primary-market series).
    02 Refi velocity — how long compute facilities actually stay
       outstanding before resolution (documented dates only).
    03 Filed marks — each SEC-reporting holder's fair-value mark on the
       same facility, reproduced as filed; dispersion shown when two or
       more unaffiliated advisers hold identical paper.

  Boundary (load-bearing): CCIR reproduces filed numbers and computes only
  arithmetic on them (a ratio, a month count, a max−min). Nothing on this
  page is a CCIR valuation, estimate, or opinion of value.
*/
import Base from '../../layouts/Base.astro';
import creditData from '../../data/credit_instruments.json';
import filedMarks from '../../data/filed_marks.json';
import refiVelocity from '../../data/refi_velocity.json';

const instruments = creditData.instruments;

// as-of: latest row-level as_of across tracker + marks period (same
// derivation rule as /credit — the data, not the build clock).
const AS_OF =
  [
    ...instruments.map((i: any) => i.as_of).filter(Boolean),
    (filedMarks as any)._meta.period,
  ].sort().at(-1);

// --- 01 spread at signing ---------------------------------------------------
// GPU-collateralized in-scope rows (tracker's issuance criterion) that
// disclose a SOFR spread and a signing date.
const inScope = instruments.filter(
  (i: any) => !i.exclude_from_issuance && typeof i.size_usd_m === 'number' && i.size_usd_m > 0
);
const spreadRows = inScope
  .filter(
    (i: any) =>
      i.rate?.kind === 'sofr_spread' &&
      (i.rate.value != null || i.rate.value_low != null) &&
      /^\d{4}/.test(i.issued ?? '')
  )
  .map((i: any) => ({
    issued: i.issued,
    issuer: i.issuer,
    name: i.name,
    // grid-priced facilities disclose a spread range — carried as a range,
    // never collapsed to a point
    spreadText:
      i.rate.value != null
        ? `+${i.rate.value.toFixed(2)}`
        : `+${i.rate.value_low.toFixed(2)}–${i.rate.value_high.toFixed(2)}`,
    lo: i.rate.value ?? i.rate.value_low,
    hi: i.rate.value ?? i.rate.value_high,
    size: i.size_usd_m,
    url: i.source?.url,
    status: i.status,
  }))
  .sort((a: any, b: any) => a.issued.localeCompare(b.issued));

// --- chart: spread at signing (dot chart over time; grid pricing = range bar).
// Discrete signings — dots, never a connecting line: a line would imply a
// continuous curve between deals that doesn't exist.
const SW = 960, SH = 330, SL = 46, SRp = 14, STp = 16, SBp = 34;
const monthIdx = (d: string) => +d.slice(0, 4) * 12 + (+d.slice(5, 7) || 1);
const mMin = monthIdx('2023-05');
const mMax = monthIdx('2026-09');
const sx = (d: string) => SL + ((monthIdx(d) - mMin) / (mMax - mMin)) * (SW - SL - SRp);
const sy = (v: number) => STp + (1 - v / 10) * (SH - STp - SBp);
const yTicks = [0, 2, 4, 6, 8, 10];
const xTicks = ['2024-01', '2025-01', '2026-01'].map((d) => ({ x: sx(d), label: d.slice(0, 4) }));
function shortName(r: any): string {
  if (/^DDTL/.test(r.name)) return `CRWV ${r.name.split(' (')[0]}`;
  return r.issuer.replace(/,.*$/, '').replace(/ (Inc\.|Ltd\.?|Limited|Corporation|Holdings.*)$/, '').split(' ').slice(0, 2).join(' ');
}
const spreadPts = spreadRows.map((r: any) => ({
  ...r,
  cx: sx(r.issued),
  cyLo: sy(r.lo),
  cyHi: sy(r.hi),
  isRange: r.lo !== r.hi,
  short: shortName(r),
}));
// selective direct labels, greedy placement: candidates above / below /
// beside each point, rejected on collision with ANY dot or already-placed
// label. Points that can't fit a label keep the hover title only.
type Rect = { x0: number; x1: number; y0: number; y1: number };
const dotRects: Rect[] = spreadPts.flatMap((p: any) => [
  { x0: p.cx - 7, x1: p.cx + 7, y0: p.cyHi - 7, y1: p.cyHi + 7 },
  { x0: p.cx - 7, x1: p.cx + 7, y0: p.cyLo - 7, y1: p.cyLo + 7 },
]);
const labelRects: Rect[] = [];
const placedLabels: { x: number; y: number; text: string; anchor: string }[] = [];
const overlaps = (a: Rect, b: Rect) => a.x0 < b.x1 && a.x1 > b.x0 && a.y0 < b.y1 && a.y1 > b.y0;
for (const p of spreadPts) {
  const text = `${p.short} ${p.spreadText}`;
  const w = text.length * 6.2;
  const midY = (p.cyLo + p.cyHi) / 2;
  const cands: { x: number; y: number; anchor: string }[] = [
    { x: p.cx, y: p.cyHi - 11, anchor: 'middle' },
    { x: p.cx, y: p.cyLo + 19, anchor: 'middle' },
    { x: p.cx + 10, y: midY + 3.5, anchor: 'start' },
    { x: p.cx - 10, y: midY + 3.5, anchor: 'end' },
  ];
  for (const c of cands) {
    const x0 = c.anchor === 'start' ? c.x : c.anchor === 'end' ? c.x - w : c.x - w / 2;
    const rect: Rect = { x0, x1: x0 + w, y0: c.y - 9, y1: c.y + 3 };
    if (rect.x0 < 2 || rect.x1 > SW - 2 || rect.y0 < STp - 12 || rect.y1 > SH - SBp) continue;
    if (dotRects.some((d) => overlaps(rect, d)) || labelRects.some((l) => overlaps(rect, l))) continue;
    labelRects.push(rect);
    placedLabels.push({ x: c.x, y: c.y, text, anchor: c.anchor });
    break;
  }
}

// --- 02 refi velocity --------------------------------------------------------
const refiRows = (refiVelocity as any).rows ?? [];
const refiInsufficient = (refiVelocity as any).insufficient ?? [];
function median(xs: number[]): number | null {
  if (!xs.length) return null;
  const s = [...xs].sort((a, b) => a - b);
  const m = Math.floor(s.length / 2);
  return s.length % 2 ? s[m] : (s[m - 1] + s[m]) / 2;
}
const refiMonthsAll = refiRows.map((r: any) => r.months_outstanding).filter((x: any) => typeof x === 'number');
const refiMonthsNonBridge = refiRows
  .filter((r: any) => r.resolution_type !== 'bridge_takeout')
  .map((r: any) => r.months_outstanding)
  .filter((x: any) => typeof x === 'number');
const refiMedianAll = median(refiMonthsAll);
const refiMedianNonBridge = median(refiMonthsNonBridge);

// --- 03 filed marks ----------------------------------------------------------
const marks = (filedMarks as any).marks;
const byId = new Map(instruments.map((i: any) => [i.id, i]));

// facility grouping: mapped rows group by ledger instrument; unmapped rows
// group by borrower + economics (rate + maturity), never by each holder's
// own instrument label — labels differ across filers for identical paper.
function facilityKey(m: any): string {
  if (m.ccir_instrument_id) return m.ccir_instrument_id;
  const t = m.tranche ?? {};
  const entity = m.borrower_entity.split('(')[0].trim().toLowerCase().replace(/,? (llc|inc|ltd|corp).*$/, '');
  const rate = t.rate_kind === 'fixed' ? `fx${t.all_in_pct}` : `fl${t.spread_pct}`;
  return `${entity}|${rate}|${(t.maturity_as_filed ?? '').slice(0, 7)}`;
}
function facilityLabel(m: any): string {
  const row = m.ccir_instrument_id ? byId.get(m.ccir_instrument_id) : null;
  if (row) return `${row.issuer} — ${row.name}`;
  const entity = m.borrower_entity.split('(')[0].trim().replace(/,$/, '');
  const inst = (m.tranche?.instrument ?? '').split(';')[0].trim();
  return inst ? `${entity} — ${inst}` : entity;
}
const facilityOrder: string[] = [];
const facilities = new Map<string, any[]>();
for (const m of marks) {
  const k = facilityKey(m);
  if (!facilities.has(k)) {
    facilities.set(k, []);
    facilityOrder.push(k);
  }
  facilities.get(k)!.push(m);
}
function dispersion(rows: any[]): { n: number; spread: number } | null {
  const byAdviser = new Map<string, number>();
  for (const r of rows) {
    if (r.mark_pct == null || !r.funded) continue;
    // one mark per adviser: principal-weighted not needed at this n; last write wins
    // is avoided by averaging.
    const prev = byAdviser.get(r.adviser);
    byAdviser.set(r.adviser, prev == null ? r.mark_pct : (prev + r.mark_pct) / 2);
  }
  if (byAdviser.size < 2) return null;
  const vals = [...byAdviser.values()];
  return { n: byAdviser.size, spread: Math.max(...vals) - Math.min(...vals) };
}
// --- chart: filed-marks dispersion (dot strip per facility, min–max
// connector, emphasized par line). Only facilities with a cross-adviser
// pair chart; single-holder facilities stay table-only.
function chartShortLabel(rows: any[]): string {
  const m = rows[0];
  const row = m.ccir_instrument_id ? byId.get(m.ccir_instrument_id) : null;
  if (row) return `${row.issuer.replace(/,.*$/, '')} ${row.name.split(' (')[0]}`;
  const entity = m.borrower_entity.split('(')[0].trim().replace(/,? (LLC|Inc\.?|Ltd|Corp).*$/i, '');
  const t = m.tranche ?? {};
  const rate = t.rate_kind === 'fixed' ? `${t.all_in_pct}% fixed` : `S+${t.spread_pct}`;
  return `${entity} ${rate}`;
}
const MW = 960, MGL = 236, MGR = 84, MTOP = 34, MROW = 56;
const mDomain = [97, 104];
const mx = (v: number) => MGL + ((v - mDomain[0]) / (mDomain[1] - mDomain[0])) * (MW - MGL - MGR);
const marksChart = facilityOrder
  .map((k) => {
    const rows = facilities.get(k)!;
    const disp = dispersion(rows);
    if (!disp) return null;
    const dots = rows
      .filter((r: any) => r.funded && r.mark_pct != null)
      .map((r: any) => ({ holder: r.holder, mark: r.mark_pct, x: mx(r.mark_pct) }));
    const lo = Math.min(...dots.map((d) => d.mark));
    const hi = Math.max(...dots.map((d) => d.mark));
    return { label: chartShortLabel(rows), dots, lo, hi, disp };
  })
  .filter(Boolean) as any[];
const MH = MTOP + marksChart.length * MROW + 10;
const mTicks = [97, 98, 99, 100, 101, 102, 103, 104];

function fmtK(x: number | null): string {
  if (x == null) return '—';
  return x.toLocaleString('en-US', { maximumFractionDigits: 1 });
}
function fmtMark(x: number | null): string {
  return x == null ? '—' : x.toFixed(2);
}
function rateText(t: any): string {
  if (!t) return '—';
  if (t.rate_kind === 'fixed') return `${t.all_in_pct?.toFixed(2)}% fixed`;
  if (t.spread_pct != null)
    return `${t.reference ?? 'SOFR'} + ${t.spread_pct.toFixed(2)}%${t.all_in_pct != null ? ` (${t.all_in_pct.toFixed(2)}%)` : ''}`;
  return '—';
}
const marksPeriod = (filedMarks as any)._meta.period;
const nHolders = new Set(marks.map((m: any) => m.holder)).size;
---

<Base
  title="Credit Reference Series — CCIR"
  description="Derived reference series for compute credit: spread at signing, refi velocity, and lender-filed fair-value marks — computed only from filed numbers."
>
  <nav class="apps-navband" aria-label="credit section">
    <div class="wrap apps-nav-inner">
      <span class="hub-group">
        <a class="apps-nav-link hub-link" href="/credit">Instruments</a>
        <span class="hub-sep" aria-hidden="true">·</span>
        <span class="apps-nav-link hub-link hub-on">Series</span>
      </span>
      <span class="hub-divider" aria-hidden="true"></span>
      <a class="apps-nav-link" href="#spreads">Spread at signing</a>
      <a class="apps-nav-link" href="#refi-velocity">Refi velocity</a>
      <a class="apps-nav-link" href="#filed-marks">Filed marks</a>
      <a class="apps-nav-link" href="#methodology">Method</a>
    </div>
  </nav>

  <section class="wrap top">
    <div class="hero-solo">
      <div class="kicker">Market Intelligence · Compute Credit · as of {AS_OF}</div>
      <h1>Credit Reference Series</h1>
      <p class="standfirst lede">
        The derived layer of the credit record. The
        <a href="/credit">instrument tracker</a> reproduces each facility as
        filed; this page computes from it — and from the schedules of
        investments of SEC-reporting funds that hold the same paper. Three
        series: the spread each GPU-collateralized facility signed at, how
        long facilities actually stay outstanding, and the fair-value marks
        different lenders file on identical instruments. Every number here is
        either reproduced from a primary document or is arithmetic on two
        filed figures — a ratio, a month count, a max−min.
        <em>Nothing on this page is a CCIR valuation.</em>
      </p>
    </div>
  </section>

  <!-- ================= 01 SPREAD AT SIGNING ================= -->
  <section class="wrap" id="spreads">
    <h2><span class="n">01</span> Spread at Signing</h2>
    <p class="sec-lede">
      Disclosed spreads on GPU-collateralized instruments, ordered by signing
      date — the primary-market series. Of the {inScope.length} instruments in
      the tracker's issuance scope, {spreadRows.length} disclose a floating
      spread and a signing date; the rest are fixed-coupon (see the
      <a href="/credit#coupons">coupon section</a> of the tracker) or file the
      rate as undisclosed, and undisclosed stays undisclosed.
      <a class="csv-link" href="/credit/series/spreads.csv">series CSV ↓</a>
    </p>
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">Disclosed spread at signing, GPU-collateralized facilities</div>
          <div class="panel-sub">PP OVER SOFR · EACH DOT ONE SIGNING · BAR = DISCLOSED GRID RANGE · JUL 2023 – JUN 2026</div>
        </div>
        <span class="badge">{spreadRows.length} SIGNINGS</span>
      </div>
      <svg viewBox={`0 0 ${SW} ${SH}`} role="img" aria-label="Disclosed spread over SOFR at signing for GPU-collateralized facilities, July 2023 to June 2026">
        {yTicks.map((t) => (
          <>
            <line class="grid" x1={SL} x2={SW - SRp} y1={sy(t)} y2={sy(t)} />
            <text class="tick tick-y" x={SL - 8} y={sy(t) + 3}>+{t}</text>
          </>
        ))}
        {xTicks.map((t) => (
          <>
            <line class="grid" x1={t.x} x2={t.x} y1={STp} y2={SH - SBp} />
            <text class="tick tick-x" x={t.x} y={SH - SBp + 16}>{t.label}</text>
          </>
        ))}
        <line class="axis" x1={SL} x2={SW - SRp} y1={SH - SBp} y2={SH - SBp} />
        {spreadPts.map((p: any) => (
          <g>
            <title>{p.issuer} — {p.name} · signed {p.issued} · {p.spreadText} pp over SOFR</title>
            {p.isRange ? (
              <>
                <line class="range-bar" x1={p.cx} x2={p.cx} y1={p.cyLo} y2={p.cyHi} />
                <circle class="pt" cx={p.cx} cy={p.cyLo} r="4.5" />
                <circle class="pt" cx={p.cx} cy={p.cyHi} r="4.5" />
              </>
            ) : (
              <circle class="pt" cx={p.cx} cy={p.cyLo} r="4.5" />
            )}
          </g>
        ))}
        {placedLabels.map((l) => (
          <text class="pt-label" x={l.x} y={l.y} text-anchor={l.anchor}>{l.text}</text>
        ))}
      </svg>
      <div class="panel-foot">
        <p>
          Spreads as disclosed in each signing document; grid-priced facilities
          show their disclosed range. Hover a dot for the instrument. Window:
          the tracker's full GPU-collateralized record, July 2023 – June 2026.
        </p>
      </div>
    </div>
    <div class="table-scroll">
      <table class="series-table">
        <thead>
          <tr>
            <th>Signed</th><th>Issuer</th><th>Instrument</th>
            <th class="num">Spread (pp over SOFR)</th><th class="num">Size ($M)</th><th>Status</th><th>Source</th>
          </tr>
        </thead>
        <tbody>
          {spreadRows.map((r: any) => (
            <tr>
              <td class="mono">{r.issued}</td>
              <td>{r.issuer}</td>
              <td class="c-inst">{r.name}</td>
              <td class="num mono">{r.spreadText}</td>
              <td class="num mono">{r.size.toLocaleString('en-US')}</td>
              <td><span class={`chip chip-${r.status}`}>{r.status}</span></td>
              <td class="c-srclink">{r.url && <a href={r.url} target="_blank" rel="noopener noreferrer">doc ↗</a>}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="tbl-note">
      Spreads are at signing, as disclosed — this series does not restate,
      interpolate, or update a spread after the signing document. Amendments
      that reprice a facility appear as their own disclosed events.
    </p>
  </section>

  <!-- ================= 02 REFI VELOCITY ================= -->
  <section class="wrap" id="refi-velocity">
    <h2><span class="n">02</span> Refi Velocity</h2>
    <p class="sec-lede">
      How long compute-sector facilities actually stay outstanding. Each row
      is a resolved facility where both the signing date and the resolution
      date are documented in primary sources; months outstanding is the count
      between the two. Borrower-side resolutions only — a fund selling its
      position is not a resolution. Bridges are reported but carry their
      design tenor, so the headline median excludes them.
    </p>
    {refiRows.length === 0 ? (
      <p class="pending">Evidence table in final verification — publishing with the launch build.</p>
    ) : (
      <>
        <div class="stat-line">
          <span class="stat">
            <span class="stat-num">{refiMedianNonBridge?.toFixed(0)}</span>
            <span class="stat-label">median months outstanding, ex-bridges (n={refiMonthsNonBridge.length})</span>
          </span>
          <span class="stat">
            <span class="stat-num">{refiMedianAll?.toFixed(0)}</span>
            <span class="stat-label">median incl. bridges (n={refiMonthsAll.length})</span>
          </span>
        </div>
        <div class="table-scroll">
          <table class="series-table">
            <thead>
              <tr>
                <th>Facility</th><th>Issuer</th><th class="num">Size ($M)</th>
                <th>Signed</th><th>Resolved</th><th class="num">Months</th>
                <th>Resolution</th><th>Taken out by</th><th>Source</th>
              </tr>
            </thead>
            <tbody>
              {refiRows.map((r: any) => (
                <tr>
                  <td class="c-inst">{r.facility}</td>
                  <td>{r.issuer}</td>
                  <td class="num mono">{r.size_usd_m ? r.size_usd_m.toLocaleString('en-US') : '—'}</td>
                  <td class="mono">{r.issued}</td>
                  <td class="mono">{r.resolved}</td>
                  <td class="num mono">{r.months_outstanding}</td>
                  <td class="mono res-type">{(r.resolution_type ?? '').replace(/_/g, ' ')}</td>
                  <td class="c-inst">{r.takeout_instrument ?? '—'}</td>
                  <td class="c-srclink">{r.sources?.[0]?.url && <a href={r.sources[0].url} target="_blank" rel="noopener noreferrer">doc ↗</a>}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {refiInsufficient.length > 0 && (
          <p class="tbl-note">
            {refiInsufficient.length} additional resolved facilities are excluded
            because one of the two dates cannot yet be documented; they are
            listed in the method note rather than estimated.
          </p>
        )}
      </>
    )}
  </section>

  <!-- ================= 03 FILED MARKS ================= -->
  <section class="wrap" id="filed-marks">
    <h2><span class="n">03</span> Filed Marks</h2>
    <p class="sec-lede">
      Fair-value marks filed by SEC-reporting funds on compute-credit
      facilities, reproduced from each holder's schedule of investments
      (period {marksPeriod}; {nHolders} holders). Where two or more
      unaffiliated advisers hold the same facility, the panel shows the
      max−min spread of their filed marks. The mark column is the ratio of
      two filed numbers — fair value over principal — and nothing more.
      Marks are each fund's own, determined by its valuation designee under
      its own policies; conflicting filed terms across holders are reproduced,
      not reconciled.
    </p>
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">Same facility, different filed marks</div>
          <div class="panel-sub">% OF PAR AT {marksPeriod} · ONE DOT PER HOLDER · LINE SPANS MIN–MAX · FACILITIES WITH ≥2 UNAFFILIATED ADVISERS</div>
        </div>
        <span class="badge">PAR = 100</span>
      </div>
      <svg viewBox={`0 0 ${MW} ${MH}`} role="img" aria-label="Filed fair-value marks as percent of par, by facility and holder">
        {mTicks.map((t) => (
          <>
            <line class={t === 100 ? 'par-line' : 'grid'} x1={mx(t)} x2={mx(t)} y1={MTOP - 6} y2={MH - 8} />
            <text class="tick tick-x" x={mx(t)} y={MTOP - 12}>{t}</text>
          </>
        ))}
        {marksChart.map((f: any, i: number) => {
          const cy = MTOP + i * MROW + MROW / 2;
          return (
            <g>
              <text class="row-label" x="0" y={cy + 4}>{f.label}</text>
              <line class="range-line" x1={mx(f.lo)} x2={mx(f.hi)} y1={cy} y2={cy} />
              {f.dots.map((d: any) => (
                <circle class="pt pt-ring" cx={d.x} cy={cy} r="5">
                  <title>{d.holder}: {d.mark.toFixed(2)}% of par</title>
                </circle>
              ))}
              <text class="val-label" x={mx(f.lo)} y={cy + 22} text-anchor="middle">{f.lo.toFixed(f.lo % 1 ? 1 : 0)}</text>
              {f.hi - f.lo > 0.25 && (
                <text class="val-label" x={mx(f.hi)} y={cy + 22} text-anchor="middle">{f.hi.toFixed(f.hi % 1 ? 1 : 0)}</text>
              )}
              <text class="disp-label" x={MW - 4} y={cy + 4} text-anchor="end">{f.disp.spread.toFixed(2)} pts</text>
            </g>
          );
        })}
      </svg>
      <div class="panel-foot">
        <p>
          Each dot is one holder's filed mark; the line spans the lowest to
          highest mark on the same facility at the same date. The par line is
          drawn at 100. Hover a dot for the holder. Right margin: max−min in
          points of par.
        </p>
      </div>
    </div>
    {facilityOrder.map((k) => {
      const rows = facilities.get(k)!;
      const disp = dispersion(rows);
      const notes = [...new Set(rows.map((r: any) => r.notes).filter(Boolean))];
      return (
        <div class="facility">
          <div class="facility-head">
            <span class="facility-name">{facilityLabel(rows[0])}</span>
            <span class="facility-rate mono">{rateText(rows[0].tranche)}</span>
            {disp && (
              <span class="facility-disp mono">
                {disp.spread.toFixed(2)} pts max−min · {disp.n} advisers
              </span>
            )}
          </div>
          <div class="table-scroll">
            <table class="series-table marks-table">
              <thead>
                <tr>
                  <th>Holder</th><th>Filing</th>
                  <th class="num">Principal ($k)</th><th class="num">Cost ($k)</th>
                  <th class="num">Fair value ($k)</th><th class="num">Mark (% of par)</th>
                  <th>Flags</th><th>Source</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((m: any) => (
                  <tr>
                    <td class="c-holder">{m.holder}</td>
                    <td class="mono">{m.filing.form} · {m.filing.period_end}</td>
                    <td class="num mono">{fmtK(m.principal_k)}</td>
                    <td class="num mono">{fmtK(m.cost_k)}</td>
                    <td class="num mono">{fmtK(m.fair_value_k)}</td>
                    <td class="num mono mark-cell">{fmtMark(m.mark_pct)}</td>
                    <td class="c-flags">
                      {m.level3 && <span class="chip chip-l3">level 3</span>}
                      {m.transacted_qtr && <span class="chip chip-transacted">transacted</span>}
                      {!m.funded && <span class="chip chip-unfunded">unfunded</span>}
                      {m.funded && m.unfunded_k != null && <span class="chip chip-unfunded">part-drawn</span>}
                    </td>
                    <td class="c-srclink"><a href={m.filing.url} target="_blank" rel="noopener noreferrer">10-Q ↗</a></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
          {notes.length > 0 && (
            <ul class="facility-notes">
              {notes.map((n) => <li>{n}</li>)}
            </ul>
          )}
        </div>
      );
    })}
    <p class="tbl-note">
      Coverage is holders that file schedules of investments with the SEC
      (business development companies and registered funds); bank and private
      lenders do not publish marks. Marks refresh with each quarterly filing
      cycle.
    </p>
  </section>

  <!-- ================= METHOD ================= -->
  <section class="wrap" id="methodology">
    <h2>Sources &amp; method</h2>
    <div class="method">
      <p>
        <strong>Derivation boundary.</strong> Every value on this page is
        either reproduced verbatim from a primary document (an SEC filing or
        an issuer/lender release, linked on the row) or is arithmetic on two
        such values: mark = fair value ÷ principal; months outstanding =
        resolution date − signing date; dispersion = maximum − minimum of
        filed marks. CCIR does not estimate, interpolate, model, or opine on
        value. Where holders file conflicting terms for the same facility,
        both are reproduced and the conflict is noted.
      </p>
      <p>
        <strong>Spread at signing.</strong> Instruments from the
        <a href="/credit">tracker's</a> issuance scope (GPU-collateralized,
        disclosed size) whose signing documents state a floating spread.
        Spreads are not updated after signing; repricings enter as new
        disclosed events.
      </p>
      <p>
        <strong>Refi velocity.</strong> A facility enters only when both its
        signing and resolution dates are documented; facilities missing one
        date are counted and named but not estimated. Resolution types are
        taken from the resolving document. Bridge facilities are shown but
        excluded from the headline median, since their tenor is by design.
      </p>
      <p>
        <strong>Filed marks.</strong> Rows are reproduced from schedules of
        investments in holder 10-Qs/10-Ks, at each filing's stated period end
        and units. One row per holder per tranche; positions held through
        joint-venture vehicles are flagged, as their marks may not be
        independent of the venture partners. Marks on facilities with large
        undrawn commitments can embed netted fees and original-issue discount
        in a small funded balance — those rows are flagged rather than
        adjusted. Fund-level exits (a holder selling its position) appear as
        <span class="chip chip-transacted">transacted</span> flags here and do
        not enter refi velocity.
      </p>
      <p>
        <strong>Cadence.</strong> The marks panel refreshes with the quarterly
        BDC/registered-fund filing cycle; spread and refi series update as
        signing or resolving documents are filed. This page carries
        reference-series governance: series definitions do not change without
        a dated method note.
      </p>
    </div>
  </section>
</Base>

