      text-decoration: none;
      white-space: nowrap;
    }
    .apps-nav-link:hover { color: var(--ink); text-decoration: none; }
    .apps-nav-inner { align-items: center; }
    .hub-group { display: inline-flex; align-items: center; gap: 10px; }
    .hub-link { font-weight: var(--weight-strong); }
    .hub-on { color: var(--accent); }
    .hub-sep { color: var(--ink-faint); }
    .hub-divider {
      width: 1px;
      align-self: stretch;
      background: var(--rule-2);
      flex-shrink: 0;
    }
    #issuance, #spreads, #coupons, #ledger,
    #collateral-treatment, #methodology { scroll-margin-top: 52px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    h2 {
      font-size: var(--fs-2xl);
      margin: 0 0 10px;
    }
    .lede { font-size: var(--fs-lg); }
    .lede em { font-style: italic; color: var(--accent); }
    .hero-solo { margin-bottom: 26px; max-width: 84ch; }

    /* --- panels ---------------------------------------------------------- */
    .panel {
      background: var(--surface);
      border: 1px solid var(--rule);
      margin-bottom: 28px;
    }
    .panel-head {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: var(--pad-panel) var(--pad-panel) 8px;
    }
    .panel-title {
      font-family: var(--font-display);
      font-size: var(--fs-lg);
      font-weight: var(--weight-display);
    }
    .panel-sub {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      margin-top: 4px;
      letter-spacing: 0.03em;
    }
    .badge {
      margin-left: auto;
      flex-shrink: 0;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--tracking-eye);
      color: var(--accent);
      border: 1px solid color-mix(in srgb, var(--accent) 55%, transparent);
      padding: 3px 8px;
    }
    .panel svg { display: block; width: 100%; height: auto; }
    .panel-foot {
      padding: 4px var(--pad-panel) var(--pad-panel);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.5;
      max-width: 100ch;
    }
    .panel-foot p { margin: 0 0 9px; }
    .panel-foot p:last-child { margin-bottom: 0; }
    /* Chart definitions — collapsed by default, expandable (site pattern). */
    .panel-foot-disclosure { margin: 0; }
    .panel-foot-disclosure > summary {
      list-style: none; cursor: pointer;
      font-family: var(--font-mono); font-size: var(--fs-xs);
      letter-spacing: var(--tracking-eye); text-transform: uppercase;
      color: var(--ink-dim); font-weight: var(--weight-strong);
      padding: 4px var(--pad-panel) 10px;
    }
    .panel-foot-disclosure > summary::-webkit-details-marker { display: none; }
    .panel-foot-disclosure > summary::before { content: '▸ '; color: var(--accent); }
    .panel-foot-disclosure[open] > summary::before { content: '▾ '; }
    .panel-foot-disclosure[open] > summary { padding-bottom: 2px; }

    /* --- svg marks -------------------------------------------------------- */
    .grid { stroke: color-mix(in srgb, var(--rule) 70%, transparent); stroke-width: 1; }
    .axis { stroke: var(--rule-2); stroke-width: 1; }
    .tick {
      font-family: var(--font-mono);
      font-size: 10px;
      fill: var(--ink-faint);
    }
    .tick-y { text-anchor: end; }
    .tick-x { text-anchor: middle; }
    .pt { fill: var(--accent); }
    .pt-ctx { fill: var(--ink-faint); }
    .pt-hollow { fill: none; stroke-width: 1.6; }
    .range { stroke-width: 2; }
    .ring { fill: none; stroke-width: 1.4; opacity: 0.85; }
    /* Credit-enhancement ramp — strong → weak support. Dedicated per-theme
       colours (not the semantic tokens): teal / gold / rose ≈ cyan/yellow/
       magenta, a near-maximal three-hue spread so the tiers read distinctly.
       teal/blue collapses in the dark theme and teal/amber/red left two
       adjacent warm hues too close; this set separates cleanly in both.
       Reinforced by y-position + legend, so colour is redundant. */
    .panel {
      --ct-strong: #0d9488;
      --ct-mid: #b9770a;
      --ct-weak: #c11f57;
    }
    html[data-theme="terminal"] .panel {
      --ct-strong: #2dd4bf;
      --ct-mid: #ffb400;
      --ct-weak: #ff4d84;
    }
    .tier-strong, .tier-fill-strong { fill: var(--ct-strong); }
    .tier-mid, .tier-fill-mid { fill: var(--ct-mid); }
    .tier-weak, .tier-fill-weak { fill: var(--ct-weak); }
    .tier-stroke-strong { stroke: var(--ct-strong); }
    .tier-stroke-mid { stroke: var(--ct-mid); }
    .tier-stroke-weak { stroke: var(--ct-weak); }
    /* Chronological reading aid only — deliberately faint + dashed so it
       reads as sequence, not a single-driver trend. */
    .path-seq {
      fill: none;
      stroke: var(--ink-faint);
      stroke-width: 1;
      stroke-dasharray: 3 3;
      opacity: 0.5;
    }
    .leader {
      stroke: var(--ink-faint);
      stroke-width: 0.75;
      opacity: 0.55;
    }
    .hot { cursor: pointer; }
    .hot:hover { opacity: 0.75; }

    /* --- chart legend ----------------------------------------------------- */
    .legend {
      display: flex;
      flex-direction: column;
      gap: 5px;
      padding: 0 var(--pad-panel) 10px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
    }
    .lg-line {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 6px 18px;
    }
    .lg-head {
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: 0.04em;
    }
    .lg-item { display: inline-flex; align-items: center; gap: 6px; }
    .lg-dot {
      width: 9px; height: 9px; border-radius: 50%;
      display: inline-block; flex-shrink: 0;
    }
    .lg-dot.tier-strong { background: var(--ct-strong); }
    .lg-dot.tier-mid { background: var(--ct-mid); }
    .lg-dot.tier-weak { background: var(--ct-weak); }
    .lg-note { color: var(--ink-faint); }
    .pt-label {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 600;
      fill: var(--ink);
      text-anchor: middle;
    }
    .pt-tag {
      font-family: var(--font-mono);
      font-size: 9px;
      fill: var(--ink-dim);
      text-anchor: middle;
      letter-spacing: 0.04em;
    }
    .pt-sub {
      font-family: var(--font-mono);
      font-size: 8px;
      fill: var(--ink-faint);
      text-anchor: middle;
    }

    /* --- filters + table --------------------------------------------------- */
    .ledger-head { margin: 8px 0 14px; max-width: 84ch; }
    .filters {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      margin-bottom: 12px;
    }
    .filters select,
    .filters input {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      background: var(--surface);
      border: 1px solid var(--rule-2);
      border-radius: var(--rad);
      padding: 6px 8px;
    }
    .filters input { min-width: 240px; flex: 1 1 240px; max-width: 360px; }
    .filters .count {
      margin-left: auto;
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
    }
    .table-scroll { overflow-x: auto; border: 1px solid var(--rule); }
    #credit-table { min-width: 1240px; }

    /* --- resizable columns ------------------------------------------------ */
    #credit-table th { position: relative; }
    .col-grip {
      position: absolute;
      top: 0;
      right: -4px;
      width: 9px;
      height: 100%;
      cursor: col-resize;
      z-index: 2;
    }
    .col-grip::after {
      content: '';
      position: absolute;
      top: 20%;
      bottom: 20%;
      right: 4px;
      width: 1px;
      background: var(--rule-2);
    }
    .col-grip:hover::after {
      background: var(--accent);
      width: 2px;
    }
    /* under fixed layout the col width governs truncation — lift the
       hardcoded per-cell caps and let every cell ellipsize to its column */
    #credit-table.resizable td {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    #credit-table.resizable .c-issuer,
    #credit-table.resizable .c-name,
    #credit-table.resizable .c-type,
    #credit-table.resizable .c-rate,
    #credit-table.resizable .c-issued,
    #credit-table.resizable .c-src,
    #credit-table.resizable .c-lenders { max-width: none; }
    #credit-table.resizable .c-lenders .lender-first,
    #credit-table.resizable .c-src a { max-width: 100%; }
    #credit-table td { font-size: var(--fs-sm); }
    #credit-table th.sortable {
      cursor: pointer;
      user-select: none;
      white-space: nowrap;
    }
    #credit-table th.sortable::after {
      content: '↕';
      margin-left: 5px;
      opacity: 0.35;
      font-size: 0.9em;
    }
    #credit-table th.sortable:hover { color: var(--ink); }
    #credit-table th.sort-asc::after { content: '▲'; opacity: 1; color: var(--accent); }
    #credit-table th.sort-desc::after { content: '▼'; opacity: 1; color: var(--accent); }
    #credit-table tbody tr.stripe:not(:hover) td {
      background: color-mix(in srgb, var(--surface-2) 55%, transparent);
    }
    .c-issuer, .c-name, .c-type, .c-rate, .c-issued { white-space: nowrap; max-width: 104px; overflow: hidden; text-overflow: ellipsis; }
    .c-mat, .c-sen, .c-lenders, .c-status, .c-src { text-align: left !important; }
    .c-name { max-width: 300px; }
    .c-src { max-width: 180px; }
    .c-src a {
      display: inline-block;
      max-width: 180px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
      vertical-align: bottom;
    }
    .c-lenders { max-width: 210px; }
    .c-lenders .lender-first {
      display: inline-block;
      max-width: 165px;
      overflow: hidden;
      text-overflow: ellipsis;
      white-space: nowrap;
