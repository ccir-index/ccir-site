  ['Newmark (arranger)', /newmark/i],
];
const lenderSlug = (name: string) => name.toLowerCase().replace(/[^a-z0-9]+/g, '-');
function lenderTags(i: any): string[] {
  const txt = (i.lenders ?? []).join(' · ');
  return LENDER_CANON.filter(([, re]) => re.test(txt)).map(([n]) => n);
}
const lenderFacet = LENDER_CANON
  .map(([n]) => n)
  .filter((n) => instruments.some((i: any) => lenderTags(i).includes(n)));

// --- chart geometry ----------------------------------------------------------
const W = 920;
const H = 340;
const M = { top: 26, right: 30, bottom: 44, left: 46 };
const x0 = M.left, x1 = W - M.right, y0 = M.top, y1 = H - M.bottom;

function monthsSince(iso: string, epoch: string): number {
  const [ey, em] = epoch.split('-').map(Number);
  const [y, m, d] = iso.split('-').map(Number);
  return (y - ey) * 12 + (m - em) + ((d ?? 15) - 1) / 30;
}

// --- label layout solver -----------------------------------------------------
// Greedy, deterministic, build-time. Each label is a block of 1–3 mono lines
// anchored to a mark. Candidates fan out above/below and sideways; the first
// candidate that collides with no placed label and no mark wins. Labels are
// clamped to the plot; a leader line is flagged when the block sits away
// from its mark.
type LabLine = { t: string; cls: 'pt-label' | 'pt-tag' | 'pt-sub' };
interface LabIn { x: number; y: number; lines: LabLine[]; rid?: string; v?: number }
interface LabOut extends LabIn {
  lx: number; ly: number; w: number; h: number; leader: boolean;
  linePos: { t: string; cls: string; y: number }[];
}
const CHAR_W: Record<string, number> = { 'pt-label': 6.9, 'pt-tag': 5.8, 'pt-sub': 5.2 };
const LINE_H: Record<string, number> = { 'pt-label': 11, 'pt-tag': 10, 'pt-sub': 9 };

function layoutLabels(items: LabIn[], marks: { x: number; y: number }[]): LabOut[] {
  const placed: LabOut[] = [];
  type Box = { lx: number; ly: number; w: number; h: number };
  const collide = (a: Box, b: Box) =>
    Math.abs(a.lx - b.lx) < (a.w + b.w) / 2 + 6 &&
    a.ly < b.ly + b.h + 3 && b.ly < a.ly + a.h + 3;
  // Within a local x-window, a lower-value mark's label must not sit above a
  // higher-value one's — else near-tied points (e.g. 5.96 vs 6.00, ~2px apart)
  // read inverted. Penalise value-order violations so the solver picks a
  // slightly-less-ideal but order-consistent slot over the nearest one.
  const INV_PEN = 1000;
  const X_WIN = 120;
  for (const it of [...items].sort((a, b) => a.x - b.x || a.y - b.y)) {
    const w = Math.max(...it.lines.map((l) => l.t.length * CHAR_W[l.cls]));
    const h = it.lines.reduce((s, l) => s + LINE_H[l.cls], 0);
    const cands: { lx: number; ly: number }[] = [];
    for (const dx of [0, -30, 30, -60, 60, -95, 95]) {
      for (const dir of [-1, 1]) {
        for (let step = 0; step < 6; step++) {
          const gap = 9 + step * 12;
          cands.push({ lx: it.x + dx, ly: dir < 0 ? it.y - gap - h : it.y + gap });
        }
      }
    }
    let box: Box | null = null;
    let bestCost = Infinity;
    for (let ci = 0; ci < cands.length; ci++) {
      const c = cands[ci];
      const lx = Math.min(Math.max(c.lx, x0 + w / 2 + 2), x1 - w / 2 - 2);
      const ly = Math.min(Math.max(c.ly, y0 + 2), y1 - h - 2);
      const b = { lx, ly, w, h };
      if (placed.some((p) => collide(b, p))) continue;
      const hitMark = marks.some(
        (d) =>
          !(d.x === it.x && d.y === it.y) &&
          Math.abs(lx - d.x) < w / 2 + 8 &&
          d.y > ly - 6 && d.y < ly + h + 6
      );
      if (hitMark) continue;
      // cost = original preference order (ci) + value-inversion penalty
      let cost = ci;
      if (it.v != null) {
        const cy = ly + h / 2;
        for (const p of placed) {
          if (p.v == null || Math.abs(p.x - it.x) > X_WIN) continue;
          const pcy = p.ly + p.h / 2;
          if (it.v > p.v && cy > pcy + 2) cost += INV_PEN;
          else if (it.v < p.v && cy < pcy - 2) cost += INV_PEN;
        }
      }
      if (cost < bestCost) { bestCost = cost; box = b; }
      if (cost === 0) break; // ideal, order-consistent slot — stop scanning
    }
    if (!box) {
      // Worst case: stack straight down from the mark past whatever is there.
      const lx = Math.min(Math.max(it.x, x0 + w / 2 + 2), x1 - w / 2 - 2);
      let ly = it.y + 9, guard = 0;
      while (placed.some((p) => collide({ lx, ly, w, h }, p)) && guard++ < 60) ly += 6;
      box = { lx, ly: Math.min(ly, y1 - h - 2), w, h };
    }
    const above = box.ly + h <= it.y;
    const vGap = above ? it.y - (box.ly + h) : box.ly - it.y;
    const leader = Math.abs(box.lx - it.x) > 16 || vGap > 26;
    let yc = box.ly;
    const linePos = it.lines.map((l) => {
      const y = yc + LINE_H[l.cls] - 2;
      yc += LINE_H[l.cls];
      return { t: l.t, cls: l.cls, y };
    });
    placed.push({ ...it, lx: box.lx, ly: box.ly, w, h, leader, linePos });
  }
  return placed;
}

// ---- Chart A: GPU-collateral SOFR spread tape -------------------------------
// x = signing/closing date per filing; y = filed spread over SOFR (pp).
const A_EPOCH = '2023-06';
const A_SPAN = 38; // months, Jun 2023 → Aug 2026
const ax = (iso: string) => x0 + (x1 - x0) * (monthsSince(iso, A_EPOCH) / A_SPAN);
const A_YMAX = 14;
const ay = (v: number) => y0 + (y1 - y0) * ((A_YMAX - v) / A_YMAX);

// Credit-enhancement tier is the primary encoding, not the date: the low
// spreads are the IG-contract-wrapped facilities, the high ones the
// unwrapped GPU-only / non-IG legs. Colour carries that; the eye should
// read "cheap = wrapped," not "cheap = later." Tiers, strong → weak:
//   strong = IG-offtake-contract-wrapped (Microsoft)
//   mid    = customer offtake contracts, no single-IG wrap (2.0/2.1 IG+unrated mix; 3.0 = OpenAI, single/unrated; 5.0 = 2 non-IG customers)
//   weak   = unwrapped GPU-only / non-IG leg
type Tier = 'strong' | 'mid' | 'weak';
const tapeCfg = [
  { id: 'crwv-ddtl-1', date: '2023-07-30', v: 9.62, tag: 'CRWV DDTL 1.0', sub: "as amended '24", tier: 'weak' as Tier },
  { id: 'crwv-ddtl-2', date: '2024-05-16', v: null, lo: 6.0, hi: 6.5, extra: 13.0, tag: 'CRWV DDTL 2.0', sub: 'IG / non-IG', tier: 'strong' as Tier, tierExtra: 'mid' as Tier },
  { id: 'crwv-ddtl-3', date: '2025-07-28', v: 4.0, tag: 'CRWV DDTL 3.0', sub: 'OpenAI offtake', tier: 'mid' as Tier },
  { id: 'crwv-ddtl-2-1', date: '2025-09-29', v: 4.25, tag: 'CRWV DDTL 2.1', sub: null, tier: 'mid' as Tier },
  { id: 'crwv-ddtl-4', date: '2026-03-30', v: 2.25, tag: 'CRWV DDTL 4.0', sub: 'contract-wrapped', tier: 'strong' as Tier },
  { id: 'crwv-ddtl-5', date: '2026-05-15', v: 4.5, tag: 'CRWV DDTL 5.0', sub: '2 non-IG customers', tier: 'mid' as Tier },
  { id: 'iren-hw3-ddtl', date: '2026-05-29', v: 2.25, tag: 'IREN H3', sub: 'contract-wrapped', tier: 'strong' as Tier },
].map((p) => ({ ...p, inst: inst(p.id) }));

interface Mark { kind: 'dot' | 'diamond' | 'range'; x: number; y?: number; yLo?: number; yHi?: number; rid: string; tier: Tier }
const aMarks: Mark[] = [];
const aObstacles: { x: number; y: number }[] = [];
const aLabelItems: LabIn[] = [];
for (const p of tapeCfg) {
  const X = ax(p.date);
  const rid = `row-${p.id}`;
  if (p.v != null) {
    const Y = ay(p.v);
    aMarks.push({ kind: 'dot', x: X, y: Y, rid, tier: p.tier });
    aObstacles.push({ x: X, y: Y });
    const lines: LabLine[] = [
      { t: `+${p.v.toFixed(2)}`, cls: 'pt-label' },
      { t: p.tag, cls: 'pt-tag' },
    ];
    if (p.sub) lines.push({ t: p.sub, cls: 'pt-sub' });
    aLabelItems.push({ x: X, y: Y, lines, rid, v: p.v });
  } else {
    const yLo = ay(p.lo!), yHi = ay(p.hi!), yEx = ay(p.extra!);
    aMarks.push({ kind: 'range', x: X, yLo, yHi, rid, tier: p.tier });
    aMarks.push({ kind: 'diamond', x: X, y: yEx, rid, tier: (p as any).tierExtra ?? p.tier });
    aObstacles.push({ x: X, y: yLo }, { x: X, y: yHi }, { x: X, y: yEx }, { x: X, y: (yLo + yHi) / 2 });
    const lines: LabLine[] = [
      { t: `+${p.lo!.toFixed(2)}–${p.hi!.toFixed(2)}`, cls: 'pt-label' },
      { t: p.tag, cls: 'pt-tag' },
    ];
    if (p.sub) lines.push({ t: p.sub, cls: 'pt-sub' });
    aLabelItems.push({ x: X, y: yHi, lines, rid, v: (p.lo! + p.hi!) / 2 });
    aLabelItems.push({ x: X, y: yEx, lines: [{ t: `+${p.extra!.toFixed(2)}`, cls: 'pt-label' }], rid, v: p.extra! });
  }
}
const aLabels = layoutLabels(aLabelItems, aObstacles);

const A_TICKS_Y = [0, 2, 4, 6, 8, 10, 12, 14];
const A_TICKS_X = [
  { label: 'Jul ’23', iso: '2023-07-15' },
  { label: 'Jan ’24', iso: '2024-01-15' },
  { label: 'Jul ’24', iso: '2024-07-15' },
  { label: 'Jan ’25', iso: '2025-01-15' },
  { label: 'Jul ’25', iso: '2025-07-15' },
  { label: 'Jan ’26', iso: '2026-01-15' },
  { label: 'Jul ’26', iso: '2026-07-15' },
];

// ---- Chart B: lease-backed project-bond coupon compression -------------------
const B_EPOCH = '2025-09';
const B_SPAN = 11; // months, Sep 2025 → Aug 2026
const bx = (iso: string) => x0 + (x1 - x0) * (monthsSince(iso, B_EPOCH) / B_SPAN);
const B_YMIN = 5, B_YMAX = 10;
const by = (v: number) => y0 + (y1 - y0) * ((B_YMAX - v) / (B_YMAX - B_YMIN));

// Credit-support tier is the primary encoding here too — the coupon fell
// because the offtake credit improved, not merely because time passed.
// Tiers, strongest → weakest support, ordered as the market priced them:
//   strong = hyperscaler-IG tenant (AWS/Amazon/Microsoft/Oracle) or IG-rated bond
//   mid    = Google-guaranteed lease (Fluidstack is the tenant, Google guarantees)
//   weak   = neocloud / self-operated offtake, unrated
// `long` marks the 2042 maturities — their coupon embeds ~16y of duration
// the 2030–31 bonds don't, so they are not like-for-like on the y-axis.
const bondPath = [
  { id: 'wulf-notes-7750-2030', date: '2025-10-22', tag: 'WULF 7.750', tier: 'mid' as Tier },
  { id: 'cifr-7125-2030', date: '2025-11-13', tag: 'CIFR 7.125', tier: 'mid' as Tier },
  { id: 'apld-9250-2030', date: '2025-11-20', tag: 'APLD 9.250', tier: 'weak' as Tier },
  { id: 'cifr-6125-2031', date: '2026-02-11', tag: 'CIFR 6.125', tier: 'strong' as Tier },
  { id: 'hut-riverbend-6192-2042', date: '2026-04-30', tag: 'HUT 6.192', tier: 'strong' as Tier, long: true },
  { id: 'iren-hw3-notes', date: '2026-05-29', tag: 'IREN 5.96', tier: 'strong' as Tier },
  { id: 'hut-beaconpoint-6129-2042', date: '2026-06-09', tag: 'HUT 6.129', tier: 'strong' as Tier, long: true },
  { id: 'cifr-6000-2031', date: '2026-06-15', tag: 'CIFR 6.000', tier: 'strong' as Tier },
].map((p) => ({ ...p, inst: inst(p.id), v: inst(p.id).rate.value as number }));

// Context: the other filed project bonds of the window. Meridian Arc (the
// large SPV landlord bond) is now confirmed — issuer-counsel priced release
// + Fitch BB — so it is a filled dot, no longer hollow. No silent caps.
const bondContext = [
  { id: 'wulf-jv-7250-2030', date: '2025-12-29', tag: 'WULF JV 7.250', tier: 'mid' as Tier, press: false },
  { id: 'apld-6750-2031', date: '2026-03-10', tag: 'APLD 6.750', tier: 'strong' as Tier, press: false },
  { id: 'corz-7750-2031', date: '2026-05-06', tag: 'CORZ 7.750', tier: 'weak' as Tier, press: false },
  { id: 'apld-7000-2031', date: '2026-06-16', tag: 'APLD 7.000', tier: 'weak' as Tier, press: false },
  { id: 'fluidstack-meridian-arc', date: '2026-04-16', tag: 'Meridian Arc 6.250', tier: 'mid' as Tier, press: false },
].map((p) => ({ ...p, inst: inst(p.id), v: inst(p.id).rate.value as number }));

const bObstacles = [
  ...bondPath.map((p) => ({ x: bx(p.date), y: by(p.v) })),
  ...bondContext.map((p) => ({ x: bx(p.date), y: by(p.v) })),
];
const bLabelItems: LabIn[] = [
  ...bondPath.map((p) => ({
    x: bx(p.date), y: by(p.v), v: p.v,
    lines: [
      { t: p.v.toFixed(3), cls: 'pt-label' } as LabLine,
      { t: p.tag, cls: 'pt-tag' } as LabLine,
    ],
    rid: `row-${p.id}`,
  })),
  ...bondContext.map((p) => ({
    x: bx(p.date), y: by(p.v), v: p.v,
    lines: [{ t: p.tag, cls: 'pt-tag' } as LabLine],
    rid: `row-${p.id}`,
  })),
];
const bLabels = layoutLabels(bLabelItems, bObstacles);

const B_TICKS_Y = [5, 6, 7, 8, 9, 10];
const B_TICKS_X = [
  { label: 'Oct ’25', iso: '2025-10-15' },
  { label: 'Dec ’25', iso: '2025-12-15' },
  { label: 'Feb ’26', iso: '2026-02-15' },
  { label: 'Apr ’26', iso: '2026-04-15' },
  { label: 'Jun ’26', iso: '2026-06-15' },
];
const bondLine = bondPath.map((p) => `${bx(p.date).toFixed(1)},${by(p.v).toFixed(1)}`).join(' ');
---
<Base
  title="Compute Credit Tracker — GPU-Backed Loans & Financing, As Filed · CCIR"
  description="GPU-backed loans and compute financing tracked as filed — CoreWeave, Crusoe, Nscale, Applied Digital, Core Scientific, IREN, Soluna, Hut 8, TeraWulf, Lambda and 30+ more issuers. Coupons, spreads, collateral, and lenders from SEC filings and lender releases, source linked on every row."
  ogImage="/og/credit.png"
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Dataset',
