---
/*
  /credit — Compute Credit Tracker (v1). Live on main per John 2026-07-04;
  the staging/cmr-cutover copy carries the CMR wording and supersedes this
  file at the flip (expect a trivial merge conflict here — take staging's).

  Filings-as-filed: every row in src/data/credit_instruments.json traces to
  a primary document (SEC EDGAR filing or issuer/lender release) and links
  it. Undisclosed stays undisclosed — no estimates. Retired instruments are
  excluded from the table and listed in the methodology note.

  Charts read the same JSON by instrument id (inst() throws at build time if
  an id disappears), so the tape can never drift from the ledger. Chart
  labels are placed by a build-time greedy solver (layoutLabels) that
  guarantees no label-label or label-mark overlap; a faint leader line is
  drawn whenever a label had to move away from its mark.
*/
import Base from '../layouts/Base.astro';
import creditData from '../data/credit_instruments.json';
import CreditIssuanceChart from '../components/CreditIssuanceChart.astro';

const instruments = creditData.instruments;
const retired = creditData.retired;

// "As of" = latest row-level verification date, so the kicker tracks the
// ledger itself; _meta.as_of is only a fallback if rows ever lack the field.
const AS_OF =
  instruments
    .map((i: any) => i.as_of)
    .filter(Boolean)
    .sort()
    .at(-1) ?? creditData._meta.as_of;

const byId = new Map(instruments.map((i: any) => [i.id, i]));
function inst(id: string): any {
  const r = byId.get(id);
  if (!r) throw new Error(`credit_instruments.json: missing id ${id}`);
  return r;
}

// --- rate / size formatting ------------------------------------------------
function fmtRate(rate: any): string {
  if (rate.kind === 'undisclosed') return 'Undisclosed';
  if (rate.kind === 'sofr_spread') {
    if (rate.value == null && rate.value_low != null)
      return `SOFR +${rate.value_low.toFixed(2)}–${rate.value_high.toFixed(2)}%`;
    return `SOFR +${rate.value.toFixed(2)}%`;
  }
  if (rate.kind === 'fixed') {
    if (rate.value == null && rate.value_low != null)
      return `${rate.value_low.toFixed(2)}–${rate.value_high.toFixed(2)}%`;
    if (rate.value == null) return 'See note';
    return `${rate.value.toFixed(3).replace(/0$/, '')}%`;
  }
  // floating_other — benchmark lives in the note; show its lead clause.
  if (rate.note) {
    const short = rate.note.split(';')[0];
    return short.length > 34 ? short.slice(0, 32) + '…' : short;
  }
  return 'Floating';
}
function rateTitle(rate: any): string {
  return rate.note ?? '';
}
// Sort key for the issued column: first ISO date inside the value (a few
// rows carry prose like 'Assumed 2021' or 'Priced ~2026-04-16/17').
const issuedSortKey = (v: any) => {
  const m = String(v ?? '').match(/\d{4}(-\d{2}){0,2}/);
  return m ? m[0] : '';
};

// Numeric sort key for the rate column: coupon or spread where filed.
function rateSortKey(rate: any): number | null {
  return rate.value ?? rate.value_low ?? null;
}
function fmtSize(v: number | null): string {
  if (v == null) return '—';
  if (v >= 1000) return v.toLocaleString('en-US', { maximumFractionDigits: 0 });
  if (v >= 10) return v.toLocaleString('en-US', { maximumFractionDigits: 1 });
  return v.toLocaleString('en-US', { maximumFractionDigits: 2 });
}
function senClass(seniority: string | null): string {
  const s = (seniority ?? '').toLowerCase();
  if (s.includes('unsecured')) return 'unsecured';
  if (s.includes('secured') || s.includes('mortgage') || s.includes('lien')) return 'secured';
  return 'other';
}
const TYPE_LABEL: Record<string, string> = {
  bond: 'Bond',
  convertible: 'Convertible',
  credit_facility: 'Credit facility',
  lease: 'Lease',
  abs: 'ABS',
  other: 'Other',
};

// --- facets ------------------------------------------------------------------
const issuers = [...new Set(instruments.map((i: any) => i.issuer))];
const types = [...new Set(instruments.map((i: any) => i.instrument_type))];

// GPU-collateralized subset — the strict issuance scope charted below. The
// full ledger also carries convertibles, unsecured notes, and data-center
// credit, tracked for context but not secured by the GPUs themselves.
const inScopeC = instruments.filter((i: any) => !i.exclude_from_issuance && typeof i.size_usd_m === 'number' && i.size_usd_m > 0);
const inScopeUsdB = Math.round(inScopeC.reduce((a: number, i: any) => a + i.size_usd_m, 0) / 1000);

// Collateral-treatment scan — amortization-family language anywhere in an
// instrument's filed fields (schedules, depreciated-cost borrowing bases,
// DSCR-targeted paydowns). Residual-value references tracked separately so
// the section below stays true as rows change.
const AMORT_RX = /amorti[sz]|depreciat|balloon|borrowing base|DSCR/i;
const amortC = inScopeC.filter((i: any) => AMORT_RX.test(JSON.stringify(i)));
const residualRefs = instruments.filter((i: any) => /residual[ -]value/i.test(JSON.stringify(i)));

// Lender facet. Filings name the same institution many ways ("Morgan
// Stanley (lead)", "MS Senior Funding", bare "MS"), so rows are tagged with
// canonical institution names via pattern match over the filed lender
// strings. The display column keeps the strings exactly as filed.
const LENDER_CANON: [string, RegExp][] = [
