    <!-- Collateral treatment -->
    <div class="metho" id="collateral-treatment">
      <h2>Collateral treatment</h2>
      <p>
        Of the {inScopeC.length} GPU-collateralized instruments, {amortC.length}
        disclose amortization mechanics in their filed terms — depreciated-cost
        borrowing bases, scheduled quarterly or monthly amortization,
        debt-service coverage ratio (DSCR)-targeted paydowns,
        amortization-plus-balloon structures. Every
        disclosed schedule points the same direction: collateral value is
        written down toward zero over the facility's life. No GPU-collateralized
        instrument on this ledger references a market residual value; the
        remainder do not disclose amortization mechanics in any primary
        document. The only residual-value references anywhere on the ledger
        sit outside the GPU-collateral scope: the Hyperion data-center JV
        notes, where the guarantee is Meta's, on real-estate leases; and the
        Apollo / Blackstone Anthropic SPV, where Broadcom guarantees the
        residual on Google TPUs. Neither is secured by GPUs.
      </p>
      <p>
        A structure that amortizes collateral to zero embeds no assumption
        about terminal value. A structure that does not — partial
        amortization, a balloon sized to a resale assumption — substitutes an
        assumption for a schedule, and the difference between the two is
        something to monitor, not to fix at close: worked covenant, rollover,
        and pool-surveillance mechanics are at
        <a href="/applications">/applications</a>, and the measured
        per-generation decline path is at
        <a href="/research/gpu-age-curve">/research/gpu-age-curve</a>.
      </p>
    </div>

    <!-- Methodology -->
    <div class="metho" id="methodology">
      <h2>Sources &amp; method</h2>
      <p>
        This ledger is compiled from primary documents only: SEC EDGAR filings
        (annual, quarterly, and current reports (10-K/10-Q/8-K),
        foreign-issuer equivalents (20-F/6-K), prospectuses, indentures filed
        as exhibits)
        for public issuers, and company, lender, or arranger releases for
        private issuers. Terms are reproduced as filed. Where a rate, size,
        maturity, or collateral description is not stated in any primary
        document, the field reads <em>undisclosed</em> — no figure on this
        page is estimated or interpolated. Journalist-sourced terms that lack
        a primary-party release are flagged <span class="chip chip-press">press</span>;
        transactions reported as in-talks with no announced close are flagged
        <span class="chip chip-rumored">rumored</span>. Items flagged UNVERIFIED
        inside a note reproduce the ledger's own open questions.
      </p>
      <p>
        Updates are event-driven: rows change when a new filing or release
        lands, not on a fixed schedule. Corrections are welcome via the
        <a href="/contact">contact page</a> and are applied against the cited
        document. This page is a research publication of CCIR; it is not
        investment advice, an offer, or a solicitation.
      </p>
      <details class="def-disclosure">
        <summary>Retired and excluded instruments</summary>
        <p class="retired-lede">
          Instruments verified repaid, extinguished, settled, superseded, or
          determined not to be debt are excluded from the ledger above and
          recorded here so the panel's history stays auditable.
        </p>
        <ul class="retired-list">
          {retired.map((r: any) => (
            <li>
              <strong>{r.issuer}</strong>
              <ul>
                {r.items.map((it: string) => <li>{it}</li>)}
              </ul>
            </li>
          ))}
        </ul>
      </details>
    </div>
  </section>

  <script is:inline>
    (function () {
      var selIssuer = document.getElementById('f-issuer');
      var selType = document.getElementById('f-type');
      var selSen = document.getElementById('f-sen');
      var selStatus = document.getElementById('f-status');
      var selLender = document.getElementById('f-lender');
      var q = document.getElementById('f-q');
      var count = document.getElementById('f-count');
      var tbody = document.querySelector('#credit-table tbody');
      var rows = Array.prototype.slice.call(tbody.querySelectorAll('tr'));
      rows.forEach(function (r, idx) { r.dataset.orig = idx; });

      function restripe() {
        var vis = 0;
        rows.forEach(function (r) {
          if (r.style.display !== 'none') {
            r.classList.toggle('stripe', vis % 2 === 1);
            vis++;
          }
        });
      }

      function apply() {
        var vi = selIssuer.value, vt = selType.value, vs = selSen.value,
            vst = selStatus.value, vl = selLender.value,
            vq = q.value.trim().toLowerCase();
        var shown = 0;
        rows.forEach(function (r) {
          var ok =
            (!vi || r.dataset.issuer === vi) &&
            (!vt || r.dataset.type === vt) &&
            (!vs || r.dataset.sen === vs) &&
            (!vst || r.dataset.status === vst) &&
            (!vl || (r.dataset.lenders || '').split('|').indexOf(vl) !== -1) &&
            (!vq || r.textContent.toLowerCase().indexOf(vq) !== -1 ||
              (r.querySelector('.c-name').title || '').toLowerCase().indexOf(vq) !== -1 ||
              (r.querySelector('.c-lenders').title || '').toLowerCase().indexOf(vq) !== -1);
          r.style.display = ok ? '' : 'none';
          if (ok) shown++;
        });
        count.textContent = shown + ' / ' + rows.length + ' instruments';
        restripe();
      }

      // --- column sorting ---------------------------------------------------
      var sortKey = null, sortDir = 1;
      var NUMERIC = { size: true, rate: true };
      function rowVal(r, key) {
        if (key === 'name') return r.cells[1].textContent.trim().toLowerCase();
        var v = r.dataset[key];
        if (NUMERIC[key]) {
          var n = parseFloat(v);
          return isNaN(n) ? null : n;
        }
        return v === undefined || v === '' ? null : v.toLowerCase();
      }
      function sortRows() {
        var sorted = rows.slice().sort(function (a, b) {
          if (sortKey === null) return a.dataset.orig - b.dataset.orig;
          var va = rowVal(a, sortKey), vb = rowVal(b, sortKey);
          if (va === null && vb === null) return a.dataset.orig - b.dataset.orig;
          if (va === null) return 1;  // blanks/undisclosed always last
          if (vb === null) return -1;
          if (va < vb) return -1 * sortDir;
          if (va > vb) return 1 * sortDir;
          return a.dataset.orig - b.dataset.orig;
        });
        sorted.forEach(function (r) { tbody.appendChild(r); });
        restripe();
      }
      var headers = document.querySelectorAll('#credit-table th.sortable');
      headers.forEach(function (th) {
        th.addEventListener('click', function () {
          var key = th.dataset.key;
          if (sortKey === key) {
            if (sortDir === 1) { sortDir = -1; }
            else { sortKey = null; sortDir = 1; } // third click: back to ledger order
          } else {
            sortKey = key;
            sortDir = 1;
          }
          headers.forEach(function (h) {
            h.classList.remove('sort-asc', 'sort-desc');
            h.removeAttribute('aria-sort');
          });
          if (sortKey) {
            th.classList.add(sortDir === 1 ? 'sort-asc' : 'sort-desc');
            th.setAttribute('aria-sort', sortDir === 1 ? 'ascending' : 'descending');
          }
          sortRows();
        });
      });

      [selIssuer, selType, selSen, selStatus, selLender].forEach(function (el) {
        el.addEventListener('change', apply);
      });
      q.addEventListener('input', apply);
      apply();

      // --- chart mark -> ledger row -----------------------------------------
      // Clicking a data point (or its label) clears filters so the row is
      // visible, scrolls it to center, and flashes it.
      document.querySelectorAll('svg .hot[data-row]').forEach(function (el) {
        el.addEventListener('click', function () {
          var row = document.getElementById(el.getAttribute('data-row'));
          if (!row) return;
          selIssuer.value = ''; selType.value = ''; selSen.value = '';
          selStatus.value = ''; selLender.value = ''; q.value = '';
          apply();
          row.scrollIntoView({ behavior: 'smooth', block: 'center' });
          row.classList.remove('flash');
          void row.offsetWidth; // restart the animation on repeat clicks
          row.classList.add('flash');
        });
      });

      // --- resizable columns -------------------------------------------------
      // Fixed layout with measured initial widths; a grip on each header edge
      // drags its column. Column width then governs truncation instead of the
      // per-cell max-width caps (lifted via the .resizable class). Widths
      // persist per browser in localStorage.
      (function () {
        var table = document.getElementById('credit-table');
        if (!table) return;
        var ths = table.querySelectorAll('thead th');
        var KEY = 'credit-col-widths-v1';
        var saved = null;
        try { saved = JSON.parse(localStorage.getItem(KEY) || 'null'); } catch (e) {}
        if (saved && saved.length !== ths.length) saved = null;

        var colgroup = document.createElement('colgroup');
        var cols = [];
        ths.forEach(function (th, i) {
          var w = (saved && saved[i]) || th.getBoundingClientRect().width;
          var col = document.createElement('col');
          col.style.width = Math.round(w) + 'px';
          colgroup.appendChild(col);
          cols.push(col);
        });
        table.insertBefore(colgroup, table.firstChild);
        table.classList.add('resizable');
        table.style.tableLayout = 'fixed';
        function totalWidth() {
          return cols.reduce(function (s, c) { return s + parseFloat(c.style.width); }, 0);
        }
        table.style.width = totalWidth() + 'px';
        table.style.minWidth = '0';

        function persist() {
          try {
            localStorage.setItem(KEY, JSON.stringify(cols.map(function (c) { return parseFloat(c.style.width); })));
          } catch (e) {}
        }

        ths.forEach(function (th, i) {
          var grip = document.createElement('span');
          grip.className = 'col-grip';
          grip.setAttribute('aria-hidden', 'true');
          th.appendChild(grip);
          grip.addEventListener('click', function (e) { e.stopPropagation(); });
          grip.addEventListener('mousedown', function (e) {
            e.preventDefault();
            e.stopPropagation();
            var startX = e.clientX;
            var startW = parseFloat(cols[i].style.width);
            document.body.style.cursor = 'col-resize';
            document.body.style.userSelect = 'none';
            function move(ev) {
              var w = Math.max(44, startW + (ev.clientX - startX));
              cols[i].style.width = Math.round(w) + 'px';
              table.style.width = totalWidth() + 'px';
            }
            function up() {
              document.removeEventListener('mousemove', move);
              document.removeEventListener('mouseup', up);
              document.body.style.cursor = '';
              document.body.style.userSelect = '';
              persist();
            }
            document.addEventListener('mousemove', move);
            document.addEventListener('mouseup', up);
          });
          // double-click a grip: reset that column to its natural width
          grip.addEventListener('dblclick', function (e) {
            e.stopPropagation();
            cols[i].style.width = '';
            var natural = ths[i].getBoundingClientRect().width;
            cols[i].style.width = Math.round(natural) + 'px';
            table.style.width = totalWidth() + 'px';
            persist();
          });
        });
      })();
    })();
  </script>

  <style>
    .top { padding-top: 28px; }

    /* Sticky on-page jump bar (same pattern as /applications) */
    .apps-navband {
      position: sticky;
      top: 0;
      z-index: 40;
      background: var(--bg);
      border-bottom: 1px solid var(--rule);
    }
    .apps-nav-inner {
      display: flex;
      gap: 24px;
      overflow-x: auto;
      scrollbar-width: none;
      padding-top: 9px;
      padding-bottom: 9px;
    }
    .apps-nav-inner::-webkit-scrollbar { display: none; }
    .apps-nav-link {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
