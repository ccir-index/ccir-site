    .chip-confirmed { color: var(--pos); border-color: color-mix(in srgb, var(--pos) 55%, transparent); }
    .chip-press { color: var(--warn); border-color: color-mix(in srgb, var(--warn) 55%, transparent); }
    .chip-rumored { color: var(--neutral); border-color: color-mix(in srgb, var(--neutral) 55%, transparent); }
    .tbl-foot {
      font-size: var(--fs-xs);
