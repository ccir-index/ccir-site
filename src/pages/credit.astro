---
/*
  /credit — Compute Credit Tracker (v1). Live on main per John 2026-07-04;
  the staging/cmr-cutover copy carries the CMR wording and supersedes this
  file at the flip (expect a trivial merge conflict here — take staging's).

  Filings-as-filed: every row in src/data/credit_instruments.json traces to
  a primary document (SEC EDGAR filing or issuer/lender release) and links
  it. Undisclosed stays undisclosed — no estimates. Retired instruments are
  excluded from the table and listed in the methodology note.

  Charts read the same JSON by instrument id (chartPoint throws at build
  time if an id disappears), so the tape can never drift from the ledger.
*/
import Base from '../layouts/Base.astro';
import creditData from '../data/credit_instruments.json';

const AS_OF = creditData._meta.as_of;
const instruments = creditData.instruments;
const retired = creditData.retired;

const byId = new Map(instruments.map((i: any) => [i.id, i]));
function inst(id: string): any {
  const r = byId.get(id);
  if (!r) throw new Error(`credit_instruments.json: missing id ${id}`);
  return r;
}

// --- rate / size formatting ------------------------------------------------
function fmtRate(rate: any): string {
  if (rate.kind === 'undisclosed') return 'Undisclosed';
  if (rate.kind === 'sofr_spread') {
    if (rate.value == null && rate.value_low != null)
      return `SOFR +${rate.value_low.toFixed(2)}–${rate.value_high.toFixed(2)}%`;
    return `SOFR +${rate.value.toFixed(2)}%`;
  }
  if (rate.kind === 'fixed') {
    if (rate.value == null && rate.value_low != null)
      return `${rate.value_low.toFixed(2)}–${rate.value_high.toFixed(2)}%`;
    if (rate.value == null) return 'See note';
    return `${rate.value.toFixed(3).replace(/0$/, '')}%`;
  }
  // floating_other — benchmark lives in the note; show its lead clause.
  if (rate.note) {
    const short = rate.note.split(';')[0];
    return short.length > 34 ? short.slice(0, 32) + '…' : short;
  }
  return 'Floating';
}
function rateTitle(rate: any): string {
  return rate.note ?? '';
}
function fmtSize(v: number | null): string {
  if (v == null) return '—';
  if (v >= 1000) return v.toLocaleString('en-US', { maximumFractionDigits: 0 });
  if (v >= 10) return v.toLocaleString('en-US', { maximumFractionDigits: 1 });
  return v.toLocaleString('en-US', { maximumFractionDigits: 2 });
}
function senClass(seniority: string | null): string {
  const s = (seniority ?? '').toLowerCase();
  if (s.includes('unsecured')) return 'unsecured';
  if (s.includes('secured') || s.includes('mortgage') || s.includes('lien')) return 'secured';
  return 'other';
}
const TYPE_LABEL: Record<string, string> = {
  bond: 'Bond',
  convertible: 'Convertible',
  credit_facility: 'Credit facility',
  lease: 'Lease',
  abs: 'ABS',
  other: 'Other',
};

// --- facets ------------------------------------------------------------------
const issuers = [...new Set(instruments.map((i: any) => i.issuer))];
const types = [...new Set(instruments.map((i: any) => i.instrument_type))];

// --- chart geometry ----------------------------------------------------------
const W = 920;
const H = 320;
const M = { top: 26, right: 30, bottom: 40, left: 46 };
const x0 = M.left, x1 = W - M.right, y0 = M.top, y1 = H - M.bottom;

function monthsSince(iso: string, epoch: string): number {
  const [ey, em] = epoch.split('-').map(Number);
  const [y, m, d] = iso.split('-').map(Number);
  return (y - ey) * 12 + (m - em) + ((d ?? 15) - 1) / 30;
}

// ---- Chart A: GPU-collateral SOFR spread tape -------------------------------
// x = signing/closing date per filing; y = filed spread over SOFR (pp).
const A_EPOCH = '2023-06';
const A_SPAN = 38; // months, Jun 2023 → Aug 2026
const ax = (iso: string) => x0 + (x1 - x0) * (monthsSince(iso, A_EPOCH) / A_SPAN);
const A_YMAX = 14;
const ay = (v: number) => y0 + (y1 - y0) * ((A_YMAX - v) / A_YMAX);

// dy = label offset; issuer tag drawn under the spread label.
const tapeCfg = [
  { id: 'crwv-ddtl-1', date: '2023-07-30', v: 9.62, tag: 'CRWV DDTL 1.0', sub: "as amended '24", dy: -14 },
  { id: 'crwv-ddtl-2', date: '2024-05-16', v: null, lo: 6.0, hi: 6.5, extra: 13.0, tag: 'CRWV DDTL 2.0', sub: 'IG / non-IG', dy: -14 },
  { id: 'crwv-ddtl-3', date: '2025-07-28', v: 4.0, tag: 'CRWV DDTL 3.0', sub: null, dy: 22 },
  { id: 'crwv-ddtl-2-1', date: '2025-09-29', v: 4.25, tag: 'CRWV DDTL 2.1', sub: null, dy: -14 },
  { id: 'crwv-ddtl-4', date: '2026-03-30', v: 2.25, tag: 'CRWV DDTL 4.0', sub: 'contract-wrapped', dy: 22 },
  { id: 'crwv-ddtl-5', date: '2026-05-15', v: 4.5, tag: 'CRWV DDTL 5.0', sub: null, dy: -14 },
  { id: 'iren-hw3-ddtl', date: '2026-05-29', v: 2.25, tag: 'IREN H3', sub: 'contract-wrapped', dy: -14 },
].map((p) => ({ ...p, inst: inst(p.id) }));

const A_TICKS_Y = [0, 2, 4, 6, 8, 10, 12, 14];
const A_TICKS_X = [
  { label: 'Jul ’23', iso: '2023-07-15' },
  { label: 'Jan ’24', iso: '2024-01-15' },
  { label: 'Jul ’24', iso: '2024-07-15' },
  { label: 'Jan ’25', iso: '2025-01-15' },
  { label: 'Jul ’25', iso: '2025-07-15' },
  { label: 'Jan ’26', iso: '2026-01-15' },
  { label: 'Jul ’26', iso: '2026-07-15' },
];

// ---- Chart B: lease-backed project-bond coupon compression -------------------
const B_EPOCH = '2025-09';
const B_SPAN = 11; // months, Sep 2025 → Aug 2026
const bx = (iso: string) => x0 + (x1 - x0) * (monthsSince(iso, B_EPOCH) / B_SPAN);
const B_YMIN = 5, B_YMAX = 10;
const by = (v: number) => y0 + (y1 - y0) * ((B_YMAX - v) / (B_YMAX - B_YMIN));

// Headline compression path (the brief's named vintages), by pricing/close date.
const bondPath = [
  { id: 'wulf-notes-7750-2030', date: '2025-10-22', tag: 'WULF 7.750', dy: -12 },
  { id: 'cifr-7125-2030', date: '2025-11-13', tag: 'CIFR 7.125', dy: 22 },
  { id: 'apld-9250-2030', date: '2025-11-20', tag: 'APLD 9.250', dy: -12 },
  { id: 'cifr-6125-2031', date: '2026-02-11', tag: 'CIFR 6.125', dy: 22 },
  { id: 'hut-riverbend-6192-2042', date: '2026-04-30', tag: 'HUT 6.192', dy: -12 },
  { id: 'iren-hw3-notes', date: '2026-05-29', tag: 'IREN 5.96', dy: 22 },
  { id: 'hut-beaconpoint-6129-2042', date: '2026-06-09', tag: 'HUT 6.129', dy: -14 },
  { id: 'cifr-6000-2031', date: '2026-06-15', tag: 'CIFR 6.000', dy: 24 },
].map((p) => ({ ...p, inst: inst(p.id), v: inst(p.id).rate.value as number }));

// Context: the other filed project bonds of the window (grey), plus the one
// press-reported SPV bond (hollow) — no silent caps on what the window held.
const bondContext = [
  { id: 'wulf-jv-7250-2030', date: '2025-12-29', tag: 'WULF JV 7.250', dy: -12, press: false },
  { id: 'apld-6750-2031', date: '2026-03-10', tag: 'APLD 6.750', dy: 22, press: false },
  { id: 'corz-7750-2031', date: '2026-05-06', tag: 'CORZ 7.750', dy: -12, press: false },
  { id: 'apld-7000-2031', date: '2026-06-16', tag: 'APLD 7.000', dy: -26, press: false },
  { id: 'fluidstack-meridian-arc', date: '2026-04-16', tag: 'Meridian Arc 6.250', dy: -12, press: true },
].map((p) => ({ ...p, inst: inst(p.id), v: inst(p.id).rate.value as number }));

const B_TICKS_Y = [5, 6, 7, 8, 9, 10];
const B_TICKS_X = [
  { label: 'Oct ’25', iso: '2025-10-15' },
  { label: 'Dec ’25', iso: '2025-12-15' },
  { label: 'Feb ’26', iso: '2026-02-15' },
  { label: 'Apr ’26', iso: '2026-04-15' },
  { label: 'Jun ’26', iso: '2026-06-15' },
];
const bondLine = bondPath.map((p) => `${bx(p.date).toFixed(1)},${by(p.v).toFixed(1)}`).join(' ');
---
<Base
  title="Compute Credit Tracker · CCIR"
  description="Debt facts across the compute-infrastructure capital stack — every instrument as filed, from SEC filings and issuer or lender releases, with the source linked on every row."
>
  <section class="wrap top">
    <div class="hero-solo">
      <div class="kicker">Market Intelligence · Compute Credit · as of {AS_OF}</div>
      <h1>Compute Credit Tracker</h1>
      <p class="standfirst lede">
        The debt stack behind AI compute, as filed. {instruments.length}
        instruments across {issuers.length} issuers — public companies from
        their SEC filings, private issuers from company, lender, or arranger
        statements. Coupons, spreads, collateral, and lenders are reproduced
        as disclosed; where a filing does not state a term, the row says
        <em>undisclosed</em> — nothing here is estimated.
      </p>
      <div class="disclosure">
        <strong>Sourced as filed</strong>
        Compiled from SEC EDGAR filings and issuer/lender releases as filed.
        Every row links its source document. Confirmation flags:
        <span class="chip chip-confirmed">confirmed</span> company/lender/arranger
        statement · <span class="chip chip-press">press</span> journalist-sourced,
        no primary-party release · <span class="chip chip-rumored">rumored</span> in
        talks, no close announced. Updated event-driven as filings land.
        Corrections welcome. Not investment advice.
      </div>
    </div>

    <!-- Chart A — GPU-collateral SOFR spread tape -->
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">GPU-collateral floating-rate tape — spread over SOFR</div>
          <div class="panel-sub">
            Filed spreads on GPU-secured floating-rate facilities at signing ·
            window Jul 2023 – Jun 2026 · CoreWeave DDTL vintages + IREN Hardware 3
          </div>
        </div>
        <span class="badge">FILED TERMS</span>
      </div>
      <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Spread over SOFR on GPU-collateralized facilities, July 2023 to June 2026, compressing from +9.62 to +2.25">
        {A_TICKS_Y.map((t) => (
          <>
            <line x1={x0} y1={ay(t)} x2={x1} y2={ay(t)} class="grid" />
            <text x={x0 - 8} y={ay(t) + 3} class="tick tick-y">+{t}</text>
          </>
        ))}
        {A_TICKS_X.map((t) => (
          <text x={ax(t.iso)} y={y1 + 24} class="tick tick-x">{t.label}</text>
        ))}
        <line x1={x0} y1={y1} x2={x1} y2={y1} class="axis" />
        {tapeCfg.map((p) => (
          <g>
            {p.v != null && (
              <>
                <circle cx={ax(p.date)} cy={ay(p.v)} r="4.5" class="pt" />
                <text x={ax(p.date)} y={ay(p.v) + p.dy} class="pt-label">+{p.v.toFixed(2)}</text>
                <text x={ax(p.date)} y={ay(p.v) + p.dy + 11} class="pt-tag">{p.tag}</text>
                {p.sub && <text x={ax(p.date)} y={ay(p.v) + p.dy + 21} class="pt-sub">{p.sub}</text>}
              </>
            )}
            {p.lo != null && (
              <>
                <line x1={ax(p.date)} y1={ay(p.lo)} x2={ax(p.date)} y2={ay(p.hi)} class="range" />
                <line x1={ax(p.date) - 5} y1={ay(p.lo)} x2={ax(p.date) + 5} y2={ay(p.lo)} class="range" />
                <line x1={ax(p.date) - 5} y1={ay(p.hi)} x2={ax(p.date) + 5} y2={ay(p.hi)} class="range" />
                <circle cx={ax(p.date)} cy={ay(p.extra)} r="4.5" class="pt pt-alt" />
                <text x={ax(p.date)} y={ay(p.extra) - 10} class="pt-label">+{p.extra.toFixed(2)}</text>
                <text x={ax(p.date)} y={ay(p.hi) + p.dy} class="pt-label">+{p.lo.toFixed(2)}–{p.hi.toFixed(2)}</text>
                <text x={ax(p.date)} y={ay(p.hi) + p.dy + 11} class="pt-tag">{p.tag}</text>
                {p.sub && <text x={ax(p.date)} y={ay(p.hi) + p.dy + 21} class="pt-sub">{p.sub}</text>}
              </>
            )}
          </g>
        ))}
      </svg>
      <div class="panel-foot">
        Spreads as stated in the credit agreements (percentage points over the
        SOFR variant named in each filing). DDTL 2.0 prints as a bar: +6.00–6.50%
        on investment-grade contract loans, +13.00% (marked ◆) non-IG. DDTL 4.0
        and IREN Hardware 3 (+2.25%, 2026) are effectively Microsoft/IG-contract-wrapped.
        Vintage date = signing/closing per filing.
      </div>
    </div>

    <!-- Chart B — project-bond coupon compression -->
    <div class="panel">
      <div class="panel-head">
        <div>
          <div class="panel-title">Lease-backed project-bond coupons — fixed-rate senior secured 144A</div>
          <div class="panel-sub">
            Coupon at pricing/close, single-campus SPV issuers against hyperscaler / AI-lab
            leases · window Oct 2025 – Jun 2026
          </div>
        </div>
        <span class="badge">FILED TERMS</span>
      </div>
      <svg viewBox={`0 0 ${W} ${H}`} role="img" aria-label="Lease-backed project bond coupons, October 2025 to June 2026, compressing from 9.25 percent to under 6 percent">
        {B_TICKS_Y.map((t) => (
          <>
            <line x1={x0} y1={by(t)} x2={x1} y2={by(t)} class="grid" />
            <text x={x0 - 8} y={by(t) + 3} class="tick tick-y">{t.toFixed(1)}</text>
          </>
        ))}
        {B_TICKS_X.map((t) => (
          <text x={bx(t.iso)} y={y1 + 24} class="tick tick-x">{t.label}</text>
        ))}
        <line x1={x0} y1={y1} x2={x1} y2={y1} class="axis" />
        <polyline points={bondLine} class="path" />
        {bondContext.map((p) => (
          <g>
            <circle cx={bx(p.date)} cy={by(p.v)} r="4" class={p.press ? 'pt pt-hollow' : 'pt pt-ctx'} />
            <text x={bx(p.date)} y={by(p.v) + p.dy} class="pt-tag pt-tag-ctx">{p.tag}</text>
          </g>
        ))}
        {bondPath.map((p) => (
          <g>
            <circle cx={bx(p.date)} cy={by(p.v)} r="4.5" class="pt" />
            <text x={bx(p.date)} y={by(p.v) + p.dy} class="pt-label">{p.v.toFixed(3)}</text>
            <text x={bx(p.date)} y={by(p.v) + p.dy + 11} class="pt-tag">{p.tag}</text>
          </g>
        ))}
      </svg>
      <div class="panel-foot">
        Solid teal: the compression path APLD 9.25 → WULF 7.75 → CIFR 7.125 →
        6.125 → HUT 6.19/6.13 → CIFR 6.00 + IREN 5.96, dated by pricing/close
        per filing. Grey: other fixed-rate senior secured project issues filed
        in the window. Hollow: Meridian Arc 6.25% — press-reported (Bloomberg/LCD),
        no issuer release; SPV landlord paper against a Google-guaranteed
        Fluidstack lease, shown for completeness and flagged accordingly.
      </div>
    </div>

    <!-- Ledger table -->
    <div class="ledger-head">
      <h2>Instrument ledger</h2>
      <p class="standfirst">
        Every live instrument across the panel. Filter by issuer, type,
        seniority, or confirmation status; each row links the filing or
        release it was taken from.
      </p>
    </div>
    <div class="filters" id="credit-filters">
      <select id="f-issuer" aria-label="Filter by issuer">
        <option value="">All issuers</option>
        {issuers.map((i) => <option value={i}>{i}</option>)}
      </select>
      <select id="f-type" aria-label="Filter by instrument type">
        <option value="">All types</option>
        {types.map((t) => <option value={t}>{TYPE_LABEL[t] ?? t}</option>)}
      </select>
      <select id="f-sen" aria-label="Filter by seniority">
        <option value="">All seniorities</option>
        <option value="secured">Secured</option>
        <option value="unsecured">Unsecured</option>
        <option value="other">Other / not stated</option>
      </select>
      <select id="f-status" aria-label="Filter by status">
        <option value="">All statuses</option>
        <option value="confirmed">Confirmed</option>
        <option value="press">Press</option>
        <option value="rumored">Rumored</option>
      </select>
      <input id="f-q" type="search" placeholder="Search issuer, lender, collateral…" aria-label="Search rows" />
      <span class="count mono" id="f-count"></span>
    </div>
    <div class="table-scroll">
      <table class="data" id="credit-table">
        <thead>
          <tr>
            <th>Issuer</th>
            <th>Instrument</th>
            <th>Type</th>
            <th>Size $M</th>
            <th>Rate</th>
            <th>Maturity</th>
            <th>Seniority</th>
            <th>Status</th>
            <th>Source</th>
          </tr>
        </thead>
        <tbody>
          {instruments.map((i: any) => (
            <tr
              data-issuer={i.issuer}
              data-type={i.instrument_type}
              data-sen={senClass(i.seniority)}
              data-status={i.status}
            >
              <td class="c-issuer">
                <span class="issuer-name">{i.issuer}</span>
                {i.ticker && <span class="ticker mono">{i.ticker}</span>}
              </td>
              <td class="c-name" title={[i.entity, i.security, i.size_note].filter(Boolean).join(' · ')}>
                {i.name}
                {(i.entity || i.security || i.size_note) && <span class="has-note" aria-hidden="true">†</span>}
              </td>
              <td class="c-type">{TYPE_LABEL[i.instrument_type] ?? i.instrument_type}</td>
              <td class="c-size num" title={i.size_note ?? ''}>{fmtSize(i.size_usd_m)}</td>
              <td class="c-rate" title={rateTitle(i.rate)}>
                <span class:list={{ dim: i.rate.kind === 'undisclosed' }}>{fmtRate(i.rate)}</span>
              </td>
              <td class="c-mat" title={i.maturity_note ?? ''}>{i.maturity ?? '—'}</td>
              <td class="c-sen" title={i.seniority ?? ''}>{senClass(i.seniority)}</td>
              <td class="c-status"><span class={`chip chip-${i.status}`}>{i.status}</span></td>
              <td class="c-src"><a href={i.source.url} target="_blank" rel="noopener noreferrer" title={i.source.doc}>{i.source.doc.split(';')[0]}</a></td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="tbl-foot">
      † hover for borrower entity, collateral, and size notes. Sizes are
      latest-reported principal outstanding where filed, committed/face where
      drawn balances are undisclosed (hover the size). Non-USD sizes use the
      USD equivalents reported in the filings themselves.
    </p>

    <!-- Methodology -->
    <div class="metho" id="methodology">
      <h2>Methodology</h2>
      <p>
        This ledger is compiled from primary documents only: SEC EDGAR filings
        (10-K/10-Q/8-K/20-F/6-K, prospectuses, indentures filed as exhibits)
        for public issuers, and company, lender, or arranger releases for
        private issuers. Terms are reproduced as filed. Where a rate, size,
        maturity, or collateral description is not stated in any primary
        document, the field reads <em>undisclosed</em> — no figure on this
        page is estimated or interpolated. Journalist-sourced terms that lack
        a primary-party release are flagged <span class="chip chip-press">press</span>;
        transactions reported as in-talks with no announced close are flagged
        <span class="chip chip-rumored">rumored</span>. Items flagged UNVERIFIED
        inside a note reproduce the ledger's own open questions.
      </p>
      <p>
        Updates are event-driven: rows change when a new filing or release
        lands, not on a fixed schedule. Corrections are welcome via the
        <a href="/contact">contact page</a> and are applied against the cited
        document. This page is a research publication of CCIR; it is not
        investment advice, an offer, or a solicitation.
      </p>
      <details class="def-disclosure">
        <summary>Retired and excluded instruments</summary>
        <p class="retired-lede">
          Instruments verified repaid, extinguished, settled, superseded, or
          determined not to be debt are excluded from the ledger above and
          recorded here so the panel's history stays auditable.
        </p>
        <ul class="retired-list">
          {retired.map((r: any) => (
            <li>
              <strong>{r.issuer}</strong>
              <ul>
                {r.items.map((it: string) => <li>{it}</li>)}
              </ul>
            </li>
          ))}
        </ul>
      </details>
    </div>
  </section>

  <script is:inline>
    (function () {
      var selIssuer = document.getElementById('f-issuer');
      var selType = document.getElementById('f-type');
      var selSen = document.getElementById('f-sen');
      var selStatus = document.getElementById('f-status');
      var q = document.getElementById('f-q');
      var count = document.getElementById('f-count');
      var rows = Array.prototype.slice.call(
        document.querySelectorAll('#credit-table tbody tr')
      );
      function apply() {
        var vi = selIssuer.value, vt = selType.value, vs = selSen.value,
            vst = selStatus.value, vq = q.value.trim().toLowerCase();
        var shown = 0;
        rows.forEach(function (r) {
          var ok =
            (!vi || r.dataset.issuer === vi) &&
            (!vt || r.dataset.type === vt) &&
            (!vs || r.dataset.sen === vs) &&
            (!vst || r.dataset.status === vst) &&
            (!vq || r.textContent.toLowerCase().indexOf(vq) !== -1 ||
              (r.querySelector('.c-name').title || '').toLowerCase().indexOf(vq) !== -1);
          r.style.display = ok ? '' : 'none';
          if (ok) shown++;
        });
        count.textContent = shown + ' / ' + rows.length + ' instruments';
      }
      [selIssuer, selType, selSen, selStatus].forEach(function (el) {
        el.addEventListener('change', apply);
      });
      q.addEventListener('input', apply);
      apply();
    })();
  </script>

  <style>
    .top { padding-top: 28px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    h2 {
      font-size: var(--fs-2xl);
      margin: 0 0 10px;
    }
    .lede { font-size: var(--fs-lg); }
    .lede em { font-style: italic; color: var(--accent); }
    .hero-solo { margin-bottom: 26px; max-width: 84ch; }

    /* --- panels ---------------------------------------------------------- */
    .panel {
      background: var(--surface);
      border: 1px solid var(--rule);
      margin-bottom: 28px;
    }
    .panel-head {
      display: flex;
      align-items: flex-start;
      gap: 16px;
      padding: var(--pad-panel) var(--pad-panel) 8px;
    }
    .panel-title {
      font-family: var(--font-display);
