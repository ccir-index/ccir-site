---
import Base from '../layouts/Base.astro';
import { headlineRates, meta, seriesHistory } from '../data/snapshot';
import { TIERS, TIER_LABELS, REGION_LABELS } from '../data/types';

// Inline-SVG sparkline string — mirrors components/Sparkline.astro.
function buildSparkSvg(seriesId: string, median: number, width = 56, height = 16, windowDays = 30): string {
  const empty = `<span class="sparkline-empty" style="display:inline-block;width:${width}px;height:${height}px;"></span>`;
  let merged = seriesHistory(seriesId);
  if (merged.length === 0) return empty;
  const last = merged[merged.length - 1]!;
  if (Number.isFinite(median) && Math.abs(last.median - median) > 1e-9) merged = [...merged, { date: '', median }];
  const points = merged.slice(-windowDays);
  if (points.length < 2) return empty;
  const PAD = 1;
  const innerW = Math.max(1, width - PAD * 2);
  const innerH = Math.max(1, height - PAD * 2);
  const ys = points.map((p) => p.median);
  const lo = Math.min(...ys), hi = Math.max(...ys), span = hi - lo;
  const stepX = innerW / (points.length - 1);
  const coords = points.map((p, i) => {
    const x = PAD + i * stepX;
    const y = span > 0 ? PAD + innerH - ((p.median - lo) / span) * innerH : PAD + innerH / 2;
    return [x, y] as const;
  });
  const polyline = coords.map(([x, y]) => `${x.toFixed(2)},${y.toFixed(2)}`).join(' ');
  const [endX, endY] = coords[coords.length - 1]!;
  return `<svg class="sparkline" width="${width}" height="${height}" viewBox="0 0 ${width} ${height}" role="img" aria-label="${windowDays}-day trend"><polyline points="${polyline}" fill="none" stroke="currentColor" stroke-width="1" stroke-linejoin="round" stroke-linecap="round" vector-effect="non-scaling-stroke" /><circle cx="${endX.toFixed(2)}" cy="${endY.toFixed(2)}" r="1.4" fill="currentColor" /></svg>`;
}

const FORM_ORDER = ['SXM', 'PCIe', 'NVL', 'ALL'];
const REGION_ORDER = ['US', 'EU', 'APAC', 'Other', 'ALL'];
const CHIP_ORDER = ['GB200', 'GB300', 'B300', 'B200', 'H200', 'H100', 'A100', 'MI300X',
  'L40S', 'L40', 'L4', 'RTXPRO6000', '5090', '4090', 'A40', 'A30', '3090', 'V100'];

// One pool: every operator-segment series, dropping the fully-pooled cell
// (form=int=region=ALL) — that headline blend lives on /rates. What's left is
// the grain breakouts: by form, by interruptibility, by region.
const source = headlineRates.filter(
  (r) => !(r.form_factor === 'ALL' && r.interruptibility === 'ALL' && r.region === 'ALL'),
);

const forms = Array.from(new Set(source.map((r) => r.form_factor)))
  .filter((f) => f !== 'ALL')
  .sort((a, b) => FORM_ORDER.indexOf(a) - FORM_ORDER.indexOf(b));
const regions = Array.from(new Set(source.map((r) => r.region)))
  .filter((rg) => rg !== 'ALL')
  .sort((a, b) => REGION_ORDER.indexOf(a) - REGION_ORDER.indexOf(b));
const chips = Array.from(new Set(source.map((r) => r.gpu_model)))
  .sort((a, b) => {
    const ai = CHIP_ORDER.indexOf(a), bi = CHIP_ORDER.indexOf(b);
    return (ai === -1 ? 99 : ai) - (bi === -1 ? 99 : bi) || a.localeCompare(b);
  });

const rows = source.map((r) => ({
  id: r.series_id,
  tier: r.tier!,
  tier_label: TIER_LABELS[r.tier!],
  chip: r.gpu_model,
  form: r.form_factor,
  region: r.region,
  region_label: REGION_LABELS[r.region],
  interrupt: r.interruptibility,
  mean: r.price_mean,
  p25: r.price_p25,
  p75: r.price_p75,
  n_src: r.n_sources,
  spark: buildSparkSvg(r.series_id, r.price_median),
}));
---
<Base
  title="Explorer · CCIR"
  description="The whole compute market, unfiltered — every series, every chip, every grain. Filter by segment, chip, form, interruptibility, and region."
  ogImage="/og/explorer.png"
>
  <section class="wrap top">
    <div class="kicker">Series Explorer · {meta.as_of_date}</div>
    <h1>The whole market, unfiltered</h1>
    <p class="standfirst lede">
      Every grain we track — {rows.length} series across {chips.length} chips
      and three operator segments (Hyperscaler / Neocloud / Marketplace), broken
      out by form, interruptibility, and region. No curation: single-source
      cells sit alongside deep ones, each shown with its source count
      <em>n</em>. A dash means the axis isn't broken out for that series.
      On-demand rates.
    </p>

    <div class="filter-bank">
      <div class="filters" id="filters">
        <div class="fgroup">
          <label for="f-tier">Segment</label>
          <select id="f-tier" data-filter="tier">
            <option value="">All</option>
            {TIERS.map((t) => <option value={t}>{TIER_LABELS[t]}</option>)}
          </select>
        </div>
        <div class="fgroup">
          <label for="f-chip">Chip</label>
          <select id="f-chip" data-filter="chip">
            <option value="">All</option>
            {chips.map((c) => <option value={c}>{c}</option>)}
          </select>
        </div>
        <div class="fgroup">
          <label for="f-form">Form</label>
          <select id="f-form" data-filter="form">
            <option value="">All</option>
            {forms.map((f) => <option value={f}>{f}</option>)}
          </select>
        </div>
        <div class="fgroup">
          <label for="f-int">Interrupt</label>
          <select id="f-int" data-filter="interrupt">
            <option value="">All</option>
            <option value="GTD">Guaranteed</option>
            <option value="INT">Interruptible</option>
          </select>
        </div>
        <div class="fgroup">
          <label for="f-region">Region</label>
          <select id="f-region" data-filter="region">
            <option value="">All</option>
            {regions.map((rg) => <option value={rg}>{REGION_LABELS[rg as keyof typeof REGION_LABELS]}</option>)}
          </select>
        </div>
        <div class="fgroup fgroup-search">
          <label for="f-search">Search</label>
          <input type="text" id="f-search" placeholder="series_id substring" />
        </div>
      </div>
      <div class="filter-actions">
        <span class="match-pill">Matching: <span id="match">0</span></span>
        <button type="button" id="reset" class="reset-btn">Reset</button>
      </div>
    </div>

    <div class="table-wrap">
      <table class="data" id="rows-table">
        <thead>
          <tr>
            <th>Series</th>
            <th>Segment</th>
            <th>Chip</th>
            <th>Form</th>
            <th>Int</th>
            <th>Region</th>
            <th>Mean $/hr</th>
            <th>Trend · 30d</th>
            <th>IQR</th>
            <th>n</th>
          </tr>
        </thead>
        <tbody id="rows-tbody"></tbody>
      </table>
    </div>
  </section>

  <script is:inline define:vars={{ ROWS: rows }}>
    (function () {
      function fmt(n, dp) { return Number(n).toFixed(dp != null ? dp : 2); }
      function dash(tok, label) { return tok === 'ALL' ? '—' : label; }
      var F = { tier: '', chip: '', form: '', interrupt: '', region: '', search: '' };
      var tbody = document.getElementById('rows-tbody');
      var match = document.getElementById('match');
      function matches(r) {
        if (F.tier && r.tier !== F.tier) return false;
        if (F.chip && r.chip !== F.chip) return false;
        if (F.form && r.form !== F.form) return false;
        if (F.interrupt && r.interrupt !== F.interrupt) return false;
        if (F.region && r.region !== F.region) return false;
        if (F.search && r.id.toLowerCase().indexOf(F.search.toLowerCase()) === -1) return false;
        return true;
      }
      function render() {
        var rs = ROWS.filter(matches);
        match.textContent = rs.length;
        tbody.innerHTML = rs.map(function (r) {
          return '<tr>' +
            '<td class="sid"><code>' + r.id + '</code></td>' +
            '<td><span class="tier-badge tier-badge-' + r.tier.toLowerCase() + '" title="' + r.tier_label + '">' + r.tier_label + '</span></td>' +
            '<td class="chip">' + r.chip + '</td>' +
            '<td class="dim">' + dash(r.form, r.form) + '</td>' +
            '<td class="dim">' + dash(r.interrupt, r.interrupt) + '</td>' +
            '<td class="dim">' + dash(r.region, r.region_label) + '</td>' +
            '<td class="num posted">$' + fmt(r.mean) + '</td>' +
            '<td class="num spark">' + r.spark + '</td>' +
            '<td class="num dim">$' + fmt(r.p25) + '–$' + fmt(r.p75) + '</td>' +
            '<td class="num">' + r.n_src + '</td>' +
          '</tr>';
        }).join('');
      }
      document.querySelectorAll('#filters select, #filters input').forEach(function (el) {
        var key = el.getAttribute('data-filter') || (el.id === 'f-search' ? 'search' : null);
        if (!key) return;
        el.addEventListener('input', function () { F[key] = el.value; render(); });
        el.addEventListener('change', function () { F[key] = el.value; render(); });
      });
      document.getElementById('reset').addEventListener('click', function () {
        document.querySelectorAll('#filters select').forEach(function (s) { s.value = ''; });
        document.getElementById('f-search').value = '';
        F = { tier: '', chip: '', form: '', interrupt: '', region: '', search: '' };
        render();
      });
      render();
    })();
  </script>

  <style>
    .top { padding-top: 28px; }
    h1 { font-family: var(--font-display); font-size: var(--fs-2xl); margin: 6px 0 12px; letter-spacing: -0.005em; }
    .lede { max-width: 84ch; margin: 8px 0 22px; }
    .lede em { font-style: italic; color: var(--accent); }

    .filter-bank { background: var(--surface-2); border: 1px solid var(--rule); padding: 12px 14px; margin-bottom: 14px; }
    .filters { display: grid; grid-template-columns: repeat(auto-fit, minmax(150px, 1fr)); gap: 10px 14px; align-items: end; }
    .filter-actions { display: flex; gap: 12px; align-items: center; justify-content: flex-end; margin-top: 12px; padding-top: 10px; border-top: 1px dashed var(--rule); }
    .match-pill { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--ink-dim); letter-spacing: var(--tracking-eye); text-transform: uppercase; }
    .match-pill span { color: var(--accent); font-weight: var(--weight-strong); }
    .fgroup { display: flex; flex-direction: column; gap: 4px; }
    .fgroup-search { grid-column: span 2; min-width: 0; }
    .fgroup label { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--ink-dim); text-transform: uppercase; letter-spacing: var(--tracking-eye); font-weight: var(--weight-strong); }
    .fgroup select, .fgroup input { font-family: var(--font-mono); font-size: var(--fs-sm); background: var(--surface); color: var(--ink); border: 1px solid var(--rule-2); padding: 6px 8px; border-radius: var(--rad); }
    .reset-btn { background: transparent; border: 1px solid var(--rule-2); color: var(--ink-dim); font-family: var(--font-mono); font-size: var(--fs-xs); padding: 6px 14px; cursor: pointer; border-radius: var(--rad); letter-spacing: var(--tracking-eye); text-transform: uppercase; font-weight: var(--weight-strong); }
    .reset-btn:hover { color: var(--ink); border-color: var(--accent); }

    .table-wrap { border: 1px solid var(--rule); background: var(--surface); overflow-x: auto; }
    #rows-table td.sid code { font-family: var(--font-mono); font-size: calc(var(--fs-sm) - 1px); color: var(--accent); letter-spacing: 0.02em; }
    #rows-table td.chip { color: var(--ink); font-weight: var(--weight-strong); }
    #rows-table td.posted { color: var(--ink); font-weight: var(--weight-strong); }
    td.spark { color: var(--accent); padding: 4px 8px; }
    .sparkline { opacity: 0.5; vertical-align: middle; }
  </style>
</Base>
