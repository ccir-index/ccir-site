---
import Base from '../layouts/Base.astro';
import ObsPanel from '../components/ObsPanel.astro';

// /utilization — the SUPPLY & DEMAND page (prototype rebuild, 2026-07-02).
//
// The page is the instrumentation layer for a composite supply–demand index
// in development. Five instruments, one panel each:
//
//   01 MEASURED    measured marketplace utilization (Vast rented/total —
//                  the one measured source)                       [live feed]
//   02 BREADTH     availability breadth (X of Y venues, Cluster vs
//                  Fractional) + three-state upgrade placeholder  [live feed]
//   03 DEMAND      spot-to-on-demand spread per chip (AWS)        [future feed]
//   04 DEPTH       executable market depth — offer counts + posted
//                  price range across marketplace venues          [future feed]
//   05 DIVERGENCE  posted vs executable — the signature chart     [future feed]
//
// Sections 03–05 are wired to /data/ CSVs the pipeline does not export yet
// (contracts in DESIGN.md at repo root). Until those land, each falls back
// to a deterministic PLACEHOLDER sample rendered under an "Illustrative
// sample" badge; flip SHOW_SAMPLE_WHEN_MISSING in the script to get the
// standard "warming up" empty state instead.
//
// Naming note: "/observatory" is already taken by the (paused) Shadeform
// Availability Observatory page — this page deliberately does NOT use the
// word Observatory in its visible name to avoid the collision.
//
// Charts: sections 01–04 keep client-side Chart.js (their data is runtime
// CSVs fetched per chip — the existing pattern on this page). Section 05 is
// a client-built inline SVG following the TermCurveChart house conventions
// (chart-local per-theme series tokens, direct end labels, mono captions,
// hover <title> depth disclosure). Series colors reuse the TermCurveChart
// validated pair and re-passed the dataviz six-checks on both surfaces
// (2026-07-02): dark #cc7d00/#00829e worst CVD ΔE 79.7 PASS; light
// #a3660f/#0d96b6 worst CVD ΔE 75.0 PASS.
const CHIPS = [
  { slug: 'h100-sxm',      label: 'H100',  vast: 'h100-sxm' },
  { slug: 'h200-sxm',      label: 'H200',  vast: 'h200-sxm' },
  { slug: 'b200-sxm',      label: 'B200',  vast: 'b200-sxm' },
  { slug: 'a100-sxm-80gb', label: 'A100',  vast: 'a100-sxm' },
  { slug: 'gb200',         label: 'GB200', vast: 'gb200' },
];
const DEFAULT_CHIP = 'h100-sxm';
---
<Base
  title="Supply & Demand · CCIR"
  description="CCIR — the supply–demand instrument panel: measured marketplace utilization, availability breadth across genuine-capacity venues, the spot-to-on-demand spread, executable market depth, and the posted-vs-executable divergence."
  ogImage="/og-utilization.png"
>
  <section class="wrap sd-page">
    <div class="kicker">CCIR · SUPPLY &amp; DEMAND <span class="mi-tag">Market&nbsp;Intelligence</span></div>
    <h1>Supply &amp; Demand</h1>
    <p class="deck">
      Five instruments, each measuring one thing. <strong>Measured
      utilization</strong> — of the capacity the one marketplace we can measure
      actually lists, how much is occupied. <strong>Availability breadth</strong>
      — of the genuine-capacity venues we probe, how many show launchable stock.
      <strong>Demand gauge</strong> — the posted spot ask as a share of the same
      venue's posted on-demand rate. <strong>Executable depth</strong> — how many
      launchable offers the marketplace venues list, and at what posted range.
      <strong>Divergence</strong> — the gap between the posted-rate reference and
      the executable component. Together they are the component gauges of a
      composite supply–demand index in development.
    </p>

    <!-- chip selector — sections 01/02 overlay every selected chip;
         sections 03–05 follow the FIRST selected chip -->
    <div class="chips" role="tablist" aria-label="GPU model">
      {CHIPS.map((c) => (
        <button class="chip" role="tab" data-chip={c.slug} data-vast={c.vast}
                aria-selected={c.slug === DEFAULT_CHIP ? 'true' : 'false'}>{c.label}</button>
      ))}
      <span class="chip-hint">select one or more to compare · sections 03–05 follow the first selection</span>
    </div>

    <!-- ══ Section 01 · MEASURED — Vast rented/total, the only measured source ══ -->
    <ObsPanel num="01" kicker="Measured" title="Measured marketplace utilization" windowId="util-window">
      <p class="panel-sub" slot="sub">
        Vast.ai — the one marketplace venue that discloses rented / total listed
        GPUs. Rolling 7-day occupancy of listed supply, denominator fixed to each
        window's median listed capacity.
      </p>
      <div class="util-grid">
        <div class="util-now" id="util-now">
          <span class="util-big" id="u-now">—</span>
          <span class="util-now-lbl" id="u-now-lbl">trailing 7-day utilization</span>
        </div>
        <div class="chart-wrap util-wrap"><canvas id="utilChart"></canvas></div>
      </div>
      <div class="empty" id="util-empty" hidden>Vast utilization warming up.</div>
      <p slot="caption">
        Measures: share of listed GPUs occupied on Vast.ai — one measured source.
        A rented GPU and a host-paused GPU are indistinguishable in the
        disclosure, so the series reads as an upper bound on paid occupancy.
        Trailing 7-day window · daily marks.
      </p>
    </ObsPanel>

    <!-- ══ Section 02 · BREADTH — X of Y venues with launchable stock ══ -->
    <ObsPanel num="02" kicker="Breadth" title="Availability breadth" windowId="avail-window">
      <p class="panel-sub" slot="sub">
        Rolling 7-day breadth — the share of genuine-capacity venues
        (<strong>X of Y</strong>) showing launchable stock; falling = venues
        selling out. Dashed verticals mark a change in the venue panel.
        <span id="trend-mode">Cluster (8×) vs Fractional.</span>
      </p>

      <div class="band" id="band">
        <div class="stat stat-frac">
          <span class="stat-lbl">Fractional — venues available</span>
          <span class="stat-val" id="s-frac">—</span>
          <span class="stat-sub" id="s-frac-sub">any launchable shape · 7d</span>
        </div>
        <div class="stat stat-clu">
          <span class="stat-lbl">Cluster (8×) — venues available</span>
          <span class="stat-val" id="s-clu">—</span>
          <span class="stat-sub" id="s-clu-sub">full 8-GPU node · 7d</span>
        </div>
        <div class="stat">
          <span class="stat-lbl">Panel sources</span>
          <span class="stat-val" id="s-srcs">—</span>
          <span class="stat-sub" id="s-srcs-sub">venues probed</span>
        </div>
        <!-- THREE-STATE UPGRADE — reserved stat cell (hidden). When the
             three-state feed lands this becomes the "advertised ·
             unfulfillable" venue count; see the placeholder block below. -->
        <div class="stat stat-adv" id="s-adv-cell" hidden>
          <span class="stat-lbl">Advertised · unfulfillable</span>
          <span class="stat-val" id="s-adv">—</span>
          <span class="stat-sub" id="s-adv-sub">listed but waitlist / quote-only · 7d</span>
        </div>
      </div>

      <div class="card-head">
        <div class="confbadge" id="confbadge"></div>
      </div>
      <div class="chart-wrap"><canvas id="trendChart"></canvas></div>
      <div class="empty" id="trend-empty" hidden>Series warming up — first publish lands on the next daily build.</div>

      <!-- ── THREE-STATE BREADTH UPGRADE — PLACEHOLDER ──────────────────────
           Today each venue in the breadth read is binary: in stock vs no
           stock observed. Wave-1 probing already captures waitlist /
           out-of-stock / quote-only chips, which split "no stock" into two
           distinct states:

             in stock · advertised but unfulfillable · not listed

           When the pipeline exports the extra columns (availability_index
           trend v2 — column contract in DESIGN.md), (a) unhide this legend,
           (b) unhide the #s-adv-cell stat above, and (c) add a stacked
           per-state venue-count band beneath the trend chart in the slot
           marked #state-band-slot. The nodes are kept in the DOM (hidden)
           so the layout already reserves their space plan. -->
      <div class="state-legend" id="state-legend" hidden aria-hidden="true">
        <span class="state-chip st-in"><i></i>in stock</span>
        <span class="state-chip st-adv"><i></i>advertised · unfulfillable</span>
        <span class="state-chip st-not"><i></i>not listed</span>
      </div>
      <div id="state-band-slot" hidden aria-hidden="true">
        <!-- future: stacked venue-count band (in-stock / advertised-but-
             unfulfillable / not-listed), same x-axis as the trend chart -->
      </div>

      <details class="panel-details">
        <summary>
          <span class="sum-main">The panel <span class="sum-count" id="panel-count"></span></span>
          <span class="sum-sub">Each genuine-capacity source, one vote · 7-day availability</span>
          <span class="sum-chev" aria-hidden="true">▾</span>
        </summary>
        <div class="panel" id="panel"></div>
        <p class="foot">Excludes catalog-eligibility (Azure) and probabilistic-score (AWS) sources from the headline. Resellers that duplicate a directly-probed operator are deduped. Sources below the minimum observed-cycle threshold are held out until they accumulate probes.</p>
      </details>

      <p slot="caption">
        Measures: of the Y genuine-capacity venues that disclosed a signal for
        this chip (venue count in the stat band; per-venue detail above), the
        share X/Y that showed launchable stock. Breadth, not a median —
        availability is bimodal and a median collapses on a bare majority.
        Rolling 7-day window · daily marks.
      </p>
    </ObsPanel>

    <!-- ══ Section 03 · DEMAND GAUGE — spot ask as % of posted on-demand ══ -->
    <ObsPanel num="03" kicker="Demand gauge" title="Spot-to-on-demand spread" sampleId="gauge-sample" windowId="gauge-window">
      <p class="panel-sub" slot="sub">
        The posted spot ask as a share of the same instance's posted on-demand
        rate. A spread tightening toward parity reads as demand pressure; a
        widening discount reads as slack.
      </p>
      <div class="chart-wrap gauge-wrap"><canvas id="gaugeChart"></canvas></div>
      <div class="empty" id="gauge-empty" hidden>Demand gauge warming up — feed lands with the pipeline export.</div>
      <p slot="caption">
        Measures: AWS posted spot ask ÷ posted on-demand rate for the matching
        instance, pooled across regions (region count on hover) — one source
        until another venue discloses a comparable posted pair. Both legs are
        posted prices; the ratio is a posted-price spread, not a transaction
        record. Dashed guide = parity with the posted on-demand rate. Daily
        marks.
      </p>
    </ObsPanel>

    <!-- ══ Section 04 · DEPTH — executable offers: count + posted range ══ -->
    <ObsPanel num="04" kicker="Depth" title="Executable market depth" sampleId="depth-sample" windowId="depth-window">
      <p class="panel-sub" slot="sub">
        Offers you can launch against right now, across the executable
        marketplace venues: how many, and at what posted per-GPU range. Two
        panels, one axis each — count and price are different scales.
      </p>
      <div class="depth-legend">
        <span class="lg-swatch lg-band"><i></i>min–max posted range</span>
        <span class="lg-swatch lg-med"><i></i>median posted ask</span>
      </div>
      <div class="chart-wrap depth-wrap"><canvas id="depthPriceChart"></canvas></div>
      <div class="depth-count-lbl">launchable offers · count</div>
      <div class="chart-wrap depth-count-wrap"><canvas id="depthCountChart"></canvas></div>
      <div class="empty" id="depth-empty" hidden>Depth series warming up — feed lands with the pipeline export.</div>
      <p slot="caption">
        Measures: the number of launchable offers and their posted per-GPU $/hr
        range (min / median / max) across the executable marketplace venues
        (venue count on hover). Offers are list-asks you can launch against —
        listings, not transactions. Daily marks.
      </p>
    </ObsPanel>

    <!-- ══ Section 05 · DIVERGENCE — posted vs executable (signature chart) ══ -->
    <ObsPanel num="05" kicker="Divergence" title="Posted vs executable" sampleId="dvg-sample" windowId="dvg-window">
      <p class="panel-sub" slot="sub">
        The posted-rate reference steps when operators reprice their rate cards;
        the executable component moves daily with launchable marketplace offers.
        The shaded region is the gap between them.
      </p>
      <div class="dvg-legend">
        <span class="lg-swatch lg-posted"><i></i>posted-rate reference (steps)</span>
        <span class="lg-swatch lg-exec"><i></i>executable component (daily)</span>
        <span class="lg-swatch lg-gap"><i></i>gap</span>
      </div>
      <div class="dvg-scroll"><div id="dvg-chart"></div></div>
      <div class="empty" id="dvg-empty" hidden>Divergence series warming up — feed lands with the pipeline export.</div>
      <p slot="caption">
        Measures: the operator-equal median of posted on-demand asks across the
        rate panel (posted-rate reference; source count on hover) against the
        median posted ask across launchable marketplace offers (executable
        component; venue count on hover). Both legs are posted asks — the gap
        is a posted-price spread between the posted market and the market you
        can launch against right now. Daily marks.
      </p>
    </ObsPanel>

    <aside class="composite-note" role="note">
      <span class="kicker">In development</span>
      A composite supply–demand index built from these five instruments.
      Sections 03–05 currently render illustrative samples where badged; the
      composite publishes once the demand-gauge and depth feeds are live.
    </aside>

    <details class="method-details">
      <summary>Methodology</summary>
      <p class="method">
        <strong>Utilization</strong> is a measured metric — rented / total listed
        GPUs as one marketplace discloses them — and is never blended into
        availability. <strong>Breadth</strong>: each source's window rate is its
        share of capacity-probes that found stock, count-weighted within source;
        the headline is the share of venues with any stock, shown Fractional
        (any shape) and Cluster (full 8-GPU node). Each rolling point uses the
        venues present in that window, and dashed verticals flag where the panel
        set changed, so added venues don't read as a demand move.
        <strong>Demand gauge, depth, divergence</strong> are posted-price
        instruments: every input is a publicly posted ask; no series on this
        page represents transactions. Every trend labels the time window it
        draws.
      </p>
    </details>
  </section>

  <script>
    import Chart from 'chart.js/auto';
    import { lastValueLabelPlugin, LAST_VALUE_GUTTER } from '../data/chartExtras';

    const DEFAULT_CHIP = 'h100-sxm';
    // The charts run on independent timelines. Availability begins where the
    // full venue panel is live; utilization runs back to the first full 7-day
    // Vast window (raw data begins 2026-05-13; first ~6 days are ramp).
    const AVAIL_START = '2026-06-16';
    const UTIL_START  = '2026-05-19';
    const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const fmtDate = (iso) => { const p = String(iso).split('-'); return p.length === 3 ? `${MONTHS[+p[1]-1]} ${+p[2]}` : iso; };
    const catAxis = (ink) => ({
      ticks: { color: ink, autoSkip: true, maxTicksLimit: 7, maxRotation: 0,
               font: { family: 'IBM Plex Mono', size: 10 } },
      grid: { display: false },
    });
    const $ = (id) => document.getElementById(id);
    const pct = (v) => (v == null || isNaN(v)) ? '—' : (v * 100).toFixed(0) + '%';
    const ACCENT = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#ff9100';
    const css = (n, f) => (getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f);
    // chart-local series tokens (per-theme values set in <style>; validated
    // pair — see frontmatter comment)
    const seriesPosted = () => {
      const el = document.querySelector('.sd-page');
      return (el && getComputedStyle(el).getPropertyValue('--series-posted').trim()) || '#cc7d00';
    };
    const seriesExec = () => {
      const el = document.querySelector('.sd-page');
      return (el && getComputedStyle(el).getPropertyValue('--series-exec').trim()) || '#00829e';
    };

    // tiny CSV parser (numeric/clean fields only)
    async function loadCsv(path) {
      try {
        const r = await fetch(path, { cache: 'no-cache' });
        if (!r.ok) return null;
        const txt = (await r.text()).trim();
        if (!txt || txt.startsWith('<')) return null; // 200-with-HTML dev fallback
        const [head, ...lines] = txt.split(/\r?\n/);
        const cols = head.split(',');
        return lines.map((ln) => {
          const cells = ln.split(',');
          const o = {};
          cols.forEach((c, i) => (o[c] = cells[i]));
          return o;
        });
      } catch { return null; }
    }

    const num = (x) => (x === '' || x == null ? null : Number(x));
    let trendChart, utilChart, gaugeChart, depthPriceChart, depthCountChart;
    const state = {
      headline: null, sources: null, util: null,
      trend: {}, vtrend: {},
      gauge: {}, depth: {}, dvg: {},   // future-feed caches (per chip)
    };
    // fixed per-chip colors for the multi-chip overlays (sections 01/02 —
    // unchanged from the live page; readable on both themes).
    const CHIP_COLORS = {
      'h100-sxm': '#ff9100', 'a100-sxm-80gb': '#14b8a6', 'b200-sxm': '#8b5cf6',
      'h200-sxm': '#3b82f6', 'gb200': '#ec4899',
    };
    const colorFor = (slug) => CHIP_COLORS[slug] || ACCENT;

    function gradient(ctx, color) {
      const g = ctx.createLinearGradient(0, 0, 0, 260);
      g.addColorStop(0, color + '55');
      g.addColorStop(1, color + '05');
      return g;
    }

    const setWindow = (id, rows) => {
      const el = $(id);
      if (!el) return;
      if (!rows || !rows.length) { el.textContent = ''; return; }
      el.textContent = `${fmtDate(rows[0].as_of_date)} → ${fmtDate(rows[rows.length - 1].as_of_date)} · daily marks`;
    };

    // ════════════════════════════════════════════════════════════════════
    // PLACEHOLDER SAMPLE DATA — sections 03–05.
    //
    // The pipeline does not export these feeds yet (CSV contracts in
    // DESIGN.md at repo root). Until it does, a missing CSV falls back to
    // the deterministic samples below and the panel shows its
    // "Illustrative sample" badge. Flip SHOW_SAMPLE_WHEN_MISSING to false
    // at product launch to show the standard "warming up" empty state for
    // any chip whose feed hasn't landed.
    //
    // Every sample row carries the SAME column names as the future CSV, so
    // the renderers are already contract-shaped and switching to live data
    // is a pure pipeline change.
    // ════════════════════════════════════════════════════════════════════
    const SHOW_SAMPLE_WHEN_MISSING = true;

    const sampleDates = (n) => {
      const out = []; const today = new Date();
      for (let i = n - 1; i >= 0; i--) {
        const t = new Date(today); t.setDate(today.getDate() - i);
        out.push(t.toISOString().slice(0, 10));
      }
      return out;
    };

    // PLACEHOLDER: /data/spot_gauge_{chip}.csv — spot tightening toward OD.
    const SAMPLE_GAUGE_PCT = [
      0.34, 0.33, 0.35, 0.34, 0.36, 0.35, 0.33, 0.34, 0.36, 0.37,
      0.36, 0.38, 0.37, 0.39, 0.38, 0.40, 0.39, 0.41, 0.40, 0.42,
      0.41, 0.43, 0.42, 0.44, 0.43, 0.45, 0.44, 0.46,
    ];
    const sampleGauge = () => sampleDates(28).map((d, i) => ({
      as_of_date: d,
      spot_pct_of_od: String(SAMPLE_GAUGE_PCT[i]),
      spot_median_usd: (SAMPLE_GAUGE_PCT[i] * 6.0).toFixed(2),
      od_posted_usd: '6.00',
      n_regions: '6',
    }));

    // PLACEHOLDER: /data/executable_depth_{chip}.csv — drifting cheaper,
    // deepening offer count.
    const SAMPLE_DEPTH = {
      n:   [52, 54, 51, 55, 57, 54, 56, 58, 55, 57, 60, 58, 56, 59,
            61, 58, 60, 57, 59, 62, 60, 58, 61, 63, 60, 62, 59, 61],
      min: [1.79, 1.75, 1.79, 1.72, 1.75, 1.79, 1.75, 1.72, 1.69, 1.72,
            1.75, 1.72, 1.69, 1.65, 1.69, 1.72, 1.69, 1.65, 1.69, 1.65,
            1.62, 1.65, 1.69, 1.65, 1.62, 1.65, 1.62, 1.65],
      med: [2.38, 2.36, 2.39, 2.35, 2.33, 2.36, 2.32, 2.30, 2.33, 2.29,
            2.31, 2.28, 2.30, 2.26, 2.28, 2.25, 2.27, 2.24, 2.26, 2.22,
            2.24, 2.21, 2.23, 2.20, 2.22, 2.19, 2.21, 2.18],
      max: [3.45, 3.40, 3.48, 3.42, 3.38, 3.44, 3.40, 3.36, 3.42, 3.38,
            3.34, 3.40, 3.36, 3.32, 3.38, 3.34, 3.30, 3.36, 3.32, 3.28,
            3.34, 3.30, 3.26, 3.32, 3.28, 3.24, 3.30, 3.26],
    };
    const sampleDepth = () => sampleDates(28).map((d, i) => ({
      as_of_date: d,
      n_offers: String(SAMPLE_DEPTH.n[i]),
      n_venues: '4',
      price_min: String(SAMPLE_DEPTH.min[i]),
      price_median: String(SAMPLE_DEPTH.med[i]),
      price_max: String(SAMPLE_DEPTH.max[i]),
    }));

    // PLACEHOLDER: /data/posted_executable_{chip}.csv — posted reference
    // stepping down twice while the executable component breathes below it.
    const SAMPLE_DVG_EXEC = [
      2.41, 2.38, 2.44, 2.36, 2.40, 2.33, 2.37, 2.30, 2.35, 2.28,
      2.31, 2.24, 2.29, 2.21, 2.26, 2.18, 2.23, 2.15, 2.20, 2.12,
      2.16, 2.08, 2.13, 2.05, 2.10, 2.02, 2.06, 1.98,
    ];
    const sampleDvg = () => sampleDates(28).map((d, i) => ({
      as_of_date: d,
      posted_median_usd: i < 10 ? '2.99' : i < 19 ? '2.79' : '2.49',
      executable_median_usd: String(SAMPLE_DVG_EXEC[i]),
      n_posted_sources: '29',
      n_executable_venues: '4',
    }));
    // ════════════════════ end PLACEHOLDER block ═════════════════════════

    // ── shared chart plumbing (sections 01/02 — carried from live page) ──
    const markerPlugin = {
      id: 'changeMarkers',
      afterDraw(chart) {
        const marks = chart.$markers;
        if (!marks || !marks.length) return;
        const { ctx, chartArea, scales } = chart;
        if (!chartArea || !scales.x) return;
        ctx.save();
        ctx.strokeStyle = (css('--ink-faint', '#8e8a82')) + 'aa';
        ctx.lineWidth = 1; ctx.setLineDash([3, 3]);
        marks.forEach((i) => {
          const xp = scales.x.getPixelForValue(i);
          ctx.beginPath(); ctx.moveTo(xp, chartArea.top); ctx.lineTo(xp, chartArea.bottom); ctx.stroke();
        });
        ctx.restore();
      },
    };

    async function avTrend(chip) {
      if (state.trend[chip] === undefined) state.trend[chip] = await loadCsv(`/data/availability_index_trend_${chip}.csv`);
      return state.trend[chip] || [];
    }
    async function vuTrend(vast) {
      if (state.vtrend[vast] === undefined) state.vtrend[vast] = await loadCsv(`/data/vast_utilization_trend_${vast}.csv`);
      return state.vtrend[vast] || [];
    }
    async function futureCsv(cache, chip, path) {
      if (cache[chip] === undefined) cache[chip] = await loadCsv(path);
      return cache[chip];
    }
    const mapByDate = (rows, key) => { const m = {}; (rows || []).forEach((r) => (m[r.as_of_date] = num(r[key]))); return m; };
    const unionDates = (lists) => [...new Set(lists.flat().map((r) => r.as_of_date))].sort();

    const baseLineOpts = (ink, gridc) => ({
      responsive: true, maintainAspectRatio: false, interaction: { mode: 'index', intersect: false },
      scales: {
        y: { min: 0, max: 100, ticks: { color: ink, callback: (v) => v + '%', font: { family: 'IBM Plex Mono' } }, grid: { color: gridc } },
        x: catAxis(ink),
      },
      plugins: {
        legend: { display: true, position: 'top', align: 'end',
          labels: { color: ink, boxWidth: 10, boxHeight: 10, usePointStyle: true, pointStyle: 'line', font: { family: 'IBM Plex Mono', size: 11 } } },
        tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${c.parsed.y == null ? '—' : c.parsed.y.toFixed(0) + '%'}` } },
      },
    });

    function renderBand(chip) {
      const h = (state.headline || []).find((r) => r.chip_slug === chip && r.scope === 'global');
      const has = (v) => v !== '' && v != null;
      $('s-frac').textContent = (h && has(h.n_available)) ? `${h.n_available} / ${h.n_sources}` : '—';
      $('s-frac-sub').textContent = (h && has(h.breadth)) ? `${pct(num(h.breadth))} of venues · any shape · 7d` : 'any launchable shape · 7d';
