    // ── Section 05 · posted vs executable — house-style inline SVG ──────
    // Client-built because the data is a runtime CSV; follows the
    // TermCurveChart conventions (theme-token classes, direct end labels,
    // hover <title> depth disclosure). All .dvg-* styles are :global in the
    // page <style> — the SVG is injected via innerHTML, so Astro's scoped
    // attribute never lands on these nodes (house gotcha).
    function niceStep(raw) {
      const p = Math.pow(10, Math.floor(Math.log10(raw)));
      const m = raw / p;
      return (m <= 1 ? 1 : m <= 2 ? 2 : m <= 5 ? 5 : 10) * p;
    }
    function renderDivergence(rows, sample) {
      $('dvg-sample').hidden = !sample;
      const wrap = $('dvg-chart');
      const empty = $('dvg-empty');
      if (!rows || !rows.length) { wrap.innerHTML = ''; empty.hidden = false; $('dvg-window').textContent = ''; return; }
      empty.hidden = true;
      setWindow('dvg-window', rows);

      const posted = rows.map((r) => num(r.posted_median_usd));
      const exec = rows.map((r) => num(r.executable_median_usd));
      const N = rows.length;
      const W = 920, H = 330;
      const M = { top: 16, right: 170, bottom: 30, left: 46 };
      const x0 = M.left, x1 = W - M.right, yT = M.top, yB = H - M.bottom;
      const all = posted.concat(exec).filter((v) => v != null);
      let lo = Math.min(...all), hi = Math.max(...all);
      const padY = (hi - lo) * 0.18 || 0.5;
      lo = Math.max(0, lo - padY); hi += padY;
      const X = (i) => x0 + (x1 - x0) * (N === 1 ? 0.5 : i / (N - 1));
      const Y = (v) => yB - (yB - yT) * ((v - lo) / (hi - lo));
      const f1 = (n) => n.toFixed(1);

      // y grid — nice ticks
      const step = niceStep((hi - lo) / 4);
      const ticks = [];
      for (let v = Math.ceil(lo / step) * step; v <= hi + 1e-9; v += step) ticks.push(v);
      let g = '';
      ticks.forEach((v) => {
        g += `<line class="dvg-grid" x1="${x0}" x2="${x1}" y1="${f1(Y(v))}" y2="${f1(Y(v))}"/>`;
        g += `<text class="dvg-tick dvg-ytick" x="${x0 - 8}" y="${f1(Y(v) + 3.5)}">$${v.toFixed(2)}</text>`;
      });
      // x ticks — ~5 evenly spaced dates
      const nx = Math.min(5, N);
      for (let k = 0; k < nx; k++) {
        const i = Math.round((N - 1) * (nx === 1 ? 0 : k / (nx - 1)));
        g += `<text class="dvg-tick dvg-xtick" x="${f1(X(i))}" y="${yB + 16}">${fmtDate(rows[i].as_of_date)}</text>`;
      }

      // gap region: posted step-after forward, executable reversed
      let gap = `M${f1(X(0))},${f1(Y(posted[0]))}`;
      for (let i = 1; i < N; i++) gap += ` H${f1(X(i))} V${f1(Y(posted[i]))}`;
      for (let i = N - 1; i >= 0; i--) gap += ` L${f1(X(i))},${f1(Y(exec[i]))}`;
      gap += ' Z';

      // posted — step-after (rate cards reprice discretely)
      let pPath = `M${f1(X(0))},${f1(Y(posted[0]))}`;
      for (let i = 1; i < N; i++) pPath += ` H${f1(X(i))} V${f1(Y(posted[i]))}`;
      // executable — daily polyline
      const ePath = exec.map((v, i) => `${i ? 'L' : 'M'}${f1(X(i))},${f1(Y(v))}`).join(' ');

      // per-day hover bands with full depth disclosure
      let hits = '';
      const colW = (x1 - x0) / Math.max(1, N - 1);
      rows.forEach((r, i) => {
        const gapPct = posted[i] ? ((exec[i] - posted[i]) / posted[i]) * 100 : null;
        const t = `${r.as_of_date} · posted $${posted[i]?.toFixed(2)} (${r.n_posted_sources ?? '—'} sources) · ` +
                  `executable $${exec[i]?.toFixed(2)} (${r.n_executable_venues ?? '—'} venues)` +
                  (gapPct == null ? '' : ` · gap ${gapPct > 0 ? '+' : '−'}${Math.abs(gapPct).toFixed(0)}%`);
        const xa = i === 0 ? x0 : X(i) - colW / 2;
        const wdt = i === 0 || i === N - 1 ? colW / 2 : colW;
        hits += `<rect class="dvg-hit" x="${f1(xa)}" y="${yT}" width="${f1(wdt)}" height="${f1(yB - yT)}"><title>${t}</title></rect>`;
      });

      // direct end labels — colored swatch + ink text; collision-pushed
      const last = N - 1;
      const gapPctEnd = posted[last] ? ((exec[last] - posted[last]) / posted[last]) * 100 : null;
      const items = [
        { key: 'posted', yRaw: Y(posted[last]), txt: `Posted ${posted[last].toFixed(2)}`, extra: '' },
        { key: 'exec', yRaw: Y(exec[last]), txt: `Executable ${exec[last].toFixed(2)}`,
          extra: gapPctEnd == null ? '' : `${gapPctEnd > 0 ? '+' : '−'}${Math.abs(gapPctEnd).toFixed(0)}% vs posted` },
      ].sort((a, b) => a.yRaw - b.yRaw).map((it) => ({ ...it, y: it.yRaw }));
      if (items[1].y - items[0].y < 16) items[1].y = items[0].y + 16;
      let lbls = '';
      items.forEach((it) => {
        if (Math.abs(it.y - it.yRaw) > 2) lbls += `<line class="dvg-leader" x1="${x1 + 5}" y1="${f1(it.yRaw)}" x2="${x1 + 8}" y2="${f1(it.y)}"/>`;
        lbls += `<rect class="dvg-sw dvg-sw-${it.key}" x="${x1 + 10}" y="${f1(it.y - 4)}" width="8" height="3" rx="1.5"/>`;
        lbls += `<text class="dvg-lbl" x="${x1 + 22}" y="${f1(it.y + 1)}">${it.txt}` +
                (it.extra ? `<tspan class="dvg-lbl-dim" dx="5">${it.extra}</tspan>` : '') + `</text>`;
      });

      const aria = `Posted versus executable, ${rows[0].as_of_date} to ${rows[last].as_of_date}: ` +
        `the posted-rate reference (stepped line) against the executable component (daily line), USD per GPU-hour, with the gap shaded. ` +
        `Latest: posted $${posted[last].toFixed(2)}, executable $${exec[last].toFixed(2)}` +
        (gapPctEnd == null ? '.' : `, a ${Math.abs(gapPctEnd).toFixed(0)} percent posted-price spread.`);

      wrap.innerHTML =
        `<svg class="dvg-svg" viewBox="0 0 ${W} ${H}" role="img" aria-label="${aria}">` +
        g +
        `<path class="dvg-gap" d="${gap}"/>` +
        `<path class="dvg-posted" d="${pPath}"/>` +
        `<path class="dvg-exec" d="${ePath}"/>` +
        lbls + hits +
        `</svg>`;
    }

    // ── future-feed refresh (sections 03–05 follow the primary chip) ─────
    async function refreshFuture(chip) {
      const [g, d, v] = await Promise.all([
        futureCsv(state.gauge, chip, `/data/spot_gauge_${chip}.csv`),
        futureCsv(state.depth, chip, `/data/executable_depth_${chip}.csv`),
        futureCsv(state.dvg, chip, `/data/posted_executable_${chip}.csv`),
      ]);
      const pick = (rows, sampler) =>
        (rows && rows.length) ? { rows, sample: false }
        : SHOW_SAMPLE_WHEN_MISSING ? { rows: sampler(), sample: true }
        : { rows: null, sample: false };
      const G = pick(g, sampleGauge); renderGauge(G.rows, G.sample);
      const D = pick(d, sampleDepth); renderDepth(D.rows, D.sample);
      const V = pick(v, sampleDvg); renderDivergence(V.rows, V.sample);
    }

    async function renderAll(selected) {
      const primary = selected[0];
      renderBand(primary.slug);
      renderPanel(primary.slug);
      const trends = {}, vtrends = {};
      await Promise.all(selected.map(async (ch) => {
        trends[ch.slug] = (await avTrend(ch.slug)).filter((r) => r.confidence === 'ok' && r.as_of_date >= AVAIL_START);
        vtrends[ch.vast] = (await vuTrend(ch.vast)).filter((r) => r.as_of_date >= UTIL_START);
      }));
      const trimStart = (dates, maps) => {
        const firsts = maps.map((m) => dates.find((d) => m[d] != null)).filter(Boolean);
        if (!firsts.length) return dates;
        const start = firsts.reduce((a, b) => (a > b ? a : b));
        return dates.filter((d) => d >= start);
      };
      const aMaps = [];
      selected.forEach((ch) => {
        aMaps.push(mapByDate(trends[ch.slug], 'breadth_8x'));
        if (selected.length === 1) aMaps.push(mapByDate(trends[ch.slug], 'breadth'));
      });
      const aDates = trimStart(unionDates(Object.values(trends)), aMaps);
      const uMaps = selected.map((ch) => mapByDate(vtrends[ch.vast], 'utilization'));
      const uDates = trimStart(unionDates(Object.values(vtrends)), uMaps);
      renderTrend(selected, aDates, trends);
      renderUtil(selected, uDates, vtrends);
      await refreshFuture(primary.slug);
    }

    function init() {
      Promise.all([
        loadCsv('/data/availability_index_headline.csv'),
        loadCsv('/data/availability_index_sources.csv'),
        loadCsv('/data/vast_utilization.csv'),
      ]).then(([h, s, u]) => {
        state.headline = h; state.sources = s; state.util = u;
        const tabs = Array.from(document.querySelectorAll('.chip'));
        const meta = (slug) => { const t = tabs.find((x) => x.dataset.chip === slug); return t ? { slug, vast: t.dataset.vast, label: t.textContent.trim() } : null; };
        let selected = [DEFAULT_CHIP];
        const apply = () => {
          tabs.forEach((t) => {
            const on = selected.includes(t.dataset.chip);
            t.setAttribute('aria-selected', on ? 'true' : 'false');
            const c = on ? (CHIP_COLORS[t.dataset.chip] || '') : '';
            t.style.background = c; t.style.borderColor = c; t.style.color = on ? '#0b0c0e' : '';
          });
          renderAll(selected.map(meta).filter(Boolean));
        };
        tabs.forEach((t) => t.addEventListener('click', () => {
          const slug = t.dataset.chip;
          if (selected.includes(slug)) { if (selected.length > 1) selected = selected.filter((s2) => s2 !== slug); }
          else selected = [...selected, slug];
          apply();
        }));
        apply();
      });
    }
    init();
  </script>

  <style>
    .sd-page {
      max-width: 1040px;
      /* chart-local series tokens — one set per theme, validated pair (see
         frontmatter comment). Terminal values double as the default. */
      --series-posted: #cc7d00;
      --series-exec: #00829e;
    }
    :global(html[data-theme='editorial']) .sd-page {
      --series-posted: #a3660f;
      --series-exec: #0d96b6;
    }

    .kicker { font-family: var(--font-mono); font-size: .72rem; letter-spacing: .18em; color: var(--accent); margin-bottom: .4rem; }
    /* MI family tag — same treatment as the landing product card; no
       "not a citable reference rate" disclaimer here (page publishes no
       rate — measured utilization + availability breadth + posted-price
       spread instruments only). */
    .mi-tag {
      font-family: var(--font-mono);
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      padding: 2px 7px;
      margin-left: 8px;
      border: 1px solid var(--accent);
      color: var(--accent);
      white-space: nowrap;
      vertical-align: middle;
    }
    .sd-page h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); line-height: 1.05; margin: 0 0 .6rem; }
    .deck { max-width: 72ch; color: var(--ink-dim); line-height: 1.6; margin: 0 0 1.8rem; }
    .deck strong { color: var(--ink); font-weight: 600; }

    .chips { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
    .chip { font-family: var(--font-mono); font-size: .8rem; padding: .4rem .9rem; border: 1px solid var(--rule); background: transparent; color: var(--ink-dim); border-radius: 999px; cursor: pointer; transition: all .15s; }
    .chip:hover { color: var(--ink); border-color: var(--ink-faint); }
    .chip[aria-selected='true'] { background: var(--accent); color: #0b0c0e; border-color: var(--accent); font-weight: 600; }
    .chip-hint { font-family: var(--font-mono); font-size: .68rem; color: var(--ink-faint); align-self: center; margin-left: .3rem; }

    .panel-sub { font-size: .82rem; color: var(--ink-dim); margin: .35rem 0 0; max-width: 84ch; }
    .panel-sub strong { color: var(--ink); }

    .band { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: 12px; overflow: hidden; margin-bottom: 1.2rem; }
    /* THREE-STATE PLACEHOLDER: when #s-adv-cell unhides, the band grid grows
       to four columns — flip the template below at the same time. */
    /* .band { grid-template-columns: repeat(4, 1fr); } */
    .stat { background: var(--bg); padding: 1.1rem 1.2rem; display: flex; flex-direction: column; gap: .25rem; }
    .stat-lbl { font-size: .68rem; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-faint); }
    .stat-val { font-family: var(--font-mono); font-size: 2rem; font-weight: 600; line-height: 1; color: var(--ink); }
    .stat-clu .stat-val { color: var(--accent); }
    .stat-frac .stat-val { color: var(--ink-dim); }
    .stat-clu { background: color-mix(in srgb, var(--accent) 6%, var(--bg)); }
    .stat-sub { font-size: .68rem; color: var(--ink-faint); }

    .card-head { display: flex; justify-content: flex-end; margin-bottom: .5rem; }

    .chart-wrap { position: relative; height: 300px; }
    .util-wrap { height: 240px; }
    .gauge-wrap { height: 260px; }
    .depth-wrap { height: 240px; }
    .depth-count-wrap { height: 140px; }
    .depth-count-lbl { font-family: var(--font-mono); font-size: .66rem; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-faint); margin: .8rem 0 .2rem; }
    .empty { text-align: center; color: var(--ink-faint); font-size: .85rem; padding: 2rem 0; }

    .confbadge { font-family: var(--font-mono); font-size: .62rem; text-transform: uppercase; letter-spacing: .08em; padding: .25rem .6rem; border-radius: 999px; white-space: nowrap; }
    .confbadge.ok { background: color-mix(in srgb, #4cc4b0 18%, transparent); color: #4cc4b0; }
    .confbadge.thin { background: color-mix(in srgb, var(--accent) 16%, transparent); color: var(--accent); }

    /* THREE-STATE PLACEHOLDER legend — hidden until the v2 feed lands.
       Status-palette job: each state carries a swatch + label, never
       color-alone. */
    .state-legend { display: flex; gap: 1rem; flex-wrap: wrap; margin: .6rem 0 0; }
    .state-chip { font-family: var(--font-mono); font-size: .68rem; color: var(--ink-dim); display: inline-flex; align-items: center; gap: .35rem; }
    .state-chip i { width: .7rem; height: .7rem; border-radius: 2px; display: inline-block; }
    .st-in i { background: var(--pos); }
    .st-adv i { background: var(--accent); }
    .st-not i { background: transparent; border: 1px solid var(--ink-faint); }

    /* collapsed source panel inside section 02 */
    .panel-details { border-top: 1px solid var(--rule); margin-top: 1rem; }
    .panel-details > summary { list-style: none; cursor: pointer; padding: .9rem 0; display: grid; grid-template-columns: 1fr auto; grid-template-areas: 'main chev' 'sub chev'; align-items: center; gap: .15rem .8rem; }
    .panel-details > summary::-webkit-details-marker { display: none; }
    .sum-main { grid-area: main; font-family: var(--font-display); font-size: 1.05rem; display: flex; align-items: baseline; gap: .6rem; }
    .sum-count { font-family: var(--font-mono); font-size: .78rem; color: var(--accent); }
    .sum-sub { grid-area: sub; font-size: .78rem; color: var(--ink-dim); }
    .sum-chev { grid-area: chev; color: var(--ink-faint); font-size: 1rem; transition: transform .2s; }
    .panel-details[open] .sum-chev { transform: rotate(180deg); }
    .panel { display: flex; flex-direction: column; gap: .35rem; padding: .4rem 0 .8rem; }
    .row { display: grid; grid-template-columns: 9rem 1fr 2.6rem auto; align-items: center; gap: .7rem; font-family: var(--font-mono); font-size: .78rem; }
    .row-name { color: var(--ink-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .row-bar { height: .55rem; background: color-mix(in srgb, var(--ink) 8%, transparent); border-radius: 3px; overflow: hidden; }
    .row-fill { display: block; height: 100%; background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 55%, transparent), var(--accent)); border-radius: 3px; }
    .row-pct { text-align: right; color: var(--ink); }
    .bar-8x { font-size: .64rem; color: var(--ink-faint); }
    .foot { font-size: .72rem; color: var(--ink-faint); line-height: 1.5; margin: .4rem 0 0; }

    .util-grid { display: grid; grid-template-columns: 200px 1fr; gap: 1.5rem; align-items: center; }
    .util-now { display: flex; flex-direction: column; gap: .2rem; }
    /* Built via innerHTML in renderUtil — scoped styles never land on these
       nodes, so the rules must be :global (house gotcha). */
    :global(.util-big) { font-family: var(--font-mono); font-size: 3rem; font-weight: 600; line-height: 1; color: var(--accent); }
    :global(.util-now-lbl) { font-size: .72rem; color: var(--ink-dim); }
    :global(.util-list) { display: flex; flex-direction: column; gap: .55rem; margin-bottom: .5rem; }
    :global(.util-row) { display: flex; align-items: baseline; gap: .6rem; font-family: var(--font-mono); }
    :global(.util-row-chip) { font-size: .82rem; font-weight: 600; min-width: 3.2rem; }
    :global(.util-row-val) { font-size: 1.6rem; font-weight: 600; color: var(--ink); line-height: 1; }

    /* HTML legends for sections 04/05 — swatch carries identity, text wears
       ink tokens */
    .depth-legend, .dvg-legend { display: flex; gap: 1rem; flex-wrap: wrap; margin: .2rem 0 .6rem; }
    .lg-swatch { font-family: var(--font-mono); font-size: .68rem; color: var(--ink-dim); display: inline-flex; align-items: center; gap: .4rem; }
    .lg-swatch i { display: inline-block; border-radius: 2px; }
    .lg-band i { width: .85rem; height: .55rem; background: color-mix(in srgb, var(--series-exec) 22%, transparent); border: 1px solid color-mix(in srgb, var(--series-exec) 45%, transparent); }
    .lg-med i { width: .85rem; height: 3px; background: var(--series-exec); }
    .lg-posted i { width: .85rem; height: 3px; background: var(--series-posted); }
    .lg-exec i { width: .85rem; height: 3px; background: var(--series-exec); }
    .lg-gap i { width: .85rem; height: .55rem; background: color-mix(in srgb, var(--series-posted) 12%, transparent); border: 1px dashed color-mix(in srgb, var(--series-posted) 40%, transparent); }

    /* ── divergence SVG (injected via innerHTML → :global required) ────── */
    .dvg-scroll { overflow-x: auto; }
    :global(.dvg-svg) { display: block; width: 100%; min-width: 680px; height: auto; }
    :global(.dvg-grid) { stroke: var(--rule); stroke-width: 1; }
    :global(.dvg-tick) { font-family: var(--font-mono); font-size: 10.5px; fill: var(--ink-faint); font-variant-numeric: tabular-nums; }
    :global(.dvg-ytick) { text-anchor: end; }
    :global(.dvg-xtick) { text-anchor: middle; }
    :global(.dvg-gap) { fill: var(--series-posted); opacity: .1; stroke: none; }
    :global(.dvg-posted) { stroke: var(--series-posted); fill: none; stroke-width: 2; }
    :global(.dvg-exec) { stroke: var(--series-exec); fill: none; stroke-width: 2.25; stroke-linejoin: round; stroke-linecap: round; }
    :global(.dvg-hit) { fill: transparent; cursor: help; }
    :global(.dvg-leader) { stroke: var(--ink-faint); stroke-width: 1; }
    :global(.dvg-sw) { stroke: none; }
    :global(.dvg-sw-posted) { fill: var(--series-posted); }
    :global(.dvg-sw-exec) { fill: var(--series-exec); }
    :global(.dvg-lbl) { font-family: var(--font-mono); font-size: 11px; fill: var(--ink); font-variant-numeric: tabular-nums; }
    :global(.dvg-lbl-dim) { fill: var(--ink-faint); font-size: 10px; }

    .composite-note {
      margin: 0 0 1.6rem;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface);
      font-size: .82rem;
      color: var(--ink-dim);
      line-height: 1.6;
      max-width: 84ch;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .composite-note .kicker { margin-bottom: 0; }

    .method-details { border-top: 1px solid var(--rule); padding-top: 1rem; }
    .method-details > summary { list-style: none; cursor: pointer; font-family: var(--font-mono); font-size: .68rem; letter-spacing: .1em; text-transform: uppercase; color: var(--ink-faint); }
    .method-details > summary::-webkit-details-marker { display: none; }
    .method-details > summary::before { content: '▸ '; }
    .method-details[open] > summary::before { content: '▾ '; }
    .method { font-size: .76rem; color: var(--ink-faint); line-height: 1.65; max-width: 70ch; margin: .8rem 0 0; }
    .method strong { color: var(--ink-dim); font-weight: 600; }

    @media (max-width: 720px) {
      .band { grid-template-columns: repeat(2, 1fr); }
      .util-grid { grid-template-columns: 1fr; }
      .row { grid-template-columns: 7rem 1fr 2.4rem; }
      .bar-8x { display: none; }
    }
  </style>
</Base>
