---
import Base from '../layouts/Base.astro';
import { meta } from '../data/snapshot';
import { UTIL_CHIPS } from '../data/utilization';

const DEFAULT_CHIP = 'h100-sxm';
const utilMeta = (meta as any).utilization;
const windowDays = utilMeta?.window_days ?? 90;
const nSources = utilMeta?.n_sources ?? '—';
const seriesStart = utilMeta?.imu_series_start ?? '—';
---
<Base
  title="Market Utilization · CCIR"
  description="Implied GPU market utilization: how often each operator class shows zero posted availability for a chip, observed multiple times daily across named providers."
>
  <section class="wrap top vast-page utilization-page">
    <div class="kicker">IMPLIED MARKET UTILIZATION · BREADTH / DEPTH / LEVEL</div>
    <h1>Market Utilization</h1>
    <div class="ticker-strip" role="group" aria-label="Snapshot stats">
      <div class="tk-cell"><span class="tk-lbl">Window</span><span class="tk-val">{windowDays}d</span></div>
      <div class="tk-cell"><span class="tk-lbl">Sources</span><span class="tk-val">{nSources}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Series start</span><span class="tk-val">{seriesStart}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Cadence</span><span class="tk-val">~7–10 obs/day</span></div>
      <div class="tk-cell tk-status"><span class="tk-dot"></span><span class="tk-val">LIVE</span></div>
    </div>
    <p class="standfirst lede">
      The reference rates publish what operators <em>ask</em>. This page reads
      demand through inventory, with three instruments that answer different
      questions. <strong>Supply tightness</strong> (below): how widespread is
      tightness — a diffusion-style read across named providers, drawn at two
      bounds (any configuration vs full 8-GPU node, which is what “sold
      out” means in practice). <strong>Observable idle inventory</strong>:
      how deep is the available pool, counted in GPUs. The <strong>utilization
      level</strong> itself is only honest where machine state is observable —
      the machine-reconstructed series on the <a href="/basis">Vast
      overlay</a>. Breadth, depth, level — never blended into one number.
    </p>

    <div class="controls">
      <div class="control-row chip-row">
        <span class="control-label">Chip</span>
        <div class="pill-group" id="chip-pills" role="group" aria-label="Select a chip">
          {UTIL_CHIPS.map((c) => (
            <button type="button" class="pill" data-chip={c.id} data-default={c.id === DEFAULT_CHIP}>
              {c.label}
            </button>
          ))}
        </div>
      </div>
      <div class="control-row toggles-row">
        <label class="toggle">
          <input type="checkbox" id="class-toggle" />
          Show operator classes (any-config)
        </label>
      </div>
    </div>

    <div class="macro-strip" id="macro-strip" hidden>
      <div class="macro-cell">
        <span class="macro-val" id="macro-breadth">—</span>
        <span class="macro-lbl">providers with no full 8-GPU node posted (latest day)</span>
      </div>
      <div class="macro-cell">
        <span class="macro-val" id="macro-idle">—</span>
        <span class="macro-lbl" id="macro-idle-lbl">observable idle supply</span>
      </div>
      <div class="macro-cell">
        <span class="macro-val"><a href="/basis" id="macro-occ">—</a></span>
        <span class="macro-lbl">marketplace implied utilization → Vast overlay</span>
      </div>
    </div>

    <header class="legend-head">
      <span class="sec-kicker-label">SUPPLY TIGHTNESS · DIFFUSION ACROSS THE PANEL</span>
      <span class="sec-note">trailing {windowDays}d · daily · share of observed windows with zero posted availability · source-equal</span>
    </header>
    <div class="chart-wrap chart-wrap-hero">
      <div class="chart-status" id="chart-status">Loading…</div>
      <canvas id="chart" aria-label="Share of observed windows with zero posted availability, over time"></canvas>
    </div>

    <section class="legend-section">
      <header class="legend-head">
        <span class="sec-kicker-label">INVENTORY · OBSERVABLE IDLE GPUS, BY THE HOUR</span>
        <span class="sec-note">30d window · history begins 2026-05-28 · count-disclosing sources only · level, not a share</span>
      </header>
      <div class="chart-wrap">
        <div class="chart-status" id="inv-status">Loading…</div>
        <canvas id="inv-chart" aria-label="Observable idle GPUs through the day, with shape-weighted availability share"></canvas>
      </div>
    </section>

    <section class="legend-section">
      <header class="legend-head">
        <span class="sec-kicker-label">BREAKOUTS · LATEST DAY</span>
        <span class="sec-note" id="breakout-note">cells with fewer than 2 sources are not drawn</span>
      </header>
      <div class="table-wrap">
        <table class="data" id="breakout-table">
          <thead>
            <tr>
              <th>Scope</th>
              <th class="num">Sources</th>
              <th class="num">Sold out · any config</th>
              <th class="num">Sold out · 8× node</th>
            </tr>
          </thead>
          <tbody id="breakout-tbody"></tbody>
        </table>
      </div>
    </section>

    <section class="legend-section">
      <header class="legend-head">
        <span class="sec-kicker-label">PANEL · PER-SOURCE DETAIL</span>
        <span class="sec-note" id="source-note">—</span>
      </header>
      <div class="table-wrap">
        <table class="data" id="source-table">
          <thead>
            <tr>
              <th>Source</th>
              <th>Operator class</th>
              <th>Geo</th>
              <th>Signal</th>
              <th>Since</th>
              <th class="num">Sold out · any</th>
              <th class="num">Sold out · 8×</th>
            </tr>
          </thead>
          <tbody id="source-tbody"></tbody>
        </table>
      </div>
    </section>

    <p class="footnote">
      <strong>Supply tightness</strong> is a diffusion-style read — like a purchasing-managers index, it measures how WIDESPREAD tightness is, not its level; the utilization level lives where machine state is observable (Vast overlay). The underlying stockout rate = share of observed collection windows in
      which a source showed zero posted availability for the chip; the
      denominator is windows actually observed (~7–10 per day), never
      wall-clock hours. Each named source contributes one vote per day
      (source-equal mean), mirroring the operator-equal discipline of the
      reference rates. The <strong>8× node</strong> line counts only instance
      shapes of 8 GPUs or more; sources whose APIs disclose no such shape are
      excluded from it and ride the any-configuration line only. Utilization
      here is stratified by <strong>operator class</strong>; the reference
      rates are stratified per-SKU — an operator's class and a specific SKU's
      tier can differ. AWS's signal is a capacity <em>score</em> (Spot
      Placement Score), structurally more optimistic than bookable-stock
      checks — see the signal column. The <strong>inventory chart</strong> is a
      level, not a share: the sum of integer idle-GPU counts over a fixed panel
      of count-disclosing sources (most providers disclose no fleet total, so
      no panel-wide percentage exists). Its dashed companion is the
      shape-weighted availability share — an in-stock 8× listing counts eight
      times a 1× — weighted by listed SKU shapes, not fleet. History begins on
      the first day the availability panel collected intraday cycles; earlier
      periods are not backfilled.
    </p>
  </section>

  <script>
    import Chart from 'chart.js/auto';
    import 'chartjs-adapter-date-fns';
    import {
      fetchImplied, fetchSources, fetchMacro, fetchIntraday, operatorClassLabel,
      type UtilChipId, type ImpliedRow, type SourceRow, type MacroRow, type IntradayRow,
    } from '../data/utilization';
    import {
      lastValueLabelPlugin, ccirTimeScaleDefaults, LAST_VALUE_GUTTER,
    } from '../data/chartExtras';

    const DEFAULT_CHIP: UtilChipId = 'h100-sxm';
    const MIN_SOURCES = 2;

    const state = {
      chip: DEFAULT_CHIP as UtilChipId,
      show_classes: false,
      cache: new Map<UtilChipId, ImpliedRow[] | null>(),
      intradayCache: new Map<UtilChipId, IntradayRow[] | null>(),
      sources: null as SourceRow[] | null,
      macro: null as MacroRow[] | null,
    };

    const statusEl = document.getElementById('chart-status') as HTMLDivElement;
    const canvas = document.getElementById('chart') as HTMLCanvasElement;
    const classToggle = document.getElementById('class-toggle') as HTMLInputElement;
    const macroStrip = document.getElementById('macro-strip') as HTMLElement;
    const breakoutTbody = document.getElementById('breakout-tbody') as HTMLElement;
    const sourceTbody = document.getElementById('source-tbody') as HTMLElement;
    const sourceNote = document.getElementById('source-note') as HTMLElement;

    let chart: Chart<'line'> | null = null;

    function setStatus(msg: string | null) {
      statusEl.style.display = msg === null ? 'none' : 'flex';
      statusEl.textContent = msg ?? '';
    }

    function readToken(name: string): string {
      try {
        return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      } catch { return ''; }
    }

    const fmtDay = new Intl.DateTimeFormat('en-US', {
      timeZone: 'UTC', month: 'short', day: 'numeric',
    });
    const pct = (v: number | null) => (v === null ? '—' : (v * 100).toFixed(0) + '%');

    const CLASS_COLORS: Record<string, string> = {
      'tier:T1': '#a84040', 'tier:T2': '#2d6a94', 'tier:T3': '#2c8055', 'tier:T4': '#9467bd',
    };

    function renderChart(rows: ImpliedRow[]) {
      const globalRows = rows.filter((r) => r.scope === 'global');
      const accent = readToken('--accent') || '#d68a2a';
      const inkDim = readToken('--ink-dim') || '#9a9991';
      const ink = readToken('--ink') || '#e8e6e1';
      const grid = readToken('--vast-grid') || 'rgba(128,128,128,0.2)';
      const monoFont = { family: 'IBM Plex Mono, ui-monospace, Menlo, monospace', size: 11 };

      const datasets: any[] = [
        {
          label: 'Any configuration',
          data: globalRows.filter((r) => r.stockout_any_mean !== null)
            .map((r) => ({ x: r.date_ms, y: (r.stockout_any_mean as number) * 100 })),
          borderColor: accent, backgroundColor: accent,
          borderWidth: 2, pointRadius: 1.5, pointHoverRadius: 4, tension: 0, spanGaps: true,
        },
        {
          label: 'Full 8-GPU node',
          data: globalRows.filter((r) => r.stockout_8x_mean !== null)
            .map((r) => ({ x: r.date_ms, y: (r.stockout_8x_mean as number) * 100 })),
          borderColor: ink, backgroundColor: ink,
          borderWidth: 2, borderDash: [5, 4], pointRadius: 0, pointHoverRadius: 4,
          tension: 0, spanGaps: true,
        },
      ];

      if (state.show_classes) {
        for (const scope of ['tier:T1', 'tier:T2', 'tier:T3', 'tier:T4']) {
          const sr = rows.filter((r) => r.scope === scope
            && r.n_sources >= MIN_SOURCES && r.stockout_any_mean !== null);
          if (sr.length === 0) continue;
          datasets.push({
            label: operatorClassLabel(scope.slice(5)),
            data: sr.map((r) => ({ x: r.date_ms, y: (r.stockout_any_mean as number) * 100 })),
            borderColor: CLASS_COLORS[scope], backgroundColor: CLASS_COLORS[scope],
            borderWidth: 1, pointRadius: 0, pointHoverRadius: 3, tension: 0, spanGaps: true,
          });
        }
      }

      if (chart) chart.destroy();
      chart = new Chart(canvas, {
        type: 'line',
        data: { datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'nearest', axis: 'x', intersect: false },
          // Right gutter keeps end-of-line value labels from clipping.
          layout: { padding: { right: LAST_VALUE_GUTTER } },
          plugins: {
            legend: {
              // Two-line base view labels lines directly at their end points;
              // the legend returns when operator-class breakouts are toggled.
              display: datasets.length > 3, position: 'top',
              labels: { color: inkDim, font: monoFont, boxWidth: 18, boxHeight: 2 },
            },
            ccirLastValueLabel: {
              format: (v: number) => v.toFixed(0) + '%',
              datasetLabels: (ds: { label?: string }) => {
                if (ds.label === 'Any configuration') return 'any config';
                if (ds.label === 'Full 8-GPU node') return '8× node';
                return ds.label ?? null;
              },
            },
            tooltip: {
              displayColors: true,
              callbacks: {
                title: (items) => {
                  const x = items[0]?.parsed?.x;
                  return x ? fmtDay.format(x) : '';
                },
                label: (ctx) => `${ctx.dataset.label}: ${(ctx.parsed.y as number).toFixed(0)}% of observed windows sold out`,
              },
            },
          },
          scales: {
            x: ccirTimeScaleDefaults({
              color: inkDim, grid, font: monoFont, unit: 'day', title: 'Date (UTC)',
            }) as any,
            y: {
              min: 0, max: 100,
              title: { display: true, text: '% of observed windows sold out', color: inkDim, font: monoFont },
              ticks: { color: ink, font: monoFont, callback: (v) => v + '%' },
              grid: { color: grid },
              border: { color: grid },
            },
          },
        },
        plugins: [lastValueLabelPlugin],
      });
    }

    const invStatus = document.getElementById('inv-status') as HTMLElement;
    const invCanvas = document.getElementById('inv-chart') as HTMLCanvasElement;
    let invChart: Chart<'line'> | null = null;

    function setInvStatus(msg: string | null) {
      invStatus.style.display = msg === null ? 'none' : 'flex';
      invStatus.textContent = msg ?? '';
    }

    function renderInventory(rows: IntradayRow[]) {
      const accent = readToken('--accent') || '#d68a2a';
      const ink = readToken('--ink') || '#e8e6e1';
      const inkDim = readToken('--ink-dim') || '#9a9991';
      const grid = readToken('--vast-grid') || 'rgba(128,128,128,0.2)';
      const monoFont = { family: 'IBM Plex Mono, ui-monospace, Menlo, monospace', size: 11 };

      const idle = rows.filter((r) => r.idle_gpus_observable !== null)
        .map((r) => ({ x: r.hour_ms, y: r.idle_gpus_observable as number }));
      const gpuw = rows.filter((r) => r.gpuw_pct_source_equal !== null)
        .map((r) => ({ x: r.hour_ms, y: (r.gpuw_pct_source_equal as number) * 100 }));

      if (invChart) invChart.destroy();
      if (idle.length === 0 && gpuw.length === 0) {
        setInvStatus('No intraday inventory yet — accrues as collection cycles land.');
        return;
      }
      setInvStatus(null);
      // No end-of-line value badges here: the right-hand shape-weighted axis
      // (y2) occupies the gutter the badges would draw into. The top legend
      // carries the line identities instead.
      invChart = new Chart(invCanvas, {
        type: 'line',
        data: {
          datasets: [
            {
              label: 'Observable idle GPUs (count-disclosing panel)',
              data: idle, borderColor: accent, backgroundColor: accent,
              borderWidth: 2, pointRadius: 0, pointHoverRadius: 4,
              tension: 0, spanGaps: false, yAxisID: 'y',
            },
            {
              label: 'Shape-weighted availability (listed SKU shapes)',
              data: gpuw, borderColor: ink, backgroundColor: ink,
              borderWidth: 1.5, borderDash: [5, 4], pointRadius: 0, pointHoverRadius: 4,
              tension: 0, spanGaps: false, yAxisID: 'y2',
            },
          ],
        },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'nearest', axis: 'x', intersect: false },
          plugins: {
            legend: {
              display: true, position: 'top',
              labels: { color: inkDim, font: monoFont, boxWidth: 18, boxHeight: 2 },
            },
            tooltip: {
              callbacks: {
                label: (ctx) => ctx.dataset.yAxisID === 'y'
                  ? `${ctx.dataset.label}: ${(ctx.parsed.y as number).toLocaleString('en-US')} GPUs`
                  : `${ctx.dataset.label}: ${(ctx.parsed.y as number).toFixed(0)}%`,
              },
            },
          },
          scales: {
            x: ccirTimeScaleDefaults({
              color: inkDim, grid, font: monoFont, unit: 'day', title: 'Hour (UTC)',
            }) as any,
            y: {
              position: 'left', min: 0,
              title: { display: true, text: 'idle GPUs (level)', color: inkDim, font: monoFont },
              ticks: { color: ink, font: monoFont },
              grid: { color: grid },
              border: { color: grid },
            },
            y2: {
              position: 'right', min: 0, max: 100,
              title: { display: true, text: 'shape-weighted available %', color: inkDim, font: monoFont },
              ticks: { color: inkDim, font: monoFont, callback: (v) => v + '%' },
              grid: { drawOnChartArea: false },
              border: { color: grid },
            },
          },
        },
      });
    }

    function renderMacro() {
      const m = (state.macro ?? []).filter((r) => r.chip_slug === state.chip);
      if (m.length === 0) { macroStrip.hidden = true; return; }
      const latest = m[m.length - 1];
      macroStrip.hidden = false;
      (document.getElementById('macro-breadth') as HTMLElement).textContent =
        latest.n_providers_8x_pool > 0
          ? `${latest.n_providers_stocked_out_8x} of ${latest.n_providers_8x_pool}`
          : '—';
      const idleEl = document.getElementById('macro-idle') as HTMLElement;
      const idleLbl = document.getElementById('macro-idle-lbl') as HTMLElement;
      if (latest.idle_gpus_observable !== null) {
        idleEl.textContent = latest.idle_gpus_observable.toLocaleString('en-US') + ' GPUs';
        idleLbl.textContent = `observable idle supply (${latest.n_inventory_sources} count-disclosing sources)`;
      } else {
        idleEl.textContent = '—';
      }
      (document.getElementById('macro-occ') as HTMLElement).textContent =
        latest.marketplace_implied_utilization !== null
          ? pct(latest.marketplace_implied_utilization)
          : 'view';
    }

    function renderBreakouts(rows: ImpliedRow[]) {
      const dates = rows.map((r) => r.as_of_date).sort();
      const latest = dates[dates.length - 1];
      const day = rows.filter((r) => r.as_of_date === latest && r.scope !== 'global');
      const shown = day.filter((r) => r.n_sources >= MIN_SOURCES);
      breakoutTbody.innerHTML = shown.map((r) => {
        const label = r.scope.startsWith('tier:')
          ? operatorClassLabel(r.scope.slice(5))
          : r.scope.replace('geo:', 'Geography · ');
        const e8 = r.n_sources_8x > 0 ? pct(r.stockout_8x_mean) : '<span class="dim">—</span>';
        return '<tr>' +
          `<td>${label}</td>` +
          `<td class="num">${r.n_sources}</td>` +
          `<td class="num">${pct(r.stockout_any_mean)}</td>` +
          `<td class="num">${e8}</td>` +
        '</tr>';
      }).join('') || '<tr><td colspan="4" class="dim">No breakout cell reaches the 2-source floor yet.</td></tr>';
    }

    function renderSources() {
      const rows = (state.sources ?? []).filter((r) => r.chip_slug === state.chip);
      sourceNote.textContent = `${rows.length} sources · ${state.chip}`;
      sourceTbody.innerHTML = rows.map((r) => {
        const e8 = r.shape_disclosed
          ? `<td class="num">${pct(r.stockout_8x)}</td>`
          : '<td class="num dim">no shape ≥8 disclosed</td>';
        const sig = r.signal_type === 'score'
          ? '<span class="sig-warn">score</span>' : r.signal_type;
        return '<tr>' +
          `<td><code>${r.source}</code></td>` +
          `<td>${r.operator_class}</td>` +
          `<td>${r.geo_buckets}</td>` +
          `<td>${sig}</td>` +
          `<td>${r.series_start}</td>` +
          `<td class="num">${pct(r.stockout_any)}</td>` +
          e8 +
        '</tr>';
      }).join('');
    }

    async function refresh() {
      setStatus('Loading…');
      if (!state.cache.has(state.chip)) {
        try {
          state.cache.set(state.chip, await fetchImplied(state.chip));
        } catch { state.cache.set(state.chip, null); }
      }
      if (!state.intradayCache.has(state.chip)) {
        try {
          state.intradayCache.set(state.chip, await fetchIntraday(state.chip));
        } catch { state.intradayCache.set(state.chip, null); }
      }
      if (state.sources === null) {
        try { state.sources = await fetchSources(); } catch { state.sources = []; }
      }
      if (state.macro === null) {
        try { state.macro = await fetchMacro(); } catch { state.macro = []; }
      }

      const rows = state.cache.get(state.chip) ?? [];
      if (rows.length === 0) {
        setStatus(`No data for ${state.chip} yet — history accrues as the daily pipeline runs.`);
        if (chart) { chart.destroy(); chart = null; }
        breakoutTbody.innerHTML = '';
        sourceTbody.innerHTML = '';
        macroStrip.hidden = true;
        return;
      }
      setStatus(null);
      renderChart(rows);
      renderInventory(state.intradayCache.get(state.chip) ?? []);
      renderMacro();
      renderBreakouts(rows);
      renderSources();
    }

    function syncPills() {
      document.querySelectorAll<HTMLButtonElement>('#chip-pills .pill').forEach((p) => {
        p.classList.toggle('on', p.dataset.chip === state.chip);
      });
    }

    document.getElementById('chip-pills')!.addEventListener('click', (ev) => {
      const pill = (ev.target as HTMLElement).closest<HTMLButtonElement>('.pill');
      if (!pill || !pill.dataset.chip) return;
      state.chip = pill.dataset.chip as UtilChipId;
      syncPills();
      refresh();
    });
    classToggle.addEventListener('change', () => {
      state.show_classes = classToggle.checked;
      refresh();
    });

    syncPills();
    refresh();
  </script>

  <style>
    /* Reuses the .vast-page chrome (see marketplace.astro for the canonical
       copy of this block — Astro styles are per-route, so the shared chrome
       is inlined per page by convention). */
    .vast-page.top { padding-top: 24px; }
    .vast-page > .kicker { color: var(--accent); letter-spacing: 0.14em; margin-bottom: 4px; }
    .vast-page h1 {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      margin: 0 0 10px;
      letter-spacing: -0.01em;
      line-height: 1.1;
    }
    .vast-page .ticker-strip {
      display: flex; flex-wrap: wrap; align-items: stretch;
      border: 1px solid var(--rule-2); background: var(--vast-panel-bg);
      margin: 0 0 18px; font-family: var(--font-mono);
    }
    .vast-page .tk-cell {
      display: flex; align-items: baseline; gap: 8px;
      padding: 7px 14px; border-right: 1px solid var(--rule); flex: 0 0 auto;
    }
    .vast-page .tk-cell:last-child { border-right: 0; }
    .vast-page .tk-lbl {
      font-size: calc(var(--fs-xs) - 1px); color: var(--ink-dim);
      text-transform: uppercase; letter-spacing: 0.10em; font-weight: var(--weight-strong);
    }
    .vast-page .tk-val {
      font-size: var(--fs-sm); color: var(--ink);
      font-variant-numeric: tabular-nums; font-weight: var(--weight-strong);
    }
    .vast-page .tk-status { margin-left: auto; gap: 6px; }
    .vast-page .tk-status .tk-val { color: var(--pos); letter-spacing: 0.10em; }
    .vast-page .tk-dot {
      width: 7px; height: 7px; background: var(--pos);
      box-shadow: 0 0 6px var(--pos); display: inline-block;
      border-radius: 50%; animation: vast-pulse 2.4s ease-in-out infinite;
    }
    @keyframes vast-pulse { 0%, 100% { opacity: 1; } 50% { opacity: 0.35; } }
    .vast-page .lede { max-width: 80ch; margin: 4px 0 22px; }
    .vast-page .lede a { color: var(--accent); }
    .vast-page .controls {
      background: var(--vast-panel-bg); border: 1px solid var(--rule);
      padding: 12px 14px; margin-bottom: 18px;
      display: flex; flex-direction: column; gap: 10px;
    }
    .vast-page .control-row { display: flex; align-items: center; gap: 14px; flex-wrap: wrap; }
    .vast-page .control-label {
      font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--ink-dim);
      text-transform: uppercase; letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong); min-width: 56px;
    }
    .vast-page .pill-group { display: flex; flex-wrap: wrap; gap: 5px; }
    .vast-page .pill {
