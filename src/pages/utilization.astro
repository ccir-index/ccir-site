---
import Base from '../layouts/Base.astro';

// Preview route for the reframed supply page (Availability Index + measured Vast
// utilization). Final route/name TBD. Reads the export_availability_index CSVs
// from /data/ client-side; degrades to a "warming up" state if absent.
const CHIPS = [
  { slug: 'h100-sxm',      label: 'H100',  vast: 'h100-sxm' },
  { slug: 'h200-sxm',      label: 'H200',  vast: 'h200-sxm' },
  { slug: 'b200-sxm',      label: 'B200',  vast: 'b200-sxm' },
  { slug: 'a100-sxm-80gb', label: 'A100',  vast: 'a100-sxm' },
  { slug: 'gb200',         label: 'GB200', vast: 'gb200' },
];
const DEFAULT_CHIP = 'h100-sxm';
---
<Base
  title="Availability & Utilization · CCIR"
  description="CCIR Availability Index — the share of hourly capacity-probes across a fixed panel of genuine-capacity GPU sources that found launchable stock, with measured marketplace utilization."
>
  <section class="wrap ai-page">
    <div class="kicker">CCIR · SUPPLY OBSERVATORY</div>
    <h1>Availability &amp; Utilization</h1>
    <p class="deck">
      Two lenses on GPU supply. <strong>Availability</strong> — across a fixed,
      disclosed panel of genuine-capacity sources, what share of probes found
      launchable stock. <strong>Utilization</strong> — of the capacity the one
      marketplace we can measure actually lists, how much is rented.
    </p>

    <!-- chip selector -->
    <div class="chips" role="tablist" aria-label="GPU model">
      {CHIPS.map((c) => (
        <button class="chip" role="tab" data-chip={c.slug} data-vast={c.vast}
                aria-selected={c.slug === DEFAULT_CHIP ? 'true' : 'false'}>{c.label}</button>
      ))}
      <span class="chip-hint">select one or more to compare</span>
    </div>

    <!-- headline stat band -->
    <div class="band" id="band">
      <div class="stat stat-frac">
        <span class="stat-lbl">Fractional availability</span>
        <span class="stat-val" id="s-frac">—</span>
        <span class="stat-sub">any launchable shape · 7d</span>
      </div>
      <div class="stat stat-clu">
        <span class="stat-lbl">Cluster (8×) availability</span>
        <span class="stat-val" id="s-clu">—</span>
        <span class="stat-sub">full 8-GPU node · 7d</span>
      </div>
      <div class="stat">
        <span class="stat-lbl">Panel sources</span>
        <span class="stat-val" id="s-srcs">—</span>
        <span class="stat-sub" id="s-srcs-sub">venues probed</span>
      </div>
    </div>

    <!-- primary: availability over time -->
    <div class="card chart-card">
      <div class="card-head">
        <div>
          <h2>Availability over time</h2>
          <p class="card-sub">Rolling 7-day source-equal median, from the first market-read day (panel ≥ 3 sources). <span id="trend-mode">Cluster (8×) vs Fractional.</span></p>
        </div>
        <div class="confbadge" id="confbadge"></div>
      </div>
      <div class="chart-wrap"><canvas id="trendChart"></canvas></div>
      <div class="empty" id="trend-empty" hidden>Series warming up — first publish lands on the next daily build.</div>
    </div>

    <!-- source panel (collapsed by default) -->
    <details class="card panel-card">
      <summary>
        <span class="sum-main"><h2>The panel</h2><span class="sum-count" id="panel-count"></span></span>
        <span class="sum-sub">Each genuine-capacity source, one vote · 7-day availability</span>
        <span class="sum-chev" aria-hidden="true">▾</span>
      </summary>
      <div class="panel" id="panel"></div>
      <p class="foot">Excludes catalog-eligibility (Azure) and probabilistic-score (AWS) sources from the headline. Resellers that duplicate a directly-probed operator are deduped. Sources below the minimum observed-cycle threshold are held out until they accumulate probes.</p>
    </details>

    <!-- measured utilization (Vast) -->
    <div class="card util-card">
      <div class="card-head">
        <div>
          <h2>Measured utilization <span class="tag">one marketplace source</span></h2>
          <p class="card-sub">Vast.ai — the only marketplace that discloses rented / total. Rolling 7-day occupancy, denominator fixed to each window's median listed capacity.</p>
        </div>
      </div>
      <div class="util-grid">
        <div class="util-now">
          <span class="util-big" id="u-now">—</span>
          <span class="util-now-lbl" id="u-now-lbl">trailing 7-day occupancy</span>
        </div>
        <div class="chart-wrap util-wrap"><canvas id="utilChart"></canvas></div>
      </div>
      <div class="empty" id="util-empty" hidden>Vast occupancy warming up.</div>
    </div>

    <details class="method-details">
      <summary>Methodology</summary>
      <p class="method">
        Each source's window rate is its share of hourly capacity-probes that
        found stock, count-weighted within source; the headline is the
        source-equal <em>median</em> across the panel (manipulation-resistant),
        shown as Fractional (any shape) and Cluster (full 8-GPU node). Utilization
        is a separate measured depth metric — never blended into availability.
      </p>
    </details>
  </section>

  <script>
    import Chart from 'chart.js/auto';

    const DEFAULT_CHIP = 'h100-sxm';
    // Plain category x-axis with pre-formatted date labels — no time adapter, so
    // nothing to break. autoSkip thins the labels as the range grows.
    const MONTHS = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const fmtDate = (iso) => { const p = String(iso).split('-'); return p.length === 3 ? `${MONTHS[+p[1]-1]} ${+p[2]}` : iso; };
    const catAxis = (ink) => ({
      ticks: { color: ink, autoSkip: true, maxTicksLimit: 7, maxRotation: 0,
               font: { family: 'IBM Plex Mono', size: 10 } },
      grid: { display: false },
    });
    const $ = (id) => document.getElementById(id);
    const pct = (v) => (v == null || isNaN(v)) ? '—' : (v * 100).toFixed(0) + '%';
    const ACCENT = getComputedStyle(document.documentElement).getPropertyValue('--accent').trim() || '#ff9100';
    const TEAL = '#4cc4b0';
    const css = (n, f) => (getComputedStyle(document.documentElement).getPropertyValue(n).trim() || f);

    // tiny CSV parser (numeric/clean fields only)
    async function loadCsv(path) {
      try {
        const r = await fetch(path, { cache: 'no-cache' });
        if (!r.ok) return null;
        const txt = (await r.text()).trim();
        if (!txt) return null;
        const [head, ...lines] = txt.split(/\r?\n/);
        const cols = head.split(',');
        return lines.map((ln) => {
          const cells = ln.split(',');
          const o = {};
          cols.forEach((c, i) => (o[c] = cells[i]));
          return o;
        });
      } catch { return null; }
    }

    const num = (x) => (x === '' || x == null ? null : Number(x));
    let trendChart, utilChart;
    const state = { headline: null, sources: null, util: null, trend: {}, vtrend: {} };
    // fixed per-chip colors for the multi-chip overlays (readable on both themes).
    const CHIP_COLORS = {
      'h100-sxm': '#ff9100', 'a100-sxm-80gb': '#14b8a6', 'b200-sxm': '#8b5cf6',
      'h200-sxm': '#3b82f6', 'gb200': '#ec4899',
    };
    const colorFor = (slug) => CHIP_COLORS[slug] || ACCENT;

    function gradient(ctx, color) {
      const g = ctx.createLinearGradient(0, 0, 0, 260);
      g.addColorStop(0, color + '55');
      g.addColorStop(1, color + '05');
      return g;
    }

    // lazy-load + cache a per-chip trend CSV
    async function avTrend(chip) {
      if (state.trend[chip] === undefined) state.trend[chip] = await loadCsv(`/data/availability_index_trend_${chip}.csv`);
      return state.trend[chip] || [];
    }
    async function vuTrend(vast) {
      if (state.vtrend[vast] === undefined) state.vtrend[vast] = await loadCsv(`/data/vast_utilization_trend_${vast}.csv`);
      return state.vtrend[vast] || [];
    }
    const mapByDate = (rows, key) => { const m = {}; (rows || []).forEach((r) => (m[r.as_of_date] = num(r[key]))); return m; };
    const unionDates = (lists) => [...new Set(lists.flat().map((r) => r.as_of_date))].sort();

    const baseLineOpts = (ink, gridc) => ({
      responsive: true, maintainAspectRatio: false, interaction: { mode: 'index', intersect: false },
      scales: {
        y: { min: 0, max: 100, ticks: { color: ink, callback: (v) => v + '%', font: { family: 'IBM Plex Mono' } }, grid: { color: gridc } },
        x: catAxis(ink),
      },
      plugins: {
        legend: { display: true, position: 'top', align: 'end',
          labels: { color: ink, boxWidth: 10, boxHeight: 10, usePointStyle: true, pointStyle: 'line', font: { family: 'IBM Plex Mono', size: 11 } } },
        tooltip: { callbacks: { label: (c) => `${c.dataset.label}: ${c.parsed.y == null ? '—' : c.parsed.y.toFixed(0) + '%'}` } },
      },
    });

    function renderBand(chip) {
      const h = (state.headline || []).find((r) => r.chip_slug === chip && r.scope === 'global');
      $('s-frac').textContent = h ? pct(num(h.pct_available_median)) : '—';
      $('s-clu').textContent = h ? pct(num(h.pct_available_8x_median)) : '—';
      $('s-srcs').textContent = h ? h.n_sources : '—';
      $('s-srcs-sub').textContent = h && Number(h.n_sources_thin) > 0
        ? `${h.n_sources_thin} warming up` : 'venues probed';
      const badge = $('confbadge');
      if (h) { badge.textContent = h.confidence === 'thin' ? 'thin panel' : 'market read';
               badge.className = 'confbadge ' + (h.confidence === 'thin' ? 'thin' : 'ok'); }
      else badge.textContent = '';
    }

    function renderPanel(chip) {
      const rows = (state.sources || []).filter((r) => r.chip_slug === chip)
        .sort((a, b) => num(b.pct_available) - num(a.pct_available));
      const el = $('panel');
      const cnt = $('panel-count'); if (cnt) cnt.textContent = rows.length ? `${rows.length} sources` : '';
      if (!rows.length) { el.innerHTML = '<div class="empty">Panel warming up.</div>'; return; }
      el.innerHTML = rows.map((r) => {
        const p = num(r.pct_available) * 100;
        const name = r.source.startsWith('shadeform:') ? r.source.slice(10) + ' ·sf' : r.source.replace(/_caps|_stocks/, '');
        const c8 = r.pct_available_8x === '' || r.pct_available_8x == null ? '' : `<span class="bar-8x">8× ${(num(r.pct_available_8x)*100).toFixed(0)}%</span>`;
        return `<div class="row">
          <span class="row-name" title="${r.signal_type}">${name}</span>
          <span class="row-bar"><span class="row-fill" style="width:${p.toFixed(0)}%"></span></span>
          <span class="row-pct">${p.toFixed(0)}%</span>${c8}</div>`;
      }).join('');
    }

    function renderTrend(selected, dates, trends) {
      const empty = $('trend-empty');
      const ctx = $('trendChart').getContext('2d');
      if (!dates.length) { empty.hidden = false; if (trendChart) { trendChart.destroy(); trendChart = null; } return; }
      empty.hidden = true;
      const labels = dates.map(fmtDate);
      const ink = css('--ink-dim', '#9a9991');
      const grid = css('--rule', '#2a2a2a') + '44';
      const series = (rows, key) => { const m = mapByDate(rows, key); return dates.map((d) => (m[d] == null ? null : m[d] * 100)); };
      let datasets;
      if (selected.length === 1) {
        const c = colorFor(selected[0].slug);
        datasets = [
          { label: 'Fractional', data: series(trends[selected[0].slug], 'pct_available_median'), borderColor: css('--ink-faint', '#8e8a82'), borderWidth: 1.25, borderDash: [4, 3], fill: false, tension: 0.3, pointRadius: 0, pointHoverRadius: 3, order: 2 },
          { label: 'Cluster (8×)', data: series(trends[selected[0].slug], 'pct_available_8x_median'), borderColor: c, backgroundColor: gradient(ctx, c), borderWidth: 2.75, fill: true, tension: 0.3, pointRadius: 0, pointHoverRadius: 5, order: 1 },
        ];
        $('trend-mode').textContent = 'Cluster (8×) vs Fractional.';
      } else {
        datasets = selected.map((ch) => ({
          label: ch.label, data: series(trends[ch.slug], 'pct_available_8x_median'),
          borderColor: colorFor(ch.slug), borderWidth: 2.25, fill: false, tension: 0.3, pointRadius: 0, pointHoverRadius: 4,
        }));
        $('trend-mode').textContent = 'Cluster (8×) availability by chip.';
      }
      const cfg = { type: 'line', data: { labels, datasets }, options: baseLineOpts(ink, grid) };
      try {
        if (trendChart) { trendChart.data = cfg.data; trendChart.update(); }
        else trendChart = new Chart(ctx, cfg);
      } catch (err) { empty.hidden = false; empty.textContent = 'CHART ERR: ' + (err && err.message ? err.message : String(err)); }
    }

    function renderUtil(selected, dates, vtrends) {
      const primary = selected[0];
      const u = (state.util || []).find((r) => r.chip_slug === primary.vast);
      $('u-now').textContent = u ? pct(num(u.utilization)) : '—';
      $('u-now-lbl').textContent = `${primary.label} · trailing 7-day occupancy`;
      const empty = $('util-empty');
      const ctx = $('utilChart').getContext('2d');
      const anyData = selected.some((ch) => (vtrends[ch.vast] || []).length);
      if (!anyData || !dates.length) { empty.hidden = false; if (utilChart) { utilChart.destroy(); utilChart = null; } return; }
      empty.hidden = true;
      const labels = dates.map(fmtDate);
      const ink = css('--ink-dim', '#9a9991');
      const single = selected.length === 1;
      const datasets = selected.map((ch) => {
        const m = mapByDate(vtrends[ch.vast], 'utilization');
        const c = colorFor(ch.slug);
        return { label: ch.label, data: dates.map((d) => (m[d] == null ? null : m[d] * 100)),
          borderColor: c, backgroundColor: single ? gradient(ctx, c) : 'transparent', borderWidth: 2.5, fill: single, tension: 0.3, pointRadius: 0, pointHoverRadius: 5, spanGaps: false };
      });
      const cfg = { type: 'line', data: { labels, datasets }, options: baseLineOpts(ink, css('--rule', '#2a2a2a') + '33') };
      try {
        if (utilChart) { utilChart.data = cfg.data; utilChart.update(); }
        else utilChart = new Chart(ctx, cfg);
      } catch (err) { empty.hidden = false; empty.textContent = 'CHART ERR: ' + (err && err.message ? err.message : String(err)); }
    }

    async function renderAll(selected) {
      const primary = selected[0];
      renderBand(primary.slug);
      renderPanel(primary.slug);
      const trends = {}, vtrends = {};
      await Promise.all(selected.map(async (ch) => {
        // Only plot days the panel is a market read (confidence=ok, ≥3 sources).
        // The early cold-start days are single-source and whipsaw — the data
        // flags them thin; we suppress them rather than draw an unreliable line.
        trends[ch.slug] = (await avTrend(ch.slug)).filter((r) => r.confidence === 'ok');
        vtrends[ch.vast] = await vuTrend(ch.vast);
      }));
      let dates = unionDates([...Object.values(trends), ...Object.values(vtrends)]);
      // Trim the left edge to the first day where every displayed series has data
      // ("full data"), so there's no empty/partial leading region. Both charts
      // share this start, so they stay vertically aligned.
      const maps = [];
      selected.forEach((ch) => {
        maps.push(mapByDate(trends[ch.slug], 'pct_available_8x_median'));
        if (selected.length === 1) maps.push(mapByDate(trends[ch.slug], 'pct_available_median'));
        maps.push(mapByDate(vtrends[ch.vast], 'utilization'));
      });
      const firsts = maps.map((m) => dates.find((d) => m[d] != null)).filter(Boolean);
      if (firsts.length) { const start = firsts.reduce((a, b) => (a > b ? a : b)); dates = dates.filter((d) => d >= start); }
      renderTrend(selected, dates, trends);
      renderUtil(selected, dates, vtrends);
    }

    function init() {
      Promise.all([
        loadCsv('/data/availability_index_headline.csv'),
        loadCsv('/data/availability_index_sources.csv'),
        loadCsv('/data/vast_utilization.csv'),
      ]).then(([h, s, u]) => {
        state.headline = h; state.sources = s; state.util = u;
        const tabs = Array.from(document.querySelectorAll('.chip'));
        const meta = (slug) => { const t = tabs.find((x) => x.dataset.chip === slug); return t ? { slug, vast: t.dataset.vast, label: t.textContent.trim() } : null; };
        let selected = [DEFAULT_CHIP];
        const apply = () => {
          tabs.forEach((t) => {
            const on = selected.includes(t.dataset.chip);
            t.setAttribute('aria-selected', on ? 'true' : 'false');
            const c = on ? (CHIP_COLORS[t.dataset.chip] || '') : '';
            t.style.background = c; t.style.borderColor = c; t.style.color = on ? '#0b0c0e' : '';
          });
          renderAll(selected.map(meta).filter(Boolean));
        };
        tabs.forEach((t) => t.addEventListener('click', () => {
          const slug = t.dataset.chip;
          if (selected.includes(slug)) { if (selected.length > 1) selected = selected.filter((s2) => s2 !== slug); }
          else selected = [...selected, slug];
          apply();
        }));
        apply();
      });
    }
    init();
  </script>

  <style>
    .ai-page { max-width: 1040px; }
    .kicker { font-family: var(--font-mono); font-size: .72rem; letter-spacing: .18em; color: var(--accent); margin-bottom: .4rem; }
    .ai-page h1 { font-family: var(--font-display); font-size: clamp(2rem, 5vw, 3rem); line-height: 1.05; margin: 0 0 .6rem; }
    .deck { max-width: 64ch; color: var(--ink-dim); line-height: 1.6; margin: 0 0 1.8rem; }
    .deck strong { color: var(--ink); font-weight: 600; }

    .chips { display: flex; gap: .4rem; flex-wrap: wrap; margin-bottom: 1.4rem; }
    .chip { font-family: var(--font-mono); font-size: .8rem; padding: .4rem .9rem; border: 1px solid var(--rule); background: transparent; color: var(--ink-dim); border-radius: 999px; cursor: pointer; transition: all .15s; }
    .chip:hover { color: var(--ink); border-color: var(--ink-faint); }
    .chip[aria-selected='true'] { background: var(--accent); color: #0b0c0e; border-color: var(--accent); font-weight: 600; }
    .chip-hint { font-family: var(--font-mono); font-size: .68rem; color: var(--ink-faint); align-self: center; margin-left: .3rem; }

    .band { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--rule); border: 1px solid var(--rule); border-radius: 12px; overflow: hidden; margin-bottom: 1.6rem; }
    .stat { background: var(--bg); padding: 1.1rem 1.2rem; display: flex; flex-direction: column; gap: .25rem; }
    .stat-lbl { font-size: .68rem; text-transform: uppercase; letter-spacing: .08em; color: var(--ink-faint); }
    .stat-val { font-family: var(--font-mono); font-size: 2rem; font-weight: 600; line-height: 1; color: var(--ink); }
    .stat-clu .stat-val { color: var(--accent); }
    .stat-frac .stat-val { color: var(--ink-dim); }
    .stat-clu { background: color-mix(in srgb, var(--accent) 6%, var(--bg)); }
    .stat-sub { font-size: .68rem; color: var(--ink-faint); }

    .card { border: 1px solid var(--rule); border-radius: 12px; padding: 1.4rem; margin-bottom: 1.6rem; background: color-mix(in srgb, var(--ink) 2%, transparent); }
    .card-head { display: flex; justify-content: space-between; align-items: flex-start; gap: 1rem; margin-bottom: 1rem; }
    .card h2 { font-family: var(--font-display); font-size: 1.3rem; margin: 0 0 .2rem; }
    .card-sub { font-size: .82rem; color: var(--ink-dim); margin: 0; }
    .tag { font-family: var(--font-mono); font-size: .6rem; text-transform: uppercase; letter-spacing: .1em; background: color-mix(in srgb, var(--accent) 16%, transparent); color: var(--accent); padding: .15rem .5rem; border-radius: 4px; vertical-align: middle; margin-left: .4rem; }
    .lg { font-family: var(--font-mono); font-size: .78rem; padding-left: 1.1rem; position: relative; }
    .lg::before { content: ''; position: absolute; left: 0; top: 50%; transform: translateY(-50%); width: .7rem; height: .2rem; border-radius: 2px; }
    .lg-clu::before { background: var(--accent); width: .9rem; height: .26rem; }
    .lg-frac::before { background: var(--ink-faint); }
    .lg-fix::before { background: var(--accent); width: .9rem; height: .26rem; }
    .lg-naive::before { background: var(--ink-faint); }

    .chart-wrap { position: relative; height: 300px; }
    .util-wrap { height: 240px; }
    .empty { text-align: center; color: var(--ink-faint); font-size: .85rem; padding: 2rem 0; }

    .confbadge { font-family: var(--font-mono); font-size: .62rem; text-transform: uppercase; letter-spacing: .08em; padding: .25rem .6rem; border-radius: 999px; white-space: nowrap; }
    .confbadge.ok { background: color-mix(in srgb, #4cc4b0 18%, transparent); color: #4cc4b0; }
    .confbadge.thin { background: color-mix(in srgb, var(--accent) 16%, transparent); color: var(--accent); }

    .panel-card { padding: 0; }
    .panel-card > summary { list-style: none; cursor: pointer; padding: 1.2rem 1.4rem; display: grid; grid-template-columns: 1fr auto; grid-template-areas: 'main chev' 'sub chev'; align-items: center; gap: .15rem .8rem; }
    .panel-card > summary::-webkit-details-marker { display: none; }
    .sum-main { grid-area: main; display: flex; align-items: baseline; gap: .6rem; }
    .sum-main h2 { margin: 0; font-family: var(--font-display); font-size: 1.3rem; }
    .sum-count { font-family: var(--font-mono); font-size: .78rem; color: var(--accent); }
    .sum-sub { grid-area: sub; font-size: .82rem; color: var(--ink-dim); }
    .sum-chev { grid-area: chev; color: var(--ink-faint); font-size: 1rem; transition: transform .2s; }
    .panel-card[open] .sum-chev { transform: rotate(180deg); }
    .panel-card[open] > summary { border-bottom: 1px solid var(--rule); }
    .panel { display: flex; flex-direction: column; gap: .35rem; padding: 1.2rem 1.4rem; }
    .row { display: grid; grid-template-columns: 9rem 1fr 2.6rem auto; align-items: center; gap: .7rem; font-family: var(--font-mono); font-size: .78rem; }
    .row-name { color: var(--ink-dim); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .row-bar { height: .55rem; background: color-mix(in srgb, var(--ink) 8%, transparent); border-radius: 3px; overflow: hidden; }
    .row-fill { display: block; height: 100%; background: linear-gradient(90deg, color-mix(in srgb, var(--accent) 55%, transparent), var(--accent)); border-radius: 3px; }
    .row-pct { text-align: right; color: var(--ink); }
    .bar-8x { font-size: .64rem; color: var(--ink-faint); }
    .foot { font-size: .72rem; color: var(--ink-faint); line-height: 1.5; margin: 1rem 0 0; }
    .panel-card .foot { padding: 0 1.4rem 1.3rem; margin-top: .2rem; }

    .util-grid { display: grid; grid-template-columns: 200px 1fr; gap: 1.5rem; align-items: center; }
    .util-now { display: flex; flex-direction: column; gap: .2rem; }
    .util-big { font-family: var(--font-mono); font-size: 3rem; font-weight: 600; line-height: 1; color: var(--accent); }
    .util-now-lbl { font-size: .72rem; color: var(--ink-dim); }
    .util-naive { font-family: var(--font-mono); font-size: .72rem; color: var(--ink-faint); margin-top: .3rem; }

