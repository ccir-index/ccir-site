      $('s-clu-sub').textContent = (h && has(h.breadth_8x)) ? `${pct(num(h.breadth_8x))} of venues · full node · 7d` : 'full 8-GPU node · 7d';
      $('s-srcs').textContent = h ? h.n_sources : '—';
