---
import Base from '../layouts/Base.astro';
import TierDefinitions from '../components/TierDefinitions.astro';
import SpreadMatrix from '../components/SpreadMatrix.astro';
import { tierMatrix, premiumChipsList, meta } from '../data/snapshot';
import {
  TIERS,
  TIER_LABELS,
  TIER_LABELS_SHORT,
  PREMIUM_CHIPS,
} from '../data/types';

const fmt = (n: number) => n.toFixed(2);

const chips = (() => {
  const live = premiumChipsList();
  return live.length > 0 ? live : [...PREMIUM_CHIPS];
})();

const ladder = chips.map((chip) => ({ chip, cells: tierMatrix(chip) }));

function chipDisplay(token: string): string {
  return token.replace(/-/g, ' ');
}
---
<Base
  title="Tier structure · CCIR"
  description="The three Intelligence Factory tiers — T1IF, T2IF, T3IF — defined by fabric bandwidth, deployment grade, and capability bundle. Tier-class reference rates for GPU compute."
  ogImage="/og/tiers.png"
>
  <section class="wrap top">
    <div class="hero-solo">
      <div class="kicker">Intelligence Factory Taxonomy · {meta.as_of_date}</div>
      <h1>Three Tiers of Intelligence Factory</h1>
      <details class="def-disclosure">
        <summary>How to read this</summary>
        <p class="standfirst lede">
          CCIR publishes one independent reference rate per tier so the
          rate cited matches the deployment grade
          of the collateral pledged.
        </p>
      </details>
    </div>

    <section class="ladder-section">
      <header class="lh-head">
        <div class="kicker">Per-Silicon Ladder · On-Demand · {meta.as_of_date}</div>
        <h2>Same chip, three tiers.</h2>
        <details class="def-disclosure">
          <summary>Definitions &amp; methodology</summary>
          <p class="standfirst">
            Median rate per chip across each Intelligence Factory tier.
            <em>n</em> is the number of independent operators contributing to
            that median. An em-dash means the cell has no Published row in
            today's snapshot.
          </p>
        </details>
      </header>

      <div class="table-wrap">
        <table class="data ladder-table">
          <thead>
            <tr>
              <th rowspan="2" class="chip-col">Silicon</th>
              {TIERS.map((t) => (
                <th colspan="2" class={`tier-col tier-col-${t.toLowerCase()}`}>
                  <span class="th-tier">{t}</span>
                  <span class="th-name">{TIER_LABELS_SHORT[t]}</span>
                </th>
              ))}
            </tr>
            <tr class="sub-row">
              {TIERS.map(() => (
                <>
                  <th class="sub">Median $/hr</th>
                  <th class="sub">n</th>
                </>
              ))}
            </tr>
          </thead>
          <tbody>
            {ladder.map(({ chip, cells }) => (
              <tr>
                <td class="chip-cell">{chipDisplay(chip)}</td>
                {TIERS.map((t) => {
                  const c = cells[t];
                  if (!c) {
                    return (
                      <>
                        <td class="num empty">—</td>
                        <td class="num empty">—</td>
                      </>
                    );
                  }
                  const isShadow = c.promotion_status === 'Shadow';
                  return (
                    <>
                      <td class={`num posted tier-pos-${t.toLowerCase()} ${isShadow ? 'shadow' : ''}`}
                          title={`Median ${fmt(c.price_median)} · Mean ${fmt(c.price_mean)} · IQR ${fmt(c.price_p25)}–${fmt(c.price_p75)} · ${c.n_sources} sources / ${c.n_observations} obs${isShadow ? ' · Shadow (panel below 3-source / 5-obs gate)' : ''}`}>
                        ${fmt(c.price_median)}
                      </td>
                      <td class="num n">{c.n_sources}</td>
                    </>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="defs-section">
      <header class="sec-head">
        <div class="kicker">Capability bundle · per tier</div>
        <h2>What each tier packages.</h2>
      </header>
      <TierDefinitions headerless={true} />
    </section>

    <section class="classification">
      <header class="sec-head">
        <div class="kicker">Classification</div>
        <h2>How the algorithm assigns a tier.</h2>
      </header>
      <details class="def-disclosure">
        <summary>Definitions &amp; methodology</summary>
        <p class="class-body">
          Tier assignment is per-SKU and grade-based — driven by the
          capability bundle each SKU exposes, not by which operator hosts
          it. An interruptible SKU from any operator routes to T3IF; a
          dedicated-host SKU with top-grade fabric and a full enterprise
          bundle routes to T1IF; a dedicated-host SKU with mid-grade
          disclosed fabric routes to T2IF; everything else routes to T3IF.
          The same operator can therefore appear in two or three tiers
          across its SKU catalog, depending on what each SKU actually
          packages.
        </p>
      </details>
    </section>

    <section class="defs-section">
      <header class="sec-head">
        <div class="kicker">Basis decomposition · Disc./Prem. vs T1IF</div>
        <h2>What's in the rate.</h2>
        <details class="def-disclosure">
          <summary>Definitions &amp; methodology</summary>
          <p class="standfirst">
            Reading <strong>across a row</strong> (same chip, varying tier)
            isolates the deployment premium — fabric, support, compliance,
            operational wrap. Reading <strong>down a column</strong> (same
            tier, varying generation) isolates the generation premium with the
            bundle held constant. Every cell is anchored to T1IF.
          </p>
        </details>
      </header>
      <SpreadMatrix />
    </section>

    <p class="page-leadout">
      Worked credit drafting examples — defined terms, covenant
      mechanics, fallback waterfall — live in
      <a href="/applications">Applications</a>. The full rate history
      across tier, chip, and term is in the
      <a href="/explorer">Explorer</a>.
    </p>

  </section>

  <style>
    /* Collapsible chart definitions — collapsed by default, expandable. */
    .def-disclosure { margin: 4px 0 18px; }
    .def-disclosure > summary {
      list-style: none; cursor: pointer;
      font-family: var(--font-mono); font-size: var(--fs-xs);
      letter-spacing: var(--tracking-eye); text-transform: uppercase;
      color: var(--ink-dim); font-weight: var(--weight-strong);
      padding: 6px 0;
    }
    .def-disclosure > summary::-webkit-details-marker { display: none; }
    .def-disclosure > summary::before { content: '▸ '; color: var(--accent); }
    .def-disclosure[open] > summary::before { content: '▾ '; }
    .def-disclosure[open] > summary { margin-bottom: 4px; }

    .top { padding-top: 28px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    .hero-solo { max-width: 78ch; margin-bottom: 28px; }
    .lede { font-size: var(--fs-md); }
    .lede em { font-style: italic; color: var(--accent); }

    .ladder-section { margin: 32px 0 32px; }
    .lh-head { max-width: 80ch; margin-bottom: 14px; }
    .lh-head h2 {
      font-size: var(--fs-xl);
      margin: 4px 0 8px;
    }

    .table-wrap {
      border: 1px solid var(--rule);
      background: var(--surface);
      overflow-x: auto;
    }
    table.ladder-table { width: 100%; border-collapse: collapse; }
    table.ladder-table thead tr:first-child th {
      padding: 10px 14px;
    }
    .tier-col {
      text-align: center;
    }
    .tier-col .th-tier {
      display: block;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      font-weight: var(--weight-strong);
      letter-spacing: 0.08em;
    }
    .tier-col .th-name {
      display: block;
      font-family: var(--font-display);
      font-size: var(--fs-sm);
      color: var(--ink);
      font-weight: var(--weight-body);
      margin-top: 2px;
    }
    .tier-col-t1if .th-tier { color: var(--tier-t1if); }
    .tier-col-t2if .th-tier { color: var(--tier-t2if); }
    .tier-col-t3if .th-tier { color: var(--tier-t3if); }

    table.ladder-table th.sub {
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      font-weight: var(--weight-body);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      padding: 6px 14px 8px;
    }
    table.ladder-table .chip-cell {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      font-weight: var(--weight-strong);
      letter-spacing: 0.04em;
      white-space: nowrap;
    }
    table.ladder-table td.posted { font-weight: var(--weight-strong); cursor: help; }
    table.ladder-table td.posted.shadow { color: var(--ink-dim); font-style: italic; }
    table.ladder-table td.tier-pos-t1if { color: var(--tier-t1if); }
    table.ladder-table td.tier-pos-t2if { color: var(--ink); }
    table.ladder-table td.tier-pos-t3if { color: var(--ink); }
    table.ladder-table td.empty { color: var(--ink-faint); }
    table.ladder-table td.n { color: var(--ink-dim); }

    .defs-section { margin: 32px 0 32px; }
    .defs-section .sec-head { max-width: 80ch; }

    .classification { margin: 32px 0 32px; max-width: 80ch; }
    .sec-head { margin-bottom: 12px; }
    .sec-head h2 {
      font-size: var(--fs-xl);
      margin: 4px 0 10px;
    }
    .class-body {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.65;
      margin: 0;
    }

    .page-leadout {
      margin: 32px 0 24px;
      max-width: 80ch;
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.65;
    }
    .page-leadout a {
      color: var(--accent);
      border-bottom: 1px solid var(--accent);
      padding-bottom: 1px;
    }
    .page-leadout a:hover { opacity: 0.8; }
  </style>
</Base>
