    /* ----------------------------------------------------------------------
       MOBILE RESPONSIVE
       Desktop layout above is unchanged. All mobile fixes scoped to
       <=720px and <=480px breakpoints. Goals:
       - Ticker strip scrolls horizontally with sticky LIVE pill on the right
       - Quant strip breaks 6→3 cols at 720px, 6→2 cols at 480px (MEDIAN
         spans full width on the smallest viewport so it remains prominent)
       - Section headers stack vertically (kicker row above, note below h2)
       - Chip-group dividers drop their vertical hairline
       - Tables remain inside .table-wrap (already overflow-x:auto)
       - Hero charts shrink to 280-300px on the smallest phones
    ---------------------------------------------------------------------- */
    @media (max-width: 720px) {
      /* Ticker strip — horizontal scroll with sticky LIVE cell on the right */
      .vast-page .ticker-strip {
        flex-wrap: nowrap;
        overflow-x: auto;
        scroll-snap-type: x proximity;
        -webkit-overflow-scrolling: touch;
