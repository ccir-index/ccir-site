---
import Base from '../layouts/Base.astro';
import {
  committedBandCell, headlineRates, meta, premiumChipsList, tierMatrix,
} from '../data/snapshot';
import { TIERS } from '../data/types';
import type { Term } from '../data/types';

const chipCount = premiumChipsList().length;

const fmt = (n: number, dp = 2) => n.toFixed(dp);

// Anchor — T1IF H100 SXM on-demand. Featured stat block on the hero.
const ANCHOR = 'CRI-T1IF-H100-SXM-GTD-OD-ALL';
const anchorRate = headlineRates.find((r) => r.series_id === ANCHOR);
const anchorMedian = anchorRate?.price_median ?? 0;

// Product-card previews. Rates card: the H100 tier ladder. Term card: the
// H100 neocloud committed strip (OD → tenors) — market intelligence, badged.
const anchorChip = 'H100';
const anchorMatrix = tierMatrix(anchorChip);
const ratesPreview = TIERS.map((t) => ({
  tier: t,
  median: anchorMatrix[t]?.price_median,
}));
const TERM_PREVIEW_TENORS: Term[] = ['3M', '6M', '1Y'];
const t2Od = anchorMatrix.T2IF?.price_median;
const termPreview = TERM_PREVIEW_TENORS.map((t) => ({
  tenor: t,
  median: committedBandCell(anchorChip, t)?.price_median,
}));
---
<Base
  title="Reference Rates · CCIR"
  description="Daily reference rates for GPU compute across the Intelligence Factory Taxonomy. T1IF, T2IF, and T3IF tier medians published each morning by 07:30 ET."
  ogImage="/og/home.png"
>
  <section class="wrap top">
    <div class="hero">
      <div class="kicker">CCIR · Independent Reference Rates · {meta.as_of_date}</div>
      <h1>Independent Reference Rates for GPU Compute</h1>
      <p class="standfirst lede">
        CCIR provides a reference rate for all levels of the GPU
        compute market — <em>Tier 1</em>, <em>Tier 2</em>,
        <em>Tier 3</em> across the Intelligence Factory Taxonomy.
      </p>
    </div>

    <section class="featured">
      <div class="product-cards">
        <a class="product-card" href="/rates">
          <div class="pc-head">
            <span class="kicker">Reference Rates</span>
            <span class="pc-tag citable">Citable</span>
          </div>
          <div class="pc-kicker">Today · T1IF · {anchorChip} SXM · On-demand</div>
          <div class="pc-number">${fmt(anchorMedian)}<span class="pc-unit">/GPU-hr</span></div>
          <div class="pc-preview">
            {ratesPreview.map(({ tier, median }) => (
              <span class="pc-cell">
                <span class={`pc-label tier-${tier.toLowerCase()}`}>{tier}</span>
                <span class="pc-val">{median != null ? `$${fmt(median)}` : '—'}</span>
              </span>
            ))}
          </div>
          <p class="pc-desc">One independent rate per tier, per premium
          silicon — with US / EU splits. The benchmark.</p>
          <div class="pc-series"><code>{ANCHOR}</code></div>
          <span class="pc-foot">Tier ladder →</span>
        </a>

        <a class="product-card" href="/term">
          <div class="pc-head">
            <span class="kicker">Committed Term Structure</span>
            <span class="pc-tag mi">Market&nbsp;Intelligence</span>
          </div>
          <div class="pc-kicker">Today · {anchorChip} · 1-year committed · Neocloud band</div>
          <div class="pc-number">{termPreview.find((t) => t.tenor === '1Y')?.median != null
            ? `$${fmt(termPreview.find((t) => t.tenor === '1Y')!.median!)}`
            : '—'}<span class="pc-unit">/GPU-hr</span></div>
          <div class="pc-preview">
            <span class="pc-cell">
              <span class="pc-label">OD</span>
              <span class="pc-val">{t2Od != null ? `$${fmt(t2Od)}` : '—'}</span>
            </span>
            {termPreview.map(({ tenor, median }) => (
              <span class="pc-cell">
                <span class="pc-label">{tenor}</span>
                <span class="pc-val">{median != null ? `$${fmt(median)}` : '—'}</span>
              </span>
            ))}
          </div>
          <p class="pc-desc">Posted committed asks by tenor, beside the
          on-demand rate — the term axis of the compute market.</p>
          <div class="pc-series"><code>CRI-NEOCLOUD-{anchorChip}-ALL-GTD-1yr-ALL</code></div>
          <span class="pc-foot">Term structure →</span>
        </a>
      </div>
    </section>

    <aside class="independence-block" aria-label="Independence statement">
      <p>
        CCIR holds no positions in the markets it measures. No
        marketplace operations, no swap desk, no trading
        relationships.
      </p>
      <p class="ib-tag">Built for citation.</p>
    </aside>

    <ul class="hero-tagline" aria-label="Index principles">
      <li>Independent</li>
      <li>Open methodology</li>
      <li>Built for citation</li>
      <li>Capability-graded</li>
    </ul>

    <section class="coverage">
      <header class="sec-head">
        <div class="kicker">Section 01 · Coverage</div>
        <h2>Premium silicon, three tiers, daily.</h2>
      </header>
      <div class="cov-grid">
        <div class="cov-card">
          <span class="cov-num">{TIERS.length}</span>
          <span class="cov-label">Intelligence Factory tiers</span>
        </div>
        <div class="cov-card">
          <span class="cov-num">{chipCount}</span>
          <span class="cov-label">premium silicons</span>
        </div>
        <div class="cov-card">
          <span class="cov-num">{meta.contributing_today}</span>
          <span class="cov-label">contributing operators today</span>
        </div>
        <div class="cov-card">
          <span class="cov-num">{meta.methodology_version}</span>
          <span class="cov-label">methodology</span>
        </div>
      </div>
    </section>

    <section class="ladder-section">
      <header class="sec-head">
        <div class="kicker">Section 02 · Tier Structure</div>
        <h2>Same Chip — Three Products</h2>
        <p class="standfirst">
          The same H100 silicon is deployed at all three tiers — hyperscale,
          dedicated cluster, marketplace. Each tier is a distinct capability
          bundle — fabric, tenancy, bundle depth — and each carries its own
          rate. CCIR prices all three; the full ladder, with US / EU splits
          and per-tier panels, lives on <a href="/rates">/rates</a>.
        </p>
      </header>
    </section>

    <section class="methodology">
      <header class="sec-head">
        <div class="kicker">Section 03 · Methodology</div>
        <h2>How the rate is built.</h2>
      </header>
      <div class="meth-grid">
        <div class="meth-item">
          <span class="meth-label">Inputs</span>
          <p>Provider-posted rate cards and on-demand pricing pages, scraped daily. No solicited quotes, no broker feeds.</p>
        </div>
        <div class="meth-item">
          <span class="meth-label">Aggregation</span>
          <p>Operator-equal median: each operator counts as one vote regardless of SKU count. Median of per-source medians at each tier.</p>
        </div>
        <div class="meth-item">
          <span class="meth-label">Gate</span>
          <p>3 sources / 5 observations to publish. Below-gate cells emit as Shadow series and are flagged in the explorer.</p>
        </div>
        <div class="meth-item">
          <span class="meth-label">Tier classification</span>
          <p>Per-SKU algorithmic classifier on a capability bundle (fabric, host topology, support, compliance). Premium silicons only.</p>
        </div>
      </div>
      <p class="meth-tail">
        See <a href="/tiers">/tiers</a> for tier definitions, the
        T1IF-anchored spread matrix, and classification, and
        <a href="/applications">/applications</a> for worked
        credit-document examples.
      </p>
      <p class="meth-cta">
        <a href="https://github.com/ccir-index/ccir-methodology/blob/main/CCIR_Methodology_v2_0_0.md">
          Read the full methodology · v2.0.0 →
        </a>
      </p>
    </section>

    <section class="disclosures">
      <header class="sec-head">
        <div class="kicker">Section 04 · Disclosures</div>
        <h2>Scope and independence.</h2>
      </header>
      <ul class="disc-list">
        <li>
          <strong>Indicative reference rates.</strong> Long-tail chips
          (L4, L40S, A40, T4, V100, 3090, 4090, 5090, etc.) appear in the
          explorer as panel medians with no tier coverage. Treat them as
          reference points, not benchmark rates.
        </li>
        <li>
          <strong>No positions.</strong> CCIR holds no positions in the
          markets it measures.
        </li>
        <li>
          <strong>Credit document citation.</strong> The
          <a href="/applications">Applications</a> page contains worked
          drafting examples — defined terms, covenant mechanics, fallback
          waterfall — showing how a CCIR rate fits into a senior-secured
          GPU-backed facility.
        </li>
      </ul>
    </section>
  </section>

  <style>
    .top { padding-top: 32px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 18px;
      letter-spacing: -0.01em;
      max-width: 22ch;
    }
    .hero { margin-bottom: 24px; max-width: 80ch; }
    .lede { font-size: var(--fs-lg); }
    .lede em { font-style: italic; color: var(--accent); white-space: nowrap; }

    .featured {
      border-top: 1px solid var(--rule-2);
      border-bottom: 1px solid var(--rule-2);
      padding: 24px 0;
      margin: 8px 0 18px;
    }
    .product-cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 20px;
      align-items: stretch;
    }
    @media (max-width: 820px) {
      .product-cards { grid-template-columns: 1fr; }
    }
    .product-card {
      display: flex;
      flex-direction: column;
      gap: 10px;
      padding: 18px 20px;
      border: 1px solid var(--rule);
      background: var(--surface);
      text-decoration: none;
      color: var(--ink);
    }
    .pc-kicker {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }
    .pc-number {
      font-family: var(--font-mono);
      font-size: 46px;
      font-weight: var(--weight-strong);
      color: var(--ink);
      line-height: 1.05;
      letter-spacing: -0.02em;
    }
    .pc-unit {
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      margin-left: 6px;
      font-weight: var(--weight-body);
    }
    .pc-series {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--ink-faint);
      letter-spacing: 0.03em;
    }
    .pc-series code { color: var(--ink-faint); }
    .product-card:hover { border-color: var(--accent); text-decoration: none; }
    .pc-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 10px;
    }
    .pc-tag {
      font-family: var(--font-mono);
      font-size: 9px;
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      padding: 2px 7px;
      border: 1px solid var(--rule-2);
      white-space: nowrap;
    }
    .pc-tag.citable { color: var(--pos); border-color: var(--pos); }
    .pc-tag.mi { color: var(--accent); border-color: var(--accent); }
    .pc-desc {
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.5;
    }
    .pc-preview {
      display: flex;
      gap: 18px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
    }
    .pc-cell { display: flex; flex-direction: column; gap: 2px; }
    .pc-label {
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: 0.05em;
      font-size: 10px;
    }
    .pc-label.tier-t1if { color: var(--tier-t1if); }
    .pc-label.tier-t2if { color: var(--tier-t2if); }
    .pc-label.tier-t3if { color: var(--tier-t3if); }
    .pc-val { color: var(--ink); font-weight: var(--weight-strong); }
    .pc-foot {
      margin-top: auto;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }

    .independence-block {
      margin: 8px 0 14px;
      padding: 16px 18px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface);
      max-width: 80ch;
    }
    .independence-block p {
      margin: 0;
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.6;
    }
    .independence-block .ib-tag {
      margin-top: 8px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
    }

    .hero-tagline {
      list-style: none;
      margin: 0 0 36px;
      padding: 8px 0;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 22px;
      align-items: baseline;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      border-bottom: 1px solid var(--rule);
    }
    .hero-tagline li::before {
      content: "›";
      color: var(--accent);
      margin-right: 8px;
      font-weight: var(--weight-strong);
    }

    .sec-head { margin-bottom: 16px; max-width: 80ch; }
    .sec-head h2 {
      font-size: var(--fs-2xl);
      margin: 4px 0 10px;
    }

    .coverage { margin: 28px 0 32px; }
    .cov-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    @media (max-width: 720px) { .cov-grid { grid-template-columns: repeat(2, 1fr); } }
    .cov-card {
      background: var(--surface);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .cov-num {
      font-family: var(--font-mono);
      font-size: var(--fs-2xl);
      color: var(--accent);
      font-weight: var(--weight-strong);
      letter-spacing: -0.005em;
      line-height: 1.05;
    }
    .cov-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }

    .ladder-section { margin: 32px 0 24px; }
    .table-wrap {
      border: 1px solid var(--rule);
      background: var(--surface);
      overflow-x: auto;
    }
    table.ladder-table { width: 100%; border-collapse: collapse; }
    table.ladder-table th.chip-col {
      text-align: left;
      width: 14%;
    }
    table.ladder-table th.tier-col {
      text-align: center;
      padding: 10px 14px;
    }
    table.ladder-table th.tier-col-t1if { color: var(--tier-t1if); }
    table.ladder-table th.tier-col-t2if { color: var(--tier-t2if); }
    table.ladder-table th.tier-col-t3if { color: var(--tier-t3if); }
    table.ladder-table th.sub {
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      font-weight: var(--weight-body);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      padding: 6px 14px 8px;
    }
    table.ladder-table .chip-cell {
      white-space: nowrap;
    }
    table.ladder-table .chip-cell .chip-name {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      font-weight: var(--weight-strong);
      letter-spacing: 0.04em;
    }
    table.ladder-table .chip-cell .chip-series {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      font-weight: 400;
      margin-top: 2px;
    }
    table.ladder-table td.posted { font-weight: var(--weight-strong); cursor: help; }
    table.ladder-table td.posted.shadow { color: var(--ink-dim); font-style: italic; }
    table.ladder-table td.tier-pos-t1if { color: var(--tier-t1if); }
    table.ladder-table td.tier-pos-t2if { color: var(--ink); }
    table.ladder-table td.tier-pos-t3if { color: var(--ink); }
    table.ladder-table td.empty { color: var(--ink-faint); }
    table.ladder-table td.n { color: var(--ink-dim); }

    .methodology { margin: 32px 0 32px; }
    .meth-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    @media (max-width: 720px) { .meth-grid { grid-template-columns: 1fr; } }
    .meth-item {
      background: var(--surface);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .meth-item p {
      font-family: var(--font-body);
      color: var(--ink);
      margin: 0;
      font-size: var(--fs-sm);
      line-height: 1.55;
    }
    .meth-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
    }
    .meth-tail {
      margin: 16px 0 0;
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
    }
    .meth-cta {
      margin: 14px 0 0;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      letter-spacing: 0.04em;
    }
    .meth-cta a {
      color: var(--accent);
      border-bottom: 1px solid var(--accent);
      padding-bottom: 1px;
    }
    .meth-cta a:hover { opacity: 0.8; }

    .disclosures { margin: 32px 0 32px; }
    .disc-list {
      list-style: none; margin: 0; padding: 0;
      display: flex; flex-direction: column; gap: 12px;
      max-width: 80ch;
    }
    .disc-list li {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink);
      line-height: 1.6;
      padding-left: 16px;
      border-left: 2px solid var(--rule);
    }
    .disc-list li strong { color: var(--accent); font-weight: var(--weight-strong); }
  </style>
</Base>
