---
import Base from '../layouts/Base.astro';
import { headlineRates, meta, premiumChipsList } from '../data/snapshot';
import { TIERS, TIER_LABELS_SHORT } from '../data/types';
import type { Rate, Tier } from '../data/types';

const fmt = (n: number, dp = 2) => n.toFixed(dp);

// --- headline ladder (mirrors /rates) -------------------------------------
// Guaranteed on-demand reference: int=GTD, form + region pooled. Stat rule:
// n≥10 → mean (deep enough to trust), else median (small panels skew).
const N_MEAN_THRESHOLD = 10;
const STAT_RANK: Record<string, number> = { Published: 0, Provisional: 1, Shadow: 2 };
// Mirrors /rates exactly: US only, no region fallback — the home ladder and
// the rates ladder must always show the same numbers, and a missing US cell
// shows a dash rather than substituting the all-regions pool.
function odCell(tier: Tier, chip: string): Rate | undefined {
  return headlineRates
    .filter((r) => r.tier === tier && r.gpu_model === chip &&
                   r.commitment_term === 'OnDemand' && r.form_factor === 'ALL' &&
                   r.region === 'US' && r.interruptibility === 'GTD' &&
                   r.promotion_status !== 'Shadow')
    .sort((a, b) =>
      (STAT_RANK[a.promotion_status] ?? 3) - (STAT_RANK[b.promotion_status] ?? 3) ||
      (b.n_sources ?? 0) - (a.n_sources ?? 0))[0];
}
function headlineStat(c: Rate): number {
  return c.n_sources >= N_MEAN_THRESHOLD ? c.price_mean : c.price_median;
}
function cellTitle(c: Rate): string {
  const kind = c.n_sources >= N_MEAN_THRESHOLD ? 'mean' : 'median';
  return `${kind}, n=${c.n_sources} · median ${fmt(c.price_median)} · mean ${fmt(c.price_mean)} · IQR ${fmt(c.price_p25)}–${fmt(c.price_p75)}`;
}

const chips = (() => {
  const live = premiumChipsList();
  return (live.length > 0 ? live : ['B200', 'H200', 'H100', 'A100']);
})();
const ladder = chips
  .map((chip) => ({ chip, cells: Object.fromEntries(TIERS.map((t) => [t, odCell(t, chip)])) as Record<Tier, Rate | undefined> }))
  .filter((row) => TIERS.some((t) => row.cells[t]));

// --- market-intelligence pieces (same set as /intelligence) ----------------
const miPieces: { href: string; title: string; blurb: string }[] = [
  { href: '/term', title: 'Committed Term Structure', blurb: 'Guaranteed capacity priced by tenor.' },
  { href: '/basis', title: 'On-Demand vs Clearing Basis', blurb: 'List asks vs where it transacts.' },
  { href: '/chip-economics', title: 'Chip Economics', blurb: 'Earning power per spec-sheet unit — one lens is flat.' },
  { href: '/realized/', title: 'Realized vs Rate Card', blurb: 'What clouds actually earn per GPU-hr.' },
  { href: '/utilization', title: 'Utilization & Availability', blurb: 'How much of the fleet is working.' },
  { href: '/research/od-vs-committed', title: 'The Commitment Discount', blurb: 'On-demand vs committed H100 posted prices, Oct 2023 – Jun 2026.' },
  { href: '/research/gpu-age-curve', title: 'Rent and Age', blurb: 'Five generations, one date — how the market prices chip age.' },
];
---
<Base
  title="Reference Rates for the Compute Market · CCIR"
  description="Citable reference rates and independent analysis for the GPU compute market — rates, term structure, credit, and supply, tracked daily across chips and deployment classes."
  ogImage="/og/home.png"
>
  <section class="wrap top">
    <header class="hero">
      <div class="kicker">CCIR · Citable Reference Rates · Independent Analysis · {meta.as_of_date}</div>
      <h1>Reference Rates for the Compute Market</h1>
      <p class="standfirst lede">
        Tracked daily across chips and deployment classes — premium silicon to
        the long tail — from {meta.contributing_today} providers.
      </p>
    </header>

    <!-- Layer 1 — the reference ladder -->
    <section class="ladder-block">
      <div class="block-head">
        <span class="kicker">Reference Rates · Guaranteed on-demand</span>
        <a class="block-link" href="/rates">Full ladder →</a>
      </div>
      <div class="table-wrap">
        <table class="data ladder-table">
          <thead>
            <tr>
              <th class="chip-col">Silicon</th>
              {TIERS.map((t) => (
                <th class={`tier-col tier-col-${t.toLowerCase()}`}>{TIER_LABELS_SHORT[t]}</th>
              ))}
            </tr>
          </thead>
          <tbody>
            {ladder.map(({ chip, cells }) => (
              <tr>
                <td class="chip-cell">{chip.replace(/-/g, ' ')}</td>
                {TIERS.map((t) => {
                  const c = cells[t];
                  if (!c) return <td class="num empty">—</td>;
                  return (
                    <td class={`num posted tier-pos-${t.toLowerCase()}`} title={cellTitle(c)}>
                      ${fmt(headlineStat(c))}
                      <div class="cell-sid">{c.series_id}</div>
                    </td>
                  );
                })}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="block-foot">USD per GPU-hour · guaranteed on-demand, US series only · mean where the panel is deep (n≥10), median below · a dash means no published US series · same series as <a href="/rates">/rates</a>.</p>
    </section>

    <!-- Layer 2 — market intelligence -->
    <section class="mi-block">
      <div class="block-head">
        <span class="kicker">Research</span>
        <a class="block-link" href="/research">All monitors &amp; notes →</a>
      </div>
      <div class="mi-grid">
        {miPieces.map((p) => (
          <a class="mi-card" href={p.href}>
            <h3 class="mi-title">{p.title}</h3>
            <p class="mi-blurb">{p.blurb}</p>
          </a>
        ))}
      </div>
    </section>

    <!-- Layer 3 — credit -->
    <a class="credit-strip" href="/credit">
      <div class="cs-text">
        <span class="kicker">Credit</span>
        <span class="cs-line">GPU-backed debt — issuance, spreads, and the borrowers financing the buildout.</span>
      </div>
      <span class="cs-foot">Credit tracker →</span>
    </a>

    <p class="data-line">
      CCIR publishes citable reference series from observed prices and holds
      no positions in the markets it measures. Citing a series, or interested
      in a data partnership? <a href="/contact">Get in touch →</a>
    </p>
  </section>

  <style>
    .top { padding-top: 32px; }
    .hero { margin-bottom: 26px; max-width: 80ch; }
    .hero h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
      max-width: 22ch;
    }
    .lede { font-size: var(--fs-lg); }

    .block-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 12px;
      margin-bottom: 10px;
    }
    .block-link, .block-foot a { color: var(--accent); }
    .block-link {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }

    .ladder-block { margin: 0 0 34px; }
    .table-wrap { border: 1px solid var(--rule); background: var(--surface); overflow-x: auto; }
    table.ladder-table { width: 100%; border-collapse: collapse; }
    table.ladder-table th.chip-col { text-align: left; width: 16%; }
    table.ladder-table th.tier-col { text-align: center; padding: 10px 14px; }
    table.ladder-table th.tier-col-t1 { color: var(--tier-t1); }
    table.ladder-table th.tier-col-t2 { color: var(--tier-t2); }
    table.ladder-table th.tier-col-t3 { color: var(--tier-t3); }
    table.ladder-table td.chip-cell {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      font-weight: var(--weight-strong);
      letter-spacing: 0.04em;
      white-space: nowrap;
    }
    table.ladder-table td.num { text-align: center; }
    table.ladder-table td.posted { font-weight: var(--weight-strong); cursor: help; }
    .cell-sid {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 2px);
      font-weight: var(--weight-body);
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      margin-top: 3px;
      white-space: nowrap;
    }
    /* Middle tier (Neocloud) is the market that matters — give it the accent. */
    table.ladder-table td.tier-pos-t2 { color: var(--accent); }
    table.ladder-table th.tier-col-t2 { color: var(--accent); }
    table.ladder-table td.tier-pos-t1, table.ladder-table td.tier-pos-t3 { color: var(--ink); }
    table.ladder-table td.empty { color: var(--ink-faint); }
    .block-foot {
      margin: 10px 0 0;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      letter-spacing: 0.02em;
    }

    .mi-block { margin: 0 0 32px; }
    .mi-grid {
      display: grid;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    @media (max-width: 860px) { .mi-grid { grid-template-columns: 1fr 1fr; } }
    @media (max-width: 520px) { .mi-grid { grid-template-columns: 1fr; } }
    .mi-card {
      background: var(--surface);
      padding: 15px 17px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      text-decoration: none;
      color: var(--ink);
    }
    .mi-card:hover { background: var(--surface-2); text-decoration: none; }
    .mi-title {
      font-family: var(--font-display);
      font-size: var(--fs-md);
      font-weight: var(--weight-display);
      margin: 0;
    }
    .mi-blurb {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.5;
      margin: 0;
    }

    .credit-strip {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 18px 20px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface);
      text-decoration: none;
      color: var(--ink);
      margin: 0 0 28px;
    }
    .credit-strip:hover { background: var(--surface-2); text-decoration: none; }
    .cs-text { display: flex; flex-direction: column; gap: 5px; }
    .cs-line { font-family: var(--font-body); font-size: var(--fs-md); color: var(--ink); line-height: 1.5; }
    .cs-foot {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      white-space: nowrap;
    }

    .data-line {
      margin: 0 0 24px;
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.6;
    }
    .data-line a { color: var(--accent); }
  </style>
</Base>
