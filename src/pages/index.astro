---
import Base from '../layouts/Base.astro';
import TierDefinitions from '../components/TierDefinitions.astro';
import Sparkline from '../components/Sparkline.astro';
import { headlineRates, meta, premiumChipsList, tierMatrix } from '../data/snapshot';
import { TIERS } from '../data/types';

const fmt = (n: number, dp = 2) => n.toFixed(dp);

// Anchor — T1IF H100 SXM on-demand. Featured stat block on the hero.
const ANCHOR = 'CRI-T1IF-H100-SXM-GTD-OD-ALL';
const anchorRate = headlineRates.find((r) => r.series_id === ANCHOR);
const anchorMedian = anchorRate?.price_median ?? 0;

// T1IF/T2IF/T3IF anchor ladder for the homepage spotlight on H100.
const anchorChip = 'H100';
const anchorMatrix = tierMatrix(anchorChip);
const anchorRows = TIERS.map((t) => ({ tier: t, cell: anchorMatrix[t] }));
const anchorMax = Math.max(
  0,
  ...anchorRows.map((r) => r.cell?.price_median ?? 0),
);

// Per-silicon ladder: 5 premium silicons × 3 tiers, OD baseline.
const chips = (() => {
  const live = premiumChipsList();
  return live.length > 0 ? live : ['GB200', 'B200', 'H200', 'H100', 'A100'];
})();
const chipLadder = chips.map((c) => ({ chip: c, cells: tierMatrix(c) }));

function chipDisplay(token: string): string {
  return token.replace(/-/g, ' ');
}
---
<Base title="Reference Rates · CCIR">
  <section class="wrap top">
    <div class="hero">
      <div class="kicker">CCIR · Decomposed Benchmark Rates · {meta.as_of_date}</div>
      <h1>Reference Rates for GPU Compute Markets</h1>
      <p class="standfirst lede">
        CCIR publishes a reference rate at each Intelligence Factory
        tier — <em>Tier 1</em>, <em>Tier 2</em>, <em>Tier 3</em> —
        because compute becomes financeable not when it is flattened
        into one price, but when it is segmented into real, transactable
        capability bundles.
      </p>
    </div>

    <section class="featured">
      <div class="featured-grid">
        <div class="featured-stat">
          <div class="kicker">Today · T1IF · H100 SXM · On-demand</div>
          <div class="stat-number">${fmt(anchorMedian)}<span class="stat-unit">/GPU-hr</span></div>
          <div class="stat-spark">
            {anchorRate && <Sparkline seriesId={anchorRate.series_id} median={anchorRate.price_median} width={140} height={36} />}
          </div>
          <div class="stat-meta">
            Reference: <code>{ANCHOR}</code>
          </div>
        </div>

        <aside class="featured-ladder" aria-label={`Tier ladder for ${anchorChip} on-demand`}>
          <div class="ladder-head">
            <span class="kicker">{anchorChip} · On-demand · Tier ladder</span>
          </div>
          <ul class="ladder-rows">
            {anchorRows.map(({ tier, cell }) => {
              if (!cell) {
                return (
                  <li class="ladder-row empty">
                    <span class={`ladder-tier tier-${tier.toLowerCase()}`}>{tier}</span>
                    <span class="ladder-track"></span>
                    <span class="ladder-prices"><span class="ladder-price empty">—</span></span>
                  </li>
                );
              }
              const pctOfMax = anchorMax > 0 ? (cell.price_median / anchorMax) * 100 : 0;
              return (
                <li class="ladder-row">
                  <span class={`ladder-tier tier-${tier.toLowerCase()}`}>{tier}</span>
                  <span class="ladder-track">
                    <span
                      class={`ladder-fill fill-${tier.toLowerCase()}`}
                      style={`width: ${pctOfMax}%`}
                    ></span>
                  </span>
                  <span class="ladder-prices">
                    <span class="ladder-price">${fmt(cell.price_median)}</span>
                    <span class="ladder-spark">
                      <Sparkline seriesId={cell.series_id} median={cell.price_median} width={48} height={14} />
                    </span>
                  </span>
                </li>
              );
            })}
          </ul>
          <div class="ladder-foot">USD per GPU-hour · operator-equal median</div>
        </aside>
      </div>
    </section>

    <ul class="hero-tagline" aria-label="Index principles">
      <li>Independent</li>
      <li>Open methodology</li>
      <li>Built for citation</li>
      <li>Capability-graded</li>
    </ul>

    <section class="coverage">
      <header class="sec-head">
        <div class="kicker">Section 01 · Coverage</div>
        <h2>Premium silicon, three tiers, daily.</h2>
      </header>
      <div class="cov-grid">
        <div class="cov-card">
          <span class="cov-num">{TIERS.length}</span>
          <span class="cov-label">Intelligence Factory tiers</span>
        </div>
        <div class="cov-card">
          <span class="cov-num">{chips.length}</span>
          <span class="cov-label">premium silicons</span>
        </div>
        <div class="cov-card">
          <span class="cov-num">{meta.contributing_today}</span>
          <span class="cov-label">contributing operators today</span>
        </div>
        <div class="cov-card">
          <span class="cov-num">{meta.methodology_version}</span>
          <span class="cov-label">methodology</span>
        </div>
      </div>
    </section>

    <section class="ladder-section">
      <header class="sec-head">
        <div class="kicker">Section 02 · Tier Structure</div>
        <h2>Same Chip — Three Rates</h2>
        <p class="standfirst">
          The same H100 silicon is deployed across all three tiers. A buyer
          choosing among a Tier 1 hyperscale deployment, a Tier 2 dedicated
          cluster, and a Tier 3 marketplace listing isn't choosing between
          three prices of the same product — they're choosing between three
          products that happen to share a chip.
        </p>
      </header>

      <div class="table-wrap">
        <table class="data ladder-table">
          <thead>
            <tr>
              <th rowspan="2" class="chip-col">Silicon</th>
              {TIERS.map((t) => (
                <th colspan="3" class={`tier-col tier-col-${t.toLowerCase()}`}>
                  <span class={`tier-badge tier-badge-${t.toLowerCase()}`}>{t}</span>
                </th>
              ))}
            </tr>
            <tr class="sub-row">
              {TIERS.map(() => (
                <>
                  <th class="sub">Median $/hr</th>
                  <th class="sub">Trend · 7d</th>
                  <th class="sub">n</th>
                </>
              ))}
            </tr>
          </thead>
          <tbody>
            {chipLadder.map(({ chip, cells }) => {
              const refSeries = cells.T1IF?.series_id ?? cells.T2IF?.series_id ?? cells.T3IF?.series_id;
              return (
              <tr>
                <td class="chip-cell">
                  <div class="chip-name">{chipDisplay(chip)}</div>
                  {refSeries && <code class="chip-series">{refSeries}</code>}
                </td>
                {TIERS.map((t) => {
                  const c = cells[t];
                  if (!c) {
                    return (
                      <>
                        <td class="num empty">—</td>
                        <td class="num empty"></td>
                        <td class="num empty">—</td>
                      </>
                    );
                  }
                  const isShadow = c.promotion_status === 'Shadow';
                  return (
                    <>
                      <td class={`num posted tier-pos-${t.toLowerCase()} ${isShadow ? 'shadow' : ''}`}
                          title={`Median ${fmt(c.price_median)} · Mean ${fmt(c.price_mean)} · IQR ${fmt(c.price_p25)}–${fmt(c.price_p75)} · ${c.n_sources} sources / ${c.n_observations} obs${isShadow ? ' · Shadow (panel below 3-source / 5-obs gate)' : ''}`}>
                        ${fmt(c.price_median)}
                      </td>
                      <td class="num spark-cell">
                        <Sparkline seriesId={c.series_id} median={c.price_median} width={56} height={16} />
                      </td>
                      <td class="num n">{c.n_sources}</td>
                    </>
                  );
                })}
              </tr>
              );
            })}
          </tbody>
        </table>
      </div>
    </section>

    <TierDefinitions />

    <section class="methodology">
      <header class="sec-head">
        <div class="kicker">Section 03 · Methodology</div>
        <h2>How the rate is built.</h2>
      </header>
      <div class="meth-grid">
        <div class="meth-item">
          <span class="meth-label">Inputs</span>
          <p>Provider-posted rate cards and on-demand pricing pages, scraped daily. No solicited quotes, no broker feeds.</p>
        </div>
        <div class="meth-item">
          <span class="meth-label">Aggregation</span>
          <p>Operator-equal median: each operator counts as one vote regardless of SKU count. Median of per-source medians at each tier.</p>
        </div>
        <div class="meth-item">
          <span class="meth-label">Gate</span>
          <p>3 sources / 5 observations to publish. Below-gate cells emit as Shadow series and are flagged in the explorer.</p>
        </div>
        <div class="meth-item">
          <span class="meth-label">Tier classification</span>
          <p>Per-SKU algorithmic classifier on a capability bundle (fabric, host topology, support, compliance). Premium silicons only.</p>
        </div>
      </div>
      <p class="meth-tail">
        See <a href="/tiers">/tiers</a> for the editorial framing,
        <a href="/spreads">/spreads</a> for the T1IF-anchored spread matrix,
        and <a href="/applications">/applications</a> for worked credit-document examples.
      </p>
      <p class="meth-cta">
        <a href="https://github.com/ccir-index/ccir-v2-data/blob/main/methodology/CCIR_Methodology_v2_0_0.md">
          Read the full methodology · v2.0.0 →
        </a>
      </p>
    </section>

    <section class="disclosures">
      <header class="sec-head">
        <div class="kicker">Section 04 · Disclosures</div>
        <h2>Scope and independence.</h2>
      </header>
      <ul class="disc-list">
        <li>
          <strong>Indicative reference rates.</strong> Long-tail chips
          (L4, L40S, A40, T4, V100, 3090, 4090, 5090, etc.) appear in the
          explorer as panel medians with no tier coverage. Treat them as
          reference points, not benchmark rates.
        </li>
        <li>
          <strong>No positions.</strong> CCIR holds no positions in the
          markets it measures.
        </li>
      </ul>
    </section>
  </section>

  <style>
    .top { padding-top: 32px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 18px;
      letter-spacing: -0.01em;
      max-width: 22ch;
    }
    .hero { margin-bottom: 24px; max-width: 80ch; }
    .lede { font-size: var(--fs-lg); }
    .lede em { font-style: italic; color: var(--accent); white-space: nowrap; }

    .featured {
      border-top: 1px solid var(--rule-2);
      border-bottom: 1px solid var(--rule-2);
      padding: 24px 0;
      margin: 8px 0 18px;
    }
    .featured-grid {
      display: grid;
      grid-template-columns: minmax(0, 1.1fr) minmax(280px, 1fr);
      gap: 36px;
      align-items: stretch;
    }
    @media (max-width: 820px) {
      .featured-grid { grid-template-columns: 1fr; }
    }
    .featured-stat {
      display: flex;
      flex-direction: column;
      gap: 8px;
    }
    .featured-stat .kicker { color: var(--accent); }
    .stat-number {
      font-family: var(--font-mono);
      font-size: 64px;
      font-weight: var(--weight-strong);
      color: var(--ink);
      line-height: 1.05;
      letter-spacing: -0.02em;
    }
    .stat-unit {
      font-size: var(--fs-md);
      color: var(--ink-dim);
      margin-left: 6px;
      font-weight: var(--weight-body);
    }
    .stat-spark { color: var(--accent); margin: 4px 0 6px; }
    .stat-meta {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      line-height: 1.6;
    }
    .stat-meta code {
      font-family: var(--font-mono);
      color: var(--accent);
      letter-spacing: 0.04em;
    }

    .featured-ladder {
      border-left: 1px solid var(--rule);
      padding-left: 24px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    @media (max-width: 820px) {
      .featured-ladder { border-left: none; padding-left: 0; border-top: 1px solid var(--rule); padding-top: 16px; }
    }
    .ladder-rows {
      list-style: none; margin: 0; padding: 0;
      display: flex; flex-direction: column; gap: 8px;
    }
    .ladder-row {
      display: grid;
      grid-template-columns: 44px minmax(0, 1fr) auto;
      align-items: center;
      gap: 10px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
    }
    .ladder-tier { font-weight: var(--weight-strong); letter-spacing: 0.06em; }
    .ladder-tier.tier-t1if { color: var(--tier-t1if); }
    .ladder-tier.tier-t2if { color: var(--tier-t2if); }
    .ladder-tier.tier-t3if { color: var(--tier-t3if); }
    .ladder-track {
      display: block;
      height: 10px;
      background: var(--surface-3);
      border: 1px solid var(--rule);
    }
    .ladder-fill { display: block; height: 100%; }
    .fill-t1if { background: var(--tier-t1if); }
    .fill-t2if { background: var(--tier-t2if); }
    .fill-t3if { background: var(--tier-t3if); }
    .ladder-prices {
      display: inline-flex; align-items: center; gap: 8px;
      min-width: 110px; justify-content: flex-end;
    }
    .ladder-price { color: var(--ink); font-weight: var(--weight-strong); }
    .ladder-price.empty { color: var(--ink-faint); }
    .ladder-spark { color: var(--accent); }
    .ladder-foot {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }

    .hero-tagline {
      list-style: none;
      margin: 0 0 36px;
      padding: 8px 0;
      display: flex;
      flex-wrap: wrap;
      gap: 8px 22px;
      align-items: baseline;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      border-bottom: 1px solid var(--rule);
    }
    .hero-tagline li::before {
      content: "›";
      color: var(--accent);
      margin-right: 8px;
      font-weight: var(--weight-strong);
    }

    .sec-head { margin-bottom: 16px; max-width: 80ch; }
    .sec-head h2 {
      font-size: var(--fs-2xl);
      margin: 4px 0 10px;
    }

    .coverage { margin: 28px 0 32px; }
    .cov-grid {
      display: grid;
      grid-template-columns: repeat(4, minmax(0, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    @media (max-width: 720px) { .cov-grid { grid-template-columns: repeat(2, 1fr); } }
    .cov-card {
      background: var(--surface);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }
    .cov-num {
      font-family: var(--font-mono);
      font-size: var(--fs-2xl);
      color: var(--accent);
      font-weight: var(--weight-strong);
      letter-spacing: -0.005em;
      line-height: 1.05;
    }
    .cov-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
    }

    .ladder-section { margin: 32px 0 24px; }
    .table-wrap {
      border: 1px solid var(--rule);
      background: var(--surface);
      overflow-x: auto;
    }
    table.ladder-table { width: 100%; border-collapse: collapse; }
    table.ladder-table th.chip-col {
      text-align: left;
      width: 14%;
    }
    table.ladder-table th.tier-col {
      text-align: center;
      padding: 10px 14px;
    }
    table.ladder-table th.tier-col-t1if { color: var(--tier-t1if); }
    table.ladder-table th.tier-col-t2if { color: var(--tier-t2if); }
    table.ladder-table th.tier-col-t3if { color: var(--tier-t3if); }
    table.ladder-table th.sub {
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      font-weight: var(--weight-body);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      padding: 6px 14px 8px;
    }
    table.ladder-table .chip-cell {
      white-space: nowrap;
    }
    table.ladder-table .chip-cell .chip-name {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      font-weight: var(--weight-strong);
      letter-spacing: 0.04em;
    }
    table.ladder-table .chip-cell .chip-series {
      display: block;
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      font-weight: 400;
      margin-top: 2px;
    }
    table.ladder-table td.posted { font-weight: var(--weight-strong); cursor: help; }
    table.ladder-table td.posted.shadow { color: var(--ink-dim); font-style: italic; }
    table.ladder-table td.tier-pos-t1if { color: var(--tier-t1if); }
    table.ladder-table td.tier-pos-t2if { color: var(--ink); }
    table.ladder-table td.tier-pos-t3if { color: var(--ink); }
    table.ladder-table td.empty { color: var(--ink-faint); }
    table.ladder-table td.spark-cell {
      text-align: center;
      color: var(--accent);
      padding: 4px 8px;
    }
    table.ladder-table td.n { color: var(--ink-dim); }

    .methodology { margin: 32px 0 32px; }
    .meth-grid {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
    }
    @media (max-width: 720px) { .meth-grid { grid-template-columns: 1fr; } }
    .meth-item {
      background: var(--surface);
      padding: 16px 18px;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .meth-item p {
      font-family: var(--font-body);
      color: var(--ink);
      margin: 0;
      font-size: var(--fs-sm);
      line-height: 1.55;
    }
    .meth-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
    }
    .meth-tail {
      margin: 16px 0 0;
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
    }
    .meth-cta {
      margin: 14px 0 0;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      letter-spacing: 0.04em;
    }
    .meth-cta a {
      color: var(--accent);
      border-bottom: 1px solid var(--accent);
      padding-bottom: 1px;
    }
    .meth-cta a:hover { opacity: 0.8; }

    .disclosures { margin: 32px 0 32px; }
    .disc-list {
      list-style: none; margin: 0; padding: 0;
      display: flex; flex-direction: column; gap: 12px;
      max-width: 80ch;
    }
    .disc-list li {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink);
      line-height: 1.6;
      padding-left: 16px;
      border-left: 2px solid var(--rule);
    }
    .disc-list li strong { color: var(--accent); font-weight: var(--weight-strong); }
  </style>
</Base>
