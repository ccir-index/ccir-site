---
import Base from '../layouts/Base.astro';
import TermCurveChart from '../components/TermCurveChart.astro';
// HyperscalerTermChart PULLED same-day it shipped (John, 2026-07-16): T1 US
// cells are n=2-4 and cell-to-cell %s manufactured a fake H200 "1Y −26%"
// (within-provider truth: −7%). Replacement = per-provider reservation
// schedules (Azure/GCP/AWS own ladders, named) — needs a listings-grain
// export lane; queue with the azure/gcp leg-replacement decision (07-23).
// Component stays in src/components; reinstating is one import + one tag.
import { meta } from '../data/snapshot';
// Implied-forwards section CUT (John 2026-07-02): with the par curve's OD
// anchor moving to the pooled NEOCLOUD band OD (apples-to-apples), the
// derived step chart adds confusion without adding signal for most readers.
// The within-provider forwards DATA still ships in committed_mi.csv and
// ForwardStepChart.astro (already rewired to it) stays in src/components —
// reinstating is one import + one tag.
---
<Base
  title="GPU Reserved & Committed Pricing — 1M to 3Y Term Structure · CCIR"
  description="Reserved and committed GPU pricing by tenor, one month to three years — posted committed asks and each operator's discount to on-demand, updated daily. The term structure of GPU compute."
  ogImage="/og/term-structure-2026-07.png"
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'CCIR GPU Committed Term Structure',
    description: 'Reserved and committed GPU pricing by tenor, one month to three years — posted committed asks and within-provider discounts to on-demand, computed daily as the operator-equal median of each operator’s committed ask against its own on-demand rate.',
    url: 'https://ccir.io/term',
    creator: { '@type': 'Organization', name: 'CCIR', url: 'https://ccir.io' },
    temporalCoverage: '2026-05/..',
    keywords: [
      'GPU reserved pricing', 'committed GPU pricing', 'GPU term structure',
      'H100 1 year price', 'H100 3 year reserved', 'GPU commitment discount',
      'reserved instance GPU pricing', 'long-term GPU rental rates',
      'GPU lease rates', 'multi-year GPU contract pricing',
    ],
    license: 'https://creativecommons.org/licenses/by/4.0/',
    isAccessibleForFree: true,
  })} />
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Market Intelligence · {meta.as_of_date}</div>
      <h1>Committed Term Structure</h1>
      <p class="standfirst">
        The price of guaranteed capacity, by tenor. Posted committed asks from
        one month to three years, and the discount each tenor carries to
        on-demand — the term axis the on-demand headline can't see.
      </p>
    </header>

    <aside class="mi-banner" role="note">
      <strong>A market-intelligence series on committed-term pricing.</strong>
      Committed-term cells are a descriptive market-intelligence product, not
      a citable reference rate. A committed price is a <strong>fixed
      schedule</strong> — the posted price of a commitment starting today,
      held for its term — not a forecast of future on-demand rates.
      Construction, geographic scope, and panel-depth conventions are in the
      chart notes beneath the figure.
    </aside>

    <section class="curve-section">
      <header class="sec-head">
        <div class="kicker">Section 01 · Committed asks by tenor</div>
        <h2>The Neocloud Committed Term Curve</h2>
      </header>

      <TermCurveChart />
    </section>

    <aside class="mi-more">
      <span class="kicker">More research</span>
      <a href="/realized/">Realized vs. Rate Card — what operators actually
      realize per GPU-hour, estimated from public filings →</a>
    </aside>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { margin-bottom: 18px; max-width: 84ch; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-3xl);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 12px;
    }
    .standfirst em { font-style: italic; color: var(--accent); }

    .mi-banner {
      margin: 0 0 28px;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface);
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink);
      line-height: 1.6;
      max-width: 84ch;
    }
    .mi-banner strong { color: var(--accent); }
    .mi-banner a { color: var(--accent); }

    .sec-head { margin-bottom: 14px; max-width: 84ch; }
    .sec-head h2 { font-size: var(--fs-2xl); margin: 4px 0 10px; }
    .sec-lede {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.6;
      margin: 0 0 4px;
    }

    .curve-section { margin: 0 0 36px; }

    .mi-more {
      margin: 0 0 36px;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      background: var(--surface);
      max-width: 84ch;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .mi-more a {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--accent);
      line-height: 1.5;
    }
  </style>
</Base>
