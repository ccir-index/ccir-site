---
import Base from '../layouts/Base.astro';
import TermCurveChart from '../components/TermCurveChart.astro';
import { meta } from '../data/snapshot';
// Implied-forwards section CUT (John 2026-07-02): with the par curve's OD
// anchor moving to the pooled NEOCLOUD band OD (apples-to-apples), the
// derived step chart adds confusion without adding signal for most readers.
// The within-provider forwards DATA still ships in committed_mi.csv and
// ForwardStepChart.astro (already rewired to it) stays in src/components —
// reinstating is one import + one tag.
---
<Base
  title="Committed Term Structure · CCIR"
  description="Committed-term GPU compute rates by tenor, one month to three years — posted committed asks and the discount to on-demand, charted against the on-demand anchor. A CCIR market-intelligence series, updated daily."
  ogImage="/og/term-structure.png"
>
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Market Intelligence · {meta.as_of_date}</div>
      <h1>Committed Term Structure</h1>
      <p class="standfirst">
        The price of guaranteed capacity, by tenor. Posted committed asks from
        one month to three years, and the discount each tenor carries to
        on-demand — the term axis the on-demand headline can't see.
      </p>
    </header>

    <aside class="mi-banner" role="note">
      <strong>A market-intelligence series on committed-term pricing.</strong>
      Committed-term cells are a descriptive market-intelligence product. Panel depth is
      disclosed on every point (hover); thin cells render hollow (Provisional).
      A committed price is a <strong>fixed schedule</strong> — the posted price of a
      commitment starting today, held for its term. It is not a forecast of
      future on-demand rates, and the curve below is not a forward curve.
      <strong>Construction:</strong> tenor spreads are computed <strong>within
      provider</strong> — each operator's committed ask against its <em>own</em>
      on-demand rate — and published as the <strong>operator-equal median</strong>
      (one vote per operator), not a raw pool of posted discounts. The plotted
      tenor levels are implied off the on-demand anchor by that median spread
      (method in the chart notes).
      <strong>Geographic scope:</strong> unlike the US-only headline series on
      <a href="/rates">/rates</a>, this page pools US and EU postings —
      committed tenors are thin, and pooling preserves panel depth. The
      on-demand anchor charted here uses the same pooled panel, so the
      committed-vs-on-demand comparison stays like-for-like.
    </aside>

    <section class="curve-section">
      <header class="sec-head">
        <div class="kicker">Section 01 · Committed asks by tenor</div>
        <h2>The Neocloud committed term curve</h2>
      </header>

      <TermCurveChart />
    </section>

    <aside class="mi-more">
      <span class="kicker">More research</span>
      <a href="/realized/">Realized vs. Rate Card — what operators actually
      realize per GPU-hour, estimated from public filings →</a>
    </aside>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { margin-bottom: 18px; max-width: 84ch; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-3xl);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 12px;
    }
    .standfirst em { font-style: italic; color: var(--accent); }

    .mi-banner {
      margin: 0 0 28px;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface);
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink);
      line-height: 1.6;
      max-width: 84ch;
    }
    .mi-banner strong { color: var(--accent); }
    .mi-banner a { color: var(--accent); }

    .sec-head { margin-bottom: 14px; max-width: 84ch; }
    .sec-head h2 { font-size: var(--fs-2xl); margin: 4px 0 10px; }
    .sec-lede {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.6;
      margin: 0 0 4px;
    }

    .curve-section { margin: 0 0 36px; }

    .mi-more {
      margin: 0 0 36px;
      padding: 12px 16px;
      border: 1px solid var(--rule);
      background: var(--surface);
      max-width: 84ch;
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .mi-more a {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--accent);
      line-height: 1.5;
    }
  </style>
</Base>
