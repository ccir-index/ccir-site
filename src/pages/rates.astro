---
import Base from '../layouts/Base.astro';
import TierDefinitions from '../components/TierDefinitions.astro';
import { headlineRates, meta, premiumChipsList, headlineValue, headlineStatOf } from '../data/snapshot';
import { TIERS, TIER_LABELS_SHORT } from '../data/types';
import type { Rate, Tier } from '../data/types';

const fmt = (n: number, dp = 2) => n.toFixed(dp);

const chips = (() => {
  const live = premiumChipsList();
  return live.length > 0 ? live : ['GB200', 'B200', 'H200', 'H100', 'A100'];
})();

// Guaranteed on-demand reference cell per (segment, chip): int=GTD, form
// pooled, US only — no region fallback. A cell with no US series shows a
// dash rather than quietly substituting the all-regions pool (which mixes
// EU/APAC panels into a ladder labeled US). Guaranteed-only on purpose —
// the interruptible/spot pool (int=ALL) drags the number below the real
// on-demand rate (US H100 Hyperscaler $9.15 guaranteed vs $5.40 pooled).
const STAT_RANK: Record<string, number> = { Published: 0, Provisional: 1, Shadow: 2 };
function odCell(tier: Tier, chip: string): Rate | undefined {
  return headlineRates
    .filter((r) => r.tier === tier && r.gpu_model === chip &&
                   r.commitment_term === 'OnDemand' && r.form_factor === 'ALL' &&
                   r.region === 'US' && r.interruptibility === 'GTD' &&
                   r.promotion_status !== 'Shadow')
    .sort((a, b) =>
      (STAT_RANK[a.promotion_status] ?? 3) - (STAT_RANK[b.promotion_status] ?? 3) ||
      (b.n_sources ?? 0) - (a.n_sources ?? 0))[0];
}

type LadderRow = { chip: string; cells: Partial<Record<Tier, Rate | undefined>> };
const ladder: LadderRow[] = chips
  .map((chip) => {
    const cells: Partial<Record<Tier, Rate | undefined>> = {};
    for (const t of TIERS) cells[t] = odCell(t, chip);
    return { chip, cells };
  })
  // Drop chips with no guaranteed cell in any segment (e.g. GB200 today).
  .filter((row) => TIERS.some((t) => row.cells[t]));

function chipDisplay(token: string): string {
  return token.replace(/-/g, ' ');
}

function cellTitle(c: Rate): string {
  const kind = headlineStatOf(c);
  return `${kind === 'mean' ? 'Mean' : 'Median'} (n=${c.n_sources}) · region ${c.region} · median ${fmt(c.price_median)} · mean ${fmt(c.price_mean)} · IQR ${fmt(c.price_p25)}–${fmt(c.price_p75)}`;
}
---
<Base
  title="Reference Rates · CCIR"
  description="Daily guaranteed on-demand reference rates for GPU compute — Hyperscaler, Neocloud, and Marketplace median rates per chip."
  ogImage="/og/rates-live.png"
>
  <script is:inline type="application/ld+json" slot="head" set:html={JSON.stringify({
    '@context': 'https://schema.org',
    '@type': 'Dataset',
    name: 'CCIR GPU Compute Reference Rates',
    description: 'Daily reference rates for GPU compute rental — chip × deployment class × interruptibility × commitment term × region — computed from publicly posted rates across a fixed provider panel under a published methodology.',
    url: 'https://ccir.io/rates',
    creator: { '@type': 'Organization', name: 'CCIR', url: 'https://ccir.io' },
    temporalCoverage: '2026-04/..',
    spatialCoverage: 'United States, European Union',
    keywords: ['GPU rental rates', 'compute pricing', 'H100', 'H200', 'B200', 'reference rates', 'GPU-backed financing', 'AI infrastructure'],
    isAccessibleForFree: true,
  })} />
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Reference Rates · US · {meta.as_of_date}</div>
      <h1>Reference Rates</h1>
      <p class="standfirst">
        Guaranteed on-demand reference rate per chip across the three operator
        segments. Every cell is a published, citable series — panel depth,
        stat, and history disclosed. Committed term on <a href="/term">/term</a>;
        interruptible, regional, and every other grain on
        <a href="/explorer">/explorer</a>.
      </p>
    </header>

    <div class="table-wrap">
      <table class="data ladder-table">
        <thead>
          <tr>
            <th class="chip-col">Silicon</th>
            {TIERS.map((t) => (
              <th class={`tier-col tier-col-${t.toLowerCase()}`}>
                <span class={`tier-badge tier-badge-${t.toLowerCase()}`}>{TIER_LABELS_SHORT[t]}</span>
                <span class="th-sub">$/hr</span>
              </th>
            ))}
          </tr>
        </thead>
        <tbody>
          {ladder.map(({ chip, cells }) => (
            <tr>
              <td class="chip-cell"><div class="chip-name">{chipDisplay(chip)}</div></td>
              {TIERS.map((t) => {
                const c = cells[t];
                if (!c) return <td class="num empty">—</td>;
                return (
                  <td class={`num posted tier-pos-${t.toLowerCase()}`} title={cellTitle(c)}>
                    ${fmt(headlineValue(c))}
                    <div class="cell-sid">{c.series_id}</div>
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="table-foot">
      USD per GPU-hour · guaranteed on-demand, US series only · mean where the panel is deep (n≥10), median below that · a dash means no published US series for that cell · hover a rate for both stats, interquartile range (IQR), and panel depth.
    </p>

    <section class="defs-section">
      <TierDefinitions headerless={true} />
    </section>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { margin-bottom: 20px; max-width: 80ch; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-3xl);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 12px;
    }
    .standfirst a { color: var(--accent); }

    .table-wrap {
      border: 1px solid var(--rule);
      background: var(--surface);
      overflow-x: auto;
    }
    table.ladder-table { width: 100%; border-collapse: collapse; }
    table.ladder-table th.chip-col { text-align: left; width: 14%; }
    table.ladder-table th.tier-col { text-align: center; padding: 10px 14px; }
    table.ladder-table th.tier-col-t1 { color: var(--tier-t1); }
    table.ladder-table th.tier-col-t2 { color: var(--tier-t2); }
    table.ladder-table th.tier-col-t3 { color: var(--tier-t3); }
    table.ladder-table th .th-sub {
      display: block;
      font-size: calc(var(--fs-xs) - 2px);
      color: var(--ink-faint);
      font-weight: var(--weight-body);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      margin-top: 3px;
    }
    table.ladder-table .chip-cell { white-space: nowrap; }
    table.ladder-table .chip-cell .chip-name {
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink);
      font-weight: var(--weight-strong);
      letter-spacing: 0.04em;
    }
    table.ladder-table td.num { text-align: center; }
    table.ladder-table td.posted { font-weight: var(--weight-strong); cursor: help; }
    .cell-sid {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 2px);
      font-weight: var(--weight-body);
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      margin-top: 3px;
      white-space: nowrap;
    }
    /* Middle tier (Neocloud) is the market that matters — give it the accent. */
    table.ladder-table td.tier-pos-t2 { color: var(--accent); font-weight: var(--weight-strong); }
    table.ladder-table th.tier-col-t2 { color: var(--accent); }
    table.ladder-table td.tier-pos-t1, table.ladder-table td.tier-pos-t3 { color: var(--ink); }
    table.ladder-table td.empty { color: var(--ink-faint); }

    .table-foot {
      margin: 10px 0 0;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      line-height: 1.7;
      max-width: 90ch;
    }

    .defs-section { margin: 32px 0 0; }
  </style>
</Base>
