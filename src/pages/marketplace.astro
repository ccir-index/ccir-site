---
import Base from '../layouts/Base.astro';
import { meta } from '../data/snapshot';
import { PREMIUM_CHIPS } from '../data/marketplace';

const DEFAULT_CHIP = 'h100-sxm-80gb';
const mktMeta = (meta as any).marketplace_history;
const windowDays = mktMeta?.window_days ?? 7;
const nChips = mktMeta?.chips?.length ?? PREMIUM_CHIPS.length;
const nSources = mktMeta?.sources?.length ?? 5;
const windowEnd = mktMeta?.window_end ?? '—';
---
<Base title="Marketplace · CCIR">
  <section class="wrap top vast-page marketplace-page">
    <div class="kicker">MARKETPLACES · INTRADAY LEAST-EXPENSIVE AVAILABLE</div>
    <h1>Marketplace</h1>
    <div class="ticker-strip" role="group" aria-label="Snapshot stats">
      <div class="tk-cell"><span class="tk-lbl">Window</span><span class="tk-val">{windowDays}d</span></div>
      <div class="tk-cell"><span class="tk-lbl">Chips</span><span class="tk-val">{nChips}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Sources</span><span class="tk-val">{nSources}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Last cycle</span><span class="tk-val">{windowEnd}</span></div>
      <div class="tk-cell"><span class="tk-lbl">Cadence</span><span class="tk-val">3h</span></div>
      <div class="tk-cell tk-status"><span class="tk-dot"></span><span class="tk-val">LIVE</span></div>
    </div>
    <p class="standfirst lede">
      Intraday least-expensive available rates from third-party-host marketplaces.
      Vast.ai is restricted to verified hosts; RunPod is split by sub-product
      (Secure / Community / Spot / Cluster). Distinct from <a href="/markets">Providers</a>,
      which tracks operators that run their own datacenters.
    </p>

    <div class="controls">
      <div class="control-row chip-row">
        <span class="control-label">Chip</span>
        <div class="pill-group" id="chip-pills" role="group" aria-label="Select up to 3 chips">
          {PREMIUM_CHIPS.map((c) => (
            <button type="button" class="pill" data-chip={c.id} data-default={c.id === DEFAULT_CHIP}>
              {c.label}
            </button>
          ))}
        </div>
        <span class="chip-cap" id="chip-cap-hint">multi-select · up to 3</span>
      </div>

      <div class="control-row toggles-row">
        <label class="toggle">
          <input type="checkbox" id="spot-toggle" />
          Show interruptible
        </label>
        <label class="toggle">
          <input type="checkbox" id="cluster-toggle" checked />
          Show RunPod Cluster (bare-metal)
        </label>
        <label class="toggle log-toggle" id="log-toggle-wrap" hidden>
          <input type="checkbox" id="log-toggle" />
          Log scale
        </label>
      </div>
    </div>

    <div class="chart-wrap chart-wrap-hero">
      <div class="chart-status" id="chart-status">Loading…</div>
      <canvas id="chart" aria-label="Marketplace least-expensive available over time"></canvas>
    </div>

    <section class="legend-section">
      <header class="legend-head">
        <span class="sec-kicker-label">SUB-PRODUCTS</span>
        <span class="sec-note" id="legend-summary">—</span>
      </header>
      <div class="table-wrap">
        <table class="data multi-off" id="legend-table">
          <thead>
            <tr>
              <th class="chip-col">Chip</th>
              <th>Sub-product</th>
              <th class="num">Least expensive</th>
              <th class="num">Listings</th>
              <th class="num">Cycles</th>
            </tr>
          </thead>
          <tbody id="legend-tbody"></tbody>
        </table>
      </div>
    </section>

    <p class="footnote">
      Refreshed roughly every three hours. The plotted price is the
      lowest per-GPU rate available in each cycle. Vast.ai is restricted
      to verified hosts at 90% reliability or better; its dashed line
      shows where the typical verified listing sits relative to that
      floor. History begins on the day this product launched —
      earlier periods are not backfilled.
    </p>
  </section>

  <script>
    import Chart from 'chart.js/auto';
    import 'chartjs-adapter-date-fns';
    import {
      fetchMarketplaceCsv, filterRows, buildSeries, colorForSource,
      colorForChip, shortLabelForChip,
      type ChipId, type MarketplaceSeries,
    } from '../data/marketplace';

    const DEFAULT_CHIP: ChipId = 'h100-sxm-80gb';
    const MAX_CHIPS = 3;

    type Augmented = MarketplaceSeries & { chip: ChipId };

    const state = {
      chips: new Set<ChipId>([DEFAULT_CHIP]),
      include_spot: false,
      include_runpod_cluster: true,
      log_scale: false,
      // null entry = fetch failed / no data; treated as empty array downstream.
      cache: new Map<ChipId, Awaited<ReturnType<typeof fetchMarketplaceCsv>> | null>(),
    };

    const statusEl = document.getElementById('chart-status') as HTMLDivElement;
    const canvas = document.getElementById('chart') as HTMLCanvasElement;
    const spotToggle = document.getElementById('spot-toggle') as HTMLInputElement;
    const clusterToggle = document.getElementById('cluster-toggle') as HTMLInputElement;
    const logToggle = document.getElementById('log-toggle') as HTMLInputElement;
    const logToggleWrap = document.getElementById('log-toggle-wrap') as HTMLElement;
    const legendTbody = document.getElementById('legend-tbody') as HTMLElement;
    const legendSummary = document.getElementById('legend-summary') as HTMLElement;
    const legendTable = document.getElementById('legend-table') as HTMLElement;

    let chart: Chart<'line'> | null = null;

    function setStatus(msg: string | null) {
      if (msg === null) {
        statusEl.style.display = 'none';
        statusEl.textContent = '';
      } else {
        statusEl.style.display = 'flex';
        statusEl.textContent = msg;
      }
    }

    function syncPills() {
      const grp = document.getElementById('chip-pills');
      if (!grp) return;
      const atCap = state.chips.size >= MAX_CHIPS;
      grp.querySelectorAll<HTMLButtonElement>('.pill').forEach((p) => {
        const isOn = state.chips.has(p.dataset.chip as ChipId);
        p.classList.toggle('on', isOn);
        // At cap + not selected → muted (visual only; click is a no-op).
        p.classList.toggle('muted', atCap && !isOn);
      });
      const multi = state.chips.size > 1;
      legendTable.classList.toggle('multi-off', !multi);
      legendTable.classList.toggle('multi-on', multi);
      // Log toggle only meaningful in multi mode (single chip rarely needs it).
      logToggleWrap.hidden = !multi;
    }

    function fmtPrice(n: number | null): string {
      return n === null ? '—' : '$' + n.toFixed(2);
    }

    // Eastern Time, DST-aware. All site cadence labels are ET; chart ticks
    // and tooltips align here so users don't mentally convert from UTC.
    const ET_TZ = 'America/New_York';
    const fmtTickET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit', hourCycle: 'h23',
    });
    const fmtTickDayET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, month: 'short', day: 'numeric',
    });
    const fmtTooltipET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, year: 'numeric', month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit', hourCycle: 'h23',
    });
    function isMidnightET(ms: number): boolean {
      const parts = fmtTickET.formatToParts(ms);
      const hh = parts.find((p) => p.type === 'hour')?.value ?? '';
      const mm = parts.find((p) => p.type === 'minute')?.value ?? '';
      return hh === '00' && mm === '00';
    }

    function readToken(name: string): string {
      try {
        return getComputedStyle(document.documentElement).getPropertyValue(name).trim();
      } catch { return ''; }
    }

    function renderLegend(series: Augmented[]) {
      // Collapse cheapest+median pairs into one row each per (chip, source).
      const seen = new Set<string>();
      const rows = series.filter((s) => {
        if (s.variant !== 'cheapest') return false;
        const key = `${s.chip}::${s.source_name}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
      // Pin a vast.ai legend row per selected chip even when the series is
      // empty — explicit absence beats silent omission. Triggered only when
      // the chart already has at least one line (the all-empty case is
      // handled by the chart-status overlay upstream).
      type LegendEntry =
        | { kind: 'real'; series: Augmented }
        | { kind: 'absent'; chip: ChipId };
      const entries: LegendEntry[] = rows.map((s) => ({ kind: 'real', series: s }));
      for (const chip of state.chips) {
        const hasVast = rows.some((s) => s.chip === chip && s.source_name === 'vast_ai_verified');
        if (!hasVast) entries.push({ kind: 'absent', chip });
      }
      const totalObs = series.reduce((acc, s) => acc + s.points.length, 0);
      const subjectLabel = state.chips.size > 1
        ? `${rows.length} chip-sub-product lines`
        : `${rows.length} sub-products`;
      legendSummary.textContent = `${subjectLabel} · ${totalObs} observations`;
      const multi = state.chips.size > 1;
      legendTbody.innerHTML = entries.map((e) => {
        // Only emit the chip cell when comparing chips. Hiding via CSS broke
        // because Astro scoped styles don't reach innerHTML-inserted nodes
        // consistently — JS conditional render keeps header + body aligned.
        if (e.kind === 'absent') {
          const chipBadge = `<span class="chip-badge" style="background:${colorForChip(e.chip)}">${shortLabelForChip(e.chip)}</span>`;
          const dot = `<span class="legend-dot" style="background:${colorForSource('vast_ai_verified')};opacity:0.35"></span>`;
          const chipCell = multi ? `<td>${chipBadge}</td>` : '';
          return `<tr class="row-absent">` +
            chipCell +
            `<td class="provider">${dot}<code>vast_ai_verified</code><span class="absent-note">no data in window</span></td>` +
            `<td class="num posted">—</td>` +
            `<td class="num">—</td>` +
            `<td class="num dim">0</td>` +
          '</tr>';
        }
        const s = e.series;
        const lineColor = multi ? colorForChip(s.chip) : colorForSource(s.source_name);
        const dot = `<span class="legend-dot" style="background:${lineColor}"></span>`;
        const chipBadge = `<span class="chip-badge" style="background:${colorForChip(s.chip)}">${shortLabelForChip(s.chip)}</span>`;
        const nCell = s.latest_n !== null ? `${s.latest_n}` : '<span class="dim">—</span>';
        const chipCell = multi ? `<td>${chipBadge}</td>` : '';
        return '<tr>' +
          chipCell +
          `<td class="provider">${dot}<code>${s.source_display_name}</code></td>` +
          `<td class="num posted">${fmtPrice(s.latest_price)}</td>` +
          `<td class="num">${nCell}</td>` +
          `<td class="num dim">${s.points.length}</td>` +
        '</tr>';
      }).join('');
    }

    function renderChart(series: Augmented[]) {
      const multi = state.chips.size > 1;
      const datasets = series.map((s) => {
        const color = multi ? colorForChip(s.chip) : colorForSource(s.source_name);
        const label = multi
          ? `${shortLabelForChip(s.chip)} · ${s.source_display_name}`
          : s.source_display_name;
        return {
          label,
          data: s.points,
          borderColor: color,
          backgroundColor: color,
          borderWidth: s.variant === 'cheapest' ? 2 : 1,
          borderDash: s.variant === 'median' ? [3, 3] : [],
          pointRadius: s.variant === 'cheapest' ? 1.5 : 0,
          pointHoverRadius: 4,
          tension: 0,
          spanGaps: true,
          order: s.variant === 'median' ? 2 : 1,
        };
      });

      if (chart) chart.destroy();

      const inkDim = readToken('--ink-dim') || '#9a9991';
      const ink = readToken('--ink') || '#e8e6e1';
      const grid = readToken('--vast-grid') || 'rgba(128,128,128,0.2)';
      const monoFont = { family: 'IBM Plex Mono, ui-monospace, Menlo, monospace', size: 11 };

      chart = new Chart(canvas, {
        type: 'line',
        data: { datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'nearest', axis: 'x', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              displayColors: true,
              callbacks: {
                title: (items) => {
                  const x = items[0]?.parsed?.x;
                  return x ? `${fmtTooltipET.format(x)} ET` : '';
                },
                label: (ctx) => `${ctx.dataset.label}: $${(ctx.parsed.y as number).toFixed(2)}/h`,
              },
            },
          },
          scales: {
            x: {
              type: 'time',
              ticks: {
                color: inkDim,
                font: monoFont,
                maxRotation: 0,
                autoSkipPadding: 32,
                callback: (value) => {
                  const ms = typeof value === 'number' ? value : Number(value);
                  return isMidnightET(ms) ? fmtTickDayET.format(ms) : fmtTickET.format(ms);
                },
              },
              title: { display: true, text: 'Time (ET)', color: inkDim, font: monoFont },
              grid: { color: grid, drawOnChartArea: false },
              border: { color: grid },
            },
            y: {
              type: state.log_scale && multi ? 'logarithmic' : 'linear',
              title: { display: true, text: '$/GPU-hour', color: inkDim, font: monoFont },
              ticks: { color: ink, font: monoFont, callback: (v) => '$' + (v as number).toFixed(2) },
              grid: { color: grid },
              border: { color: grid },
            },
          },
        },
      });
    }

    async function ensureCached(chips: ChipId[]) {
      const misses = chips.filter((c) => !state.cache.has(c));
      await Promise.all(misses.map(async (c) => {
        try {
          state.cache.set(c, await fetchMarketplaceCsv(c));
        } catch (e) {
          state.cache.set(c, null);
        }
      }));
    }

    async function refresh() {
      setStatus('Loading…');
      const chips = [...state.chips];
      await ensureCached(chips);

      const series: Augmented[] = [];
      for (const chip of chips) {
        const rows = state.cache.get(chip) ?? [];
        if (rows.length === 0) continue;
        const filtered = filterRows(rows, {
          include_spot: state.include_spot,
          include_runpod_cluster: state.include_runpod_cluster,
        });
        for (const s of buildSeries(filtered)) series.push({ ...s, chip });
      }

      if (series.length === 0) {
        const label = chips.length === 1
          ? `No data for ${chips[0]} yet — history accrues as the daily pipeline runs.`
          : 'No matching observations yet for the selected chips.';
        setStatus(label);
        if (chart) { chart.destroy(); chart = null; }
        legendTbody.innerHTML = '';
        legendSummary.textContent = '0 sub-products';
        return;
      }

      setStatus(null);
      renderChart(series);
      renderLegend(series);
    }

    document.getElementById('chip-pills')!.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const pill = t.closest<HTMLButtonElement>('.pill');
      if (!pill || !pill.dataset.chip) return;
      const chip = pill.dataset.chip as ChipId;
      if (state.chips.has(chip)) {
        // Don't allow zero chips selected — drop is a no-op when only 1 left.
        if (state.chips.size > 1) state.chips.delete(chip);
      } else {
        if (state.chips.size >= MAX_CHIPS) return;
        state.chips.add(chip);
      }
      syncPills();
      refresh();
    });
    spotToggle.addEventListener('change', () => {
      state.include_spot = spotToggle.checked;
      refresh();
    });
    clusterToggle.addEventListener('change', () => {
      state.include_runpod_cluster = clusterToggle.checked;
      refresh();
    });
    logToggle.addEventListener('change', () => {
      state.log_scale = logToggle.checked;
      refresh();
    });

    syncPills();
    refresh();
  </script>

  <style>
    /* Marketplace styling reuses the Bloomberg-feel patterns from /vast via
       the shared `.vast-page` wrap class plus the `--vast-*` token group at
       the bottom of tokens.css. The page-specific `.marketplace-page` class
       is reserved for any one-off tweaks; today it just signals scope. */
    .vast-page.top { padding-top: 24px; }

    .vast-page > .kicker {
      color: var(--accent);
      letter-spacing: 0.14em;
      margin-bottom: 4px;
    }
    .vast-page h1 {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      margin: 0 0 10px;
      letter-spacing: -0.01em;
      line-height: 1.1;
    }

    /* Ticker strip — Bloomberg-style horizontal stat band */
    .vast-page .ticker-strip {
      display: flex;
      flex-wrap: wrap;
      align-items: stretch;
      border: 1px solid var(--rule-2);
      background: var(--vast-panel-bg);
      margin: 0 0 18px;
      font-family: var(--font-mono);
    }
    .vast-page .tk-cell {
      display: flex;
      align-items: baseline;
      gap: 8px;
      padding: 7px 14px;
      border-right: 1px solid var(--rule);
      flex: 0 0 auto;
    }
    .vast-page .tk-cell:last-child { border-right: 0; }
    .vast-page .tk-lbl {
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: 0.10em;
      font-weight: var(--weight-strong);
    }
    .vast-page .tk-val {
      font-size: var(--fs-sm);
      color: var(--ink);
      font-variant-numeric: tabular-nums;
      font-weight: var(--weight-strong);
    }
    .vast-page .tk-status { margin-left: auto; gap: 6px; }
    .vast-page .tk-status .tk-val { color: var(--pos); letter-spacing: 0.10em; }
    .vast-page .tk-dot {
      width: 7px;
      height: 7px;
      background: var(--pos);
      box-shadow: 0 0 6px var(--pos);
      display: inline-block;
      border-radius: 50%;
      animation: vast-pulse 2.4s ease-in-out infinite;
    }
    @keyframes vast-pulse {
      0%, 100% { opacity: 1; }
      50%      { opacity: 0.35; }
    }

    .vast-page .lede { max-width: 80ch; margin: 4px 0 22px; }
    .vast-page .lede a { color: var(--accent); }

    .vast-page .controls {
      background: var(--vast-panel-bg);
      border: 1px solid var(--rule);
      padding: 12px 14px;
      margin-bottom: 18px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .vast-page .control-row {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }
    .vast-page .control-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      min-width: 56px;
    }
    .vast-page .pill-group { display: flex; flex-wrap: wrap; gap: 5px; }
    .vast-page .pill {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--surface);
      color: var(--ink-dim);
      border: 1px solid var(--rule-2);
      padding: 5px 10px;
      cursor: pointer;
      border-radius: 0;
      font-weight: var(--weight-strong);
    }
    .vast-page .pill:hover { color: var(--ink); border-color: var(--accent); }
    .vast-page .pill.on {
      color: var(--accent);
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, transparent);
    }
    .vast-page .pill.muted { opacity: 0.45; cursor: not-allowed; }
    .vast-page .pill.muted:hover { color: var(--ink-dim); border-color: var(--rule-2); }

    .vast-page .chip-cap {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      margin-left: 8px;
    }

    .vast-page .toggles-row { gap: 22px; }
    .vast-page .toggle {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      cursor: pointer;
    }

    .vast-page .chart-wrap {
      position: relative;
      border: 1px solid var(--rule);
      background: var(--vast-panel-bg);
      padding: 14px;
      height: 460px;
      margin-bottom: 12px;
      border-radius: 0;
    }
    .vast-page .chart-wrap-hero {
      background: var(--vast-panel-bg-hero);
      border-color: var(--rule-2);
      /* Distinguishing hairline accent so users feel /marketplace is its own
         surface vs /markets — picks up the warn token (intraday cadence). */
      border-left-width: 3px;
      border-left-color: var(--vast-warn);
    }
    .vast-page .chart-status {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      background: color-mix(in srgb, var(--vast-panel-bg-hero) 80%, transparent);
      pointer-events: none;
      padding: 0 24px;
      text-align: center;
    }

    .vast-page .legend-section { margin-top: 14px; }
    .vast-page .legend-head {
      display: flex;
      align-items: baseline;
      gap: 10px;
      margin-bottom: 8px;
      flex-wrap: wrap;
    }
    .vast-page .sec-kicker-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: 0.14em;
      font-weight: var(--weight-strong);
      padding-left: 4px;
      border-left: 1px solid var(--rule-2);
      padding-right: 2px;
    }
    .vast-page .sec-note {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      margin-left: auto;
    }

    .vast-page .table-wrap {
      border: 1px solid var(--rule);
      background: var(--vast-panel-bg);
      overflow-x: auto;
    }
    .vast-page .data {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
    }
    .vast-page .data th,
    .vast-page .data td {
      padding: var(--vast-cell-y) var(--vast-cell-x);
      border-bottom: 1px solid var(--rule);
      text-align: left;
      vertical-align: middle;
      height: var(--vast-row-h);
      font-variant-numeric: tabular-nums;
    }
    .vast-page .data th + th,
    .vast-page .data td + td {
      border-left: 1px solid var(--rule);
    }
    .vast-page .data th {
      background: var(--surface-3);
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: 0.10em;
      font-weight: var(--weight-strong);
      border-bottom: 1px solid var(--rule-2);
      white-space: nowrap;
    }
    .vast-page .data td.num,
    .vast-page .data th.num {
      text-align: right;
    }
    .vast-page .data td.dim,
    .vast-page .data .dim { color: var(--ink-dim); }
    .vast-page .data tbody tr:nth-child(even) td {
      background: var(--vast-row-stripe);
    }
    .vast-page .data tbody tr:hover td { background: var(--surface-3); }
    .vast-page .data tbody tr.row-absent td { color: var(--ink-dim); }
    .vast-page .data tbody tr.row-absent td.posted { color: var(--ink-dim); }
    .vast-page .absent-note {
      font-family: var(--font-mono);
