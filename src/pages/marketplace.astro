---
import Base from '../layouts/Base.astro';
import { meta } from '../data/snapshot';
import { PREMIUM_CHIPS } from '../data/marketplace';

const DEFAULT_CHIP = 'h100-sxm-80gb';
const mktMeta = (meta as any).marketplace_history;
---
<Base title="Marketplace · CCIR">
  <section class="wrap top">
    <div class="kicker">Real-time market color · {mktMeta?.window_days ?? 7}-day window · least expensive available</div>
    <h1>Marketplace</h1>
    <p class="standfirst lede">
      Intraday least-expensive available rates from third-party-host marketplaces.
      Vast.ai is restricted to verified hosts; RunPod is split by sub-product
      (Secure / Community / Spot / Cluster). Distinct from <a href="/markets">/markets</a>,
      which tracks operators that run their own datacenters.
    </p>

    <div class="controls">
      <div class="control-row chip-row">
        <span class="control-label">Chip</span>
        <div class="pill-group" id="chip-pills" role="group" aria-label="Select up to 3 chips">
          {PREMIUM_CHIPS.map((c) => (
            <button type="button" class="pill" data-chip={c.id} data-default={c.id === DEFAULT_CHIP}>
              {c.label}
            </button>
          ))}
        </div>
        <span class="chip-cap" id="chip-cap-hint">multi-select · up to 3</span>
      </div>

      <div class="control-row toggles-row">
        <label class="toggle">
          <input type="checkbox" id="spot-toggle" />
          Show interruptible
        </label>
        <label class="toggle">
          <input type="checkbox" id="cluster-toggle" checked />
          Show RunPod Cluster (bare-metal)
        </label>
        <label class="toggle log-toggle" id="log-toggle-wrap" hidden>
          <input type="checkbox" id="log-toggle" />
          Log scale
        </label>
      </div>
    </div>

    <div class="chart-wrap">
      <div class="chart-status" id="chart-status">Loading…</div>
      <canvas id="chart" aria-label="Marketplace least-expensive available over time"></canvas>
    </div>

    <section class="legend-section">
      <header class="legend-head">
        <span class="sec-kicker">Sub-products</span>
        <span class="sec-sub" id="legend-summary">—</span>
      </header>
      <div class="table-wrap">
        <table class="data multi-off" id="legend-table">
          <thead>
            <tr>
              <th class="chip-col">Chip</th>
              <th>Sub-product</th>
              <th class="num">Least expensive</th>
              <th class="num">Listings</th>
              <th class="num">Cycles</th>
            </tr>
          </thead>
          <tbody id="legend-tbody"></tbody>
        </table>
      </div>
    </section>

    <p class="footnote">
      Per-cycle observation feed (<code>gold.marketplace_history</code>),
      published in <code>marketplace_&lt;chip&gt;.csv</code> under the
      daily snapshot. Vast.ai filter: <code>verification == 'verified'</code>
      AND <code>is_vm_deverified == False</code> AND <code>reliability ≥ 90%</code>.
      Headline price is the MIN per-GPU rate per cycle. Vast.ai's
      <em>median</em> series shows where the typical verified listing sits
      relative to the floor. History begins on the first day this product
      shipped — there is no backfill.
    </p>
  </section>

  <script>
    import Chart from 'chart.js/auto';
    import 'chartjs-adapter-date-fns';
    import {
      fetchMarketplaceCsv, filterRows, buildSeries, colorForSource,
      colorForChip, shortLabelForChip,
      type ChipId, type MarketplaceSeries,
    } from '../data/marketplace';

    const DEFAULT_CHIP: ChipId = 'h100-sxm-80gb';
    const MAX_CHIPS = 3;

    type Augmented = MarketplaceSeries & { chip: ChipId };

    const state = {
      chips: new Set<ChipId>([DEFAULT_CHIP]),
      include_spot: false,
      include_runpod_cluster: true,
      log_scale: false,
      // null entry = fetch failed / no data; treated as empty array downstream.
      cache: new Map<ChipId, Awaited<ReturnType<typeof fetchMarketplaceCsv>> | null>(),
    };

    const statusEl = document.getElementById('chart-status') as HTMLDivElement;
    const canvas = document.getElementById('chart') as HTMLCanvasElement;
    const spotToggle = document.getElementById('spot-toggle') as HTMLInputElement;
    const clusterToggle = document.getElementById('cluster-toggle') as HTMLInputElement;
    const logToggle = document.getElementById('log-toggle') as HTMLInputElement;
    const logToggleWrap = document.getElementById('log-toggle-wrap') as HTMLElement;
    const legendTbody = document.getElementById('legend-tbody') as HTMLElement;
    const legendSummary = document.getElementById('legend-summary') as HTMLElement;
    const legendTable = document.getElementById('legend-table') as HTMLElement;

    let chart: Chart<'line'> | null = null;

    function setStatus(msg: string | null) {
      if (msg === null) {
        statusEl.style.display = 'none';
        statusEl.textContent = '';
      } else {
        statusEl.style.display = 'flex';
        statusEl.textContent = msg;
      }
    }

    function syncPills() {
      const grp = document.getElementById('chip-pills');
      if (!grp) return;
      const atCap = state.chips.size >= MAX_CHIPS;
      grp.querySelectorAll<HTMLButtonElement>('.pill').forEach((p) => {
        const isOn = state.chips.has(p.dataset.chip as ChipId);
        p.classList.toggle('on', isOn);
        // At cap + not selected → muted (visual only; click is a no-op).
        p.classList.toggle('muted', atCap && !isOn);
      });
      const multi = state.chips.size > 1;
      legendTable.classList.toggle('multi-off', !multi);
      legendTable.classList.toggle('multi-on', multi);
      // Log toggle only meaningful in multi mode (single chip rarely needs it).
      logToggleWrap.hidden = !multi;
    }

    function fmtPrice(n: number | null): string {
      return n === null ? '—' : '$' + n.toFixed(2);
    }

    // Eastern Time, DST-aware. All site cadence labels are ET; chart ticks
    // and tooltips align here so users don't mentally convert from UTC.
    const ET_TZ = 'America/New_York';
    const fmtTickET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit', hourCycle: 'h23',
    });
    const fmtTickDayET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, month: 'short', day: 'numeric',
    });
    const fmtTooltipET = new Intl.DateTimeFormat('en-US', {
      timeZone: ET_TZ, year: 'numeric', month: 'short', day: 'numeric',
      hour: 'numeric', minute: '2-digit', hourCycle: 'h23',
    });
    function isMidnightET(ms: number): boolean {
      const parts = fmtTickET.formatToParts(ms);
      const hh = parts.find((p) => p.type === 'hour')?.value ?? '';
      const mm = parts.find((p) => p.type === 'minute')?.value ?? '';
      return hh === '00' && mm === '00';
    }

    function renderLegend(series: Augmented[]) {
      // Collapse cheapest+median pairs into one row each per (chip, source).
      const seen = new Set<string>();
      const rows = series.filter((s) => {
        if (s.variant !== 'cheapest') return false;
        const key = `${s.chip}::${s.source_name}`;
        if (seen.has(key)) return false;
        seen.add(key);
        return true;
      });
      // Pin a vast.ai legend row per selected chip even when the series is
      // empty — explicit absence beats silent omission. Triggered only when
      // the chart already has at least one line (the all-empty case is
      // handled by the chart-status overlay upstream).
      type LegendEntry =
        | { kind: 'real'; series: Augmented }
        | { kind: 'absent'; chip: ChipId };
      const entries: LegendEntry[] = rows.map((s) => ({ kind: 'real', series: s }));
      for (const chip of state.chips) {
        const hasVast = rows.some((s) => s.chip === chip && s.source_name === 'vast_ai_verified');
        if (!hasVast) entries.push({ kind: 'absent', chip });
      }
      const totalObs = series.reduce((acc, s) => acc + s.points.length, 0);
      const subjectLabel = state.chips.size > 1
        ? `${rows.length} chip-sub-product lines`
        : `${rows.length} sub-products`;
      legendSummary.textContent = `${subjectLabel} · ${totalObs} observations`;
      const multi = state.chips.size > 1;
      legendTbody.innerHTML = entries.map((e) => {
        if (e.kind === 'absent') {
          const chipBadge = `<span class="chip-badge" style="background:${colorForChip(e.chip)}">${shortLabelForChip(e.chip)}</span>`;
          const dot = `<span class="legend-dot absent-dot" style="background:${colorForSource('vast_ai_verified')}"></span>`;
          return '<tr class="absent-row">' +
            `<td class="chip-col">${chipBadge}</td>` +
            `<td class="provider">${dot}<code>vast_ai_verified</code><span class="absent-note">no data in window</span></td>` +
            `<td class="num posted">—</td>` +
            `<td class="num">—</td>` +
            `<td class="num dim">0</td>` +
          '</tr>';
        }
        const s = e.series;
        const lineColor = multi ? colorForChip(s.chip) : colorForSource(s.source_name);
        const dot = `<span class="legend-dot" style="background:${lineColor}"></span>`;
        const chipBadge = `<span class="chip-badge" style="background:${colorForChip(s.chip)}">${shortLabelForChip(s.chip)}</span>`;
        const nCell = s.latest_n !== null ? `${s.latest_n}` : '<span class="dim">—</span>';
        return '<tr>' +
          `<td class="chip-col">${chipBadge}</td>` +
          `<td class="provider">${dot}<code>${s.source_display_name}</code></td>` +
          `<td class="num posted">${fmtPrice(s.latest_price)}</td>` +
          `<td class="num">${nCell}</td>` +
          `<td class="num dim">${s.points.length}</td>` +
        '</tr>';
      }).join('');
    }

    function renderChart(series: Augmented[]) {
      const multi = state.chips.size > 1;
      const datasets = series.map((s) => {
        const color = multi ? colorForChip(s.chip) : colorForSource(s.source_name);
        const label = multi
          ? `${shortLabelForChip(s.chip)} · ${s.source_display_name}`
          : s.source_display_name;
        return {
          label,
          data: s.points,
          borderColor: color,
          backgroundColor: color,
          borderWidth: s.variant === 'cheapest' ? 2 : 1,
          borderDash: s.variant === 'median' ? [3, 3] : [],
          pointRadius: s.variant === 'cheapest' ? 1.5 : 0,
          pointHoverRadius: 4,
          tension: 0,
          spanGaps: true,
          order: s.variant === 'median' ? 2 : 1,
        };
      });

      if (chart) chart.destroy();

      const styles = getComputedStyle(document.documentElement);
      const inkColor = styles.getPropertyValue('--ink').trim() || '#0d0d0d';
      const ruleColor = styles.getPropertyValue('--rule').trim() || '#d4d0c4';
      const dimColor = styles.getPropertyValue('--ink-dim').trim() || '#5b5852';

      chart = new Chart(canvas, {
        type: 'line',
        data: { datasets },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'nearest', axis: 'x', intersect: false },
          plugins: {
            legend: { display: false },
            tooltip: {
              displayColors: true,
              callbacks: {
                title: (items) => {
                  const x = items[0]?.parsed?.x;
                  return x ? `${fmtTooltipET.format(x)} ET` : '';
                },
                label: (ctx) => `${ctx.dataset.label}: $${(ctx.parsed.y as number).toFixed(2)}/h`,
              },
            },
          },
          scales: {
            x: {
              type: 'time',
              ticks: {
                color: dimColor,
                maxRotation: 0,
                autoSkipPadding: 32,
                callback: (value) => {
                  const ms = typeof value === 'number' ? value : Number(value);
                  return isMidnightET(ms) ? fmtTickDayET.format(ms) : fmtTickET.format(ms);
                },
              },
              title: { display: true, text: 'Time (ET)', color: dimColor },
              grid: { color: ruleColor, drawOnChartArea: false },
              border: { color: ruleColor },
            },
            y: {
              type: state.log_scale && multi ? 'logarithmic' : 'linear',
              title: { display: true, text: '$/GPU-hour', color: dimColor },
              ticks: { color: inkColor, callback: (v) => '$' + (v as number).toFixed(2) },
              grid: { color: ruleColor },
              border: { color: ruleColor },
            },
          },
        },
      });
    }

    async function ensureCached(chips: ChipId[]) {
      const misses = chips.filter((c) => !state.cache.has(c));
      await Promise.all(misses.map(async (c) => {
        try {
          state.cache.set(c, await fetchMarketplaceCsv(c));
        } catch (e) {
          state.cache.set(c, null);
        }
      }));
    }

    async function refresh() {
      setStatus('Loading…');
      const chips = [...state.chips];
      await ensureCached(chips);

      const series: Augmented[] = [];
      for (const chip of chips) {
        const rows = state.cache.get(chip) ?? [];
        if (rows.length === 0) continue;
        const filtered = filterRows(rows, {
          include_spot: state.include_spot,
          include_runpod_cluster: state.include_runpod_cluster,
        });
        for (const s of buildSeries(filtered)) series.push({ ...s, chip });
      }

      if (series.length === 0) {
        const label = chips.length === 1
          ? `No data for ${chips[0]} yet — history accrues as the daily pipeline runs.`
          : 'No matching observations yet for the selected chips.';
        setStatus(label);
        if (chart) { chart.destroy(); chart = null; }
        legendTbody.innerHTML = '';
        legendSummary.textContent = '0 sub-products';
        return;
      }

      setStatus(null);
      renderChart(series);
      renderLegend(series);
    }

    document.getElementById('chip-pills')!.addEventListener('click', (ev) => {
      const t = ev.target as HTMLElement;
      const pill = t.closest<HTMLButtonElement>('.pill');
      if (!pill || !pill.dataset.chip) return;
      const chip = pill.dataset.chip as ChipId;
      if (state.chips.has(chip)) {
        // Don't allow zero chips selected — drop is a no-op when only 1 left.
        if (state.chips.size > 1) state.chips.delete(chip);
      } else {
        if (state.chips.size >= MAX_CHIPS) return;
        state.chips.add(chip);
      }
      syncPills();
      refresh();
    });
    spotToggle.addEventListener('change', () => {
      state.include_spot = spotToggle.checked;
      refresh();
    });
    clusterToggle.addEventListener('change', () => {
      state.include_runpod_cluster = clusterToggle.checked;
      refresh();
    });
    logToggle.addEventListener('change', () => {
      state.log_scale = logToggle.checked;
      refresh();
    });

    syncPills();
    refresh();
  </script>

  <style>
    .top { padding-top: 28px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-2xl);
      margin: 6px 0 12px;
      letter-spacing: -0.005em;
    }
    .lede {
      max-width: 80ch;
      margin: 8px 0 24px;
    }
    .lede a { color: var(--accent); }

    .controls {
      background: var(--surface-2);
      border: 1px solid var(--rule);
      padding: 14px 16px;
      margin-bottom: 18px;
      display: flex;
      flex-direction: column;
      gap: 12px;
    }
    .control-row {
      display: flex;
      align-items: center;
      gap: 14px;
      flex-wrap: wrap;
    }
    .control-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
      min-width: 56px;
    }
    .pill-group { display: flex; flex-wrap: wrap; gap: 6px; }
    .pill {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--surface);
      color: var(--ink-dim);
      border: 1px solid var(--rule-2);
      padding: 6px 12px;
      cursor: pointer;
      border-radius: var(--rad);
      font-weight: var(--weight-strong);
    }
    .pill:hover { color: var(--ink); border-color: var(--accent); }
    .pill.on {
      color: var(--accent);
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, transparent);
    }
    .pill.muted { opacity: 0.45; cursor: not-allowed; }
    .pill.muted:hover { color: var(--ink-dim); border-color: var(--rule-2); }

    .chip-cap {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      margin-left: 8px;
    }

    .toggles-row { gap: 22px; }
    .toggle {
      display: flex;
      align-items: center;
      gap: 6px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      cursor: pointer;
    }

    .chart-wrap {
      position: relative;
      border: 1px solid var(--rule);
      /* Subtle distinguishing accent so users feel /marketplace is a different
         surface than /markets. */
      border-left-width: 3px;
      border-left-color: var(--warn);
      background: var(--surface);
      padding: 16px;
      height: 460px;
      margin-bottom: 18px;
    }
    .chart-status {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      background: color-mix(in srgb, var(--surface) 80%, transparent);
      pointer-events: none;
      padding: 0 24px;
      text-align: center;
    }

    .legend-section { margin-top: 8px; }
    .legend-head {
      display: flex;
      align-items: baseline;
      gap: 16px;
      margin-bottom: 12px;
      padding-bottom: 6px;
      border-bottom: 1px solid var(--rule);
    }
    .sec-kicker {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--accent);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      font-weight: var(--weight-strong);
    }
    .sec-sub {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
    }
    .table-wrap {
      border: 1px solid var(--rule);
      background: var(--surface);
      overflow-x: auto;
    }
    #legend-table { width: 100%; }
    #legend-table td.provider {
      display: flex;
      align-items: center;
      gap: 8px;
    }
    #legend-table td.provider code {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-sm) - 1px);
      color: var(--ink);
      letter-spacing: 0.02em;
    }
    .legend-dot {
      display: inline-block;
      width: 10px;
      height: 10px;
      border-radius: 50%;
    }
    .chip-badge {
      display: inline-block;
      padding: 2px 7px;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      font-weight: var(--weight-strong);
      color: #fff;
      border-radius: var(--rad);
      letter-spacing: 0.05em;
      text-transform: uppercase;
    }
    /* Hide the chip column when only one chip is selected — keeps legend tight. */
    #legend-table.multi-off .chip-col { display: none; }

    .absent-row td { color: var(--ink-dim); }
    .absent-row .absent-dot { opacity: 0.35; }
    .absent-row .absent-note {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      letter-spacing: 0.04em;
      margin-left: 8px;
      font-style: italic;
    }

    .footnote {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      margin: 18px 0 0;
      padding: 10px 14px;
      background: var(--surface-2);
      border-left: 2px solid var(--neutral);
      max-width: 80ch;
      line-height: 1.55;
    }
    .footnote code {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-sm) - 1px);
      color: var(--accent);
    }

    @media (max-width: 720px) {
      .control-row { gap: 8px; }
      .control-label { min-width: 0; }
      .toggles-row { flex-direction: column; align-items: flex-start; gap: 8px; }
      .chart-wrap { height: 360px; padding: 10px; }
    }
  </style>
</Base>
