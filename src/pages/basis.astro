---
import Base from '../layouts/Base.astro';
import { vastBasis } from '../data/vast_basis';
import { meta } from '../data/snapshot';

const CHIP_ORDER = ['B200', 'H200', 'H100', 'A100', 'GB200'];
const rows = [...vastBasis].sort(
  (a, b) => CHIP_ORDER.indexOf(a.gpu_model) - CHIP_ORDER.indexOf(b.gpu_model),
);

const fmtUsd = (v: number | null) => (v == null ? '—' : `$${v.toFixed(2)}`);
const fmtPct = (v: number | null) =>
  v == null ? '—' : `${v >= 0 ? '+' : ''}${v.toFixed(1)}%`;
const dir = (v: number | null) =>
  v == null ? 'flat' : v > 0.5 ? 'up' : v < -0.5 ? 'down' : 'flat';
const inputLabel = (s: string) =>
  s === 'min_bid' ? 'bid · clearing floor' : 'on-demand · live ask';

const asOf = rows[0]?.as_of_date ?? meta.as_of_date;
const windowDays = rows[0]?.window_days ?? 7;
---
<Base
  title="Clearing Basis · CCIR"
  description="How the one live, executable marketplace venue (Vast) prices relative to the posted list-ask floor at matched tier. A standalone CCIR market-intelligence overlay on marketplace clearing."
>
  <section class="wrap top">
    <div class="kicker">Overlay · Marketplace clearing vs list-ask</div>
    <h1>Clearing Basis</h1>
    <p class="dek">
      CCIR's headline reference rate is built from posted list-asks — every
      panel source posts a rate card. One venue is different: Vast.ai is a live,
      continuously-repriced, executable marketplace. Vast is tracked separately so the list-ask series stays clean, and re-surfaced here as a
      basis: how the live marketplace price sits relative to the ex-Vast
      list-ask floor at matched tier (Tier 3). Positive = the live venue is
      pricing <em>above</em> posted list-asks; negative = below.
    </p>

    <table class="basis">
      <thead>
        <tr>
          <th>Chip</th>
          <th class="num">List-ask floor</th>
          <th class="num">Vast</th>
          <th class="num">Basis · {windowDays}d</th>
          <th class="num">Basis · 1d</th>
          <th class="num">n (vast/list)</th>
        </tr>
      </thead>
      <tbody>
        {rows.map((r) => (
          <tr>
            <td class="chip">{r.gpu_model}</td>
            <td class="num">{fmtUsd(r.listask_floor_7d)}</td>
            <td class="num">
              {fmtUsd(r.vast_price_7d)}
              <span class="src">{inputLabel(r.vast_input)}</span>
            </td>
            <td class={`num basis-${dir(r.basis_pct_7d)}`}>{fmtPct(r.basis_pct_7d)}</td>
            <td class={`num basis-${dir(r.basis_pct_1d)}`}>{fmtPct(r.basis_pct_1d)}</td>
            <td class="num muted">{r.n_vast_src}/{r.n_listask_src}</td>
          </tr>
        ))}
      </tbody>
    </table>

    <p class="note">
      As of {asOf} · {windowDays}-day window · operator-equal medians, matched
      tier (Tier 3). Input is the bid clearing floor where Vast exposes one,
      otherwise the on-demand live ask (flagged per row). <strong>Single-venue
      signal</strong> — Vast only; it is the lone executable marketplace in the
      panel, not the whole market. A single-venue market-intelligence signal.
    </p>

    <div class="occ-section">
      <div class="kicker">Implied market utilization · same venue, quantity side · since 2026-05-13 · 4 snapshots/day</div>
      <h2>Implied market utilization — Vast marketplace</h2>
      <p class="dek">
        The same venue's listings disclose how much of each machine is
        currently rentable — enough to reconstruct occupancy machine by
        machine, snapshot by snapshot. Both lines read the same direction —
        higher means tighter. <strong>Capacity</strong> (solid): share of listed
        GPU capacity not currently rentable. <strong>Whole nodes</strong>
        (dashed): share of machines without a rentable 8-GPU block.
        The panel-wide availability view is a separate product —
        see <a href="/utilization">Availability</a>; the two are never
        blended.
      </p>
      <div class="occ-pills" id="occ-pills" role="group" aria-label="Select a chip"></div>
      <div class="occ-chart-wrap">
        <div class="occ-status" id="occ-status">Loading…</div>
        <img
          id="occ-card"
          class="card-img"
          data-as-of={meta.as_of_date}
          alt="Occupancy chart card: Vast marketplace implied utilization over time"
        />
      </div>
      <p class="note" id="occ-note">
        Four snapshots daily. A machine with zero rentable chunks may be fully
        rented <em>or</em> host-paused — the public feed cannot distinguish
        them, so the utilization read is IMPLIED: share of listed capacity not currently
        rentable. Denominator is listed capacity only. History begins
        2026-05-13. Single-venue market-intelligence signal.
      </p>
    </div>
  </section>

  <script>
    import { OCC_CHIPS, cardUrl, type OccChipId } from '../data/utilization';

    const occState = { chip: 'h100-sxm' as OccChipId };

    const pillsEl = document.getElementById('occ-pills') as HTMLElement;
    const occStatus = document.getElementById('occ-status') as HTMLElement;
    const occImg = document.getElementById('occ-card') as HTMLImageElement;
    const AS_OF = occImg.dataset.asOf ?? '';

    pillsEl.innerHTML = OCC_CHIPS.map((c) =>
      `<button type="button" class="occ-pill" data-chip="${c.id}">${c.label}</button>`).join('');

    function currentTheme(): string {
      return document.documentElement.getAttribute('data-theme') || 'editorial';
    }

    occImg.addEventListener('load', () => {
      occImg.style.visibility = 'visible';
      occStatus.style.display = 'none';
    });
    // Occupancy cards can be absent for a chip on a given day (no GB200
    // occupancy most days) — the 404 lands here.
    occImg.addEventListener('error', () => {
      occImg.style.visibility = 'hidden';
      occStatus.style.display = 'flex';
      occStatus.textContent =
        'Card not yet published for this chip — falls back to tomorrow’s run.';
    });

    function refreshOcc() {
      occStatus.style.display = 'flex';
      occStatus.textContent = 'Loading…';
      occImg.style.visibility = 'hidden';
      occImg.src = cardUrl('occupancy', occState.chip, currentTheme(), AS_OF);
    }

    // Re-fetch the matching theme variant when the site theme toggles.
    new MutationObserver(() => refreshOcc()).observe(document.documentElement, {
      attributes: true, attributeFilter: ['data-theme'],
    });

    function syncOccPills() {
      pillsEl.querySelectorAll<HTMLButtonElement>('.occ-pill').forEach((p) => {
        p.classList.toggle('on', p.dataset.chip === occState.chip);
      });
    }

    pillsEl.addEventListener('click', (ev) => {
      const pill = (ev.target as HTMLElement).closest<HTMLButtonElement>('.occ-pill');
      if (!pill || !pill.dataset.chip) return;
      occState.chip = pill.dataset.chip as OccChipId;
      syncOccPills();
      refreshOcc();
    });

    syncOccPills();
    refreshOcc();
  </script>

  <style>
    .top { padding-top: 40px; padding-bottom: 56px; }
    .kicker {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      color: var(--accent);
      margin-bottom: 10px;
    }
    h1 { margin: 0 0 12px; }
    .dek {
      max-width: 760px;
      font-size: var(--fs-md);
      line-height: 1.6;
      color: var(--ink);
      margin-bottom: 28px;
    }
    table.basis {
      width: 100%;
      border-collapse: collapse;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
    }
    table.basis th,
    table.basis td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--rule);
      text-align: left;
      vertical-align: baseline;
    }
    table.basis th {
      font-size: var(--fs-xs);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eye);
      color: var(--ink-dim);
      font-weight: var(--weight-strong);
    }
    table.basis .num { text-align: right; font-variant-numeric: tabular-nums; }
    table.basis th.num { text-align: right; }
    td.chip { font-weight: var(--weight-strong); color: var(--ink); }
    .src {
      display: block;
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-faint);
      letter-spacing: 0.02em;
      margin-top: 2px;
    }
    .muted { color: var(--ink-faint); }
    .basis-up { color: #c0392b; font-weight: var(--weight-strong); }
    .basis-down { color: #1e7a52; font-weight: var(--weight-strong); }
    .basis-flat { color: var(--ink-dim); }
    .note {
      max-width: 760px;
      margin-top: 22px;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      line-height: 1.6;
      color: var(--ink-dim);
    }

    /* Measured-occupancy section */
    .occ-section { margin-top: 48px; }
    .occ-section h2 { margin: 0 0 12px; }
    .occ-pills { display: flex; flex-wrap: wrap; gap: 5px; margin-bottom: 12px; }
    .occ-section :global(.occ-pill) {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: 0.04em;
      text-transform: uppercase;
      background: var(--surface);
      color: var(--ink-dim);
      border: 1px solid var(--rule-2);
      padding: 5px 10px;
      cursor: pointer;
      border-radius: 0;
      font-weight: var(--weight-strong);
    }
    .occ-section :global(.occ-pill:hover) { color: var(--ink); border-color: var(--accent); }
    .occ-section :global(.occ-pill.on) {
      color: var(--accent);
      border-color: var(--accent);
      background: color-mix(in srgb, var(--accent) 8%, transparent);
    }
    .occ-chart-wrap {
      position: relative;
      border: 1px solid var(--rule);
      background: var(--vast-panel-bg, var(--surface));
      padding: 14px;
    }
    /* Pipeline-rendered 1440x810 card: aspect-ratio reserves the panel
       height before (or without) a loaded image, so the status overlay
       has a box to center in. */
    .card-img {
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 9;
    }
    .occ-status {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: var(--font-mono);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      pointer-events: none;
      padding: 0 24px;
      text-align: center;
    }
    @media (max-width: 720px) {
      .occ-chart-wrap { padding: 10px; }
    }
  </style>
</Base>
