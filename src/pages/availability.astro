---
// /availability now redirects to /utilization — the supply page was reframed
// utilization-first (measured Vast utilization is the lead chart; the Availability
// Index rides alongside). The page content lives at /utilization; this is the
// static-host-safe meta-refresh redirect kept so old links and shares still land.
const DEST = '/utilization';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta http-equiv="refresh" content={`0; url=${DEST}`} />
    <link rel="canonical" href={DEST} />
    <meta name="robots" content="noindex" />
    <title>Moved to Utilization · CMR</title>
  </head>
  <body>
    <p>This page has moved to <a href={DEST}>{DEST}</a>.</p>
    <script set:html={`location.replace(${JSON.stringify(DEST)});`}></script>
  </body>
</html>
