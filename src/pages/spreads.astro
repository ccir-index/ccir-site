---
import Base from '../layouts/Base.astro';
import SpreadMatrix from '../components/SpreadMatrix.astro';
import { meta } from '../data/snapshot';
---
<Base
  title="Tier spreads · CCIR"
  description="Premium and discount spreads across Intelligence Factory tiers, measured against T1IF as the reference. Daily basis snapshot for credit-document drafting."
  ogImage="/og/spreads.png"
>
  <section class="wrap top">
    <div class="hero-solo">
      <div class="kicker">Disc./Prem. vs Tier 1 IF · {meta.as_of_date}</div>
      <h1>Tier Spread Matrix</h1>
      <p class="standfirst lede">
        The spread matrix gives a credit analyst two views that a
        single published rate doesn't.
      </p>
      <p class="standfirst lede">
        Reading <strong>across a row</strong> — same chip, varying
        tier — shows what the market is charging for the capability
        bundle: fabric, support, compliance, operational wrap. A lender
        underwriting a T1IF facility needs to know how much of the rate
        is silicon and how much is infrastructure.
      </p>
      <p class="standfirst lede">
        Reading <strong>down a column</strong> — same tier, varying
        generation — shows the generation premium when the bundle is
        held constant: what newer silicon commands over older silicon
        at equivalent deployment grade, without the two signals
        confounding each other.
      </p>
    </div>

    <SpreadMatrix />
  </section>

  <style>
    .top { padding-top: 28px; }
    h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    .lede { font-size: var(--fs-lg); }
    .lede em { font-style: italic; color: var(--accent); }
    .hero-solo { margin-bottom: 28px; max-width: 80ch; }
  </style>
</Base>
