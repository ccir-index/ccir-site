---
import Base from '../../layouts/Base.astro';

// Calibrated to the 2026-07-06 snapshot. Research notes are dated and not
// updated in place — a re-run gets a new note.
const AS_OF = '2026-07-06';

// §02 — Neocloud column only (the deepest, most market-sensitive panel).
// The five datacenter HBM generations carry the fit; the two workstation-
// class rows are out-of-sample witnesses, deliberately outside the fit.
const ageCurve = [
  { gen: 'B300', arch: 'blackwell', archLabel: 'Blackwell', rel: 'late 2025', ageN: 0.8, age: '~0.8y', rateN: 7.85, rate: '$7.85', n: 5, fit: true, side: 'right' },
  { gen: 'B200', arch: 'blackwell', archLabel: 'Blackwell', rel: 'early 2025', ageN: 1.4, age: '~1.4y', rateN: 6.92, rate: '$6.92', n: 8, fit: true, side: 'right' },
  { gen: 'H200', arch: 'hopper', archLabel: 'Hopper', rel: 'mid 2024', ageN: 2.1, age: '~2.1y', rateN: 4.18, rate: '$4.18', n: 14, fit: true, side: 'below' },
  { gen: 'H100', arch: 'hopper', archLabel: 'Hopper', rel: 'late 2022', ageN: 3.7, age: '~3.7y', rateN: 3.22, rate: '$3.22', n: 20, fit: true, side: 'above' },
  { gen: 'A100 80GB', arch: 'ampere', archLabel: 'Ampere', rel: 'late 2020', ageN: 5.7, age: '~5.7y', rateN: 1.80, rate: '$1.80', n: 13, fit: true, side: 'above' },
  { gen: 'RTX PRO 6000', arch: 'blackwell', archLabel: 'Blackwell (workstation)', rel: 'early 2026', ageN: 0.3, age: '~0.3y', rateN: 1.97, rate: '$1.97', n: 4, fit: false, side: 'right' },
  { gen: 'L40S', arch: 'ada', archLabel: 'Ada (workstation)', rel: 'late 2023', ageN: 2.7, age: '~2.7y', rateN: 1.63, rate: '$1.63', n: 6, fit: false, side: 'below' },
];

// --- fit chart geometry (log y) --------------------------------------------
// ln(rate) on age over the five fit rows: slope -0.2957/yr (≈ -26%/yr),
// mean age 2.74, mean ln 1.436, R² 0.96.
const FIT = { slope: -0.2957, meanAge: 2.74, meanLn: 1.436 };
const CW = 680, CH = 320, CPL = 46, CPR = 150, CPT = 18, CPB = 34;
const cInnerW = CW - CPL - CPR, cInnerH = CH - CPT - CPB;
const AGE_MAX = 6.4, LN_MIN = Math.log(1.3), LN_MAX = Math.log(9.5);
const cx = (a: number) => CPL + (a / AGE_MAX) * cInnerW;
const cy = (v: number) => CPT + cInnerH * (1 - (Math.log(v) - LN_MIN) / (LN_MAX - LN_MIN));
const fitAt = (a: number) => Math.exp(FIT.meanLn + FIT.slope * (a - FIT.meanAge));
const FIT_X0 = 0.15, FIT_X1 = 6.2;
const cyTicks = [2, 3, 5, 8];
const cxTicks = [0, 1, 2, 3, 4, 5, 6];

const bwTable = [
  { gen: 'B300', bw: '~8.0 TB/s', v: '0.98' },
  { gen: 'B200', bw: '8.0 TB/s', v: '0.87' },
  { gen: 'H200', bw: '4.8 TB/s', v: '0.87' },
  { gen: 'H100 SXM', bw: '3.35 TB/s', v: '0.96' },
  { gen: 'A100 80GB', bw: '2.0 TB/s', v: '0.90' },
];

const flopTable = [
  { gen: 'B300', pf: '~2.25 PF', v: '~3.5' },
  { gen: 'B200', pf: '2.25 PF', v: '3.1' },
  { gen: 'H200', pf: '0.99 PF', v: '4.2' },
  { gen: 'H100', pf: '0.99 PF', v: '3.3' },
  { gen: 'A100 80GB', pf: '0.31 PF', v: '5.8' },
];

const wattTable = [
  { gen: 'B200', tdp: '1.0 kW', v: '6.92', shell: 'liquid' },
  { gen: 'B300', tdp: '~1.3 kW', v: '~6.0', shell: 'liquid' },
  { gen: 'H200', tdp: '0.7 kW', v: '5.97', shell: 'dense air / liquid' },
  { gen: 'L4 (Mkt)', tdp: '72 W', v: '5.83', shell: 'any air / edge' },
  { gen: 'L40S', tdp: '350 W', v: '4.66', shell: 'air' },
  { gen: 'H100', tdp: '0.7 kW', v: '4.60', shell: 'air' },
  { gen: 'A100 80GB', tdp: '400 W', v: '4.50', shell: 'air' },
  { gen: 'A40 (Mkt)', tdp: '300 W', v: '~1.3', shell: 'air' },
  { gen: '5090 / 4090 / 3090 (Mkt)', tdp: '350–575 W', v: '1.0–1.2', shell: 'consumer' },
];
---
<Base
  title="Rent and Age: Five Generations · CCIR Research"
  description="GPU earning power by generation: raw rental rates decline ≈26%/yr with age (R² 0.96), but per unit of memory bandwidth datacenter silicon is flat — the cross-section is already inference-priced."
  showTape={false}
>
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Research · calibrated to the {AS_OF} snapshot</div>
      <h1>Rent and Age: Five Generations</h1>
      <p class="standfirst">
        A GPU generation's earning power declines as it ages, and underwriting
        GPU-backed credit requires the path. This note measures one input to
        it: a single-date cross-section of published CCIR rates — five
        datacenter generations, five different ages, all priced on {AS_OF} —
        with a specific shape: close to log-linear at ≈ −26% per year in
        dollars (R² 0.96), flat per unit of memory bandwidth, banded per
        watt. The fitted line compares today's chips at today's prices; it is
        not the path any generation has traced since its launch.
      </p>
    </header>

    <section class="sec">
      <h2><span class="n">01</span> What This Measures — and What It Doesn't</h2>
      <p>
        This is the <strong>income leg only</strong>: what a chip earns per
        hour, by generation, across operator segments. It is not a residual
        value. Resale-market evidence (American Compute's
        <a href="https://www.amcompute.com/blog/gpu-depreciation-residual-value-report-2026"
        rel="noopener" target="_blank">2026 residual-value report</a>, built on
        secondary-market transactions) shows rental rates and resale prices can
        diverge — H100 rentals fell through a period in which H100 resale
        values rose on datacenter-shell scarcity. CCIR publishes observed
        prices; valuation belongs to the reader.
      </p>
      <p>
        An A100 renting below an H100 is not "the same asset, older." The chip
        has migrated down the use-case ladder (frontier training → fine-tuning
        → inference → batch → hobbyist) and often down the operator ladder —
        in the current panel, 3090 / A40 / L4 / L40 list <em>only</em> in the
        Marketplace segment, while A100 still spans all three. The curve
        deliberately measures <strong>total earning-power decline</strong>,
        reassignment included, because that is what a lender finances — the
        same convention by which an aircraft's lease-rate curve includes its
        migration from passenger to cargo.
      </p>
      <p>
        A second boundary: every figure here is <strong>gross rental
        revenue</strong> — dollars per GPU-hour before power, cooling, space,
        and operations. The per-watt figures in Section 03 are revenue per
        unit of power envelope, not margin. A cash-flow or DSCR model nets
        operating cost against this series; the cost side — power prices,
        PUE, colocation rates — is published market data of its own and
        belongs in a separate note, as does the boundary it implies: the
        point at which a generation's gross rent meets its cash operating
        cost is its economic end-of-life.
      </p>
      <p>
        One caveat governs everything below: <strong>a cross-section (many
        generations, one date) is not a cohort curve</strong> (one generation
        through time). The −26%/yr is a fit across differently-aged chips at
        current prices — it describes how the market prices age today, not
        the rate at which any chip's price actually fell, and it says nothing
        about where each generation's pricing started at launch. Reading it
        as a decline path assumes the next generation ages like the last —
        exactly the assumption an inference-led demand shift would break.
        Section 04 lists the observable markers.
      </p>
    </section>

    <section class="sec">
      <h2><span class="n">02</span> The Age Curve ({AS_OF}, Guaranteed On-Demand, $/GPU-hr)</h2>
      <p class="fit-line">
        Neocloud rate, log scale, on age: <strong>≈ −26% per year, R² 0.96</strong>
        across the five datacenter generations (ages approximate). All points
        are one date's posted prices ({AS_OF}); the line is a fit across
        generations of different ages, not the price history of any one chip.
      </p>
      <figure class="chart-fig">
        <div class="chart-box">
          <svg viewBox={`0 0 ${CW} ${CH}`} role="img"
               aria-label="Neocloud guaranteed on-demand rate per GPU-hour, log scale, against generation age. Five datacenter generations sit on a fitted line declining 26 percent per year; two workstation-class chips sit far below it.">
            {cyTicks.map((t) => (
              <g>
                <line x1={CPL} x2={CW - CPR} y1={cy(t)} y2={cy(t)} class="grid" />
                <text x={CPL - 8} y={cy(t) + 3} class="tick" text-anchor="end">${t}</text>
              </g>
            ))}
            {cxTicks.map((a) => (
              <text x={cx(a)} y={CH - 12} class="tick" text-anchor="middle">{a}y</text>
            ))}
            <text x={CW - CPR} y={CH - 12} class="tick" text-anchor="start">  age</text>
            <line x1={cx(FIT_X0)} y1={cy(fitAt(FIT_X0))} x2={cx(FIT_X1)} y2={cy(fitAt(FIT_X1))} class="fitln" />
            <text x={cx(FIT_X1) + 8} y={cy(fitAt(FIT_X1)) + 4} class="fitlab" text-anchor="start">fit −26%/yr · R² 0.96</text>
            {ageCurve.map((r) => (
              <g>
                <circle cx={cx(r.ageN)} cy={cy(r.rateN)} r="5"
                        class={`pt pt-${r.arch} ${r.fit ? '' : 'pt-witness'}`} />
                <text x={cx(r.ageN) + (r.side === 'right' ? 11 : 0)}
                      y={cy(r.rateN) + (r.side === 'above' ? -11 : r.side === 'below' ? 19 : 4)}
                      class={`ptlab lab-${r.arch}`}
                      text-anchor={r.side === 'right' ? 'start' : 'middle'}>
                  {r.gen} {r.rate}
                </text>
              </g>
            ))}
          </svg>
        </div>
        <div class="chart-legend">
          <span class="lg"><span class="dotk dk-blackwell"></span>Blackwell</span>
          <span class="lg"><span class="dotk dk-hopper"></span>Hopper</span>
          <span class="lg"><span class="dotk dk-ampere"></span>Ampere</span>
          <span class="lg"><span class="dotk dk-ada"></span>Ada</span>
          <span class="lg"><span class="dotk dk-hollow"></span>hollow = workstation-class, outside the fit</span>
        </div>
        <figcaption class="tfoot">
          Neocloud guaranteed on-demand, $/GPU-hr on a log scale, against
          generation age. Headline stat per the published rule (mean where
          n≥10, else median). Single-date cross-section ({AS_OF}) — the
          fitted line is not a traced price history.
        </figcaption>
      </figure>
      <div class="twrap">
        <table>
          <thead>
            <tr><th>Generation</th><th>Architecture</th><th>Released</th><th>Age</th><th class="num">Neocloud $/GPU-hr</th><th class="num">n</th><th>In fit</th></tr>
          </thead>
          <tbody>
            {ageCurve.map((r) => (
              <tr class={r.fit ? '' : 'witness-row'}>
                <td class="gen">{r.gen}</td>
                <td><span class={`arch-tag at-${r.arch}`}>{r.archLabel}</span></td>
                <td class="dim">{r.rel}</td><td class="dim">{r.age}</td>
                <td class="num strong">{r.rate}</td><td class="num dim">{r.n}</td>
                <td class="dim">{r.fit ? 'yes' : 'witness'}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p>
        The regularity is the finding: five generations spanning five years of
        silicon, and a single log-linear slope explains 96% of the variance in
        the Neocloud rate. The largest deviation is H200, which trades below
        the line — consistent with the bandwidth pricing in the next section.
      </p>
      <p>
        The two hollow points are the tell. <strong>RTX PRO 6000 is
        three-months-old Blackwell silicon priced at $1.97 — where
        5.7-year-old A100 trades</strong> — because its memory bandwidth
        (~1.8 TB/s of GDDR7, no HBM, no NVLink) is A100-class. A brand-new
        chip prices at the old chip's level when it carries the old chip's
        bandwidth: age is not the priced variable. Section 03 makes that
        explicit.
      </p>
    </section>

    <section class="sec">
      <h2><span class="n">03</span> Three Normalizations, Three Markets</h2>
      <p class="tfoot">Standing version of this section's tables: <a href="/chip-economics">/chip-economics</a>.</p>
      <p>
        Divide the Neocloud rate by the chip's capability and the curve
        splits. Per unit of <strong>memory bandwidth</strong> — the binding
        resource for LLM serving:
      </p>
      <div class="twrap">
        <table>
          <thead><tr><th>Generation</th><th class="num">HBM bandwidth</th><th class="num">$/TB/s-hr</th></tr></thead>
          <tbody>
            {bwTable.map((r) => (
              <tr><td class="gen">{r.gen}</td><td class="num dim">{r.bw}</td><td class="num strong">{r.v}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p>
        Datacenter silicon from eight months to 5.7 years old clears inside
        <strong>$0.87–0.98 per TB/s-hour</strong> — ±6% around $0.92. After
        bandwidth normalization there is essentially no age discount left.
      </p>
      <p>
        Per unit of <strong>dense BF16 compute</strong> — the binding resource
        for frontier training:
      </p>
      <div class="twrap">
        <table>
          <thead><tr><th>Generation</th><th class="num">BF16 dense</th><th class="num">$/PFLOP-hr</th></tr></thead>
          <tbody>
            {flopTable.map((r) => (
              <tr><td class="gen">{r.gen}</td><td class="num dim">{r.pf}</td><td class="num strong">{r.v}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p>
        Per FLOP, older chips look expensive — not because anyone charges
        more (absolute rates are far lower), but because the age discount
        does not keep pace with the FLOP gap. Each generation improves
        compute faster than it improves bandwidth, so a market that prices
        bandwidth leaves older chips above FLOP-parity automatically: a
        renter who actually wants FLOPs buys the frontier. Compute-
        normalization does not flatten the cross-section;
        bandwidth-normalization does.
      </p>
      <p>
        Per unit of <strong>nameplate power</strong> — the facility's
        constraint, which determines which datacenters can physically host a
        chip:
      </p>
      <div class="twrap">
        <table>
          <thead><tr><th>Generation</th><th class="num">TDP</th><th class="num">$/kW-hr</th><th>Shell class</th></tr></thead>
          <tbody>
            {wattTable.map((r) => (
              <tr><td class="gen">{r.gen}</td><td class="num dim">{r.tdp}</td><td class="num strong">{r.v}</td><td class="dim">{r.shell}</td></tr>
            ))}
          </tbody>
        </table>
      </div>
      <p>
        The watt-rent sorts the panel into three bands: consumer silicon with
        no datacenter bundle at ~$1/kW-hr, <strong>air-cooled datacenter
        silicon flat at $4.50–4.66</strong> across five years of age (A100 =
        H100 = L40S per watt), and liquid-class silicon at $6–7. When the
        shell is the binding constraint, chips that fit the same shells
        converge on the same watt-rent — and part of the Blackwell premium is
        rent on scarce liquid-cooled capacity. The breadth of facilities that
        can host a chip is also the residual-support mechanism visible in the
        resale data: old air-cooled generations fit the largest installed
        shell base.
      </p>
      <p>
        <strong>Reading.</strong> The marginal renter across generations is
        paying for bandwidth-hours, not FLOP-hours — the pricing signature of
        a serving-dominated market. If frontier training set the
        cross-section, old chips would trade at a steep per-FLOP discount;
        instead they trade at a per-FLOP premium and a per-bandwidth par. At
        the margin, the repricing an "inference shift" is expected to cause
        appears to have already happened.
      </p>
    </section>

    <section class="sec">
      <h2><span class="n">04</span> If Volume Keeps Moving to Inference — the Watchlist</h2>
      <p>
        Stated as observables CCIR already publishes, so each can be checked
        rather than argued:
      </p>
      <ol>
        <li><strong>The $/TB/s band is the price.</strong> Serving demand deepening → the band tightens and new generations enter at it (B300's 0.98 decaying toward 0.87–0.90 as scarcity fades). Training re-tightening → Blackwell decouples upward per-TB/s.</li>
        <li><strong>Term structure loads the short end.</strong> Inference buyers resist tenors beyond one year; the 1Y cell becomes the market's effective clearing tenor.</li>
        <li><strong>The guaranteed–interruptible spread narrows on older generations.</strong> Today: H100 Neocloud guaranteed $3.22 vs interruptible $2.00 (−38%); A100 $1.80 vs $1.14 (−36%). Structural narrowing on old generations means bursty serving demand is reaching down the ladder.</li>
        <li><strong>Old-generation floors hold.</strong> In power-market terms, depreciated chips are peakers — low carrying cost, dispatched into demand spikes — while new fleets are baseload needing committed offtake. A100 holding ~$0.90/TB/s at 5.7 years is the floor holding; watch it as Blackwell supply normalizes.</li>
        <li><strong>Utilization becomes the swing variable.</strong> Serving is diurnal, training is flat; realized-vs-posted gaps widen for serving-heavy operators even where posted rates hold.</li>
        <li><strong>Contract quality shifts.</strong> Many short-tenor customers replace one five-year offtake: diversification up, committed coverage down — and underwriting moves from offtake credit toward market-rate reference.</li>
        <li><strong>The liquid watt-premium compresses.</strong> As liquid-cooled shells build out, $6–7/kW-hr should converge toward the $4.6 air band — a facility-driven repricing of new silicon independent of age. If instead the air band decays first, old-generation floors break from the facility side.</li>
      </ol>
    </section>

    <section class="sec">
      <h2><span class="n">05</span> Limitations</h2>
      <p>
        Single cross-section, not a cohort. List asks, not executed
        transactions. The headline stat mixes mean (deep panels) and median
        (thin) per the published rule; form factor is pooled and the SXM/PCIe
        mix differs by generation; bandwidth is a crude capability proxy
        (ignores HBM capacity, interconnect domain, FP4 paths — the B300 BF16
        figure is approximate); the A100 Hyperscaler cell is a slow-moving
        rate card; thin cells (n&lt;3) are indicative. Sources and series per
        the <a href="/documents/methodology">Methodology</a>; underlying cells
        are visible in the <a href="/explorer">Explorer</a>.
      </p>
    </section>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { max-width: 82ch; margin-bottom: 10px; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    .sec { margin: 28px 0; max-width: 80ch; }
    .sec h2 {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      margin: 0 0 12px;
      display: flex;
      align-items: baseline;
      gap: 12px;
    }
    .sec .n { font-family: var(--font-mono); font-size: var(--fs-sm); color: var(--accent); font-weight: var(--weight-strong); }
    .sec p, .sec ol {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink);
      line-height: 1.65;
      margin: 0 0 13px;
    }
    .sec ol { padding-left: 22px; }
    .sec li { margin-bottom: 8px; }
    .sec strong { color: var(--accent); }
    .sec em { font-style: italic; }
    .twrap { border: 1px solid var(--rule); background: var(--surface); overflow-x: auto; margin: 0 0 12px; max-width: 700px; }
    table { width: 100%; border-collapse: collapse; font-family: var(--font-mono); font-size: var(--fs-xs); }
    th, td { padding: 8px 12px; border-bottom: 1px solid var(--rule); text-align: left; white-space: nowrap; }
    thead th { background: var(--surface-2); color: var(--ink-dim); text-transform: uppercase; letter-spacing: var(--tracking-eye); font-size: calc(var(--fs-xs) - 1px); }
    th.num, td.num { text-align: right; font-variant-numeric: tabular-nums; }
    td.gen { color: var(--ink); font-weight: var(--weight-strong); }
    td.dim { color: var(--ink-dim); }
    td.strong { color: var(--accent); font-weight: var(--weight-strong); }
    .tfoot { font-family: var(--font-mono) !important; font-size: calc(var(--fs-xs) - 1px) !important; color: var(--ink-faint) !important; }
    .fit-line {
      font-family: var(--font-mono) !important;
      font-size: var(--fs-sm) !important;
      color: var(--ink) !important;
      border: 1px solid var(--rule);
      border-left: 2px solid var(--accent);
      background: var(--surface-2);
      padding: 10px 14px;
      max-width: 700px;
    }

    /* architecture palette — same hue family as /credit's validated set */
    .top {
      --arch-blackwell: #0d9488;
      --arch-hopper: #b9770a;
      --arch-ampere: #c11f57;
      --arch-ada: #5b5852;
    }
    :global(html[data-theme='terminal']) .top {
      --arch-blackwell: #2dd4bf;
      --arch-hopper: #ffb400;
      --arch-ampere: #ff4d84;
      --arch-ada: #9a9991;
    }
    .chart-fig { margin: 0 0 14px; max-width: 700px; }
    .chart-box { border: 1px solid var(--rule); background: var(--surface); }
    .chart-box svg { display: block; width: 100%; height: auto; }
    .grid { stroke: var(--rule); stroke-width: 1; }
    .tick { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-faint); }
    .fitln { stroke: var(--ink-dim); stroke-width: 1.4; stroke-dasharray: 5 4; }
    .fitlab { font-family: var(--font-mono); font-size: 11px; font-weight: 600; fill: var(--ink-dim); }
    .pt-blackwell { fill: var(--arch-blackwell); }
    .pt-hopper { fill: var(--arch-hopper); }
    .pt-ampere { fill: var(--arch-ampere); }
    .pt-ada { fill: var(--arch-ada); }
    .pt-witness { fill: var(--surface); stroke-width: 2.2; }
    .pt-witness.pt-blackwell { stroke: var(--arch-blackwell); }
    .pt-witness.pt-ada { stroke: var(--arch-ada); }
    .ptlab { font-family: var(--font-mono); font-size: 10.5px; font-weight: 600; }
    .lab-blackwell { fill: var(--arch-blackwell); }
    .lab-hopper { fill: var(--arch-hopper); }
    .lab-ampere { fill: var(--arch-ampere); }
    .lab-ada { fill: var(--arch-ada); }
    .chart-legend { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 8px; font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--ink-dim); }
    .dotk { display: inline-block; width: 9px; height: 9px; border-radius: 50%; margin-right: 5px; vertical-align: -1px; }
    .dk-blackwell { background: var(--arch-blackwell); }
    .dk-hopper { background: var(--arch-hopper); }
    .dk-ampere { background: var(--arch-ampere); }
    .dk-ada { background: var(--arch-ada); }
    .dk-hollow { background: var(--surface); border: 2px solid var(--ink-dim); }
    .arch-tag {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      padding: 1px 7px;
      border: 1px solid currentColor;
      border-radius: 2px;
      white-space: nowrap;
    }
