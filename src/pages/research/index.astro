---
import Base from '../../layouts/Base.astro';
import { meta } from '../../data/snapshot';

// Research hub — re-planed into three species as the primary axis, so a reader
// lands on an on-ramp, not a wall:
//   PRIMERS    — evergreen; the model the rest runs on (flagship = the why)
//   MONITORS   — standing pages updated daily with the panel (live data)
//   DISPATCHES — dated notes, never revised in place; newest first, theme-tagged
interface Card { href: string; title: string; blurb: string }
interface Primer extends Card { flagship?: boolean }
interface MonitorGroup { theme: string; items: Card[] }
interface Dispatch extends Card { date: string; tag: string }

const thesis =
  "What compute earns, what it's worth as collateral, and how that shows up in " +
  'credit — worked from public filings and posted prices.';

const primers: Primer[] = [
  { href: '/research/gpu-as-income-asset', flagship: true,
    title: 'The GPU as an Income Asset',
    blurb: 'Earning power, collateral, and the reference rate — the model the rest of this research runs on, and why a lease rate sits under every GPU-credit question.' },
  { href: '/research/compute-contracts', title: 'The Compute Contract',
    blurb: 'How GPU-hours are sold, from terms of service to SEC-filed take-or-pay master agreements — including the termination formula that prices the on-demand spread.' },
  { href: '/research/gpu-spv', title: 'The GPU SPV',
    blurb: 'How lenders take compute as collateral: serial-number covenants, UCC account control, contract-realization tests, and a rating that travels with the offtake.' },
  { href: '/research/training-vs-inference', title: 'Training, Inference, and What Compute Earns',
    blurb: 'For credit readers: training demand behaves like construction backlog, inference like utility load — with the observables for each.' },
  { href: '/research/compute-glossary', title: 'A Compute Glossary for Finance',
    blurb: 'FLOPS, bandwidth, TDP, PUE, MFU, NVL72, training vs. inference — the vocabulary of compute paper, defined in finance terms.' },
];

const monitors: MonitorGroup[] = [
  { theme: 'Credit', items: [
    { href: '/credit', title: 'GPU-Backed Credit',
      blurb: 'The debt stack behind AI compute, as filed — every instrument traced to a public document.' },
    { href: '/credit/series', title: 'Credit Reference Series',
      blurb: 'Spread at signing, refinancing velocity, and lender-filed fair-value marks — arithmetic on filed numbers only.' },
  ] },
  { theme: 'Term & Price', items: [
    { href: '/term', title: 'Committed Term Structure',
      blurb: 'Posted committed asks by tenor — one month to a year, per chip.' },
    { href: '/basis', title: 'On-Demand vs Clearing Basis',
      blurb: 'Posted on-demand asks against marketplace clearing.' },
  ] },
  { theme: 'Demand & Utilization', items: [
    { href: '/realized/', title: 'Realized vs Rate Card',
      blurb: 'Per-GPU-hour realization from public filings — well below posted rate cards.' },
    { href: '/utilization', title: 'Utilization & Availability',
      blurb: 'How much of the tracked fleet is rented versus idle, and how many venues have capacity.' },
  ] },
  { theme: 'Asset Economics', items: [
    { href: '/chip-economics', title: 'Chip Economics',
      blurb: 'The daily rate re-denominated per GB, per TB/s, per PFLOP, per kW.' },
  ] },
];

const dispatches: Dispatch[] = [
  { href: '/research/nebius-first-secured-debt', date: '2026-07-20', tag: 'Credit',
    title: 'Nebius’s First Secured Debt: A $775M GPU-Backed Facility',
    blurb: 'Nebius entered its first senior secured debt facility on July 17 — its first secured debt after a history of nothing but convertibles.' },
  { href: '/research/fitch-coreweave-ddtl-5-5', date: '2026-07-17', tag: 'Credit',
    title: 'A GPU Lease Rate Enters the Rating Case',
    blurb: 'Fitch’s July 16 rating case for CoreWeave’s DDTL 5.5 leads with a new assumption: expiring contracts renew “at favorable GPU lease rates.”' },
  { href: '/research/same-facility-different-marks', date: '2026-07-12', tag: 'Credit',
    title: 'Same Facility, Different Marks',
    blurb: 'Four advisers file 99.0 / 100.0 / 102.0 / 103.1 on one GPU-backed facility at one date — marked like performing credit, dispersed like stressed.' },
  { href: '/research/rent-and-msrp', date: '2026-07-08', tag: 'Asset economics',
    title: 'Rent and MSRP: Five Generations of Posted Prices',
    blurb: 'Every generation’s gross posted-rate revenue passed its MSRP within 11–17 months; acquisition cost per unit of bandwidth fell 2.5×, rent per unit did not.' },
  { href: '/research/rental-rates-by-generation', date: '2026-07-08', tag: 'Asset economics',
    title: 'GPU Rental Rates by Generation: Nine Years of Posted Prices',
    blurb: 'Per-generation histories, 2017–2026: declines arrive in steps set by the repricers, interrupted twice by demand.' },
  { href: '/research/itel-1979', date: '2026-07-08', tag: 'Precedent',
    title: 'Betting on the Residual: Itel and the IBM 4300, 1979',
    blurb: 'The largest independent computer lessor in the world, residual-dependent leases, and the machine that obsoleted the inventory — a $433M loss ($2B today).' },
  { href: '/research/gpu-age-curve', date: '2026-07-06', tag: 'Asset economics',
    title: 'Rent and Age: Five Generations',
    blurb: 'The cross-section: ≈−26%/yr in dollars (R² 0.96) with age, flat per unit of memory bandwidth, banded per watt.' },
  { href: '/research/od-vs-committed', date: '2026-07-06', tag: 'Term',
    title: 'The Commitment Discount: Three Years of H100 Posted Prices',
    blurb: 'Neocloud H100, Oct 2023 – Jun 2026: a persistent committed discount, a $2.80 on-demand floor through 2025, a turn upward since December.' },
];

const tagClass = (t: string) => 'tag-' + t.split(' ')[0].toLowerCase();
const flagship = primers.find((p) => p.flagship);
const restPrimers = primers.filter((p) => !p.flagship);
---
<Base
  title="Research · CCIR"
  description="CCIR research — primers on how compute is priced and financed, standing market monitors updated daily, and dated dispatches that are never revised in place."
  ogImage="/og/research.png"
>
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Research · {meta.as_of_date}</div>
      <h1>Research</h1>
      <p class="thesis">{thesis}</p>
    </header>

    <!-- PRIMERS -->
    <section class="tier">
      <div class="tier-head">
        <h2>Start here</h2>
        <span class="tier-tag">Primers · the model</span>
      </div>
      {flagship && (
        <a class="flagship" href={flagship.href}>
          <span class="fl-eye">Start here</span>
          <span class="fl-title">{flagship.title}</span>
          <span class="fl-blurb">{flagship.blurb}</span>
          <span class="fl-go">Read the primer →</span>
        </a>
      )}
      <div class="primer-grid">
        {restPrimers.map((p) => (
          <a class="primer" href={p.href}>
            <span class="p-title">{p.title}</span>
            <span class="p-blurb">{p.blurb}</span>
          </a>
        ))}
      </div>
    </section>

    <!-- MONITORS -->
    <section class="tier">
      <div class="tier-head">
        <h2>Monitors</h2>
        <span class="tier-tag">Updated daily · live data</span>
      </div>
      <div class="monitor-cols">
        {monitors.map((g) => (
          <div class="mcol">
            <div class="mcol-head">{g.theme}</div>
            {g.items.map((m) => (
              <a class="monitor" href={m.href}>
                <span class="m-title">{m.title}</span>
                <span class="m-blurb">{m.blurb}</span>
              </a>
            ))}
          </div>
        ))}
      </div>
    </section>

    <!-- DISPATCHES -->
    <section class="tier">
      <div class="tier-head">
        <h2>Dispatches</h2>
        <span class="tier-tag">Dated · newest first</span>
      </div>
      <div class="dispatch-list">
        {dispatches.map((d) => (
          <a class="dispatch" href={d.href}>
            <span class="d-date">{d.date}</span>
            <span class="d-body">
              <span class="d-title">{d.title}<span class={`d-tag ${tagClass(d.tag)}`}>{d.tag}</span></span>
              <span class="d-blurb">{d.blurb}</span>
            </span>
          </a>
        ))}
      </div>
    </section>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { max-width: 82ch; margin-bottom: 8px; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-3xl);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 10px;
    }
    .thesis {
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink-dim);
      line-height: 1.6;
      margin: 0;
      max-width: 74ch;
    }

    .tier { margin: 40px 0 0; }
    .tier-head {
      display: flex;
      align-items: baseline;
      gap: 14px;
      border-bottom: 1px solid var(--rule);
      padding-bottom: 8px;
      margin-bottom: 16px;
    }
    .tier-head h2 {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      font-weight: var(--weight-display);
      margin: 0;
    }
    .tier-tag {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      color: var(--accent);
    }

    /* ---- Primers ---- */
    .flagship {
      display: block;
      background: var(--surface);
      border: 1px solid var(--rule);
      border-left: 3px solid var(--accent);
      padding: 20px 24px;
      margin-bottom: 1px;
      text-decoration: none;
      color: var(--ink);
      transition: background 0.18s ease, box-shadow 0.18s ease;
      max-width: 880px;
    }
    .flagship:hover {
      background: var(--surface-2);
      text-decoration: none;
      box-shadow: inset 0 0 0 1px var(--accent), 0 0 22px -10px var(--accent);
    }
    .fl-eye {
      display: block;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 6px;
    }
    .fl-title {
      display: block;
      font-family: var(--font-display);
      font-size: var(--fs-2xl);
      font-weight: var(--weight-display);
      letter-spacing: -0.01em;
      margin-bottom: 7px;
    }
    .flagship:hover .fl-title { color: var(--accent); }
    .fl-title, .fl-blurb, .p-title, .m-title, .d-title { transition: color 0.18s ease; }
    .fl-blurb {
      display: block;
      font-family: var(--font-body);
      font-size: var(--fs-md);
      color: var(--ink-dim);
      line-height: 1.55;
      max-width: 72ch;
    }
    .fl-go {
      display: inline-block;
      margin-top: 10px;
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      color: var(--accent);
    }

    .primer-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
      border-top: none;
      max-width: 880px;
    }
    .primer {
      background: var(--surface);
      padding: 15px 18px;
      display: flex;
      flex-direction: column;
      gap: 5px;
      text-decoration: none;
      color: var(--ink);
      transition: background 0.18s ease, box-shadow 0.18s ease;
    }
    .primer:hover {
      background: var(--surface-2);
      text-decoration: none;
      box-shadow: inset 0 0 0 1px var(--accent);
      z-index: 1;
    }
    .primer:hover .p-title { color: var(--accent); }
    .p-title {
      font-family: var(--font-display);
      font-size: var(--fs-md);
      font-weight: var(--weight-display);
      letter-spacing: -0.005em;
    }
    .p-blurb {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.5;
    }

    /* ---- Monitors ---- */
    .monitor-cols {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(210px, 1fr));
      gap: 1px;
      background: var(--rule);
      border: 1px solid var(--rule);
      max-width: 1000px;
    }
    .mcol { background: var(--surface); display: flex; flex-direction: column; }
    .mcol-head {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      color: var(--ink-faint);
      padding: 10px 16px 4px;
    }
    .monitor {
      display: flex;
      flex-direction: column;
      gap: 3px;
      padding: 9px 16px 12px;
      text-decoration: none;
      color: var(--ink);
      transition: background 0.16s ease, box-shadow 0.16s ease;
    }
    .monitor:hover {
      background: var(--surface-2);
      text-decoration: none;
      box-shadow: inset 2px 0 0 0 var(--accent);
    }
    .monitor:hover .m-title { color: var(--accent); }
    .m-title { font-family: var(--font-display); font-size: var(--fs-sm); font-weight: var(--weight-display); }
    .m-blurb { font-family: var(--font-body); font-size: var(--fs-xs); color: var(--ink-dim); line-height: 1.45; }

    /* ---- Dispatches ---- */
    .dispatch-list {
      border: 1px solid var(--rule);
      background: var(--surface);
      max-width: 900px;
      display: flex;
      flex-direction: column;
    }
    .dispatch {
      display: flex;
      gap: 16px;
      padding: 13px 18px;
      text-decoration: none;
      color: var(--ink);
      border-bottom: 1px solid var(--rule);
      transition: background 0.16s ease, box-shadow 0.16s ease;
    }
    .dispatch:last-child { border-bottom: none; }
    .dispatch:hover {
      background: var(--surface-2);
      text-decoration: none;
      box-shadow: inset 3px 0 0 0 var(--accent);
    }
    .dispatch:hover .d-title { color: var(--accent); }
    .d-date {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--ink-faint);
      white-space: nowrap;
      padding-top: 2px;
      min-width: 74px;
    }
    .d-body { display: flex; flex-direction: column; gap: 3px; }
    .d-title {
      font-family: var(--font-display);
      font-size: var(--fs-md);
      font-weight: var(--weight-display);
      letter-spacing: -0.005em;
    }
    .d-tag {
      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 2px);
      letter-spacing: var(--tracking-eye);
      text-transform: uppercase;
      color: var(--ink-faint);
      border: 1px solid var(--rule);
      border-radius: 3px;
      padding: 1px 5px;
      margin-left: 9px;
      white-space: nowrap;
      vertical-align: middle;
    }
    .d-tag.tag-credit { color: var(--accent); border-color: color-mix(in srgb, var(--accent) 45%, var(--rule)); }
    .d-blurb {
      font-family: var(--font-body);
      font-size: var(--fs-sm);
      color: var(--ink-dim);
      line-height: 1.5;
    }

    @media (max-width: 640px) {
      .dispatch { flex-direction: column; gap: 4px; }
      .d-date { min-width: 0; }
    }
  </style>
</Base>
