---
import Base from '../../layouts/Base.astro';
import { meta } from '../../data/snapshot';

const notes = [
  {
    href: '/research/itel-1979',
    date: '2026-07-08',
    title: 'The Company That Insured Itself Against Technological Change',
    blurb:
      'Itel, 1979: the largest independent computer lessor in the world, a ' +
      'residual-value assumption insured at Lloyd’s, and the IBM 4300 — ' +
      'a $433M loss (≈$2B today) recognized on the lease calendar, not the ' +
      'market calendar. Historical record, from the contemporaneous filings ' +
      'and wires.',
  },
  {
    href: '/research/training-vs-inference',
    date: '2026-07-07',
    title: 'Training, Inference, and What Compute Earns',
    blurb:
      'A primer for credit readers: training demand behaves like construction ' +
      'backlog, inference like utility load — and the difference is already ' +
      'visible in published series, in tenor structure, per-generation ' +
      'pricing, and realized-versus-posted utilization.',
  },
  {
    href: '/research/od-vs-committed',
    date: '2026-07-06',
    title: 'On-Demand vs Committed, Three Years',
    blurb:
      'Monthly neocloud H100 posted prices from an archived-page backfill, ' +
      'Oct 2023 – Jun 2026: a persistent 20–50% committed discount, a $2.80 ' +
      'on-demand floor through 2025, and a turn upward since December — with ' +
      'the composition repair that makes the series honest.',
  },
  {
    href: '/research/gpu-age-curve',
    date: '2026-07-06',
    title: 'The GPU Age Curve: −26% per Year',
    blurb:
      'GPU earning power by generation, three ways: raw rates decline ≈26%/yr (R² 0.96) ' +
      'with age, but per unit of memory bandwidth datacenter silicon is flat — ' +
      'and per watt it sorts into shell classes. What that says about an ' +
      'inference-led market, with the markers to watch.',
  },
];
---
<Base
  title="Research · CCIR"
  description="CCIR research notes — analyses of observed compute prices: generation decline curves, normalizations, and market-structure findings."
  showTape={false}
>
  <section class="wrap top">
    <header class="page-head">
      <div class="kicker">Research · {meta.as_of_date}</div>
      <h1>Research Notes</h1>
      <p class="standfirst">
        Dated analyses of observed prices from the CCIR panel. Every note works
        only from published series and public filings, states its calibration
        date, and lists what would falsify it. Notes are not updated in place —
        follow-ups get new notes.
      </p>
    </header>

    <div class="note-list">
      {notes.map((n) => (
        <a class="note-card" href={n.href}>
          <span class="note-date">{n.date}</span>
          <h2 class="note-title">{n.title}</h2>
          <p class="note-blurb">{n.blurb}</p>
        </a>
      ))}
    </div>
  </section>

  <style>
    .top { padding-top: 32px; }
    .page-head { max-width: 80ch; margin-bottom: 22px; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-hero);
      line-height: var(--lh-display);
      font-weight: var(--weight-display);
      margin: 6px 0 14px;
      letter-spacing: -0.01em;
    }
    .note-list { display: flex; flex-direction: column; gap: 1px; background: var(--rule); border: 1px solid var(--rule); max-width: 880px; margin-bottom: 40px; }
    .note-card { background: var(--surface); padding: 18px 22px; text-decoration: none; color: var(--ink); display: flex; flex-direction: column; gap: 6px; }
    .note-card:hover { background: var(--surface-2); text-decoration: none; }
    .note-date { font-family: var(--font-mono); font-size: var(--fs-xs); color: var(--ink-dim); letter-spacing: 0.04em; }
    .note-title { font-family: var(--font-display); font-size: var(--fs-xl); margin: 0; }
    .note-blurb { font-family: var(--font-body); font-size: var(--fs-sm); color: var(--ink-dim); line-height: 1.6; margin: 0; max-width: 76ch; }
  </style>
</Base>
