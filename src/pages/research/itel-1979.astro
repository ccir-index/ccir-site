const timeline = [
  { date: '1975', event: 'Lloyd’s of London begins insuring Itel against early lessee returns — "in essence, Itel was insured against technological change."', figure: '', adj: '' },
  { date: '1978', event: 'Record profit reported on a $1.7B lease book — the largest IBM-compatible lease portfolio after IBM itself.', figure: '$47.2M profit', adj: '≈$243M' },
  { date: 'late 1978', event: 'Speculation about IBM’s next generation halts customer purchases. The record profit fails its audit and is restated — explicitly for a residual-value writedown.', figure: '→ $21.5M', adj: '≈$111M' },
  { date: 'Jan 30, 1979', event: 'IBM announces the 4300 series: ~3.2× the performance of the 370/138, up to 30% cheaper. Lessees begin canceling.', figure: '', adj: '' },
  { date: 'Q1 1979', event: 'First-quarter loss — small. The repricing has happened; the recognition has not.', figure: '−$4.4M', adj: '≈−$20M' },
  { date: 'H2 1979', event: 'Cancellations and lease-ends convert January’s repricing into booked losses, one contract at a time.', figure: '~−$370M', adj: '≈−$1.7B' },
