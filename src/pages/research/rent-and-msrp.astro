      font-family: var(--font-mono);
      font-size: calc(var(--fs-xs) - 1px);
      color: var(--ink-dim);
      line-height: 1.55;
      margin: 0 0 8px;
    }
    .sm-key-body strong { color: var(--accent); font-weight: var(--weight-strong); }
    .grid { stroke: var(--rule); stroke-width: 1; }
    .grid-one { stroke: var(--ink-dim); stroke-width: 1.1; stroke-dasharray: 1 3; }
    .tick { font-family: var(--font-mono); font-size: 10px; fill: var(--ink-faint); }
    .ln { fill: none; stroke-width: 1.7; }
    .ln-thin { stroke-width: 1.1; stroke-dasharray: 3 3; opacity: 0.8; }
    .ln-ghost { stroke: var(--ink-faint); stroke-width: 1; opacity: 0.22; }
    .ln-volta { stroke: var(--arch-volta); }
    .ln-ampere { stroke: var(--arch-ampere); }
    .ln-hopper { stroke: var(--arch-hopper); }
    .ln-h200 { stroke: var(--arch-h200); }
    .ln-blackwell { stroke: var(--arch-blackwell); }
    .lab-volta { color: var(--arch-volta); fill: var(--arch-volta); }
    .lab-ampere { color: var(--arch-ampere); fill: var(--arch-ampere); }
    .lab-hopper { color: var(--arch-hopper); fill: var(--arch-hopper); }
    .lab-h200 { color: var(--arch-h200); fill: var(--arch-h200); }
    .lab-blackwell { color: var(--arch-blackwell); fill: var(--arch-blackwell); }
    .enddot { stroke: var(--surface); stroke-width: 1.2; }
    .dot-volta { fill: var(--arch-volta); }
    .dot-ampere { fill: var(--arch-ampere); }
    .dot-hopper { fill: var(--arch-hopper); }
