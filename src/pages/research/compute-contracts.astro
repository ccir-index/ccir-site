import Base from '../../layouts/Base.astro';

// Dated primer, 2026-07-09. Research notes are not updated in place.
// Every document quoted is public: CoreWeave's published Terms of Service,
// and exhibits filed on SEC EDGAR under Reg S-K Item 601. All excerpts
// verified against the filed text on 2026-07-09; [*] marks are the
// registrant's own redactions, reproduced as filed.
const DATED = '2026-07-09';

const EDGAR = {
  msft: 'https://www.sec.gov/Archives/edgar/data/1769628/000119312525044231/d899798dex1023.htm',
  openai: 'https://www.sec.gov/Archives/edgar/data/1769628/000119312525052207/d899798dex1024.htm',
  nvidia: 'https://www.sec.gov/Archives/edgar/data/1769628/000114036125036118/ny20053122x6_ex10-31.htm',
  openai2: 'https://www.sec.gov/Archives/edgar/data/1769628/000114036125036118/ny20053122x6_ex10-32.htm',
  soluna: 'https://www.sec.gov/Archives/edgar/data/64463/000149315224032123/ex10-105.htm',
  apld8k: 'https://www.sec.gov/Archives/edgar/data/1144879/000164117225013199/form8-k.htm',
  apldLease2: 'https://www.sec.gov/Archives/edgar/data/1144879/000164117225013199/ex10-1.htm',
  apldLease3: 'https://www.sec.gov/Archives/edgar/data/1144879/000164117225013199/ex10-2.htm',
  tos: 'https://docs.coreweave.com/policies/terms-of-service',
};

const spectrum = [
  {
    mode: 'On-demand',
    tenor: 'Per second / per hour',
    obligation: 'Pay for hours consumed; stop anytime',
    capacity: 'Not guaranteed; interruptible tiers exist',
    paper: 'Published terms of service — accepted, not negotiated',
  },
  {
    mode: 'Reserved / committed',
    tenor: 'One month to ~one year',
    obligation: 'Pay for the reservation whether used or not',
    capacity: 'Guaranteed for the term',
    paper: 'Order form under standard terms',
  },
  {
    mode: 'Committed MSA',
    tenor: 'One to six years',
    obligation: 'Fixed payments independent of usage; upfront payment common',
    capacity: 'Dedicated clusters; hardware-failure and SLA relief',
    paper: 'Negotiated master services agreement + order forms',
  },
];

const msas = [
  { cp: 'Microsoft', signed: 'Feb 22, 2023', filed: 'Ex. 10.23, Form S-1 (Mar 2025)', url: 'msft',
    notable: 'Take-or-pay termination mechanics with remarketing offset; 2-day hardware-failure payment relief' },
  { cp: 'NVIDIA', signed: 'Apr 10, 2023', filed: 'Ex. 10.31, Form S-4/A (Sep 2025)', url: 'nvidia',
    notable: 'Capacity cap on NVIDIA’s own usage — the “[*] Rule,” size redacted' },
  { cp: 'OpenAI', signed: 'Mar 7, 2025', filed: 'Ex. 10.24, Form S-1/A (Mar 2025)', url: 'openai',
