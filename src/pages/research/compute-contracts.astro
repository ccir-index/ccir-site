  { cp: 'OpenAI (second)', signed: 'May 8, 2025', filed: 'Ex. 10.32, Form S-4/A (Sep 2025)', url: 'openai2',
    notable: 'Separate later agreement; same bare-metal architecture' },
];
---
<Base
  title="The Compute Contract: From On-Demand Terms to Take-or-Pay · CCIR Research"
  description="A primer on how GPU-hours are actually sold, read from the public record: published terms of service at the spot end, SEC-filed master services agreements at the committed end, and the datacenter leases underneath."
  showTape={false}
>
  <nav class="apps-navband" aria-label="On this page">
    <div class="wrap apps-nav-inner">
      <a class="apps-nav-link" href="#spectrum">The spectrum</a>
      <a class="apps-nav-link" href="#on-demand">On-demand terms</a>
      <a class="apps-nav-link" href="#msa">The MSA</a>
      <a class="apps-nav-link" href="#middle-market">The middle market</a>
      <a class="apps-nav-link" href="#datacenter-lease">The lease beneath</a>
      <a class="apps-nav-link" href="#redactions">The record</a>
